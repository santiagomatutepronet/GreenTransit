            <i class="bi bi-truck nav-icon"></i>
            <span class="nav-label">Operaciones</span>
            <i class="bi bi-chevron-down nav-chevron @(NavMenuState.IsCollapsed("operaciones") ? "rotated" : "")"></i>
        </div>
