    // Se cargan en OnAfterRenderAsync (no corre durante SSR pre-rendering) para
    // evitar concurrencia con otros componentes sobre el mismo DbContext scoped.
    private IReadOnlySet<string> _allowed = ImmutableHashSet<string>.Empty;
    private bool _permissionsLoaded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _permissionsLoaded) return;
        if (CurrentUser.ProfileId == 0) return;

        _permissionsLoaded = true;

        try
        {
            var routes = await PagePermissions.GetAllowedRoutesAsync();
            // Solo re-renderizar si el conjunto cambió respecto al estado inicial vacío
            if (routes.Count > 0)
            {
                _allowed = routes;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error cargando permisos de navegación para perfil {ProfileId}",
                CurrentUser.ProfileId);
        }
    }

    /// <summary>Devuelve true si el usuario tiene acceso a la ruta según PagePermissions.</summary>
    private bool Allow(string route) => _allowed.Contains(route);

    /// <summary>Devuelve true si el usuario tiene acceso a al menos una de las rutas indicadas.</summary>
    private bool AllowAny(params string[] routes) => routes.Any(r => _allowed.Contains(r));

