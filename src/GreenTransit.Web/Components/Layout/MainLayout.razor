@inherits LayoutComponentBase
@inject ICurrentUserService CurrentUser
@inject IJSRuntime JS
@implements IAsyncDisposable
@using GreenTransit.Application.Common.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@using Radzen
@using Radzen.Blazor

<HeadContent>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</HeadContent>

<RadzenLayout class="@(_darkMode ? "dark-mode" : "")">

    @* ── Header / Topbar ─────────────────────────────────────────────────── *@
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal"
                     AlignItems="AlignItems.Center"
                     JustifyContent="JustifyContent.SpaceBetween"
                     Style="height: 100%; padding: 0 1rem;">

            <RadzenStack Orientation="Orientation.Horizontal"
                         AlignItems="AlignItems.Center"
                         Gap="0.5rem">
                <RadzenSidebarToggle Click="@(() => _sidebarExpanded = !_sidebarExpanded)" />
                <RadzenText TextStyle="TextStyle.H6" class="rz-m-0">
                    <i class="bi bi-recycle" style="color: var(--rz-success)"></i>
                    GreenTransit
                </RadzenText>
            </RadzenStack>

            <RadzenStack Orientation="Orientation.Horizontal"
                         AlignItems="AlignItems.Center"
                         Gap="1rem">

                <GlobalSearchBar />

                <div title="Tenant activo" style="display: flex; align-items: center; gap: 0.25rem;">
                    <i class="bi bi-building"></i>
                    <span>@TenantShort</span>
                </div>

                <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <i class="bi bi-person-circle" style="font-size: 1.25rem;"></i>
                    <div style="display: flex; flex-direction: column; line-height: 1.1;">
                        <span style="font-weight: 600; font-size: 0.875rem;">@CurrentUser.UserName</span>
                        @if (!string.IsNullOrEmpty(CurrentUser.UserProfile))
                        {
                            <span class="topbar-user-badge badge-@CurrentUser.UserProfile.ToLowerInvariant()"
                                  style="font-size: 0.7rem;">
                                @CurrentUser.UserProfile
                            </span>
                        }
                    </div>
                </div>

                <RadzenButton Icon="@(_darkMode ? "light_mode" : "dark_mode")"
                              ButtonStyle="ButtonStyle.Light"
                              Variant="Variant.Text"
                              Click="ToggleDarkMode"
                              title="@(_darkMode ? "Cambiar a modo claro" : "Cambiar a modo oscuro")" />

                <AuthorizeView>
                    <Authorized>
                        <a class="rz-button rz-button-sm rz-secondary rz-variant-text"
                           href="/account/logout"
                           data-enhance-nav="false"
                           title="Cerrar sesión">
                            <i class="bi bi-box-arrow-right"></i>
                        </a>
                    </Authorized>
                </AuthorizeView>

            </RadzenStack>
        </RadzenStack>
    </RadzenHeader>

    @* ── Sidebar ─────────────────────────────────────────────────────────── *@
    <RadzenSidebar Expanded="@_sidebarExpanded"
                   ExpandedChanged="@OnSidebarExpandedChanged"
                   Style="--rz-sidebar-width: 280px;">
        <NavMenu />
    </RadzenSidebar>

    @* ── Contenido principal ─────────────────────────────────────────────── *@
    <RadzenBody>
        <div class="rz-p-4">
            @Body
        </div>
    </RadzenBody>

</RadzenLayout>

@* ── Componentes globales de Radzen ──────────────────────────────────────── *@
<RadzenDialog />
<RadzenNotification />
<RadzenContextMenu />
<RadzenTooltip />

@* Error UI de Blazor *@
<div id="blazor-error-ui" data-nosnippet>
    Se produjo un error inesperado.
    <a href="." class="reload">Recargar</a>
    <span class="dismiss">✕</span>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthTask { get; set; }

    private bool _sidebarExpanded = true;
    private bool _darkMode;
    private DotNetObjectReference<MainLayout>? _dotNetRef;

    private string TenantShort => CurrentUser.OwnerId == Guid.Empty
        ? "—"
        : CurrentUser.OwnerId.ToString()[..8] + "…";

    protected override async Task OnInitializedAsync()
    {
        if (AuthTask is not null)
        {
            var state = await AuthTask;
            CurrentUser.SetInteractiveUser(state.User);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "gt-sidebar");
            var storedCollapsed = stored == "1";
            // En Radzen, Expanded=true significa visible; collapsed=true → expanded=false
            var storedExpanded = !storedCollapsed;
            if (storedExpanded != _sidebarExpanded)
            {
                _sidebarExpanded = storedExpanded;
                StateHasChanged();
            }
        }
    }

    private async Task OnSidebarExpandedChanged(bool expanded)
    {
        _sidebarExpanded = expanded;
        await JS.InvokeVoidAsync("localStorage.setItem", "gt-sidebar", expanded ? "0" : "1");
    }

    private void ToggleDarkMode() => _darkMode = !_darkMode;

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        await Task.CompletedTask;
    }
}
