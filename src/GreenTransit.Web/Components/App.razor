<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    @* ── Radzen CSS + Material Icons — debe cargarse ANTES de site.css para que los overrides surtan efecto *@
    <link id="radzen-theme" rel="stylesheet" href="_content/Radzen.Blazor/css/humanistic.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons" />
    <link rel="stylesheet" href="@Assets["site.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["GreenTransit.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    @* ── Leaflet (mapas interactivos) ──────────────────────────────────────── *@
    <link rel="stylesheet" href="lib/leaflet/leaflet.css" />
    <HeadOutlet />
</head>

<body>
    <CascadingAuthenticationState>
        <Routes @rendermode="@(new InteractiveServerRenderMode(prerender: false))" />
    </CascadingAuthenticationState>
    <ReconnectModal />
    @* ── Bootstrap Icons (iconos de marcadores del mapa) ──────────────────── *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    @* ── Leaflet + Leaflet.draw (deben cargarse ANTES que blazor.web.js     *@
    @*    para que L esté definido cuando Blazor establezca el circuito       *@
    @*    SignalR e invoque JS Interop por primera vez)                      ── *@
    <script src="lib/leaflet/leaflet.js"></script>
    <link rel="stylesheet" href="lib/leaflet.draw/leaflet.draw.css" />
    <script src="lib/leaflet.draw/leaflet.draw.js"></script>
    @* ── Interop maps (también antes de blazor.web.js por la misma razón) ── *@
    <script src="js/dashboardMap.js"></script>
    <script src="js/wasteMoveMap.js"></script>
    <script src="js/dumZoneMap.js"></script>
    <script src="js/mobilityCharts.js"></script>
    <script src="js/heatMapCharts.js"></script>
    <script src="js/carbonFootprintCharts.js"></script>
    <script src="js/complianceCharts.js"></script>
    @* ── Blazor (después de que todas las dependencias JS estén listas) ───── *@
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    @* ── Radzen JS ────────────────────────────────────────────────────────── *@
    <script src="_content/Radzen.Blazor/Radzen.Blazor.js"></script>
    <script>
        window.setTheme = function (themeName) {
            document.getElementById('radzen-theme').setAttribute('href', '_content/Radzen.Blazor/css/' + themeName + '.css');
        };
    </script>
    @* ── ApexCharts ────────────────────────────────────────────────────────── *@
    <script src="_content/Blazor-ApexCharts/js/blazor-apexcharts.js"></script>
    @* ── Descarga de ficheros generados en servidor ────────────────────────── *@
    <script>
        window.downloadBase64File = function (base64, fileName, mimeType) {
            const link = document.createElement('a');
            link.href = 'data:' + mimeType + ';base64,' + base64;
            link.download = fileName;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };
    </script>
    @* ── Sidebar toggle: JS nativo para respuesta inmediata sin esperar SignalR *@
    <script>
        window.gtSidebar = {
            _dotNet: null,

            // Llamado desde OnAfterRenderAsync: registra ref .NET y aplica estado inicial
            init: function (dotNetRef, collapsed) {
                this._dotNet = dotNetRef;
                var shell = document.querySelector('.app-shell');
                if (!shell) return;
                if (collapsed) {
                    shell.classList.add('sidebar-collapsed');
                } else {
                    shell.classList.remove('sidebar-collapsed');
                }
            },

            // Llamado desde el onclick nativo de los botones
            toggle: function () {
                var shell = document.querySelector('.app-shell');
                if (!shell) return;
                var collapsed = shell.classList.toggle('sidebar-collapsed');
                localStorage.setItem('gt-sidebar', collapsed ? '1' : '0');
                // Notificar a Blazor para mantener el estado sincronizado
                if (this._dotNet) {
                    this._dotNet.invokeMethodAsync('SetSidebar', collapsed);
                }
            }
        };
    </script>
    @* ── Radzen Blazor JS ─────────────────────────────────────────────────── *@
    <script src="_content/Radzen.Blazor/Radzen.Blazor.js"></script>
</body>

</html>
