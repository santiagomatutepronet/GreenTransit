<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["site.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["GreenTransit.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    @* ── Leaflet (mapas interactivos) ──────────────────────────────────────── *@
    <link rel="stylesheet" href="lib/leaflet/leaflet.css" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    @* ── Bootstrap Icons (iconos de marcadores del mapa) ──────────────────── *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    @* ── Leaflet + Leaflet.draw (deben cargarse ANTES que blazor.web.js     *@
    @*    para que L esté definido cuando Blazor establezca el circuito       *@
    @*    SignalR e invoque JS Interop por primera vez)                      ── *@
    <script src="lib/leaflet/leaflet.js"></script>
    <link rel="stylesheet" href="lib/leaflet.draw/leaflet.draw.css" />
    <script src="lib/leaflet.draw/leaflet.draw.js"></script>
    @* ── Interop maps (también antes de blazor.web.js por la misma razón) ── *@
    <script src="js/dashboardMap.js"></script>
    <script src="js/wasteMoveMap.js"></script>
    <script src="js/dumZoneMap.js"></script>
    @* ── Blazor (después de que todas las dependencias JS estén listas) ───── *@
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    @* ── ApexCharts ────────────────────────────────────────────────────────── *@
    <script src="_content/Blazor-ApexCharts/js/blazor-apexcharts.js"></script>
    @* ── Descarga de ficheros generados en servidor ────────────────────────── *@
    <script>
        window.downloadBase64File = function (base64, fileName, mimeType) {
            const link = document.createElement('a');
            link.href = 'data:' + mimeType + ';base64,' + base64;
            link.download = fileName;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };
    </script>
</body>

</html>
