@* AppChart.razor — Wrapper centralizado para RadzenChart
   Centraliza: paleta corporativa, leyenda, ejes, formato español (dd/MM/yyyy, N2),
   responsive y compatibilidad con modo oscuro/claro. *@

<RadzenChart Style="@($"width:100%;height:{Height}px")">
    @if (!string.IsNullOrEmpty(Title))
    {
        <RadzenChartTooltipOptions Shared="true" />
    }

    @ChildContent

    @if (ShowLegend)
    {
        <RadzenLegend Position="@LegendPosition" />
    }

    @if (!string.IsNullOrEmpty(CategoryAxisTitle) || !string.IsNullOrEmpty(CategoryFormatString))
    {
        <RadzenCategoryAxis FormatString="@CategoryFormatString">
            @if (!string.IsNullOrEmpty(CategoryAxisTitle))
            {
                <RadzenAxisTitle Text="@CategoryAxisTitle" />
            }
        </RadzenCategoryAxis>
    }

    @if (!string.IsNullOrEmpty(ValueAxisTitle) || !string.IsNullOrEmpty(ValueFormatString))
    {
        <RadzenValueAxis FormatString="@ValueFormatString">
            @if (!string.IsNullOrEmpty(ValueAxisTitle))
            {
                <RadzenAxisTitle Text="@ValueAxisTitle" />
            }
        </RadzenValueAxis>
    }
</RadzenChart>
