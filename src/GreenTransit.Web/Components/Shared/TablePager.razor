@* Componente de paginación para tablas. Solo se muestra si TotalCount > PageSize *@
@if (TotalCount > PageSize)
{
    var totalPages = (int)Math.Ceiling((double)TotalCount / PageSize);
    var from = (CurrentPage - 1) * PageSize + 1;
    var to   = Math.Min(CurrentPage * PageSize, TotalCount);

    <div class="d-flex align-items-center justify-content-between px-3 py-2 border-top bg-light rounded-bottom">
        <small class="text-muted">Mostrando @from–@to de @TotalCount registros</small>
        <nav aria-label="Paginación de tabla">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => Go(1)" disabled="@(CurrentPage == 1)" aria-label="Primera">
                        <i class="bi bi-chevron-double-left"></i>
                    </button>
                </li>
                <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => Go(CurrentPage - 1)" disabled="@(CurrentPage == 1)" aria-label="Anterior">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                </li>
                @for (var p = StartPage; p <= EndPage; p++)
                {
                    var pg = p;
                    <li class="page-item @(pg == CurrentPage ? "active" : "")">
                        <button class="page-link" @onclick="() => Go(pg)">@pg</button>
                    </li>
                }
                <li class="page-item @(CurrentPage == totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => Go(CurrentPage + 1)" disabled="@(CurrentPage == totalPages)" aria-label="Siguiente">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </li>
                <li class="page-item @(CurrentPage == totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => Go(totalPages)" disabled="@(CurrentPage == totalPages)" aria-label="Última">
                        <i class="bi bi-chevron-double-right"></i>
                    </button>
                </li>
            </ul>
        </nav>
    </div>
}

@code {
    [Parameter] public int TotalCount    { get; set; }
    [Parameter] public int PageSize      { get; set; } = 15;
    [Parameter] public int CurrentPage   { get; set; } = 1;
    [Parameter] public EventCallback<int> CurrentPageChanged { get; set; }

    private int TotalPages  => (int)Math.Ceiling((double)TotalCount / PageSize);
    private int StartPage   => Math.Max(1, CurrentPage - 2);
    private int EndPage     => Math.Min(TotalPages, StartPage + 4);

    private async Task Go(int page)
    {
        if (page < 1 || page > TotalPages || page == CurrentPage) return;
        await CurrentPageChanged.InvokeAsync(page);
    }
}
