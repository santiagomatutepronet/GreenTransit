@page "/ler-codes"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Common
@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Application.Features.LerCodes.Commands
@using GreenTransit.Application.Features.LerCodes.DTOs
@using GreenTransit.Application.Features.LerCodes.Queries
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator           Mediator
@inject NavigationManager   Nav
@inject ICurrentUserService CurrentUser

<PageTitle>Catálogo LER</PageTitle>

<div class="page-header">
    <h1 class="page-title"><i class="bi bi-list-ol me-2"></i>Catálogo LER</h1>
    @if (_isAdmin)
    {
        <button class="btn btn-primary btn-sm" @onclick="CreateNew">
            <i class="bi bi-plus-lg me-1"></i>Nuevo código LER
        </button>
    }
</div>

@* ── Filtros ───────────────────────────────────────────────────────────────── *@
<div class="filter-bar">
    <div class="filter-group">
        <label>Búsqueda</label>
        <input class="form-control"
               placeholder="Código, descripción…"
               @bind="_searchTerm" @bind:event="oninput"
               @onkeyup="@(async e => { if (e.Key == "Enter") await LoadAsync(); })" />
    </div>
    <div class="filter-group">
        <label>Peligroso</label>
        <select class="form-control" @bind="_filterDangerous">
            <option value="">— Todos —</option>
            <option value="true">Sí</option>
            <option value="false">No</option>
        </select>
    </div>
    <div class="filter-group">
        <label>RAEE</label>
        <select class="form-control" @bind="_filterRaee">
            <option value="">— Todos —</option>
            <option value="true">Sí</option>
            <option value="false">No</option>
        </select>
    </div>
    <div class="filter-actions">
        <button class="btn btn-primary btn-sm" @onclick="ApplyFilters">
            <i class="bi bi-search me-1"></i>Buscar
        </button>
        <button class="btn btn-ghost btn-sm" @onclick="ResetFilters">Limpiar</button>
        <button class="btn btn-outline btn-sm ml-auto" @onclick="ExportCsv">
            <i class="bi bi-download me-1"></i>Exportar CSV
        </button>
    </div>
</div>

@* ── Contenido ─────────────────────────────────────────────────────────────── *@
@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_pagedResult is null || _pagedResult.Items.Count == 0)
{
    <div class="alert alert-info">No se encontraron codigos LER con los filtros aplicados.</div>
}
else
{
    <div class="table-responsive mt-3">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:100px">Codigo</th>
                    <th style="width:100px">Capitulo</th>
                    <th style="width:120px">Subcapitulo</th>
                    <th>Descripcion</th>
                    <th style="width:80px" class="text-center">Peligroso</th>
                    <th style="width:60px" class="text-center">RAEE</th>
                    <th style="width:80px" class="text-center">Estado</th>
                    @if (_isAdmin)
                    {
                        <th style="width:100px" class="text-end">Acciones</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var lerCode in _pagedResult.Items)
                {
                    <tr>
                        <td><code class="fw-semibold">@lerCode.Code</code></td>
                        <td class="text-muted small">@(lerCode.Chapter ?? "---")</td>
                        <td class="text-muted small">@(lerCode.SubChapter ?? "---")</td>
                        <td>@lerCode.Description</td>
                        <td class="text-center">
                            @if (lerCode.IsDangerous) { <span class="badge bg-danger">Si</span> }
                            else { <span class="text-muted">---</span> }
                        </td>
                        <td class="text-center">
                            @if (lerCode.IsRAEE) { <span class="badge bg-warning text-dark">Si</span> }
                            else { <span class="text-muted">---</span> }
                        </td>
                        <td class="text-center">
                            @if (lerCode.IsActive) { <span class="badge bg-success">Activo</span> }
                            else { <span class="badge bg-secondary">Inactivo</span> }
                        </td>
                        @if (_isAdmin)
                        {
                            <td class="text-end">
                                <button class="btn btn-outline-primary btn-sm py-0 px-1 me-1"
                                        title="Editar" @onclick="() => EditCode(lerCode.Id)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-outline-secondary btn-sm py-0 px-1"
                                        @onclick="() => ToggleActiveAsync(lerCode.Id)">
                                    <i class="bi @(lerCode.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (_pagedResult.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-2">
            <small class="text-muted">@_pagedResult.TotalCount codigos LER</small>
            <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-secondary" disabled="@(!_pagedResult.HasPrevious)"
                        @onclick="() => GoPageAsync(_currentPage - 1)">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <span class="btn btn-outline-secondary disabled">@_currentPage / @_pagedResult.TotalPages</span>
                <button class="btn btn-outline-secondary" disabled="@(!_pagedResult.HasNext)"
                        @onclick="() => GoPageAsync(_currentPage + 1)">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    }
}
@* ── Modal formulario Crear / Editar ───────────────────────────────────────── *@
@if (_showForm)
{
    <div class="modal-backdrop-custom" @onclick="CloseForm"></div>
    <div class="modal-panel" @onclick:stopPropagation>
        <div class="modal-panel-header">
            <h5 class="mb-0">
                <i class="bi @(_editId.HasValue ? "bi-pencil-square" : "bi-plus-circle") me-2"></i>
                @(_editId.HasValue ? "Editar código LER" : "Nuevo código LER")
            </h5>
            <button class="btn-icon" @onclick="CloseForm" title="Cerrar">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="modal-panel-body">

            @if (_formError is not null)
            {
                <div class="alert alert-danger py-2">@_formError</div>
            }

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Código <span class="text-danger">*</span></label>
                    <input class="form-control @(_formErrors.ContainsKey("Code") ? "is-invalid" : "")"
                           @bind="_form.Code" placeholder="Ej: 16 01 03" />
                    @foreach (var e in _formErrors.GetValueOrDefault("Code") ?? [])
                    { <div class="invalid-feedback">@e</div> }
                </div>
                <div class="col-md-4">
                    <label class="form-label">Código extendido</label>
                    <input class="form-control" @bind="_form.CodeExtended" placeholder="Ej: 160103" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Categoría producto</label>
                    <input class="form-control" @bind="_form.DefaultProductCategory" />
                </div>
                <div class="col-12">
                    <label class="form-label">Descripción <span class="text-danger">*</span></label>
                    <textarea class="form-control @(_formErrors.ContainsKey("Description") ? "is-invalid" : "")"
                              rows="2" @bind="_form.Description"></textarea>
                    @foreach (var e in _formErrors.GetValueOrDefault("Description") ?? [])
                    { <div class="invalid-feedback">@e</div> }
                </div>
                <div class="col-md-3">
                    <label class="form-label">Capítulo</label>
                    <input class="form-control" @bind="_form.Chapter" placeholder="Ej: 16" />
                </div>
                <div class="col-md-9">
                    <label class="form-label">Descripción capítulo</label>
                    <input class="form-control" @bind="_form.ChapterDescription" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Subcapítulo</label>
                    <input class="form-control" @bind="_form.SubChapter" placeholder="Ej: 16 01" />
                </div>
                <div class="col-md-9">
                    <label class="form-label">Descripción subcapítulo</label>
                    <input class="form-control" @bind="_form.SubChapterDescription" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Notas</label>
                    <textarea class="form-control" rows="2" @bind="_form.Notes"></textarea>
                </div>
                <div class="col-md-3 d-flex align-items-center gap-3 pt-3">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="chkDangerous"
                               @bind="_form.IsDangerous" />
                        <label class="form-check-label" for="chkDangerous">Peligroso</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="chkRaee"
                               @bind="_form.IsRAEE" />
                        <label class="form-check-label" for="chkRaee">RAEE</label>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-panel-footer">
            <button class="btn btn-ghost btn-sm" @onclick="CloseForm" disabled="@_saving">Cancelar</button>
            <button class="btn btn-primary btn-sm" @onclick="SaveFormAsync" disabled="@_saving">
                @if (_saving)
                { <span class="spinner-border spinner-border-sm me-1"></span> }
                <i class="bi bi-floppy me-1"></i>Guardar
            </button>
        </div>
    </div>
}

@code {
    private const int PageSize = 15;

    private GreenTransit.Application.Common.Models.PaginatedResult<LerCodeDto>? _pagedResult;
    private bool    _loading         = true;
    private bool    _isAdmin         = false;
    private int     _currentPage     = 1;
    private string? _searchTerm;
    private string  _filterDangerous = "";
    private string  _filterRaee      = "";

    private bool                             _showForm   = false;
    private bool                             _saving     = false;
    private Guid?                            _editId;
    private string?                          _formError;
    private Dictionary<string, List<string>> _formErrors = [];
    private LerFormModel                     _form       = new();

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = CurrentUser.UserProfile == "ADMIN";
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _pagedResult = await Mediator.Send(new GetLerCodesPagedQuery(
            IsDangerous: ParseBool(_filterDangerous),
            IsRAEE:      ParseBool(_filterRaee),
            SearchTerm:  _searchTerm,
            PageNumber:  _currentPage,
            PageSize:    PageSize));
        _loading = false;
    }

    private async Task ApplyFilters() { _currentPage = 1; await LoadAsync(); }

    private async Task ResetFilters()
    {
        _searchTerm      = null;
        _filterDangerous = "";
        _filterRaee      = "";
        _currentPage     = 1;
        await LoadAsync();
    }

    private async Task GoPageAsync(int page) { _currentPage = page; await LoadAsync(); }
private void CreateNew()
    {
        _editId    = null;
        _form      = new();
        _formError = null;
        _formErrors = [];
        _showForm  = true;
    }

    private async Task EditCode(Guid id)
    {
        var detail = await Mediator.Send(new GetLerCodeByIdQuery(id));
        if (detail is null) return;

        _editId = id;
        _form   = new LerFormModel
        {
            Code                  = detail.Code,
            CodeExtended          = detail.CodeExtended,
            Description           = detail.Description,
            Chapter               = detail.Chapter,
            ChapterDescription    = detail.ChapterDescription,
            SubChapter            = detail.SubChapter,
            SubChapterDescription = detail.SubChapterDescription,
            IsDangerous           = detail.IsDangerous,
            IsRAEE                = detail.IsRAEE,
            DefaultProductCategory = detail.DefaultProductCategory,
            Notes                 = detail.Notes
        };
        _formError  = null;
        _formErrors = [];
        _showForm   = true;
    }

    private async Task ToggleActiveAsync(Guid id)
    {
        await Mediator.Send(new ToggleLerCodeActiveCommand(id));
        await LoadAsync();
    }

    private async Task SaveFormAsync()
    {
        _saving    = true;
        _formError = null;
        _formErrors = [];
        try
        {
            if (_editId.HasValue)
            {
                await Mediator.Send(new UpdateLerCodeCommand(
                    _editId.Value,
                    _form.Code!, _form.CodeExtended, _form.Description!,
                    _form.Chapter, _form.ChapterDescription,
                    _form.SubChapter, _form.SubChapterDescription,
                    _form.IsDangerous, _form.IsRAEE,
                    _form.DefaultProductCategory, _form.Notes));
            }
            else
            {
                await Mediator.Send(new CreateLerCodeCommand(
                    _form.Code!, _form.CodeExtended, _form.Description!,
                    _form.Chapter, _form.ChapterDescription,
                    _form.SubChapter, _form.SubChapterDescription,
                    _form.IsDangerous, _form.IsRAEE,
                    _form.DefaultProductCategory, _form.Notes));
            }
            _showForm = false;
            await LoadAsync();
        }
        catch (FluentValidation.ValidationException vex)
        {
            _formErrors = vex.Errors
                .GroupBy(e => e.PropertyName)
                .ToDictionary(g => g.Key, g => g.Select(e => e.ErrorMessage).ToList());
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void CloseForm() => _showForm = false;

    // ── CSV ───────────────────────────────────────────────────────────────────
    private async Task ExportCsv()
    {
        // Construye CSV en memoria y lo descarga vía JS interop no disponible aquí.
        // Implementación completa requiere JSRuntime — se deja como extensión futura.
        await Task.CompletedTask;
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    private static bool? ParseBool(string value)
        => value switch { "true" => true, "false" => false, _ => null };

    // ── Modelo formulario ─────────────────────────────────────────────────────
    private sealed class LerFormModel
    {
        public string?  Code                  { get; set; }
        public string?  CodeExtended          { get; set; }
        public string?  Description           { get; set; }
        public string?  Chapter               { get; set; }
        public string?  ChapterDescription    { get; set; }
        public string?  SubChapter            { get; set; }
        public string?  SubChapterDescription { get; set; }
        public bool     IsDangerous           { get; set; }
        public bool     IsRAEE                { get; set; }
        public string?  DefaultProductCategory { get; set; }
        public string?  Notes                 { get; set; }
    }
}
