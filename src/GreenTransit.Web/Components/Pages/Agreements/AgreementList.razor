@using Radzen
@using Radzen.Blazor
@page "/agreements"
@attribute [Authorize(Policy = PolicyConstants.CanManageAgreements)]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.Agreements.DTOs
@using GreenTransit.Application.Features.Agreements.Queries
@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Domain.Authorization
@using GreenTransit.Domain.Entities
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator           Mediator
@inject NavigationManager   Nav
@inject ICurrentUserService CurrentUser

<PageTitle>Acuerdos</PageTitle>

<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-file-earmark-text me-2"></i>Acuerdos
    </h1>
    <AuthorizeView Policy="@PolicyConstants.CanManageAgreements">
        <Authorized>
            <button class="btn btn-primary btn-sm"
                    @onclick='() => Nav.NavigateTo("/agreements/new")'>
                <i class="bi bi-plus-lg me-1"></i>Nuevo acuerdo
            </button>
        </Authorized>
    </AuthorizeView>
</div>

@* ── Filtros ────────────────────────────────────────────────────────────────── *@
<div class="filter-bar">
    <div class="filter-group">
        <label>Estado</label>
        <select class="form-control" @bind="_filterStatus">
            <option value="">— Todos —</option>
            @foreach (var s in Agreement.Statuses.All)
            {
                <option value="@s">@s</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Año</label>
        <input type="number" class="form-control" @bind="_filterYear" placeholder="2025" style="width:90px" />
    </div>
    <div class="filter-group">
        <label>Búsqueda</label>
        <input class="form-control" @bind="_filterSearch" placeholder="Nº acuerdo…" style="min-width:180px" />
    </div>
    <button class="btn btn-secondary btn-sm" @onclick="LoadAsync">
        <i class="bi bi-search me-1"></i>Buscar
    </button>
</div>

@if (_loading)
{
    <LoadingSpinner />
}
else if (!string.IsNullOrEmpty(_errorMessage))
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">@_errorMessage</RadzenAlert>
}
else
{
    <RadzenDataGrid TItem="AgreementDto"
                    Data="@_result.Items" Count="@_result.TotalCount"
                    AllowPaging="true" PageSize="20"
                    AllowSorting="true" AllowFiltering="false"
                    EmptyText="No hay acuerdos que mostrar."
                    PagerHorizontalAlign="HorizontalAlign.Right">
        <Columns>
            <RadzenDataGridColumn TItem="AgreementDto" Property="AgreementNumber" Title="Nº Acuerdo" Width="150px">
                <Template Context="a"><strong>@a.AgreementNumber</strong></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="AgreementDto" Property="ScrapName" Title="SCRAP" Width="160px">
                <Template Context="a">@(a.ScrapName ?? "—")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="AgreementDto" Property="PublicEntityName" Title="Entidad Pública" Width="180px">
                <Template Context="a">@(a.PublicEntityName ?? "—")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="AgreementDto" Property="EffectiveFrom" Title="Vigencia" Width="160px">
                <Template Context="a">
                    @a.EffectiveFrom.ToString("dd/MM/yyyy")
                    @if (a.EffectiveTo.HasValue) { <span> → @a.EffectiveTo.Value.ToString("dd/MM/yyyy")</span> }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="AgreementDto" Title="Vence en" Width="100px">
                <Template Context="a">@RenderDaysRemaining(a)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="AgreementDto" Property="Status" Title="Estado" Width="110px">
                <Template Context="a"><span class="@StatusBadge(a.Status)">@a.Status</span></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="AgreementDto" Title="" Width="100px" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                <Template Context="a">
                    <RadzenButton Icon="visibility" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                  Click="@(() => Nav.NavigateTo($"/agreements/{a.Id}"))" />
                    @if (a.Status == Agreement.Statuses.Draft)
                    {
                        <RadzenButton Icon="edit" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                      Click="@(() => Nav.NavigateTo($"/agreements/{a.Id}/edit"))" />
                    }
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    private bool    _loading = true;
    private string? _errorMessage;
    private int     _page   = 1;

    private string? _filterStatus;
    private int?    _filterYear;
    private string? _filterSearch;

    private GreenTransit.Application.Common.Models.PaginatedResult<AgreementDto> _result =
        GreenTransit.Application.Common.Models.PaginatedResult<AgreementDto>.Create([], 0, 1, 20);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _errorMessage = null;
        try
        {
            _result = await Mediator.Send(new GetAgreementsQuery(
                Status:     _filterStatus,
                Year:       _filterYear,
                SearchTerm: _filterSearch,
                PageNumber: _page));
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _loading = false; }
    }

    private async Task ChangePage(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private static string StatusBadge(string? status) => status switch
    {
        Agreement.Statuses.Draft     => "badge bg-secondary",
        Agreement.Statuses.Active    => "badge bg-success",
        Agreement.Statuses.Expired   => "badge bg-warning text-dark",
        Agreement.Statuses.Cancelled => "badge bg-danger",
        _                            => "badge bg-light text-dark"
    };

    private static string RenderDaysRemaining(AgreementDto a)
    {
        if (!a.EffectiveTo.HasValue || a.Status != Agreement.Statuses.Active)
            return "—";

        var days = (int)(a.EffectiveTo.Value.Date - DateTime.Today).TotalDays;
        if (days < 0)  return "Vencido";
        if (days < 7)  return $"⚠ {days}d";
        if (days < 30) return $"⚠ {days}d";
        return $"{days}d";
    }
}
