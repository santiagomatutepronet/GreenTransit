@using Radzen
@using Radzen.Blazor
@page "/entities"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Common.Models
@using GreenTransit.Application.Features.Entities.Commands
@using GreenTransit.Application.Features.Entities.DTOs
@using GreenTransit.Application.Features.Entities.Queries
@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator    Mediator
@inject NavigationManager Nav
@inject IPagePermissionService PagePermissions

<PageTitle>Entidades del Ecosistema</PageTitle>

<div class="page-header">
    <h1 class="page-title"><i class="bi bi-building me-2"></i>Entidades del Ecosistema</h1>
    @if (_canWrite)
    {
        <button class="btn btn-primary btn-sm" @onclick="CreateNew">
            <i class="bi bi-plus-lg me-1"></i>Nueva Entidad
        </button>
    }
</div>

@* ── Barra de filtros ──────────────────────────────────────────────────────── *@
<div class="filter-bar">
    <div class="filter-group">
        <label>Búsqueda</label>
        <input class="form-control"
               placeholder="Nombre, NIF, NIMA…"
               @bind="_searchTerm" @bind:event="oninput"
               @onkeyup="@(async e => { if (e.Key == "Enter") await LoadAsync(); })" />
    </div>
    <div class="filter-group">
        <label>Rol</label>
        <select class="form-control" @bind="_filterRole">
            <option value="">— Todos —</option>
            @foreach (var r in EntityRoles.All)
            {
                <option value="@r">@r</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Estado</label>
        <select class="form-control" @bind="_filterActive">
            <option value="">— Todos —</option>
            <option value="true">Activo</option>
            <option value="false">Inactivo</option>
        </select>
    </div>
    <div class="filter-group">
        <label>Provincia</label>
        <input class="form-control" placeholder="Código…" @bind="_filterProvince" />
    </div>
    <div class="filter-actions">
        <button class="btn btn-primary btn-sm" @onclick="ApplyFilters">
            <i class="bi bi-search me-1"></i>Buscar
        </button>
        <button class="btn btn-ghost btn-sm" @onclick="ResetFilters">Limpiar</button>
    </div>
</div>

@* ── Grid ──────────────────────────────────────────────────────────────────── *@
<RadzenDataGrid @ref="_grid" TItem="EntityDto"
                Data="@(_result?.Items ?? [])" Count="@(_result?.TotalCount ?? 0)"
                LoadData="@OnLoadData"
                AllowPaging="true" PageSize="PageSize"
                AllowSorting="true" AllowFiltering="false"
                IsLoading="@_loading"
                EmptyText="No se encontraron entidades con los filtros aplicados."
                PagerHorizontalAlign="HorizontalAlign.Right">
    <Columns>
        <RadzenDataGridColumn TItem="EntityDto" Property="Name" Title="Nombre" Width="220px">
            <Template Context="e">
                <a class="rz-link" href="/entities/@e.Id">@e.Name</a>
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="EntityDto" Property="NationalId" Title="NIF" Width="120px">
            <Template Context="e"><code>@(e.NationalId ?? "—")</code></Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="EntityDto" Property="EntityRole" Title="Rol" Width="130px">
            <Template Context="e"><RadzenBadge Text="@e.EntityRole" /></Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="EntityDto" Property="ProvinceCode" Title="Provincia" Width="110px">
            <Template Context="e">@(e.ProvinceCode ?? "—")</Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="EntityDto" Property="IsActive" Title="Estado" Width="90px" TextAlign="TextAlign.Center">
            <Template Context="e">
                @if (e.IsActive)
                { <RadzenBadge Text="Activo" BadgeStyle="BadgeStyle.Success" /> }
                else
                { <RadzenBadge Text="Inactivo" BadgeStyle="BadgeStyle.Secondary" /> }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="EntityDto" Property="LinkedUserLogin" Title="Usuario vinculado" Width="160px">
            <Template Context="e">
                @if (!string.IsNullOrEmpty(e.LinkedUserLogin))
                { <a href="/users?login=@e.LinkedUserLogin">@e.LinkedUserLogin</a> }
                else
                { <span class="rz-text-disabled">—</span> }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="EntityDto" Title="" Width="100px" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
            <Template Context="e">
                @if (_canWrite)
                {
                    <RadzenButton Icon="edit" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                  Click="@(() => Edit(e.Id))" title="Editar" />
                    @if (e.IsActive)
                    {
                        <RadzenButton Icon="block" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Danger"
                                      Click="@(() => ConfirmDeactivate(e))" title="Desactivar" />
                    }
                }
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@* ── Modal de confirmación de desactivación ───────────────────────────────── *@
@if (_deactivateTarget is not null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Desactivar entidad</h5>
                    <button type="button" class="btn-close"
                            @onclick="() => _deactivateTarget = null"></button>
                </div>
                <div class="modal-body">
                    <p>¿Desactivar <strong>@_deactivateTarget.Name</strong>?</p>
                    @if (!string.IsNullOrEmpty(_deactivateTarget.LinkedUserLogin))
                    {
                        <div class="alert alert-warning py-2 small">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Esta entidad tiene el usuario vinculado
                            <strong>@_deactivateTarget.LinkedUserLogin</strong>.
                            ¿Desactivar también el usuario?
                        </div>
                    }
                </div>
                <div class="modal-footer gap-2">
                    <button class="btn btn-secondary btn-sm"
                            @onclick="() => _deactivateTarget = null">Cancelar</button>
                    <button class="btn btn-danger btn-sm"
                            @onclick="ExecuteDeactivate">Desactivar</button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger mt-3">@_errorMessage</div>
}

@code {
    // ── Estado ────────────────────────────────────────────────────────────────
    private RadzenDataGrid<EntityDto> _grid = default!;
    private PaginatedResult<EntityDto>? _result;
    private bool   _loading       = true;
    private string _searchTerm    = string.Empty;
    private string _filterRole    = string.Empty;
    private string _filterActive  = string.Empty;
    private string _filterProvince= string.Empty;
    private int    _pageNumber    = 1;
    private const int PageSize    = 20;
    private string? _errorMessage;

    private EntityDto? _deactivateTarget;
    private bool _canWrite;

    // ── Lifecycle ──────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _canWrite = await PagePermissions.CanWriteRouteAsync("/entities");
        await LoadAsync();
    }

    // ── LoadData (RadzenDataGrid) ──────────────────────────────────────────────
    private async Task OnLoadData(LoadDataArgs args)
    {
        _pageNumber = args.Skip.HasValue ? (args.Skip.Value / PageSize) + 1 : 1;
        await LoadAsync();
    }

    // ── Carga de datos ─────────────────────────────────────────────────────────
    private async Task LoadAsync()
    {
        _loading      = true;
        _errorMessage = null;
        try
        {
            bool? activeFilter = _filterActive switch
            {
                "true"  => true,
                "false" => false,
                _       => null
            };

            _result = await Mediator.Send(new GetEntitiesQuery(
                EntityRole:   string.IsNullOrEmpty(_filterRole)    ? null : _filterRole,
                ProvinceCode: string.IsNullOrEmpty(_filterProvince) ? null : _filterProvince,
                IsActive:     activeFilter,
                SearchTerm:   string.IsNullOrEmpty(_searchTerm)    ? null : _searchTerm,
                PageNumber:   _pageNumber,
                PageSize:     PageSize));
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al cargar entidades: {ex.Message}";
        }
        finally { _loading = false; }
    }

    private async Task ApplyFilters() { _pageNumber = 1; await LoadAsync(); if (_grid is not null) await _grid.Reload(); }
    private async Task ResetFilters()
    {
        _searchTerm = _filterRole = _filterActive = _filterProvince = string.Empty;
        _pageNumber = 1;
        await LoadAsync();
        if (_grid is not null) await _grid.Reload();
    }
    private async Task PrevPage() { _pageNumber--; await LoadAsync(); }
    private async Task NextPage() { _pageNumber++; await LoadAsync(); }

    // ── Navegación ─────────────────────────────────────────────────────────────
    private void CreateNew() => Nav.NavigateTo("/entities/new");
    private void Edit(Guid id) => Nav.NavigateTo($"/entities/{id}/edit");

    // ── Desactivación ──────────────────────────────────────────────────────────
    private void ConfirmDeactivate(EntityDto e) => _deactivateTarget = e;

    private async Task ExecuteDeactivate()
    {
        if (_deactivateTarget is null) return;
        try
        {
            await Mediator.Send(new DeactivateEntityCommand(_deactivateTarget.Id));
            _deactivateTarget = null;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _errorMessage     = $"Error al desactivar: {ex.Message}";
            _deactivateTarget = null;
        }
    }
}
