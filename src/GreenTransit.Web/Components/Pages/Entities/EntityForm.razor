@page "/entities/new"
@page "/entities/{EntityId:guid}/edit"
@attribute [Authorize]
@rendermode InteractiveServer

@using FluentValidation
@using GreenTransit.Application.Features.Entities.Commands
@using GreenTransit.Application.Features.Entities.Queries
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using Radzen
@using Radzen.Blazor

@inject IMediator        Mediator
@inject NavigationManager Nav

<PageTitle>@(_isEdit ? "Editar Entidad" : "Nueva Entidad")</PageTitle>

<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-building me-2"></i>
        @(_isEdit ? "Editar Entidad" : "Nueva Entidad")
    </h1>
</div>

@if (_loading)
{
    <div class="text-center py-5"><RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" /></div>
}
else
{
    <RadzenTemplateForm TItem="FormModel" Data="@_model" Submit="@SaveAsync">

        @* ── 1. Datos de identificación ──────────────────────────────── *@
        <RadzenFieldset Text="Datos de identificación" class="rz-mb-4">
            <RadzenRow Gap="1rem">
                <RadzenColumn SizeMD="6">
                    <RadzenFormField Text="Nombre *" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="Name" @bind-Value="_model.Name" Style="width:100%" MaxLength="256" />
                        </ChildContent>
                        <Helper><RadzenRequiredValidator Component="Name" Text="El nombre es obligatorio" /></Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="NIF / CIF" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="NationalId" @bind-Value="_model.NationalId" Style="width:100%" MaxLength="32" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="NIMA" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="CenterCode" @bind-Value="_model.CenterCode" Style="width:100%" MaxLength="64" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow Gap="1rem" class="rz-mt-4">
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="Rol de la entidad *" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="string" Name="EntityRole" @bind-Value="_model.EntityRole"
                                            Data="@EntityRoles.All"
                                            Change="@(_ => OnRoleChanged())"
                                            Style="width:100%" Placeholder="— Seleccionar —" AllowClear="true" />
                        </ChildContent>
                        <Helper><RadzenRequiredValidator Component="EntityRole" Text="El rol es obligatorio" /></Helper>
                    </RadzenFormField>
                    @if (!string.IsNullOrEmpty(_model.EntityRole))
                    {
                        @if (EntityRoles.GetAutoUserProfile(_model.EntityRole) is string autoProfile)
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" Size="AlertSize.Small" class="rz-mt-2">
                                Se generará usuario con perfil <strong>@autoProfile</strong> usando el email de la entidad.
                            </RadzenAlert>
                        }
                        else
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Base" Shade="Shade.Lighter" Size="AlertSize.Small" class="rz-mt-2">
                                Este rol no genera un usuario de acceso al sistema.
                            </RadzenAlert>
                        }
                    }
                </RadzenColumn>
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="Tipo de entidad" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="EntityType" @bind-Value="_model.EntityType" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="Actividad económica" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="EconomicActivity" @bind-Value="_model.EconomicActivity" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        @* ── 2. Clasificación normativa ──────────────────────────────── *@
        <RadzenFieldset Text="Clasificación normativa" class="rz-mb-4">
            <RadzenRow Gap="1rem">
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="Tipo de tercero" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="TypeThirdParty" @bind-Value="_model.TypeThirdParty" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="@($"Tipo de inscripción{(EntityRoles.RequiresInscriptionNumber(_model.EntityRole) ? " *" : "")}")" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="InscriptionType" @bind-Value="_model.InscriptionType" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="@($"Nº inscripción (RAT){(EntityRoles.RequiresInscriptionNumber(_model.EntityRole) ? " *" : "")}")" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="InscriptionNumber" @bind-Value="_model.InscriptionNumber" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        @* ── 3. Localización ─────────────────────────────────────────── *@
        <RadzenFieldset Text="@($"Localización{(EntityRoles.RequiresCoordinates(_model.EntityRole) ? " (coordenadas obligatorias)" : "")}")" class="rz-mb-4">
            <div class="rz-mb-4">
                <GeographySelector
                    @bind-CountryCode="_model.CountryCode"
                    @bind-StateCode="_model.StateCode"
                    @bind-ProvinceCode="_model.ProvinceCode"
                    @bind-MunicipalityCode="_model.MunicipalityCode"
                    @bind-ZipCode="_model.ZipCode" />
            </div>
            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12">
                    <RadzenFormField Text="Dirección" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="Address" @bind-Value="_model.Address" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow Gap="1rem" class="rz-mt-4">
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="@($"Latitud{(EntityRoles.RequiresCoordinates(_model.EntityRole) ? " *" : "")}")" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="Latitude" @bind-Value="_model.Latitude" Placeholder="41.3825" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="@($"Longitud{(EntityRoles.RequiresCoordinates(_model.EntityRole) ? " *" : "")}")" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="Longitude" @bind-Value="_model.Longitude" Placeholder="2.1769" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        @* ── 4. Contacto ─────────────────────────────────────────────── *@
        <RadzenFieldset Text="Contacto" class="rz-mb-4">
            <RadzenRow Gap="1rem">
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="@($"Email{(EntityRoles.GetAutoUserProfile(_model.EntityRole) is not null ? " *" : "")}")" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="Email" @bind-Value="_model.Email" InputType="InputType.Email"
                                           Change="@(_ => SuggestLogin())" Style="width:100%" />
                        </ChildContent>
                        <Helper>
                            @if (EntityRoles.GetAutoUserProfile(_model.EntityRole) is not null && string.IsNullOrWhiteSpace(_model.Email))
                            {
                                <span class="rz-color-warning">El email es obligatorio para este rol (se creará un usuario).</span>
                            }
                        </Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="Teléfono" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="PhoneNumber" @bind-Value="_model.PhoneNumber" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="Persona de contacto" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="ContactPerson" @bind-Value="_model.ContactPerson" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        @* ── 5. Acceso al sistema (solo si el rol genera usuario) ─────── *@
        @if (EntityRoles.GetAutoUserProfile(_model.EntityRole) is string profileRef)
        {
            <RadzenFieldset Text="@($"Acceso al sistema — Perfil: {profileRef}")" AllowCollapse="true" Collapsed="@(!_accessOpen)" class="rz-mb-4">
                <RadzenRow Gap="1rem">
                    <RadzenColumn SizeMD="6">
                        <RadzenFormField Text="Login sugerido" Variant="Variant.Outlined" Style="width:100%">
                            <ChildContent>
                                <RadzenTextBox Name="SuggestedLogin" @bind-Value="_model.SuggestedLogin"
                                               Placeholder="Se usará el email si se deja vacío" Style="width:100%" />
                            </ChildContent>
                            <Helper>
                                <span class="rz-text-secondary-color rz-text-sm">
                                    Se creará automáticamente un usuario con perfil <strong>@profileRef</strong>.
                                </span>
                            </Helper>
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>
            </RadzenFieldset>
        }

        @* ── Errores y acciones ──────────────────────────────────────────── *@
        @if (_validationErrors.Any())
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" class="rz-mt-4">
                <ul class="mb-0">
                    @foreach (var err in _validationErrors.Values.SelectMany(v => v))
                    {
                        <li>@err</li>
                    }
                </ul>
            </RadzenAlert>
        }

        @if (!string.IsNullOrEmpty(_serverError))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" class="rz-mt-4">@_serverError</RadzenAlert>
        }

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" class="rz-mt-4">
            <RadzenButton ButtonType="ButtonType.Submit" Text="Guardar" Icon="save"
                          ButtonStyle="ButtonStyle.Primary" Disabled="@_saving" IsBusy="@_saving" />
            <RadzenButton Text="Cancelar" Icon="cancel" ButtonStyle="ButtonStyle.Light"
                          ButtonType="ButtonType.Button" Click="@(_ => Cancel())" />
        </RadzenStack>

    </RadzenTemplateForm>
}

@code {
    [Parameter] public Guid? EntityId { get; set; }

    private bool   _isEdit  => EntityId.HasValue;
    private bool   _loading = true;
    private bool   _saving  = false;
    private bool   _accessOpen = true;
    private string? _serverError;
    private Dictionary<string, List<string>> _validationErrors = new();

    // ── Modelo del formulario ─────────────────────────────────────────────────
    private FormModel _model = new();

    private sealed class FormModel
    {
        public string  Name              { get; set; } = string.Empty;
        public string? NationalId        { get; set; }
        public string? CenterCode        { get; set; }
        public string  EntityRole        { get; set; } = string.Empty;
        public string? EntityType        { get; set; }
        public string? EconomicActivity  { get; set; }
        public string? TypeThirdParty    { get; set; }
        public string? InscriptionType   { get; set; }
        public string? InscriptionNumber { get; set; }
        public string? CountryCode       { get; set; }
        public string? StateCode         { get; set; }
        public string? ProvinceCode      { get; set; }
        public string? MunicipalityCode  { get; set; }
        public string? ZipCode           { get; set; }
        public string? Address           { get; set; }
        public string? Latitude          { get; set; }
        public string? Longitude         { get; set; }
        public string? PhoneNumber       { get; set; }
        public string? Email             { get; set; }
        public string? ContactPerson     { get; set; }
        public string? SuggestedLogin    { get; set; }
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        if (_isEdit)
        {
            var detail = await Mediator.Send(new GetEntityByIdQuery(EntityId!.Value));
            if (detail is not null)
            {
                _model = new FormModel
                {
                    Name              = detail.Name,
                    NationalId        = detail.NationalId,
                    CenterCode        = detail.CenterCode,
                    EntityRole        = detail.EntityRole,
                    EntityType        = detail.EntityType,
                    EconomicActivity  = detail.EconomicActivity,
                    TypeThirdParty    = detail.TypeThirdParty,
                    InscriptionType   = detail.InscriptionType,
                    InscriptionNumber = detail.InscriptionNumber,
                    CountryCode       = detail.CountryCode,
                    StateCode         = detail.StateCode,
                    ProvinceCode      = detail.ProvinceCode,
                    MunicipalityCode  = detail.MunicipalityCode,
                    ZipCode           = detail.ZipCode,
                    Address           = detail.Address,
                    Latitude          = detail.Latitude,
                    Longitude         = detail.Longitude,
                    PhoneNumber       = detail.PhoneNumber,
                    Email             = detail.Email,
                    ContactPerson     = detail.ContactPerson
                };
            }
        }
        _loading = false;
    }

    // ── Eventos del formulario ────────────────────────────────────────────────
    private void OnRoleChanged()
    {
        _accessOpen = EntityRoles.GetAutoUserProfile(_model.EntityRole) is not null;
        SuggestLogin();
    }

    private void SuggestLogin()
    {
        if (string.IsNullOrEmpty(_model.SuggestedLogin) && !string.IsNullOrEmpty(_model.Email))
            _model.SuggestedLogin = _model.Email;
    }

    // ── Guardar
    private async Task SaveAsync()
    {
        _validationErrors = new();
        _serverError      = null;
        _saving           = true;

        try
        {
            if (_isEdit)
            {
                await Mediator.Send(new UpdateEntityCommand(
                    EntityId!.Value,
                    _model.Name, _model.NationalId, _model.CenterCode,
                    _model.EntityRole, _model.EntityType, _model.EconomicActivity,
                    _model.TypeThirdParty, _model.InscriptionType, _model.InscriptionNumber,
                    _model.CountryCode, _model.StateCode, _model.ProvinceCode,
                    _model.MunicipalityCode, _model.ZipCode, _model.Address,
                    _model.Latitude, _model.Longitude,
                    _model.PhoneNumber, _model.Email, _model.ContactPerson));

                Nav.NavigateTo($"/entities/{EntityId!.Value}");
            }
            else
            {
                var newId = await Mediator.Send(new CreateEntityCommand(
                    _model.Name, _model.NationalId, _model.CenterCode,
                    _model.EntityRole, _model.EntityType, _model.EconomicActivity,
                    _model.TypeThirdParty, _model.InscriptionType, _model.InscriptionNumber,
                    _model.CountryCode, _model.StateCode, _model.ProvinceCode,
                    _model.MunicipalityCode, _model.ZipCode, _model.Address,
                    _model.Latitude, _model.Longitude,
                    _model.PhoneNumber, _model.Email, _model.ContactPerson,
                    _model.SuggestedLogin));

                Nav.NavigateTo($"/entities/{newId}");
            }
        }
        catch (FluentValidation.ValidationException ex)
        {
            foreach (var err in ex.Errors)
            {
                if (!_validationErrors.ContainsKey(err.PropertyName))
                    _validationErrors[err.PropertyName] = [];
                _validationErrors[err.PropertyName].Add(err.ErrorMessage);
            }
        }
        catch (Exception ex)
        {
            _serverError = ex.Message;
        }
        finally { _saving = false; }
    }

    private void Cancel() => Nav.NavigateTo("/entities");
}
