@page "/residues/new"
@page "/residues/{ResidueId:guid}/edit"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.LerCodes.DTOs
@using GreenTransit.Application.Features.LerCodes.Queries
@using GreenTransit.Application.Features.Entities.DTOs
@using GreenTransit.Application.Features.Entities.Queries
@using GreenTransit.Application.Features.Residues.Commands
@using GreenTransit.Application.Features.Residues.Queries
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using Radzen
@using Radzen.Blazor

@inject IMediator        Mediator
@inject NavigationManager Nav

<PageTitle>@(_isEdit ? "Editar Residuo / Producto" : "Nuevo Residuo / Producto")</PageTitle>

<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-recycle me-2"></i>
        @(_isEdit ? "Editar Residuo / Producto" : "Nuevo Residuo / Producto")
    </h1>
</div>

@if (_loading)
{
    <div class="gt-loading"><RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" /></div>
}
else
{
    <RadzenTemplateForm TItem="ResidueFormModel" Data="@_model" Submit="@SaveAsync">

        @* ── 1. Tipo y datos básicos ──────────────────────────────────── *@
        <RadzenFieldset Text="Datos generales" class="rz-mb-4">
            <RadzenRow Gap="1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Tipo *" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="string?" Name="ResidueType" @bind-Value="_model.ResidueType"
                                            Data="@(new[]{new{V="Waste",L="Residuo (Waste)"},new{V="Product",L="Producto (Product)"},new{V="ProductSpec",L="Ficha técnica (ProductSpec)"}})"
                                            TextProperty="L" ValueProperty="V"
                                            Change="@(_ => OnTypeChanged())"
                                            Placeholder="— Seleccionar —" AllowClear="true" Style="width:100%" />
                        </ChildContent>
                        <Helper><RadzenRequiredValidator Component="ResidueType" Text="Obligatorio" /></Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="5">
                    <RadzenFormField Text="Nombre *" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="Name" @bind-Value="_model.Name" Style="width:100%" />
                        </ChildContent>
                        <Helper><RadzenRequiredValidator Component="Name" Text="Obligatorio" /></Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="Referencia" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="Reference" @bind-Value="_model.Reference" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12">
                    <RadzenFormField Text="Descripción" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextArea Name="Description" @bind-Value="_model.Description" Rows="2" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        @* ── 2. Clasificación normativa ───────────────────────────────── *@
        <RadzenFieldset Text="Clasificación normativa" class="rz-mb-4">
            <RadzenRow Gap="1rem">
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="Código LER" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="Guid?" Name="IdLERCode" @bind-Value="_model.IdLERCode"
                                            Data="@_lerCodesFlat" TextProperty="Code" ValueProperty="Id"
                                            AllowFiltering="true" AllowClear="true"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            Placeholder="— Ninguno —" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Tipo de flujo" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="string?" Name="FlowType" @bind-Value="_model.FlowType"
                                            Data="@FlowTypes" TextProperty="Label" ValueProperty="Code"
                                            Change="@(v => OnFlowTypeChangedRadzen(v?.ToString()))"
                                            AllowClear="true" Placeholder="— Seleccionar —" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Categoría de producto" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="string?" Name="ProductCategory" @bind-Value="_model.ProductCategory"
                                            Data="@CategoriesForFlow(_model.FlowType)"
                                            Disabled="@(string.IsNullOrEmpty(_model.FlowType))"
                                            AllowClear="true" Placeholder="— Selecciona flujo primero —" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Uso del producto" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="ProductUse" @bind-Value="_model.ProductUse" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="2">
                    <RadzenStack Gap="0.75rem" class="rz-mt-2">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenCheckBox TValue="bool" Name="IsDangerous" @bind-Value="_model.IsDangerous"
                                            Change="@(_ => StateHasChanged())" />
                            <RadzenLabel Text="Peligroso" Component="IsDangerous" />
                        </RadzenStack>
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenCheckBox TValue="bool" Name="IsRAEE" @bind-Value="_model.IsRAEE" />
                            <RadzenLabel Text="RAEE" Component="IsRAEE" />
                        </RadzenStack>
                    </RadzenStack>
                </RadzenColumn>
                @if (_model.IsDangerous)
                {
                    <RadzenColumn SizeMD="4">
                        <RadzenFormField Text="Código peligrosidad * (H-codes, UN, ADR)" Variant="Variant.Outlined" Style="width:100%">
                            <ChildContent>
                                <RadzenTextBox Name="DangerousCode" @bind-Value="_model.DangerousCode" Style="width:100%" />
                            </ChildContent>
                            <Helper><RadzenRequiredValidator Component="DangerousCode" Text="Obligatorio para residuos peligrosos" /></Helper>
                        </RadzenFormField>
                    </RadzenColumn>
                }
            </RadzenRow>
        </RadzenFieldset>

        @* ── 3. Unidades y medidas ────────────────────────────────────── *@
        <RadzenFieldset Text="Unidades y medidas" class="rz-mb-4">
            <RadzenRow Gap="1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Peso por unidad (kg)" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenNumeric TValue="decimal?" Name="WeightPerUnitKg" @bind-Value="_model.WeightPerUnitKg"
                                           Min="0" Format="0.000" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Unidad de medida defecto" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="DefaultMeasureUnit" @bind-Value="_model.DefaultMeasureUnit" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        @* ── 4. Productor (solo ProductSpec) ──────────────────────────── *@
        @if (_model.ResidueType == "ProductSpec")
        {
            <RadzenFieldset Text="Productor" class="rz-mb-4">
                <RadzenRow Gap="1rem">
                    <RadzenColumn SizeMD="6">
                        <RadzenFormField Text="Productor *" Variant="Variant.Outlined" Style="width:100%">
                            <ChildContent>
                                <RadzenDropDown TValue="Guid?" Name="IdProducer" @bind-Value="_model.IdProducer"
                                                Data="@_producers" TextProperty="Name" ValueProperty="Id"
                                                AllowFiltering="true" AllowClear="true"
                                                Placeholder="— Seleccionar productor —" Style="width:100%" />
                            </ChildContent>
                            <Helper><RadzenRequiredValidator Component="IdProducer" Text="Obligatorio" /></Helper>
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn SizeMD="6">
                        <RadzenFormField Text="Referencia del productor" Variant="Variant.Outlined" Style="width:100%">
                            <ChildContent>
                                <RadzenTextBox Name="ProducerRef" @bind-Value="_model.ProducerRef" Style="width:100%" />
                            </ChildContent>
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>
            </RadzenFieldset>

            @* ── 5. Ecodiseño ──────────────────────────────────────────── *@
            <RadzenFieldset Text="Ecodiseño" class="rz-mb-4">
                <RadzenRow Gap="1rem">
                    <RadzenColumn SizeMD="3">
                        <RadzenFormField Text="Índice reparabilidad (0–10)" Variant="Variant.Outlined" Style="width:100%">
                            <ChildContent>
                                <RadzenNumeric TValue="int?" Name="ReparabilityIndex" @bind-Value="_model.ReparabilityIndex"
                                               Min="0" Max="10" Style="width:100%" />
                            </ChildContent>
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn SizeMD="3">
                        <RadzenFormField Text="Facilidad desmontaje" Variant="Variant.Outlined" Style="width:100%">
                            <ChildContent>
                                <RadzenDropDown TValue="string?" Name="DisassemblyEase" @bind-Value="_model.DisassemblyEase"
                                                Data="@(new[]{new{V="Easy",L="Fácil"},new{V="Medium",L="Media"},new{V="Hard",L="Difícil"}})"
                                                TextProperty="L" ValueProperty="V"
                                                AllowClear="true" Placeholder="— Seleccionar —" Style="width:100%" />
                            </ChildContent>
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn SizeMD="3">
                        <RadzenFormField Text="Contenido reciclado (%)" Variant="Variant.Outlined" Style="width:100%">
                            <ChildContent>
                                <RadzenNumeric TValue="decimal?" Name="RecycledContentPercent" @bind-Value="_model.RecycledContentPercent"
                                               Min="0" Max="100" Format="0.00" Style="width:100%" />
                            </ChildContent>
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn SizeMD="3" class="d-flex align-items-center rz-mt-4">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenCheckBox TValue="bool" Name="ContainsHazardousVal" @bind-Value="_model.ContainsHazardousVal" />
                            <RadzenLabel Text="Contiene sustancias peligrosas" Component="ContainsHazardousVal" />
                        </RadzenStack>
                    </RadzenColumn>
                    <RadzenColumn SizeMD="4">
                        <RadzenFormField Text="Composición (JSON)" Variant="Variant.Outlined" Style="width:100%">
                            <ChildContent>
                                <RadzenTextArea Name="CompositionJson" @bind-Value="_model.CompositionJson" Rows="3" class="rz-text-monospace" Style="width:100%" />
                            </ChildContent>
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn SizeMD="4">
                        <RadzenFormField Text="Códigos LER potenciales (JSON)" Variant="Variant.Outlined" Style="width:100%">
                            <ChildContent>
                                <RadzenTextArea Name="PotentialLERCodesJson" @bind-Value="_model.PotentialLERCodesJson" Rows="3" class="rz-text-monospace" Style="width:100%" />
                            </ChildContent>
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn SizeMD="4">
                        <RadzenFormField Text="Materiales (JSON)" Variant="Variant.Outlined" Style="width:100%">
                            <ChildContent>
                                <RadzenTextArea Name="MaterialsJson" @bind-Value="_model.MaterialsJson" Rows="3" class="rz-text-monospace" Style="width:100%" />
                            </ChildContent>
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>
            </RadzenFieldset>
        }

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" class="rz-mt-4">@_errorMessage</RadzenAlert>
        }

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" class="rz-mt-4">
            <RadzenButton ButtonType="ButtonType.Submit" Text="Guardar" Icon="save"
                          ButtonStyle="ButtonStyle.Primary" Disabled="@_saving" IsBusy="@_saving" />
            <RadzenButton Text="Cancelar" Icon="cancel" ButtonStyle="ButtonStyle.Light"
                          ButtonType="ButtonType.Button" Click="@(_ => Cancel())" />
        </RadzenStack>

    </RadzenTemplateForm>
}
@code {
    [Parameter] public Guid? ResidueId { get; set; }

    private bool    _isEdit  = false;
    private bool    _loading = true;
    private bool    _saving  = false;
    private string? _errorMessage;
    private Dictionary<string, List<string>> _validationErrors = [];

    private List<LerCodeDto>  _lerCodesFlat = [];
    private List<EntityDto>   _producers    = [];

    private ResidueFormModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        // Cargar catálogos auxiliares de forma secuencial (DbContext es Scoped y no soporta concurrencia)
        await LoadLerCodesAsync();
        await LoadProducersAsync();

        _isEdit = ResidueId.HasValue;
        if (_isEdit)
        {
            var detail = await Mediator.Send(new GetResidueByIdQuery(ResidueId!.Value));
            if (detail is not null)
                _model = ResidueFormModel.FromDetail(detail);
        }

        _loading = false;
    }

    private async Task LoadLerCodesAsync()
    {
        var chapters = await Mediator.Send(new GetLerCodesQuery());
        _lerCodesFlat = chapters
            .SelectMany(c => c.SubChapters.SelectMany(s => s.Codes))
            .OrderBy(l => l.Code)
            .ToList();
    }

    private async Task LoadProducersAsync()
    {
        var result = await Mediator.Send(new GetEntitiesQuery(EntityRole: "Producer", PageSize: 500));
        _producers = [.. result.Items];
    }

    private void OnTypeChanged() => StateHasChanged();

    private void OnFlowTypeChangedRadzen(string? value)
    {
        _model.FlowType = value;
        if (!CategoriesForFlow(_model.FlowType).Contains(_model.ProductCategory ?? string.Empty))
            _model.ProductCategory = null;
    }

    private void OnFlowTypeChanged(ChangeEventArgs e)
    {
        _model.FlowType = e.Value?.ToString();
        if (!CategoriesForFlow(_model.FlowType).Contains(_model.ProductCategory ?? string.Empty))
            _model.ProductCategory = null;
    }

    // ── Catálogos estáticos ───────────────────────────────────────────────────

    private sealed record FlowTypeItem(string Code, string Label);

    private static readonly FlowTypeItem[] FlowTypes =
    [
        new("RAEE", "RAEE - Aparatos eléctricos y electrónicos"),
        new("ENV",  "ENV - Envases"),
        new("BAT",  "BAT - Pilas y acumuladores"),
        new("NFU",  "NFU - Neumáticos fuera de uso"),
        new("OIL",  "OIL - Aceites industriales"),
        new("VFU",  "VFU - Vehículos fuera de uso")
    ];

    private static readonly Dictionary<string, string[]> CategoriesByFlow = new(StringComparer.OrdinalIgnoreCase)
    {
        ["ENV"] =
        [
            "Doméstico - Ligero", "Doméstico - Vidrio", "Doméstico - Cartón",
            "Comercial - Ligero", "Comercial - Cartón", "Comercial - Vidrio",
            "Industrial - Ligero", "Industrial - Cartón", "Industrial - Vidrio",
            "Agrario", "Fitosanitarios", "Medicamentos"
        ],
        ["RAEE"] =
        [
            "Grandes aparatos", "Pequeños aparatos",
            "Informática y telecomunicaciones", "Electrónica de consumo",
            "Alumbrado", "Herramientas", "Equipos profesionales", "Paneles fotovoltaicos"
        ],
        ["BAT"] = ["Portátiles", "Industriales", "Automoción"],
        ["NFU"] = ["Turismo", "Camión / Industrial", "Agrícola", "OTR", "Bicicleta"],
        ["OIL"] = ["Automoción", "Industrial", "Mezcla / contaminados"],
        ["VFU"] = ["Vehículo completo", "Componentes"]
    };

    private static string[] CategoriesForFlow(string? flowType)
        => !string.IsNullOrEmpty(flowType) && CategoriesByFlow.TryGetValue(flowType, out var cats)
            ? cats
            : [];

    private async Task SaveAsync()
    {
        _saving       = true;
        _errorMessage = null;
        _validationErrors = [];
        try
        {
            if (_isEdit)
            {
                await Mediator.Send(new UpdateResidueCommand(
                    ResidueId!.Value,
                    _model.ResidueType!, _model.Name!, _model.Description, _model.Reference,
                    _model.IdLERCode, _model.IsDangerous, _model.IsRAEE, _model.DangerousCode,
                    _model.FlowType, _model.ProductUse, _model.ProductCategory, _model.WeightPerUnitKg,
                    _model.DefaultMeasureUnit, _model.ReparabilityIndex, _model.DisassemblyEase,
                    _model.ContainsHazardousVal ? true : null,
                    _model.RecycledContentPercent, _model.CompositionJson,
                    _model.PotentialLERCodesJson, _model.MaterialsJson,
                    _model.IdProducer, _model.ProducerRef));
            }
            else
            {
                await Mediator.Send(new CreateResidueCommand(
                    _model.ResidueType!, _model.Name!, _model.Description, _model.Reference,
                    _model.IdLERCode, _model.IsDangerous, _model.IsRAEE, _model.DangerousCode,
                    _model.FlowType, _model.ProductUse, _model.ProductCategory, _model.WeightPerUnitKg,
                    _model.DefaultMeasureUnit, _model.ReparabilityIndex, _model.DisassemblyEase,
                    _model.ContainsHazardousVal ? true : null,
                    _model.RecycledContentPercent, _model.CompositionJson,
                    _model.PotentialLERCodesJson, _model.MaterialsJson,
                    _model.IdProducer, _model.ProducerRef));
            }
            Nav.NavigateTo("/residues");
        }
        catch (FluentValidation.ValidationException vex)
        {
            _validationErrors = vex.Errors
                .GroupBy(e => e.PropertyName)
                .ToDictionary(g => g.Key, g => g.Select(e => e.ErrorMessage).ToList());
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => Nav.NavigateTo("/residues");

    // ── Modelo formulario ─────────────────────────────────────────────────────
    private sealed class ResidueFormModel
    {
        public string?   ResidueType            { get; set; }
        public string?   Name                   { get; set; }
        public string?   Description            { get; set; }
        public string?   Reference              { get; set; }
        public Guid?     IdLERCode              { get; set; }
        public bool      IsDangerous            { get; set; }
        public bool      IsRAEE                 { get; set; }
        public string?   DangerousCode          { get; set; }
        public string?   FlowType               { get; set; }
        public string?   ProductUse             { get; set; }
        public string?   ProductCategory        { get; set; }
        public decimal?  WeightPerUnitKg        { get; set; }
        public string?   DefaultMeasureUnit     { get; set; }
        public int?      ReparabilityIndex      { get; set; }
        public string?   DisassemblyEase        { get; set; }
        public bool      ContainsHazardousVal   { get; set; }
        public decimal?  RecycledContentPercent { get; set; }
        public string?   CompositionJson        { get; set; }
        public string?   PotentialLERCodesJson  { get; set; }
        public string?   MaterialsJson          { get; set; }
        public Guid?     IdProducer             { get; set; }
        public string?   ProducerRef            { get; set; }

        // Helper para select con Guid?
        public string IdProducerStr
        {
            get => IdProducer?.ToString() ?? "";
            set => IdProducer = Guid.TryParse(value, out var g) ? g : null;
        }

        public static ResidueFormModel FromDetail(
            GreenTransit.Application.Features.Residues.DTOs.ResidueDetailDto d)
            => new()
            {
                ResidueType            = d.ResidueType,
                Name                   = d.Name,
                Description            = d.Description,
                Reference              = d.Reference,
                IdLERCode              = d.IdLERCode,
                IsDangerous            = d.IsDangerous,
                IsRAEE                 = d.IsRAEE,
                DangerousCode          = d.DangerousCode,
                FlowType               = d.FlowType,
                ProductUse             = d.ProductUse,
                ProductCategory        = d.ProductCategory,
                WeightPerUnitKg        = d.WeightPerUnitKg,
                DefaultMeasureUnit     = d.DefaultMeasureUnit,
                ReparabilityIndex      = d.ReparabilityIndex,
                DisassemblyEase        = d.DisassemblyEase,
                ContainsHazardousVal   = d.ContainsHazardous ?? false,
                RecycledContentPercent = d.RecycledContentPercent,
                CompositionJson        = d.CompositionJson,
                PotentialLERCodesJson  = d.PotentialLERCodesJson,
                MaterialsJson          = d.MaterialsJson,
                IdProducer             = d.IdProducer,
                ProducerRef            = d.ProducerRef
            };
    }
}
