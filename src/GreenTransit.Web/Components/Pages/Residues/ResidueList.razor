@using Radzen
@using Radzen.Blazor
@page "/residues"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Common.Models
@using GreenTransit.Application.Features.Residues.DTOs
@using GreenTransit.Application.Features.Residues.Queries
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator        Mediator
@inject NavigationManager Nav

<PageTitle>Residuos y Productos</PageTitle>

<div class="page-header">
    <h1 class="page-title"><i class="bi bi-recycle me-2"></i>Residuos y Productos</h1>
    <button class="btn btn-primary btn-sm" @onclick="CreateNew">
        <i class="bi bi-plus-lg me-1"></i>Nuevo
    </button>
</div>

@* ── Tabs de tipo ─────────────────────────────────────────────────────────── *@
<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @TabClass("")" @onclick='() => SetTab("")'>Todos</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @TabClass("Waste")" @onclick='() => SetTab("Waste")'>
            <i class="bi bi-trash me-1"></i>Residuos
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @TabClass("Product")" @onclick='() => SetTab("Product")'>
            <i class="bi bi-box-seam me-1"></i>Productos
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @TabClass("ProductSpec")" @onclick='() => SetTab("ProductSpec")'>
            <i class="bi bi-file-earmark-text me-1"></i>Fichas técnicas
        </button>
    </li>
</ul>

@* ── Filtros ───────────────────────────────────────────────────────────────── *@
<div class="filter-bar">
    <div class="filter-group">
        <label>Búsqueda</label>
        <input class="form-control"
               placeholder="Nombre, referencia…"
               @bind="_searchTerm" @bind:event="oninput"
               @onkeyup="@(async e => { if (e.Key == "Enter") await LoadAsync(); })" />
    </div>
    <div class="filter-group">
        <label>Peligroso</label>
        <select class="form-control" @bind="_filterDangerous">
            <option value="">— Todos —</option>
            <option value="true">Sí</option>
            <option value="false">No</option>
        </select>
    </div>
    <div class="filter-group">
        <label>RAEE</label>
        <select class="form-control" @bind="_filterRaee">
            <option value="">— Todos —</option>
            <option value="true">Sí</option>
            <option value="false">No</option>
        </select>
    </div>
    <div class="filter-actions">
        <button class="btn btn-primary btn-sm" @onclick="ApplyFilters">
            <i class="bi bi-search me-1"></i>Buscar
        </button>
        <button class="btn btn-ghost btn-sm" @onclick="ResetFilters">Limpiar</button>
    </div>
</div>

@* ── Tabla ─────────────────────────────────────────────────────────────────── *@
<RadzenDataGrid @ref="_grid" TItem="ResidueDto"
                Data="@(_result?.Items ?? [])" Count="@(_result?.TotalCount ?? 0)"
                LoadData="@OnLoadData"
                AllowPaging="true" PageSize="20"
                AllowSorting="true" AllowFiltering="false"
                IsLoading="@_loading"
                EmptyText="No se encontraron registros con los filtros aplicados."
                PagerHorizontalAlign="HorizontalAlign.Right">
    <Columns>
        <RadzenDataGridColumn TItem="ResidueDto" Property="Name" Title="Nombre" Width="200px">
            <Template Context="r"><a class="rz-link" href="/residues/@r.Id">@r.Name</a></Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ResidueDto" Property="Reference" Title="Referencia" Width="120px">
            <Template Context="r"><code>@(r.Reference ?? "—")</code></Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ResidueDto" Property="ResidueType" Title="Tipo" Width="120px">
            <Template Context="r">
                <RadzenBadge Text="@r.ResidueType"
                             BadgeStyle="@(r.ResidueType == "Waste" ? BadgeStyle.Secondary : r.ResidueType == "Product" ? BadgeStyle.Primary : BadgeStyle.Info)" />
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ResidueDto" Property="LerCode" Title="LER" Width="130px">
            <Template Context="r">
                @if (!string.IsNullOrEmpty(r.LerCode))
                { <code>@r.LerCode</code><span class="rz-text-secondary-color rz-text-sm ms-1">@r.LerDescription</span> }
                else
                { <span class="rz-text-disabled">—</span> }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ResidueDto" Property="IsDangerous" Title="Peligroso" Width="90px" TextAlign="TextAlign.Center">
            <Template Context="r">
                @if (r.IsDangerous) { <RadzenBadge Text="Sí" BadgeStyle="BadgeStyle.Danger" /> }
                else { <span class="rz-text-disabled">—</span> }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ResidueDto" Property="IsRAEE" Title="RAEE" Width="70px" TextAlign="TextAlign.Center">
            <Template Context="r">
                @if (r.IsRAEE) { <RadzenBadge Text="Sí" BadgeStyle="BadgeStyle.Warning" /> }
                else { <span class="rz-text-disabled">—</span> }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ResidueDto" Property="IsActive" Title="Estado" Width="90px" TextAlign="TextAlign.Center">
            <Template Context="r">
                @if (r.IsActive) { <RadzenBadge Text="Activo" BadgeStyle="BadgeStyle.Success" /> }
                else { <RadzenBadge Text="Inactivo" BadgeStyle="BadgeStyle.Secondary" /> }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ResidueDto" Title="" Width="80px" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
            <Template Context="r">
                <RadzenButton Icon="edit" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                              Click="@(() => Nav.NavigateTo($"/residues/{r.Id}/edit"))" title="Editar" />
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@code {
    private PaginatedResult<ResidueDto>? _result;
    private RadzenDataGrid<ResidueDto> _grid = default!;
    private bool    _loading         = true;
    private string  _activeTab       = "";
    private string? _searchTerm;
    private string  _filterDangerous = "";
    private string  _filterRaee      = "";
    private int     _page            = 1;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _result  = await Mediator.Send(new GetResiduesQuery(
            ResidueType: string.IsNullOrEmpty(_activeTab) ? null : _activeTab,
            IsDangerous: ParseBool(_filterDangerous),
            IsRAEE:      ParseBool(_filterRaee),
            SearchTerm:  _searchTerm,
            PageNumber:  _page));
        _loading = false;
    }

    private async Task OnLoadData(LoadDataArgs args)
    {
        _page = args.Skip.HasValue ? (args.Skip.Value / 20) + 1 : 1;
        await LoadAsync();
    }

    private async Task SetTab(string tab)
    {
        _activeTab = tab;
        _page      = 1;
        await LoadAsync();
        if (_grid is not null) await _grid.Reload();
    }

    private async Task ApplyFilters()
    {
        _page = 1;
        await LoadAsync();
        if (_grid is not null) await _grid.Reload();
    }

    private async Task ResetFilters()
    {
        _searchTerm      = null;
        _filterDangerous = "";
        _filterRaee      = "";
        _page            = 1;
        await LoadAsync();
        if (_grid is not null) await _grid.Reload();
    }

    private async Task GoToPage(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private void CreateNew() => Nav.NavigateTo("/residues/new");

    private string TabClass(string tab)
        => _activeTab == tab ? "active" : "";

    private static string TypeBadgeClass(string type) => type switch
    {
        "Waste"       => "bg-secondary",
        "Product"     => "bg-primary",
        "ProductSpec" => "bg-info text-dark",
        _             => "bg-light text-dark"
    };

    private static bool? ParseBool(string value)
        => value switch { "true" => true, "false" => false, _ => null };
}
