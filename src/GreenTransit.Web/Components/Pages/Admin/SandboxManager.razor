@page "/admin/sandbox"
@attribute [Authorize(Policy = PolicyConstants.AdminOnly)]
@rendermode InteractiveServer

@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Application.Common.Models
@using GreenTransit.Application.Features.EcoDataNet.Commands
@using GreenTransit.Domain.Authorization
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject ISandboxDataSeeder Seeder
@inject ILogger<SandboxManager> Logger
@inject IMediator Mediator

<PageTitle>Gestión Datos Sandbox</PageTitle>

<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-database-fill-gear me-2"></i>Gestión de Datos Sandbox
    </h1>
    <p class="text-muted mb-0">
        Inserta o elimina el conjunto de datos de demostración (~1.400 registros). Operación idempotente.
    </p>
</div>

<div class="row g-4 mt-2">

    @* ── Tarjeta: Insertar datos ─────────────────────────────────────────────── *@
    <div class="col-md-4">
        <div class="card h-100 border-success">
            <div class="card-header bg-success text-white">
                <i class="bi bi-play-circle-fill me-2"></i>Insertar datos demo
            </div>
            <div class="card-body">
                <p class="card-text">
                    Ejecuta las 7 fases de seed en orden estricto de dependencias FK:<br />
                    <small class="text-muted">
                        Catálogos → Entidades → Residuos → Acuerdos → Operaciones logísticas →
                        Entradas/Tratamiento → Economía → Declaraciones
                    </small>
                </p>
                <ul class="list-unstyled small text-muted mb-3">
                    <li><i class="bi bi-check2 text-success me-1"></i>40 Entidades (Productores, SCRAP, CAC, Plantas…)</li>
                    <li><i class="bi bi-check2 text-success me-1"></i>100 Órdenes de Servicio y Traslados</li>
                    <li><i class="bi bi-check2 text-success me-1"></i>25 Acuerdos y Liquidaciones</li>
                    <li><i class="bi bi-check2 text-success me-1"></i>~90 Cuotas de mercado (MarketShares)</li>
                    <li><i class="bi bi-check2 text-success me-1"></i>~35 Declaraciones de producción</li>
                    <li><i class="bi bi-check2 text-success me-1"></i>15 Incidencias</li>
                </ul>
                <button class="btn btn-success w-100"
                        @onclick="SeedAsync"
                        disabled="@_busy">
                    @if (_busy && _action == "seed")
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Insertando datos…</span>
                    }
                    else
                    {
                        <i class="bi bi-play-fill me-2"></i>
                        <span>Ejecutar Seed</span>
                    }
                </button>
            </div>
        </div>
    </div>

    @* ── Tarjeta: Publicar a EcoDataNet ─────────────────────────────────────── *@
    <div class="col-md-4">
        <div class="card h-100 border-primary">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-cloud-upload-fill me-2"></i>Publicar datos a EcoDataNet Waste
            </div>
            <div class="card-body">
                <p class="card-text">
                    Publica los 16 endpoints operativos de GreenTransit a la API EcoDataNet Waste
                    en lotes de hasta 100 elementos con manejo de respuestas parciales (207).
                </p>

                @if (_publishSummary is not null)
                {
                    bool _hasErr = _publishSummary.TotalErrors > 0 ||
                                   _publishSummary.Results.Any(r => r.ErrorMessage is not null);
                    bool _noData = _publishSummary.TotalItemsSent == 0;
                    string _acss = _hasErr ? "alert-danger" : _noData ? "alert-warning" : "alert-success";

                    <div class="alert @_acss py-2 small mb-2">
                        @if (_noData)
                        {
                            <i class="bi bi-exclamation-triangle-fill me-1"></i>
                            <strong>Sin datos.</strong>
                            <text> Ejecuta primero el Seed y vuelve a publicar.</text>
                        }
                        else
                        {
                            <strong>@_publishSummary.TotalEndpoints endpoints</strong>
                            <span class="mx-1 text-muted">|</span>
                            <strong>@_publishSummary.TotalItemsSent enviados</strong>
                            <span class="mx-1 text-muted">|</span>
                            <span class="text-success fw-bold">@_publishSummary.TotalSuccess OK</span>
                            <span class="mx-1 text-muted">|</span>
                            <span class="text-danger fw-bold">@_publishSummary.TotalErrors err</span>
                            <span class="mx-1 text-muted">|</span>
                            <span>@(_publishSummary.Duration.TotalSeconds.ToString("F1"))s</span>
                        }
                    </div>

                    @* Tabla detalle por endpoint *@
                    <div style="max-height:220px;overflow-y:auto;">
                        <table class="table table-sm table-bordered table-hover mb-0" style="font-size:0.72rem;">
                            <thead class="table-dark sticky-top">
                                <tr>
                                    <th>Endpoint</th>
                                    <th class="text-center">Env.</th>
                                    <th class="text-center">OK</th>
                                    <th class="text-center">Err</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in _publishSummary.Results)
                                {
                                    string rowCss;
                                    if (r.ErrorMessage is not null || r.ErrorCount > 0)
                                        rowCss = "table-danger";
                                    else if (r.TotalSent == 0)
                                        rowCss = "table-secondary";
                                    else
                                        rowCss = "table-success";

                                    <tr class="@rowCss">
                                        <td class="fw-semibold">@r.Endpoint</td>
                                        <td class="text-center">@r.TotalSent</td>
                                        <td class="text-center">@r.SuccessCount</td>
                                        <td class="text-center">@r.ErrorCount</td>
                                        <td class="text-truncate" style="max-width:120px;"
                                            title="@(r.ErrorDetail ?? r.ErrorMessage)">
                                            @(r.ErrorMessage ?? (r.TotalSent == 0 ? "sin datos" : "✓"))
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <button class="btn btn-primary w-100"
                        @onclick="PublishToEcoDataNetAsync"
                        disabled="@_busy">
                    @if (_busy && _action == "publish")
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Publicando a EcoDataNet…&nbsp;@_publishProgress</span>
                    }
                    else
                    {
                        <i class="bi bi-send-fill me-2"></i>
                        <span>Publicar a EcoDataNet</span>
                    }
                </button>
            </div>
        </div>
    </div>

    @* ── Tarjeta: Limpiar datos ──────────────────────────────────────────────── *@
    <div class="col-md-4">
        <div class="card h-100 border-danger">
            <div class="card-header bg-danger text-white">
                <i class="bi bi-trash3-fill me-2"></i>Limpiar datos demo
            </div>
            <div class="card-body">
                <p class="card-text">
                    Elimina <strong>todos</strong> los registros con <code>SourceSystem = 'SEED'</code>
                    en orden inverso de FK. No afecta datos reales.
                </p>
                <div class="alert alert-warning py-2 small mb-3">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i>
                    Esta operación es <strong>irreversible</strong>. Los datos demo se borrarán permanentemente.
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="chkCleanAll"
                           @bind="_cleanAll" disabled="@(_busy || _confirmClean)" />
                    <label class="form-check-label small" for="chkCleanAll">
                        Incluir también datos <strong>no-sandbox</strong> del tenant
                        <span class="text-danger fw-bold">(elimina TODOS los datos operativos)</span>
                    </label>
                </div>

                @if (_cleanAll && !_confirmClean)
                {
                    <div class="alert alert-danger py-2 small mb-3">
                        <i class="bi bi-radioactive me-1"></i>
                        <strong>¡Atención!</strong> Se eliminarán <strong>todos</strong> los registros del tenant,
                        incluyendo datos reales. Esta acción es <strong>irreversible</strong>.
                    </div>
                }

                @if (!_confirmClean)
                {
                    <button class="btn @(_cleanAll ? "btn-danger" : "btn-outline-danger") w-100"
                            @onclick="RequestConfirm"
                            disabled="@_busy">
                        <i class="bi bi-trash3 me-2"></i>
                        @(_cleanAll ? "Limpiar TODOS los datos del tenant…" : "Limpiar datos demo…")
                    </button>
                }
                else
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-danger flex-grow-1"
                                @onclick="ExecuteCleanAsync"
                                disabled="@_busy">
                            @if (_busy && _action == "clean")
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                <span>Eliminando…</span>
                            }
                            else
                            {
                                <i class="bi bi-check-lg me-1"></i>
                                <span>Confirmar borrado</span>
                            }
                        </button>
                        <button class="btn btn-secondary"
                                @onclick="CancelConfirm"
                                disabled="@_busy">
                            Cancelar
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* ── Log de resultados ───────────────────────────────────────────────────────── *@
@if (_messages.Count > 0)
{
    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-terminal-fill me-2"></i>Log de ejecución</span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ClearLog">
                <i class="bi bi-x-circle me-1"></i>Limpiar
            </button>
        </div>
        <div class="card-body p-0">
            <ul class="list-group list-group-flush font-monospace small" style="max-height:340px;overflow-y:auto;">
                @foreach (var msg in _messages)
                {
                    <li class="list-group-item py-1 @GetMsgClass(msg)">
                        <i class="@GetMsgIcon(msg) me-2"></i>@msg.Text
                    </li>
                }
            </ul>
        </div>
    </div>
}

@code {
    private bool          _busy           = false;
    private bool          _confirmClean   = false;
    private bool          _cleanAll       = false;
    private string        _action         = string.Empty;
    private string        _publishProgress = string.Empty;
    private PublishSummary? _publishSummary;

    private sealed record LogMessage(string Text, string Level);
    private readonly List<LogMessage> _messages = [];

    private async Task SeedAsync()
    {
        _busy   = true;
        _action = "seed";
        _messages.Clear();
        StateHasChanged();

        try
        {
            Log("Iniciando seed de datos sandbox…", "info");
            var sw = System.Diagnostics.Stopwatch.StartNew();
            await Seeder.SeedAsync();
            sw.Stop();
            Log($"✅ Seed completado en {sw.Elapsed.TotalSeconds:F1}s", "success");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error en SandboxManager.SeedAsync");
            Log($"❌ Error: {ex.Message}", "danger");
        }
        finally
        {
            _busy   = false;
            _action = string.Empty;
        }
    }

    private async Task ExecuteCleanAsync()
    {
        _busy         = true;
        _action       = "clean";
        _confirmClean = false;
        StateHasChanged();

        try
        {
            if (_cleanAll)
            {
                Log("Iniciando limpieza TOTAL de datos del tenant…", "warning");
                var sw = System.Diagnostics.Stopwatch.StartNew();
                await Seeder.CleanAllAsync();
                sw.Stop();
                Log($"✅ Limpieza total completada en {sw.Elapsed.TotalSeconds:F1}s", "success");
            }
            else
            {
                Log("Iniciando limpieza de datos sandbox…", "warning");
                var sw = System.Diagnostics.Stopwatch.StartNew();
                await Seeder.CleanAsync();
                sw.Stop();
                Log($"✅ Limpieza completada en {sw.Elapsed.TotalSeconds:F1}s", "success");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error en SandboxManager.ExecuteCleanAsync");
            Log($"❌ Error: {ex.Message}", "danger");
        }
        finally
        {
            _busy     = false;
            _action   = string.Empty;
            _cleanAll = false;
        }
    }

    private async Task PublishToEcoDataNetAsync()
    {
        _busy            = true;
        _action          = "publish";
        _publishProgress = string.Empty;
        _publishSummary  = null;
        _messages.Clear();
        StateHasChanged();

        try
        {
            Log("Iniciando publicación a EcoDataNet Waste…", "info");
            var sw = System.Diagnostics.Stopwatch.StartNew();

            _publishSummary = await Mediator.Send(new PublishToEcoDataNetCommand(
                OnProgress: (endpoint, current, total) =>
                {
                    _publishProgress = $"({current}/{total}) {endpoint}";
                    Log($"Publicando endpoint {current}/{total}: {endpoint}", "info");
                    InvokeAsync(StateHasChanged);
                }));

            sw.Stop();
            Log($"✅ Publicación completada en {sw.Elapsed.TotalSeconds:F1}s — " +
                $"{_publishSummary.TotalSuccess} ok / {_publishSummary.TotalErrors} errores", "success");

            foreach (var r in _publishSummary.Results)
            {
                if (r.ErrorMessage is not null || r.ErrorCount > 0)
                    Log($"  ❌ {r.Endpoint}: {r.TotalSent} enviados, {r.ErrorCount} errores — {r.ErrorMessage} {r.ErrorDetail}", "danger");
                else if (r.TotalSent == 0)
                    Log($"  ⚪ {r.Endpoint}: sin datos (0 registros)", "info");
                else
                    Log($"  ✅ {r.Endpoint}: {r.TotalSent} enviados, {r.SuccessCount} correctos", "success");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error en SandboxManager.PublishToEcoDataNetAsync");
            Log($"❌ Error inesperado: {ex.Message}", "danger");
        }
        finally
        {
            _busy            = false;
            _action          = string.Empty;
            _publishProgress = string.Empty;
        }
    }

    private void RequestConfirm()  => _confirmClean = true;
    private void CancelConfirm()   { _confirmClean = false; _cleanAll = false; }
    private void ClearLog()        => _messages.Clear();

    private void Log(string text, string level)
    {
        _messages.Add(new LogMessage($"[{DateTime.Now:HH:mm:ss}] {text}", level));
        StateHasChanged();
    }

    private static string GetMsgClass(LogMessage m) => m.Level switch
    {
        "success" => "list-group-item-success",
        "danger"  => "list-group-item-danger",
        "warning" => "list-group-item-warning",
        _         => string.Empty
    };

    private static string GetMsgIcon(LogMessage m) => m.Level switch
    {
        "success" => "bi bi-check-circle-fill text-success",
        "danger"  => "bi bi-x-circle-fill text-danger",
        "warning" => "bi bi-exclamation-circle-fill text-warning",
        _         => "bi bi-info-circle text-secondary"
    };
}
