@using Radzen
@using Radzen.Blazor
@page "/entry-plants"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.EntryPlants.DTOs
@using GreenTransit.Application.Features.EntryPlants.Queries
@using GreenTransit.Application.Features.WasteMoves.DTOs
@using GreenTransit.Application.Features.WasteMoves.Queries
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator        Mediator
@inject NavigationManager Nav

<PageTitle>Entradas en Planta</PageTitle>

<div class="page-header">
    <div class="page-header-info">
        <h1 class="page-title">
            <i class="bi bi-building-gear me-2"></i>Entradas en Planta — Pesaje
        </h1>
    </div>
</div>

@* ── Panel: Nueva entrada en planta ──────────────────────────────────────── *@
<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0 text-success">
            <i class="bi bi-plus-circle me-2"></i>Nueva entrada en planta
        </h6>
    </div>
    <div class="card-body">
        @if (_loadingDisponibles)
        {
            <div class="text-muted small">
                <span class="spinner-border spinner-border-sm me-1"></span>
                Cargando traslados disponibles…
            </div>
        }
        else if (_disponibles.Count == 0)
        {
            <div class="text-muted small">
                <i class="bi bi-info-circle me-1"></i>
                No hay traslados en estado <strong>RECOGIDO</strong> o <strong>EN CAC</strong>
                pendientes de entrada en planta.
            </div>
        }
        else
        {
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-8">
                    <label class="form-label form-label-sm fw-semibold">
                        Traslado disponible para pesaje
                    </label>
                    <select class="form-select" @bind="_selectedWasteMoveId">
                        <option value="">— Seleccionar traslado —</option>
                        @foreach (var wm in _disponibles)
                        {
                            <option value="@wm.Id">
                                @(wm.WasteMoveReference ?? wm.Id.ToString()[..8])
                                — @(wm.PlannedPickupStart?.ToString("dd/MM/yyyy") ?? "sin fecha")
                                (@WasteMoveStatuses.Label(wm.ServiceStatus ?? ""))
                                (@wm.ResidueCount residuo@(wm.ResidueCount != 1 ? "s" : ""))
                            </option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <button class="btn btn-primary w-100"
                            disabled="@string.IsNullOrEmpty(_selectedWasteMoveId)"
                            @onclick="GoToNewEntry">
                        <i class="bi bi-arrow-right-circle me-2"></i>Registrar pesaje
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@* ── Filtros ──────────────────────────────────────────────────────────────── *@
<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-3">
                <label class="form-label form-label-sm">Referencia traslado</label>
                <input class="form-control form-control-sm"
                       @bind="_filterReference"
                       @bind:event="oninput"
                       placeholder="WM-2024-…" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label form-label-sm">Fecha desde</label>
                <InputDate TValue="DateTime?" class="form-control form-control-sm"
                           @bind-Value="_filterDateFrom" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label form-label-sm">Fecha hasta</label>
                <InputDate TValue="DateTime?" class="form-control form-control-sm"
                           @bind-Value="_filterDateTo" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label form-label-sm">Báscula (WeighbridgeId)</label>
                <input class="form-control form-control-sm"
                       @bind="_filterWeighbridgeId"
                       @bind:event="oninput"
                       placeholder="BAS-01" />
            </div>
            <div class="col-12 col-md-2 d-flex gap-2">
                <button class="btn btn-primary btn-sm w-100" @onclick="LoadAsync">
                    <i class="bi bi-search me-1"></i>Buscar
                </button>
                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="ResetFilters"
                        title="Limpiar filtros">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
    </div>
</div>

@* ── Historial ────────────────────────────────────────────────────────────── *@
@if (_loading)
{
    <LoadingSpinner />
}
else if (_result is null || _result.Items.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-1"></i>
        No se encontraron entradas en planta con los filtros indicados.
    </div>
}
else
{
    @* ── Totales por día ─────────────────────────────────────────────── *@
    var byDay = _result.Items
        .Where(x => x.PlantEntryDate.HasValue && x.NetWeight.HasValue)
        .GroupBy(x => x.PlantEntryDate!.Value.Date)
        .OrderByDescending(g => g.Key)
        .ToList();

    @if (byDay.Count > 0)
    {
        <div class="card mb-3 border-0 bg-light">
            <div class="card-body py-2">
                <div class="d-flex flex-wrap gap-3">
                    @foreach (var g in byDay)
                    {
                        <div class="text-center">
                            <div class="text-muted small">@g.Key.ToString("dd/MM")</div>
                            <div class="fw-bold text-success">
                                @g.Sum(x => x.NetWeight!.Value).ToString("N0") kg netos
                            </div>
                            <div class="text-muted small">@g.Count() entrada@(g.Count() != 1 ? "s" : "")</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @* Vista móvil *@
    <div class="d-md-none">
        @foreach (var item in _result.Items)
        {
            <div class="card mb-2 shadow-sm" @onclick="() => GoToDetail(item.Id)"
                 style="cursor:pointer">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between">
                        <span class="fw-semibold">
                            @(item.TicketScale ?? "—")
                        </span>
                        <span class="badge text-bg-secondary">
                            @item.ResidueLineCount residuos
                        </span>
                    </div>
                    <div class="text-muted small">
                        @(item.WasteMoveReference ?? item.IdWasteMove.ToString()[..8])
                    </div>
                    <div class="text-muted small mt-1">
                        <i class="bi bi-calendar3 me-1"></i>
                        @(item.PlantEntryDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                    </div>
                    <div class="d-flex gap-3 mt-1 small">
                        <span>Bruto: <strong>@(item.GrossWeight?.ToString("N2") ?? "—") kg</strong></span>
                        <span>Tara: <strong>@(item.TareWeight?.ToString("N2") ?? "—") kg</strong></span>
                        <span class="text-success">Neto: <strong>@(item.NetWeight?.ToString("N2") ?? "—") kg</strong></span>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Vista escritorio *@
    <div class="d-none d-md-block">
        <RadzenDataGrid TItem="EntryPlantDto"
                        Data="@_result.Items" Count="@_result.TotalCount"
                        AllowPaging="false" AllowSorting="true" AllowFiltering="false"
                        EmptyText="No se encontraron entradas."
                        RowClick="@(args => GoToDetail(args.Data.Id))"
                        Style="cursor:pointer">
            <Columns>
                <RadzenDataGridColumn TItem="EntryPlantDto" Property="TicketScale" Title="Ticket báscula" Width="140px">
                    <Template Context="item">
                        <a href="/entry-plants/@item.Id" class="rz-link rz-text-weight-bold"
                           @onclick:stopPropagation>@(item.TicketScale ?? "—")</a>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="EntryPlantDto" Property="WasteMoveReference" Title="Referencia traslado" Width="150px">
                    <Template Context="item">@(item.WasteMoveReference ?? item.IdWasteMove.ToString()[..8])</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="EntryPlantDto" Property="PlantEntryDate" Title="Fecha entrada" Width="145px">
                    <Template Context="item">@(item.PlantEntryDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="EntryPlantDto" Property="WeighbridgeId" Title="Báscula" Width="100px">
                    <Template Context="item">@(item.WeighbridgeId ?? "—")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="EntryPlantDto" Property="GrossWeight" Title="Bruto (kg)" Width="100px" TextAlign="TextAlign.Right">
                    <Template Context="item">@(item.GrossWeight?.ToString("N2") ?? "—")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="EntryPlantDto" Property="TareWeight" Title="Tara (kg)" Width="100px" TextAlign="TextAlign.Right">
                    <Template Context="item">@(item.TareWeight?.ToString("N2") ?? "—")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="EntryPlantDto" Property="NetWeight" Title="Neto (kg)" Width="100px" TextAlign="TextAlign.Right">
                    <Template Context="item"><strong class="rz-color-success">@(item.NetWeight?.ToString("N2") ?? "—")</strong></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="EntryPlantDto" Property="ResidueLineCount" Title="Residuos" Width="90px" TextAlign="TextAlign.Center">
                    <Template Context="item"><RadzenBadge Text="@item.ResidueLineCount.ToString()" BadgeStyle="BadgeStyle.Secondary" /></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="EntryPlantDto" Title="" Width="70px" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                    <Template Context="item">
                        <RadzenButton Icon="visibility" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                      Click="@(() => GoToDetail(item.Id))" @onclick:stopPropagation />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>

    @if (_result.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-2">
            <span class="rz-text-secondary-color rz-text-sm">
                Mostrando @((_page - 1) * PageSize + 1)–@(Math.Min(_page * PageSize, _result.TotalCount))
                de @_result.TotalCount entradas
            </span>
            <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-secondary" disabled="@(!_result.HasPrevious)" @onclick="PrevPage">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <span class="btn btn-outline-secondary disabled">@_page / @_result.TotalPages</span>
                <button class="btn btn-outline-secondary" disabled="@(!_result.HasNext)" @onclick="NextPage">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    }
}

@code {
    private const int PageSize = 15;

    private bool      _loading           = true;
    private bool      _loadingDisponibles = true;
    private int       _page              = 1;

    private string?   _filterReference;
    private DateTime? _filterDateFrom;
    private DateTime? _filterDateTo;
    private string?   _filterWeighbridgeId;
    private string    _selectedWasteMoveId = "";

    private GreenTransit.Application.Common.Models.PaginatedResult<EntryPlantDto>? _result;
    private List<WasteMoveDto>    _disponibles = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        await LoadDisponiblesAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _result  = await Mediator.Send(new GetEntryPlantsQuery(
            WasteMoveReference:  _filterReference,
            PlantEntryDateFrom:  _filterDateFrom,
            PlantEntryDateTo:    _filterDateTo,
            WeighbridgeId:       _filterWeighbridgeId,
            PageNumber:          _page,
            PageSize:            PageSize));
        _loading = false;
    }

    private async Task LoadDisponiblesAsync()
    {
        _loadingDisponibles = true;
        // Traslados RECOGIDO
        var recogidos = await Mediator.Send(new GetWasteMovesQuery(
            ServiceStatus: WasteMoveStatuses.Recogido, PageSize: 100));
        // Traslados EN_CAC
        var enCac = await Mediator.Send(new GetWasteMovesQuery(
            ServiceStatus: WasteMoveStatuses.EnCAC, PageSize: 100));
        _disponibles = [.. recogidos.Items, .. enCac.Items];
        _loadingDisponibles = false;
    }

    private void GoToNewEntry()
    {
        if (!string.IsNullOrEmpty(_selectedWasteMoveId))
            Nav.NavigateTo($"/waste-moves/{_selectedWasteMoveId}/entry-plant");
    }

    private async Task PrevPage()
    {
        if (_page > 1) { _page--; await LoadAsync(); }
    }

    private async Task NextPage()
    {
        _page++;
        await LoadAsync();
    }

    private async Task ResetFilters()
    {
        _filterReference    = null;
        _filterDateFrom     = null;
        _filterDateTo       = null;
        _filterWeighbridgeId = null;
        _page               = 1;
        await LoadAsync();
    }

    private void GoToDetail(Guid id)
        => Nav.NavigateTo($"/entry-plants/{id}");
}
