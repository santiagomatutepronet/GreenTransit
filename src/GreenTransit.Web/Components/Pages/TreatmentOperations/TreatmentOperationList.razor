@page "/treatment-operations"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.TreatmentOperations.DTOs
@using GreenTransit.Application.Features.TreatmentOperations.Queries
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator        Mediator
@inject NavigationManager Nav

<PageTitle>Operaciones R/D</PageTitle>

<div class="page-header">
    <h1 class="page-title"><i class="bi bi-gear-fill me-2"></i>Operaciones de Tratamiento R/D</h1>
    <AuthorizeView Roles="ADMIN">
        <button class="btn btn-primary btn-sm" @onclick='() => Nav.NavigateTo("/treatment-operations/new")'>
            <i class="bi bi-plus-lg me-1"></i>Nueva operación
        </button>
    </AuthorizeView>
</div>

@* ── Filtros ───────────────────────────────────────────────────────────────── *@
<div class="filter-bar">
    <div class="filter-group">
        <label>Búsqueda</label>
        <input class="form-control"
               placeholder="Código, descripción…"
               @bind="_searchTerm" @bind:event="oninput" />
    </div>
    <div class="filter-group">
        <label>Tipo</label>
        <select class="form-control" @bind="_filterType">
            <option value="">— Todos —</option>
            <option value="Recovery">R — Valorización</option>
            <option value="Disposal">D — Eliminación</option>
        </select>
    </div>
    <div class="filter-actions">
        <button class="btn btn-primary btn-sm" @onclick="FilterAsync">
            <i class="bi bi-search me-1"></i>Buscar
        </button>
        <button class="btn btn-ghost btn-sm" @onclick="ResetFilters">Limpiar</button>
    </div>
</div>

@* ── Contenido ─────────────────────────────────────────────────────────────── *@
@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    @foreach (var group in Groups)
    {
        <div class="card mb-3">
            <div class="card-header fw-semibold d-flex align-items-center gap-2 py-2">
                @if (group.Key == "Recovery")
                {
                    <i class="bi bi-arrow-repeat text-success"></i>
                    <span>R — Valorización (R1–R13)</span>
                }
                else
                {
                    <i class="bi bi-trash text-danger"></i>
                    <span>D — Eliminación (D1–D15)</span>
                }
                <span class="badge bg-secondary ms-auto">@group.Count()</span>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:80px">Código</th>
                            <th>Descripción</th>
                            <th style="width:160px">Descripción corta</th>
                            <th style="width:90px" class="text-center">Reciclaje</th>
                            <th style="width:100px" class="text-center">Energía</th>
                            <th style="width:120px" class="text-center">Prep. reutiliz.</th>
                            <th style="width:70px" class="text-center">Estado</th>
                            <AuthorizeView Roles="ADMIN">
                                <th style="width:80px" class="text-end">Acciones</th>
                            </AuthorizeView>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var op in group)
                        {
                            <tr>
                                <td><code class="fw-semibold">@op.Code</code></td>
                                <td>@op.Description</td>
                                <td class="text-muted small">@op.ShortDescription</td>
                                <td class="text-center">
                                    @if (op.IsRecycling)
                                    {
                                        <span class="badge bg-success">♻ Sí</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (op.IsEnergyRecovery)
                                    {
                                        <span class="badge bg-warning text-dark">⚡ Sí</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (op.IsPreparationForReuse)
                                    {
                                        <span class="badge bg-info text-dark">🔄 Sí</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (op.IsActive)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivo</span>
                                    }
                                </td>
                                <AuthorizeView Roles="ADMIN">
                                    <td class="text-end">
                                        @{ var editUrl = $"/treatment-operations/{op.Id}/edit"; }
                                        <button class="btn btn-outline-secondary btn-sm"
                                                @onclick="() => Nav.NavigateTo(editUrl)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </td>
                                </AuthorizeView>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (!_result?.Items.Any() ?? true)
    {
        <div class="alert alert-info">No se encontraron operaciones con los filtros aplicados.</div>
    }
    @if (_result is not null && _result.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-2">
            <small class="text-muted">@_result.TotalCount operaciones</small>
            <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-secondary" disabled="@(!_result.HasPrevious)"
                        @onclick="() => GoPageAsync(_page - 1)">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <span class="btn btn-outline-secondary disabled">@_page / @_result.TotalPages</span>
                <button class="btn btn-outline-secondary" disabled="@(!_result.HasNext)"
                        @onclick="() => GoPageAsync(_page + 1)">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    }
}

@code {
    private const int PageSize = 15;

    private bool   _loading    = true;
    private int    _page       = 1;
    private string _searchTerm = "";
    private string _filterType = "";

    private GreenTransit.Application.Common.Models.PaginatedResult<TreatmentOperationDto>? _result;

    private IEnumerable<IGrouping<string, TreatmentOperationDto>> Groups =>
        (_result?.Items ?? [])
            .OrderBy(o => o.OperationType == "Recovery" ? 0 : 1)
            .ThenBy(o => o.SortOrder)
            .ThenBy(o => o.Code)
            .GroupBy(o => o.OperationType);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _result  = await Mediator.Send(new GetTreatmentOperationsPagedQuery(
            OperationType: string.IsNullOrWhiteSpace(_filterType) ? null : _filterType,
            SearchTerm:    string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm,
            PageNumber:    _page,
            PageSize:      PageSize));
        _loading = false;
    }

    private async Task FilterAsync() { _page = 1; await LoadAsync(); }

    private async Task GoPageAsync(int page) { _page = page; await LoadAsync(); }

    private void ResetFilters()
    {
        _searchTerm = "";
        _filterType = "";
        _page       = 1;
        _ = LoadAsync();
    }
}
