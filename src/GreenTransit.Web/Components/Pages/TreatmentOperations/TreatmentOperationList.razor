@using Radzen
@using Radzen.Blazor
@page "/treatment-operations"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.TreatmentOperations.DTOs
@using GreenTransit.Application.Features.TreatmentOperations.Queries
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator        Mediator
@inject NavigationManager Nav

<PageTitle>Operaciones R/D</PageTitle>

<div class="page-header">
    <h1 class="page-title"><i class="bi bi-gear-fill me-2"></i>Operaciones de Tratamiento R/D</h1>
    <AuthorizeView Roles="ADMIN">
        <button class="btn btn-primary btn-sm" @onclick='() => Nav.NavigateTo("/treatment-operations/new")'>
            <i class="bi bi-plus-lg me-1"></i>Nueva operación
        </button>
    </AuthorizeView>
</div>

@* ── Filtros ───────────────────────────────────────────────────────────────── *@
<div class="filter-bar">
    <div class="filter-group">
        <label>Búsqueda</label>
        <input class="form-control"
               placeholder="Código, descripción…"
               @bind="_searchTerm" @bind:event="oninput" />
    </div>
    <div class="filter-group">
        <label>Tipo</label>
        <select class="form-control" @bind="_filterType">
            <option value="">— Todos —</option>
            <option value="Recovery">R — Valorización</option>
            <option value="Disposal">D — Eliminación</option>
        </select>
    </div>
    <div class="filter-actions">
        <button class="btn btn-primary btn-sm" @onclick="FilterAsync">
            <i class="bi bi-search me-1"></i>Buscar
        </button>
        <button class="btn btn-ghost btn-sm" @onclick="ResetFilters">Limpiar</button>
    </div>
</div>

@* ── Contenido ─────────────────────────────────────────────────────────────── *@
@if (_loading)
{
    <div class="gt-loading"><RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" /></div>
}
else
{
    @foreach (var group in Groups)
    {
        <RadzenCard class="rz-mb-4">
            <div class="d-flex align-items-center gap-2 rz-mb-3">
                @if (group.Key == "Recovery")
                {
                    <RadzenIcon Icon="autorenew" Style="color: var(--rz-success)" />
                    <strong>R — Valorización (R1–R13)</strong>
                }
                else
                {
                    <RadzenIcon Icon="delete_outline" Style="color: var(--rz-danger)" />
                    <strong>D — Eliminación (D1–D15)</strong>
                }
                <RadzenBadge Text="@group.Count().ToString()" BadgeStyle="BadgeStyle.Secondary" class="ms-auto" />
            </div>
            <RadzenDataGrid TItem="TreatmentOperationDto"
                            Data="@group.ToList()"
                            AllowSorting="true" AllowFiltering="false"
                            AllowPaging="false"
                            EmptyText="No se encontraron operaciones.">
                <Columns>
                    <RadzenDataGridColumn TItem="TreatmentOperationDto" Property="Code" Title="Código" Width="80px">
                        <Template Context="op"><code class="rz-text-weight-bold">@op.Code</code></Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TreatmentOperationDto" Property="Description" Title="Descripción" />
                    <RadzenDataGridColumn TItem="TreatmentOperationDto" Property="ShortDescription" Title="Desc. corta" Width="160px">
                        <Template Context="op"><span class="rz-text-secondary-color rz-text-sm">@op.ShortDescription</span></Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TreatmentOperationDto" Property="IsRecycling" Title="Reciclaje" Width="90px" TextAlign="TextAlign.Center">
                        <Template Context="op">
                            @if (op.IsRecycling) { <RadzenBadge Text="♻ Sí" BadgeStyle="BadgeStyle.Success" /> }
                            else { <span class="rz-text-disabled">—</span> }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TreatmentOperationDto" Property="IsEnergyRecovery" Title="Energía" Width="90px" TextAlign="TextAlign.Center">
                        <Template Context="op">
                            @if (op.IsEnergyRecovery) { <RadzenBadge Text="⚡ Sí" BadgeStyle="BadgeStyle.Warning" /> }
                            else { <span class="rz-text-disabled">—</span> }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TreatmentOperationDto" Property="IsPreparationForReuse" Title="Prep. reutiliz." Width="120px" TextAlign="TextAlign.Center">
                        <Template Context="op">
                            @if (op.IsPreparationForReuse) { <RadzenBadge Text="🔄 Sí" BadgeStyle="BadgeStyle.Info" /> }
                            else { <span class="rz-text-disabled">—</span> }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TreatmentOperationDto" Property="IsActive" Title="Estado" Width="80px" TextAlign="TextAlign.Center">
                        <Template Context="op">
                            @if (op.IsActive) { <RadzenBadge Text="Activo" BadgeStyle="BadgeStyle.Success" /> }
                            else { <RadzenBadge Text="Inactivo" BadgeStyle="BadgeStyle.Secondary" /> }
                        </Template>
                    </RadzenDataGridColumn>
                    <AuthorizeView Roles="ADMIN">
                        <RadzenDataGridColumn TItem="TreatmentOperationDto" Title="" Width="70px" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                            <Template Context="op">
                                <RadzenButton Icon="edit" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                              Click="@(() => Nav.NavigateTo($"/treatment-operations/{op.Id}/edit"))" />
                            </Template>
                        </RadzenDataGridColumn>
                    </AuthorizeView>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    }

    @if (!_result?.Items.Any() ?? true)
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">No se encontraron operaciones con los filtros aplicados.</RadzenAlert>
    }
}

@code {
    private const int PageSize = 15;

    private bool   _loading    = true;
    private int    _page       = 1;
    private string _searchTerm = "";
    private string _filterType = "";

    private GreenTransit.Application.Common.Models.PaginatedResult<TreatmentOperationDto>? _result;

    private IEnumerable<IGrouping<string, TreatmentOperationDto>> Groups =>
        (_result?.Items ?? [])
            .OrderBy(o => o.OperationType == "Recovery" ? 0 : 1)
            .ThenBy(o => o.SortOrder)
            .ThenBy(o => o.Code)
            .GroupBy(o => o.OperationType);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _result  = await Mediator.Send(new GetTreatmentOperationsPagedQuery(
            OperationType: string.IsNullOrWhiteSpace(_filterType) ? null : _filterType,
            SearchTerm:    string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm,
            PageNumber:    _page,
            PageSize:      PageSize));
        _loading = false;
    }

    private async Task FilterAsync() { _page = 1; await LoadAsync(); }

    private async Task GoPageAsync(int page) { _page = page; await LoadAsync(); }

    private void ResetFilters()
    {
        _searchTerm = "";
        _filterType = "";
        _page       = 1;
        _ = LoadAsync();
    }
}
