@page "/treatment-operations/new"
@page "/treatment-operations/{OperationId:guid}/edit"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.TreatmentOperations.Commands
@using GreenTransit.Application.Features.TreatmentOperations.DTOs
@using GreenTransit.Application.Features.TreatmentOperations.Queries
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using Radzen
@using Radzen.Blazor

@inject IMediator        Mediator
@inject NavigationManager Nav

<PageTitle>@(_isEdit ? "Editar Operación R/D" : "Nueva Operación R/D")</PageTitle>

<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-gear-fill me-2"></i>
        @(_isEdit ? "Editar Operación R/D" : "Nueva Operación R/D")
    </h1>
</div>

@if (_loading)
{
    <LoadingSpinner />
}
else
{
    <RadzenTemplateForm TItem="FormModel" Data="@_model" Submit="@SaveAsync">
        <RadzenFieldset Text="Datos de la operación" class="rz-mb-4">
            <RadzenRow Gap="1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Tipo *" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="string?" Name="OperationType" @bind-Value="_model.OperationType"
                                            Data="@(new[]{new{V="Recovery",L="R — Valorización"},new{V="Disposal",L="D — Eliminación"}})"
                                            TextProperty="L" ValueProperty="V"
                                            Placeholder="— Seleccionar —" AllowClear="true" Style="width:100%" />
                        </ChildContent>
                        <Helper><RadzenRequiredValidator Component="OperationType" Text="Obligatorio" /></Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="2">
                    <RadzenFormField Text="Código *" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="Code" @bind-Value="_model.Code" Placeholder="R1, D5…" MaxLength="8" Style="width:100%" />
                        </ChildContent>
                        <Helper><RadzenRequiredValidator Component="Code" Text="Obligatorio" /></Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="2">
                    <RadzenFormField Text="Orden" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenNumeric TValue="int?" Name="SortOrder" @bind-Value="_model.SortOrder" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                @if (_isEdit)
                {
                    <RadzenColumn SizeMD="2" class="d-flex align-items-center rz-mt-4">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenCheckBox TValue="bool" Name="IsActive" @bind-Value="_model.IsActive" />
                            <RadzenLabel Text="Activo" Component="IsActive" />
                        </RadzenStack>
                    </RadzenColumn>
                }
            </RadzenRow>
            <RadzenRow Gap="1rem" class="rz-mt-4">
                <RadzenColumn Size="12">
                    <RadzenFormField Text="Descripción *" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="Description" @bind-Value="_model.Description" MaxLength="512" Style="width:100%" />
                        </ChildContent>
                        <Helper><RadzenRequiredValidator Component="Description" Text="Obligatorio" /></Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="6">
                    <RadzenFormField Text="Descripción corta" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="ShortDescription" @bind-Value="_model.ShortDescription" MaxLength="128" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow Gap="2rem" class="rz-mt-4">
                <RadzenColumn Size="12">
                    <RadzenText TextStyle="TextStyle.Subtitle2">Clasificación</RadzenText>
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem" class="rz-mt-2">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenCheckBox TValue="bool" Name="IsRecycling" @bind-Value="_model.IsRecycling" />
                            <RadzenLabel Text="♻ Reciclaje" Component="IsRecycling" />
                        </RadzenStack>
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenCheckBox TValue="bool" Name="IsEnergyRecovery" @bind-Value="_model.IsEnergyRecovery" />
                            <RadzenLabel Text="⚡ Recuperación energética" Component="IsEnergyRecovery" />
                        </RadzenStack>
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenCheckBox TValue="bool" Name="IsPreparationForReuse" @bind-Value="_model.IsPreparationForReuse" />
                            <RadzenLabel Text="🔄 Preparación para reutilización" Component="IsPreparationForReuse" />
                        </RadzenStack>
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        @if (_errorMessage is not null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" class="rz-mt-4">@_errorMessage</RadzenAlert>
        }

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" class="rz-mt-4">
            <RadzenButton ButtonType="ButtonType.Submit" Text="Guardar" Icon="save"
                          ButtonStyle="ButtonStyle.Primary" Disabled="@_saving" IsBusy="@_saving" />
            <RadzenButton Text="Cancelar" Icon="cancel" ButtonStyle="ButtonStyle.Light"
                          ButtonType="ButtonType.Button" Click="@(_ => Cancel())" />
        </RadzenStack>
    </RadzenTemplateForm>
}

@code {
    [Parameter] public Guid? OperationId { get; set; }

    private bool    _isEdit  = false;
    private bool    _loading = true;
    private bool    _saving  = false;
    private string? _errorMessage;
    private Dictionary<string, List<string>> _validationErrors = [];

    private FormModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        _isEdit = OperationId.HasValue;

        if (_isEdit)
        {
            var all    = await Mediator.Send(new GetTreatmentOperationsQuery());
            var detail = all.FirstOrDefault(o => o.Id == OperationId!.Value);

            if (detail is not null)
                _model = FormModel.From(detail);
        }

        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving       = true;
        _errorMessage = null;
        _validationErrors = [];

        try
        {
            if (_isEdit)
            {
                await Mediator.Send(new UpdateTreatmentOperationCommand(
                    OperationId!.Value,
                    _model.Code!, _model.OperationType!,
                    _model.Description!, _model.ShortDescription,
                    _model.IsRecycling, _model.IsEnergyRecovery, _model.IsPreparationForReuse,
                    _model.SortOrder, _model.IsActive));
            }
            else
            {
                await Mediator.Send(new CreateTreatmentOperationCommand(
                    _model.Code!, _model.OperationType!,
                    _model.Description!, _model.ShortDescription,
                    _model.IsRecycling, _model.IsEnergyRecovery, _model.IsPreparationForReuse,
                    _model.SortOrder));
            }

            Nav.NavigateTo("/treatment-operations");
        }
        catch (FluentValidation.ValidationException vex)
        {
            _validationErrors = vex.Errors
                .GroupBy(e => e.PropertyName)
                .ToDictionary(g => g.Key, g => g.Select(e => e.ErrorMessage).ToList());
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => Nav.NavigateTo("/treatment-operations");

    // ── Modelo ────────────────────────────────────────────────────────────────
    private sealed class FormModel
    {
        public string?  Code                  { get; set; }
        public string?  OperationType         { get; set; }
        public string?  Description           { get; set; }
        public string?  ShortDescription      { get; set; }
        public bool     IsRecycling           { get; set; }
        public bool     IsEnergyRecovery      { get; set; }
        public bool     IsPreparationForReuse { get; set; }
        public int?     SortOrder             { get; set; }
        public bool     IsActive              { get; set; } = true;

        public static FormModel From(TreatmentOperationDto d) => new()
        {
            Code                  = d.Code,
            OperationType         = d.OperationType,
            Description           = d.Description,
            ShortDescription      = d.ShortDescription,
            IsRecycling           = d.IsRecycling,
            IsEnergyRecovery      = d.IsEnergyRecovery,
            IsPreparationForReuse = d.IsPreparationForReuse,
            SortOrder             = d.SortOrder,
            IsActive              = d.IsActive
        };
    }
}
