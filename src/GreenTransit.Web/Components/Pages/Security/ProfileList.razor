@page "/profiles"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.Security.DTOs
@using GreenTransit.Application.Features.Security.Queries
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator Mediator

<PageTitle>Perfiles del sistema</PageTitle>

<div class="page-header">
    <h1 class="page-title"><i class="bi bi-person-badge-fill me-2"></i>Perfiles del sistema</h1>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Referencia</th>
                    <th>Descripción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _profiles)
                {
                    <tr>
                        <td><span class="badge bg-secondary">@p.Reference</span></td>
                        <td>@(p.Description ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private bool                      _loading  = true;
    private IReadOnlyList<ProfileDto> _profiles = [];

    protected override async Task OnInitializedAsync()
    {
        _profiles = await Mediator.Send(new GetProfilesQuery());
        _loading  = false;
    }
}
