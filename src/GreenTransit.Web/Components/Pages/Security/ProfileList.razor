@using Radzen
@using Radzen.Blazor
@page "/profiles"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.Security.DTOs
@using GreenTransit.Application.Features.Security.Queries
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator Mediator

<PageTitle>Perfiles del sistema</PageTitle>

<div class="page-header">
    <h1 class="page-title"><i class="bi bi-person-badge-fill me-2"></i>Perfiles del sistema</h1>
</div>

@if (_loading)
{
    <LoadingSpinner />
}
else
{
    <RadzenDataGrid TItem="ProfileDto"
                    Data="@_profiles"
                    AllowPaging="false" AllowSorting="true" AllowFiltering="false"
                    EmptyText="No hay perfiles registrados.">
        <Columns>
            <RadzenDataGridColumn TItem="ProfileDto" Property="Reference" Title="Referencia" Width="180px">
                <Template Context="p"><RadzenBadge Text="@p.Reference" BadgeStyle="BadgeStyle.Secondary" /></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ProfileDto" Property="Description" Title="Descripción">
                <Template Context="p">@(p.Description ?? "—")</Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    private bool                      _loading  = true;
    private IReadOnlyList<ProfileDto> _profiles = [];

    protected override async Task OnInitializedAsync()
    {
        _profiles = await Mediator.Send(new GetProfilesQuery());
        _loading  = false;
    }
}
