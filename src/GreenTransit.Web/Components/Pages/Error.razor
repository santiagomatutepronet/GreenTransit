@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<div class="page-container">
    <div class="alert alert-danger">
        <i class="bi bi-x-circle-fill alert-icon"></i>
        <div class="alert-content">
            <span class="alert-title">Se ha producido un error</span>
            <p class="mb-0">No se pudo procesar la solicitud. Por favor, inténtelo de nuevo.</p>
        </div>
    </div>

    @if (ShowRequestId)
    {
        <div class="panel panel-info mb-4">
            <strong>Request ID:</strong> <code>@RequestId</code>
        </div>
    }

    <div class="card">
        <div class="card-header">
            <span class="card-title">Información de depuración</span>
        </div>
        <div class="card-body">
            <p>Para ver más detalles del error, habilite el entorno <strong>Development</strong>
               definiendo la variable de entorno <code>ASPNETCORE_ENVIRONMENT</code> como
               <code>Development</code> y reiniciando la aplicación.</p>
            <p class="mb-0 text-muted text-sm">
                No active el entorno Development en aplicaciones en producción: podría exponer
                información sensible a los usuarios.
            </p>
        </div>
    </div>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId      { get; set; }
    private bool    ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
