@page "/service-orders/{ServiceOrderId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.ServiceOrders.Queries
@using GreenTransit.Application.Features.ServiceOrders.DTOs
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using System.Linq

@inject IMediator        Mediator
@inject NavigationManager Nav

<PageTitle>Detalle Orden de Servicio</PageTitle>

@if (_loading)
{
    <div class="text-center" style="padding:3rem 0"><div class="spinner spinner-lg"></div></div>
}
else if (_detail is null)
{
    <div class="alert alert-warning">Orden de servicio no encontrada.</div>
    <button class="btn btn-outline-neutral btn-sm" @onclick='() => Nav.NavigateTo("/service-orders")'>
        <i class="bi bi-arrow-left me-1"></i>Volver
    </button>
}
else
{
    var d = _detail;
    var hasDangerous = d.Residues.Any(r => r.LerCodeIsDangerous);
    @* URL strings to avoid Razor parser issues with $ inside attributes *@
    var editUrl  = "/service-orders/" + d.Id + "/edit";
    var moveUrl  = "/waste-moves/new?serviceOrderId=" + d.Id;

    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="bi bi-clipboard2-check me-2"></i>@d.ServiceOrderNumber
            </h1>
            <div class="d-flex gap-2 mt-1 flex-wrap">
                <span class="@ServiceOrderStatuses.BadgeCss(d.Status)">@ServiceOrderStatuses.Label(d.Status)</span>
                <span class="@ServiceOrderPriorities.BadgeCss(d.Priority)">@ServiceOrderPriorities.Label(d.Priority)</span>
                @if (hasDangerous)
                {
                    <span class="badge badge-danger">
                        <i class="bi bi-exclamation-triangle-fill"></i> Residuo peligroso
                    </span>
                }
            </div>
        </div>
        <div class="page-header-actions">
            @if (ServiceOrderStatuses.Editable.Contains(d.Status))
            {
                <button class="btn btn-outline btn-sm" @onclick="() => Nav.NavigateTo(editUrl)">
                    <i class="bi bi-pencil me-1"></i>Editar
                </button>
            }
            <button class="btn btn-primary btn-sm" @onclick="() => Nav.NavigateTo(moveUrl)">
                <i class="bi bi-truck me-1"></i>Crear Traslado
            </button>
            <button class="btn btn-outline-neutral btn-sm" @onclick='() => Nav.NavigateTo("/service-orders")'>
                <i class="bi bi-arrow-left me-1"></i>Volver
            </button>
        </div>
    </div>

    @if (hasDangerous)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle-fill alert-icon"></i>
            <div class="alert-content">
                <span class="alert-title">Residuo peligroso</span>
                Uno o más residuos de esta orden son peligrosos y requerirán NT/DI al crear el traslado.
            </div>
        </div>
    }

    <div class="row g-3 mt-2">

        @* ── Identificación ─────────────────────────────────────────────── *@
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">
                    <span class="card-title"><i class="bi bi-123 card-title-icon"></i>Identificación</span>
                </div>
                <div class="card-body">
                    <DetailRow Label="Nº Orden"       Value="@d.ServiceOrderNumber" Mono />
                    <DetailRow Label="Estado"         Value="@ServiceOrderStatuses.Label(d.Status)" />
                    <DetailRow Label="Prioridad"      Value="@ServiceOrderPriorities.Label(d.Priority)" />
                    <DetailRow Label="Fecha emisión"  Value="@d.IssuedAt.ToString("dd/MM/yyyy HH:mm")" />
                    <DetailRow Label="Versión"        Value="@d.Version.ToString()" />
                    @if (!string.IsNullOrEmpty(d.WasteMoveReference))
                    {
                        <DetailRow Label="Ref. traslado" Value="@d.WasteMoveReference" Mono />
                    }
                </div>
            </div>
        </div>

        @* ── Emisor ──────────────────────────────────────────────────────── *@
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">
                    <span class="card-title"><i class="bi bi-person-vcard card-title-icon"></i>Emisor</span>
                </div>
                <div class="card-body">
                    <DetailRow Label="Entidad emisora"   Value="@(d.IssuedByName ?? "—")" />
                    <DetailRow Label="NIF / NationalId"  Value="@d.IssuedByNationalId" />
                    <DetailRow Label="NIMA / CenterCode" Value="@d.IssuedByCenterCode" />
                </div>
            </div>
        </div>

        @* ── Recogida ────────────────────────────────────────────────────── *@
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">
                    <span class="card-title"><i class="bi bi-geo-alt card-title-icon"></i>Recogida</span>
                </div>
                <div class="card-body">
                    <DetailRow Label="Punto de recogida"    Value="@(d.PickupPointName ?? "—")" />
                    <DetailRow Label="Inicio planificado"   Value="@(d.PlannedPickupStart?.ToString("dd/MM/yyyy HH:mm"))" />
                    <DetailRow Label="Fin planificado"      Value="@(d.PlannedPickupEnd?.ToString("dd/MM/yyyy HH:mm"))" />
                    <DetailRow Label="Inicio entrega plan." Value="@(d.PlannedDeliveryStart?.ToString("dd/MM/yyyy HH:mm"))" />
                    <DetailRow Label="Fin entrega plan."    Value="@(d.PlannedDeliveryEnd?.ToString("dd/MM/yyyy HH:mm"))" />
                </div>
            </div>
        </div>

        @* ── Clasificación ───────────────────────────────────────────────── *@
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">
                    <span class="card-title"><i class="bi bi-recycle card-title-icon"></i>Clasificación</span>
                </div>
                <div class="card-body">
                    <DetailRow Label="Flujo"     Value="@d.WasteStream" />
                    <DetailRow Label="Sub-flujo" Value="@d.SubStream" />
                </div>
            </div>
        </div>

        @* ── Asignaciones ────────────────────────────────────────────────── *@
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">
                    <span class="card-title"><i class="bi bi-truck card-title-icon"></i>Asignaciones</span>
                </div>
                <div class="card-body">
                    <DetailRow Label="Transportista"   Value="@d.CarrierName" />
                    <DetailRow Label="Planta prevista" Value="@d.PlannedPlantName" />
                </div>
            </div>
        </div>

        @* ── Auditoría ───────────────────────────────────────────────────── *@
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">
                    <span class="card-title"><i class="bi bi-clock-history card-title-icon"></i>Auditoría</span>
                </div>
                <div class="card-body">
                    <DetailRow Label="Creado el"   Value="@d.CreatedAt.ToString("dd/MM/yyyy HH:mm")" />
                    <DetailRow Label="Actualizado" Value="@d.UpdatedAt.ToString("dd/MM/yyyy HH:mm")" />
                    <DetailRow Label="IdUser"      Value="@d.IdUser.ToString()" />
                </div>
            </div>
        </div>

        @* ── Líneas de residuo ───────────────────────────────────────────── *@
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <span class="card-title">
                        <i class="bi bi-list-ul card-title-icon"></i>Líneas de residuo
                        <span class="badge badge-neutral ms-2">@d.Residues.Count</span>
                    </span>
                </div>
                <div class="card-body p-0">
                    @if (d.Residues.Count == 0)
                    {
                        <div class="p-3 cell-muted">Sin líneas de residuo definidas.</div>
                    }
                    else
                    {
                        <div class="table-wrapper">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Código LER</th>
                                        <th>Descripción LER</th>
                                        <th class="cell-number">Peso est. (kg)</th>
                                        <th>Ud. medida</th>
                                        <th class="cell-number">Unidades</th>
                                        <th>Peligroso</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in d.Residues)
                                    {
                                        <tr>
                                            <td class="cell-muted">@(r.SortOrder + 1)</td>
                                            <td class="font-semibold">@(r.LerCodeCode ?? "—")</td>
                                            <td class="cell-muted">@(r.LerCodeDescription ?? "—")</td>
                                            <td class="cell-number">@(r.EstimatedWeight.HasValue ? $"{r.EstimatedWeight:N3}" : "—")</td>
                                            <td class="cell-muted">@(r.MeasureUnit?.ToString() ?? "—")</td>
                                            <td class="cell-number">@(r.Units?.ToString() ?? "—")</td>
                                            <td>
                                                @if (r.LerCodeIsDangerous)
                                                {
                                                    <span class="badge badge-danger"><i class="bi bi-exclamation-triangle-fill me-1"></i>Sí</span>
                                                }
                                                else
                                                {
                                                    <span class="cell-muted">No</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ── Contenedores JSON ───────────────────────────────────────────── *@
        @if (!string.IsNullOrEmpty(d.ContainersJson))
        {
            <div class="col-12">
                <div class="card">
                    <div class="card-header fw-semibold">
                        <i class="bi bi-boxes me-2"></i>Contenedores
                    </div>
                    <div class="card-body">
                        <pre class="small mb-0">@d.ContainersJson</pre>
                    </div>
                </div>
            </div>
        }

    </div>
}

@code {
    [Parameter] public Guid ServiceOrderId { get; set; }

    private bool                _loading = true;
    private ServiceOrderDetailDto? _detail;

    protected override async Task OnInitializedAsync()
    {
        _detail  = await Mediator.Send(new GetServiceOrderByIdQuery(ServiceOrderId));
        _loading = false;
    }
}
