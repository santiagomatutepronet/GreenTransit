@page "/service-orders/new"
@page "/service-orders/{ServiceOrderId:guid}/edit"
@attribute [Authorize]
@rendermode InteractiveServer

@using FluentValidation
@using GreenTransit.Application.Features.Entities.DTOs
@using GreenTransit.Application.Features.Entities.Queries
@using GreenTransit.Application.Features.ServiceOrders.Commands
@using GreenTransit.Application.Features.ServiceOrders.DTOs
@using GreenTransit.Application.Features.ServiceOrders.Queries
@using GreenTransit.Application.Features.LerCodes.DTOs
@using GreenTransit.Application.Features.LerCodes.Queries
@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Domain.Authorization
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using System.Text.Json
@using Radzen
@using Radzen.Blazor

@inject IMediator           Mediator
@inject NavigationManager   Nav
@inject ICurrentUserService CurrentUser

<PageTitle>@(_isEdit ? "Editar Orden de Servicio" : "Nueva Orden de Servicio")</PageTitle>

<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-clipboard2-check me-2"></i>
        @(_isEdit ? "Editar Orden de Servicio" : "Nueva Orden de Servicio")
    </h1>
</div>

@if (_loading)
{
    <div class="gt-loading"><RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" /></div>
}
else
{
    <RadzenTemplateForm TItem="FormModel" Data="@_model" Submit="@SaveAsync">

        @* ── Sección 1: Identificación ───────────────────────────────── *@
        <RadzenFieldset Text="Identificación" AllowCollapse="true" class="rz-mb-4">
            <RadzenRow Gap="1rem">
                <RadzenColumn SizeMD="5">
                    <RadzenFormField Text="Nº Orden de Servicio" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="ServiceOrderNumber" @bind-Value="_model.ServiceOrderNumber"
                                           Placeholder="Vacío = generar automáticamente" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Fecha de emisión *" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDatePicker Name="IssuedAt" @bind-Value="_model.IssuedAt"
                                              ShowTime="true" HourFormat="24" DateFormat="dd/MM/yyyy HH:mm"
                                              Style="width:100%" />
                        </ChildContent>
                        <Helper><RadzenRequiredValidator Component="IssuedAt" Text="Obligatorio" /></Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="2">
                    <RadzenFormField Text="Estado *" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="string" Name="Status" @bind-Value="_model.Status"
                                            Data="@ServiceOrderStatuses.All" Style="width:100%" />
                        </ChildContent>
                        <Helper><RadzenRequiredValidator Component="Status" Text="Obligatorio" /></Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="2">
                    <RadzenFormField Text="Prioridad *" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="string" Name="Priority" @bind-Value="_model.Priority"
                                            Data="@ServiceOrderPriorities.All" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        @* ── Sección 2: Emisor y punto de recogida ───────────────────── *@
        <RadzenFieldset Text="Emisor y punto de recogida" AllowCollapse="true" class="rz-mb-4">
            <RadzenRow Gap="1rem">
                <RadzenColumn SizeMD="6">
                    @if (_issuedByReadOnly)
                    {
                        <RadzenFormField Text="Emisor (Entidad)" Variant="Variant.Outlined" Style="width:100%">
                            <ChildContent>
                                <RadzenTextBox Style="width:100%" ReadOnly="true"
                                               Value="@(_allEntities.FirstOrDefault(e => e.Id == _model.IdIssuedBy) is { } ent ? $"{ent.Name} ({ent.NationalId})" : "— Sin entidad vinculada —")" />
                            </ChildContent>
                        </RadzenFormField>
                    }
                    else
                    {
                        <RadzenFormField Text="Emisor (Entidad)" Variant="Variant.Outlined" Style="width:100%">
                            <ChildContent>
                                <RadzenDropDown TValue="Guid?" Name="IdIssuedBy" @bind-Value="_model.IdIssuedBy"
                                                Data="@_allEntities" TextProperty="Name" ValueProperty="Id"
                                                AllowClear="true" AllowFiltering="true"
                                                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                                Placeholder="— Sin asignar —" Style="width:100%" />
                            </ChildContent>
                        </RadzenFormField>
                    }
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Nombre emisor (texto libre)" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="IssuedByName" @bind-Value="_model.IssuedByName"
                                           Placeholder="Si no está en el listado" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="NIF / NIMA emisor" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="IssuedByNationalId" @bind-Value="_model.IssuedByNationalId" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow Gap="1rem" class="rz-mt-4">
                <RadzenColumn SizeMD="6">
                    <RadzenFormField Text="Punto de recogida" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="Guid?" Name="IdPickupPoint" @bind-Value="_model.IdPickupPoint"
                                            Data="@_allEntities" TextProperty="Name" ValueProperty="Id"
                                            AllowClear="true" AllowFiltering="true"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            Change="@(_ => OnPickupPointChanged())"
                                            Placeholder="— Sin asignar —" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow Gap="1rem" class="rz-mt-4">
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Recogida planificada — Inicio" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDatePicker TValue="DateTime?" Name="PlannedPickupStart" @bind-Value="_model.PlannedPickupStart"
                                              ShowTime="true" HourFormat="24" DateFormat="dd/MM/yyyy HH:mm"
                                              Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Recogida planificada — Fin" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDatePicker TValue="DateTime?" Name="PlannedPickupEnd" @bind-Value="_model.PlannedPickupEnd"
                                              ShowTime="true" HourFormat="24" DateFormat="dd/MM/yyyy HH:mm"
                                              Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Entrega planificada — Inicio" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDatePicker TValue="DateTime?" Name="PlannedDeliveryStart" @bind-Value="_model.PlannedDeliveryStart"
                                              ShowTime="true" HourFormat="24" DateFormat="dd/MM/yyyy HH:mm"
                                              Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Entrega planificada — Fin" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDatePicker TValue="DateTime?" Name="PlannedDeliveryEnd" @bind-Value="_model.PlannedDeliveryEnd"
                                              ShowTime="true" HourFormat="24" DateFormat="dd/MM/yyyy HH:mm"
                                              Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        @* ── Sección 3: Clasificación y líneas de residuo ────────────── *@
        <RadzenFieldset Text="Clasificación del residuo" AllowCollapse="true" class="rz-mb-4">
            <RadzenRow Gap="1rem">
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="Flujo de residuo" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="string?" Name="WasteStream" @bind-Value="_model.WasteStream"
                                            Data="@WasteFlowCatalog.All" TextProperty="Name" ValueProperty="Code"
                                            AllowClear="true" Change="@(v => OnWasteStreamChanged(v?.ToString()))"
                                            Placeholder="— Seleccionar flujo —" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="Sub-flujo" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="string?" Name="SubStream" @bind-Value="_model.SubStream"
                                            Data="@_soSubflows" Disabled="@(string.IsNullOrEmpty(_model.WasteStream))"
                                            AllowClear="true" Placeholder="— Seleccionar sub-flujo —" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

            @* ── Líneas de residuo ────────────────────────── *@
            <div class="rz-mt-4">
                <RadzenText TextStyle="TextStyle.Subtitle2">Líneas de residuo (@_residueLines.Count)</RadzenText>
                <RadzenDataGrid @ref="_residueGrid" TItem="ResidueLineModel" Data="@_residueLines"
                                EditMode="DataGridEditMode.Single"
                                AllowPaging="false" AllowSorting="false" ShowPagingSummary="false"
                                class="rz-mt-2" Style="width:100%">
                    <Columns>
                        <RadzenDataGridColumn TItem="ResidueLineModel" Title="Código LER" Width="260px">
                            <Template Context="line">
                                @(_lerChapters.SelectMany(c => c.SubChapters).SelectMany(sc => sc.Codes)
                                    .FirstOrDefault(x => x.Id == line.IdLERCode)?.Description ?? "—")
                                @if (line.IsDangerous)
                                { <br /><small class="rz-color-danger"><i class="bi bi-exclamation-triangle-fill me-1"></i>Peligroso</small> }
                            </Template>
                            <EditTemplate Context="line">
                                <RadzenDropDown TValue="Guid?" @bind-Value="line.IdLERCode"
                                                Data="@_lerChapters.SelectMany(c => c.SubChapters).SelectMany(sc => sc.Codes)"
                                                TextProperty="Description" ValueProperty="Id"
                                                AllowFiltering="true" AllowClear="true"
                                                Change="@(v => OnResidueLerChanged(line, v?.ToString()))"
                                                Placeholder="— Sin asignar —" Style="width:100%" />
                            </EditTemplate>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ResidueLineModel" Title="Peso est. (kg)" Width="130px">
                            <Template Context="line">@(line.EstimatedWeight?.ToString("N3") ?? "—")</Template>
                            <EditTemplate Context="line">
                                <RadzenNumeric TValue="decimal?" @bind-Value="line.EstimatedWeight"
                                               Min="0" Format="0.000" Style="width:100%" />
                            </EditTemplate>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ResidueLineModel" Title="Unidades" Width="90px">
                            <Template Context="line">@(line.Units?.ToString() ?? "—")</Template>
                            <EditTemplate Context="line">
                                <RadzenNumeric TValue="int?" @bind-Value="line.Units" Min="0" Step="1" Style="width:100%" />
                            </EditTemplate>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ResidueLineModel" Title="" Width="100px" TextAlign="TextAlign.Center">
                            <Template Context="line">
                                <RadzenButton Icon="edit" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                              Click="@(() => _residueGrid.EditRow(line))" title="Editar" />
                                <RadzenButton Icon="delete" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Danger"
                                              Disabled="@(_residueLines.Count <= 1)"
                                              Click="@(() => RemoveResidueLine(_residueLines.IndexOf(line)))" title="Eliminar" />
                            </Template>
                            <EditTemplate Context="line">
                                <RadzenButton Icon="check" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Success"
                                              Click="@(() => _residueGrid.UpdateRow(line))" />
                                <RadzenButton Icon="close" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                              Click="@(() => _residueGrid.CancelEditRow(line))" />
                            </EditTemplate>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
                <RadzenButton Text="Añadir línea de residuo" Icon="add" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              class="rz-mt-2" Click="@(_ => AddResidueLine())" />
            </div>

            @* ── Contenedores ────────────────────────────── *@
            <div class="rz-mt-4">
                <RadzenText TextStyle="TextStyle.Subtitle2">Contenedores</RadzenText>
                <RadzenDataGrid @ref="_containerGrid" TItem="ContainerRow" Data="@_containers"
                                EditMode="DataGridEditMode.Single"
                                AllowPaging="false" AllowSorting="false" ShowPagingSummary="false"
                                class="rz-mt-2" Style="width:100%">
                    <Columns>
                        <RadzenDataGridColumn TItem="ContainerRow" Title="Tipo">
                            <Template Context="c">@(c.Type ?? "—")</Template>
                            <EditTemplate Context="c">
                                <RadzenDropDown TValue="string" @bind-Value="c.Type"
                                                Data="@(new[]{"Bigbag","Contenedor","Palet","Granel","Otro"})"
                                                Placeholder="— Seleccionar —" Style="width:100%" />
                            </EditTemplate>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ContainerRow" Title="Cantidad" Width="110px">
                            <Template Context="c">@c.Qty</Template>
                            <EditTemplate Context="c">
                                <RadzenNumeric TValue="int" @bind-Value="c.Qty" Min="1" Style="width:100%" />
                            </EditTemplate>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ContainerRow" Title="" Width="100px" TextAlign="TextAlign.Center">
                            <Template Context="c">
                                <RadzenButton Icon="edit" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                              Click="@(() => _containerGrid.EditRow(c))" />
                                <RadzenButton Icon="delete" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Danger"
                                              Click="@(() => RemoveContainer(_containers.IndexOf(c)))" />
                            </Template>
                            <EditTemplate Context="c">
                                <RadzenButton Icon="check" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Success"
                                              Click="@(() => _containerGrid.UpdateRow(c))" />
                                <RadzenButton Icon="close" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                              Click="@(() => _containerGrid.CancelEditRow(c))" />
                            </EditTemplate>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
                <RadzenButton Text="Añadir contenedor" Icon="add" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              class="rz-mt-2" Click="@(_ => AddContainer())" />
            </div>
        </RadzenFieldset>

        @* ── Sección 4: Asignaciones previstas ───────────────────────── *@
        <RadzenFieldset Text="Asignaciones previstas" AllowCollapse="true" Collapsed="true" class="rz-mb-4">
            <RadzenRow Gap="1rem">
                <RadzenColumn SizeMD="6">
                    <RadzenFormField Text="Transportista previsto" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="Guid?" Name="IdCarrier" @bind-Value="_model.IdCarrier"
                                            Data="@_allEntities" TextProperty="Name" ValueProperty="Id"
                                            AllowClear="true" AllowFiltering="true"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            Placeholder="— Sin asignar —" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="6">
                    <RadzenFormField Text="Planta de destino prevista" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="Guid?" Name="IdPlannedPlant" @bind-Value="_model.IdPlannedPlant"
                                            Data="@_allEntities" TextProperty="Name" ValueProperty="Id"
                                            AllowClear="true" AllowFiltering="true"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            Placeholder="— Sin asignar —" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        @* ── Errores y acciones ──────────────────────────────────────────────── *@
        @if (_validationErrors.Any())
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" class="rz-mt-4">
                <ul class="mb-0">
                    @foreach (var err in _validationErrors.Values.SelectMany(v => v))
                    {
                        <li>@err</li>
                    }
                </ul>
            </RadzenAlert>
        }
        @if (!string.IsNullOrEmpty(_serverError))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" class="rz-mt-4">@_serverError</RadzenAlert>
        }

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" class="rz-mt-4">
            <RadzenButton ButtonType="ButtonType.Submit" Text="Guardar" Icon="save"
                          ButtonStyle="ButtonStyle.Primary" Disabled="@_saving" IsBusy="@_saving" />
            <RadzenButton Text="Cancelar" Icon="cancel" ButtonStyle="ButtonStyle.Light"
                          ButtonType="ButtonType.Button" Click="@(_ => Cancel())" />
        </RadzenStack>

    </RadzenTemplateForm>
}

@code {
    [Parameter] public Guid? ServiceOrderId { get; set; }

    private bool _isEdit => ServiceOrderId.HasValue;
    private bool _loading = true;
    private bool _saving  = false;
    private bool _sec1Open = true;
    private bool _sec2Open = true;
    private bool _sec3Open = true;
    private bool _sec4Open = false;
    private string? _serverError;
    private Dictionary<string, List<string>> _validationErrors = new();

    private RadzenDataGrid<ResidueLineModel> _residueGrid   = default!;
    private RadzenDataGrid<ContainerRow>     _containerGrid = default!;

    // ── Modelo de cabecera ────────────────────────────────────────────────────
    private sealed class FormModel
    {
        public string    ServiceOrderNumber   { get; set; } = "";
        public DateTime  IssuedAt             { get; set; } = DateTime.UtcNow;
        public Guid?     IdIssuedBy           { get; set; }
        public string?   IssuedByName         { get; set; }
        public string?   IssuedByNationalId   { get; set; }
        public string?   IssuedByCenterCode   { get; set; }
        public string    Status               { get; set; } = ServiceOrderStatuses.Pending;
        public string    Priority             { get; set; } = ServiceOrderPriorities.Normal;
        public string?   WasteStream          { get; set; }
        public string?   SubStream            { get; set; }
        public Guid?     IdPickupPoint        { get; set; }
        public DateTime? PlannedPickupStart   { get; set; }
        public DateTime? PlannedPickupEnd     { get; set; }
        public DateTime? PlannedDeliveryStart { get; set; }
        public DateTime? PlannedDeliveryEnd   { get; set; }
        public Guid?     IdCarrier            { get; set; }
        public Guid?     IdPlannedPlant       { get; set; }
    }

    private sealed class ContainerRow
    {
        public string Type { get; set; } = "";
        public int    Qty  { get; set; } = 1;
    }

    // ── Modelo de línea de residuo ────────────────────────────────────────────
    private sealed class ResidueLineModel
    {
        public Guid?    IdLERCode       { get; set; }
        public int?     ProductUse      { get; set; }
        public int?     ProductCategory { get; set; }
        public decimal? EstimatedWeight { get; set; }
        public int?     MeasureUnit     { get; set; }
        public int?     Units           { get; set; }
        public bool     IsDangerous     { get; set; }
    }

    private FormModel          _model        = new();
    private List<ContainerRow> _containers   = [];
    private List<ResidueLineModel> _residueLines = [];

    // ── Sub-flujos disponibles (cascada WasteFlow) ────────────────────────────
    private IReadOnlyList<string> _soSubflows = [];

    // ── Datos de selectores ───────────────────────────────────────────────────
    private IReadOnlyList<EntitySelectorDto> _allEntities = [];
    private List<LerChapterDto>              _lerChapters = [];

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    private bool _issuedByReadOnly;

    protected override async Task OnInitializedAsync()
    {
        // Carga secuencial: el DbContext de Blazor Server no soporta operaciones concurrentes.
        _allEntities = await Mediator.Send(new GetEntitiesForSelectorQuery());
        _lerChapters = await Mediator.Send(new GetLerCodesQuery());

        // PRODUCER y PUBLIC_ENT: el emisor es siempre su propia entidad
        _issuedByReadOnly = CurrentUser.IsInAnyProfile(ProfileConstants.Producer, ProfileConstants.PublicEnt);

        if (_isEdit)
        {
            var detail = await Mediator.Send(new GetServiceOrderByIdQuery(ServiceOrderId!.Value));
            if (detail is not null) LoadFromDetail(detail);
        }
        else
        {
            _residueLines.Add(new ResidueLineModel());
            if (_issuedByReadOnly)
                _model.IdIssuedBy = CurrentUser.LinkedEntityId;
        }

        _loading = false;
    }

    private void LoadFromDetail(ServiceOrderDetailDto d)
    {
        _model = new FormModel
        {
            ServiceOrderNumber   = d.ServiceOrderNumber,
            IssuedAt             = d.IssuedAt,
            IdIssuedBy           = d.IdIssuedBy,
            IssuedByName         = d.IssuedByName,
            IssuedByNationalId   = d.IssuedByNationalId,
            IssuedByCenterCode   = d.IssuedByCenterCode,
            Status               = d.Status,
            Priority             = d.Priority,
            WasteStream          = d.WasteStream,
            SubStream            = d.SubStream,
            IdPickupPoint        = d.IdPickupPoint,
            PlannedPickupStart   = d.PlannedPickupStart,
            PlannedPickupEnd     = d.PlannedPickupEnd,
            PlannedDeliveryStart = d.PlannedDeliveryStart,
            PlannedDeliveryEnd   = d.PlannedDeliveryEnd,
            IdCarrier            = d.IdCarrier,
            IdPlannedPlant       = d.IdPlannedPlant
        };

        _residueLines = d.Residues.Count > 0
            ? d.Residues.Select(r => new ResidueLineModel
            {
                IdLERCode       = r.IdLERCode,
                ProductUse      = r.ProductUse,
                ProductCategory = r.ProductCategory,
                EstimatedWeight = r.EstimatedWeight,
                MeasureUnit     = r.MeasureUnit,
                Units           = r.Units,
                IsDangerous     = r.LerCodeIsDangerous
            }).ToList()
            : [new ResidueLineModel()];

        if (!string.IsNullOrEmpty(d.ContainersJson))
        {
            try
            {
                var list = JsonSerializer.Deserialize<List<ContainerRow>>(d.ContainersJson,
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                _containers = list ?? [];
            }
            catch { _containers = []; }
        }

        // Restaurar subflujos disponibles al cargar en edición
        _soSubflows = WasteFlowCatalog.FindByCode(d.WasteStream)?.Subflows ?? [];
    }

    // ── Cascade WasteFlow → SubFlow ───────────────────────────────────────────

    private void OnWasteStreamChanged(string? code)
    {
        _model.WasteStream = code;
        _model.SubStream   = null;
        _soSubflows        = WasteFlowCatalog.FindByCode(code)?.Subflows ?? [];
    }

    // ── Eventos ───────────────────────────────────────────────────────────────

    private void OnPickupPointChanged() { }   // reservado para lógica futura

    private void OnResidueLerChanged(ResidueLineModel line, string? value)
    {
        line.IdLERCode = Guid.TryParse(value, out var id) ? id : null;
        if (!line.IdLERCode.HasValue) { line.IsDangerous = false; return; }
        var flat = _lerChapters.SelectMany(c => c.SubChapters).SelectMany(sc => sc.Codes);
        var ler  = flat.FirstOrDefault(l => l.Id == line.IdLERCode);
        line.IsDangerous = ler?.IsDangerous ?? false;
    }

    private void AddResidueLine()
    {
        var line = new ResidueLineModel();
        _residueLines.Add(line);
        _residueGrid.Reload();
        _residueGrid.EditRow(line);
    }
    private void RemoveResidueLine(int idx)
    {
        if (idx >= 0 && idx < _residueLines.Count && _residueLines.Count > 1)
        {
            _residueLines.RemoveAt(idx);
            _residueGrid.Reload();
        }
    }

    private void ClearNumber() => _model.ServiceOrderNumber = "";

    private void AddContainer()
    {
        var row = new ContainerRow();
        _containers.Add(row);
        _containerGrid.Reload();
        _containerGrid.EditRow(row);
    }
    private void RemoveContainer(int idx)
    {
        if (idx >= 0 && idx < _containers.Count)
        {
            _containers.RemoveAt(idx);
            _containerGrid.Reload();
        }
    }

    private static DateTime? ParseDate(string? s)
        => DateTime.TryParse(s, out var d) ? d : null;

    // ── Guardar ───────────────────────────────────────────────────────────────
    private async Task SaveAsync()
    {
        _validationErrors = new();
        _serverError      = null;
        _saving           = true;

        if (_residueLines.Count == 0)
        {
            _validationErrors = new() { ["Residues"] = ["La orden de servicio debe tener al menos una línea de residuo."] };
            _saving = false;
            return;
        }

        var containersJson = _containers.Count > 0
            ? JsonSerializer.Serialize(_containers)
            : null;

        var residueInputs = _residueLines
            .Select((r, i) => new ServiceOrderResidueInput(
                SortOrder       : i,
                IdLERCode       : r.IdLERCode,
                ProductUse      : r.ProductUse,
                ProductCategory : r.ProductCategory,
                EstimatedWeight : r.EstimatedWeight,
                MeasureUnit     : 1,   // siempre Kg
                Units           : r.Units))
            .ToArray();

        try
        {
            if (_isEdit)
            {
                await Mediator.Send(new UpdateServiceOrderCommand(
                    Id                   : ServiceOrderId!.Value,
                    ServiceOrderNumber   : _model.ServiceOrderNumber,
                    IssuedAt             : _model.IssuedAt,
                    IdIssuedBy           : _model.IdIssuedBy,
                    IssuedByName         : _model.IssuedByName,
                    IssuedByNationalId   : _model.IssuedByNationalId,
                    IssuedByCenterCode   : _model.IssuedByCenterCode,
                    Status               : _model.Status,
                    Priority             : _model.Priority,
                    WasteStream          : _model.WasteStream,
                    SubStream            : _model.SubStream,
                    IdPickupPoint        : _model.IdPickupPoint,
                    PlannedPickupStart   : _model.PlannedPickupStart,
                    PlannedPickupEnd     : _model.PlannedPickupEnd,
                    PlannedDeliveryStart : _model.PlannedDeliveryStart,
                    PlannedDeliveryEnd   : _model.PlannedDeliveryEnd,
                    ContainersJson       : containersJson,
                    IdCarrier            : _model.IdCarrier,
                    IdPlannedPlant       : _model.IdPlannedPlant,
                    Residues             : residueInputs));

                Nav.NavigateTo($"/service-orders/{ServiceOrderId!.Value}");
            }
            else
            {
                var newId = await Mediator.Send(new CreateServiceOrderCommand(
                    ServiceOrderNumber   : _model.ServiceOrderNumber,
                    IssuedAt             : _model.IssuedAt,
                    IdIssuedBy           : _model.IdIssuedBy,
                    IssuedByName         : _model.IssuedByName,
                    IssuedByNationalId   : _model.IssuedByNationalId,
                    IssuedByCenterCode   : _model.IssuedByCenterCode,
                    Status               : _model.Status,
                    Priority             : _model.Priority,
                    WasteStream          : _model.WasteStream,
                    SubStream            : _model.SubStream,
                    IdPickupPoint        : _model.IdPickupPoint,
                    PlannedPickupStart   : _model.PlannedPickupStart,
                    PlannedPickupEnd     : _model.PlannedPickupEnd,
                    PlannedDeliveryStart : _model.PlannedDeliveryStart,
                    PlannedDeliveryEnd   : _model.PlannedDeliveryEnd,
                    ContainersJson       : containersJson,
                    IdCarrier            : _model.IdCarrier,
                    IdPlannedPlant       : _model.IdPlannedPlant,
                    Residues             : residueInputs));

                Nav.NavigateTo($"/service-orders/{newId}");
            }
        }
        catch (ValidationException ex)
        {
            foreach (var err in ex.Errors)
            {
                if (!_validationErrors.ContainsKey(err.PropertyName))
                    _validationErrors[err.PropertyName] = [];
                _validationErrors[err.PropertyName].Add(err.ErrorMessage);
            }
        }
        catch (InvalidOperationException ex) { _serverError = ex.Message; }
        catch (Exception ex)                 { _serverError = ex.Message; }
        finally { _saving = false; }
    }

    private void Cancel() => Nav.NavigateTo("/service-orders");
}
