@using Radzen
@using Radzen.Blazor
@page "/service-orders"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.ServiceOrders.DTOs
@using GreenTransit.Application.Features.ServiceOrders.Queries
@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Domain.Authorization
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator              Mediator
@inject NavigationManager      Nav
@inject ICurrentUserService    CurrentUser
@inject IPagePermissionService PagePermissions

<PageTitle>Órdenes de Servicio</PageTitle>

<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-clipboard2-check-fill me-2"></i>Órdenes de Servicio
    </h1>
    @if (_canWrite)
    {
        <button class="btn btn-primary btn-sm" @onclick='() => Nav.NavigateTo("/service-orders/new")'>
            <i class="bi bi-plus-lg me-1"></i>Nueva SO
        </button>
    }
</div>

@* ── Filtros ────────────────────────────────────────────────────────────────── *@
<div class="filter-bar">
    <div class="filter-group">
        <label>Búsqueda</label>
        <input class="form-control" style="min-width:200px"
               placeholder="Nº orden, referencia traslado…"
               @bind="_search" @bind:event="oninput" />
    </div>
    <div class="filter-group">
        <label>Estado</label>
        <select class="form-control" @bind="_filterStatus">
            <option value="">— Todos —</option>
            @foreach (var s in ServiceOrderStatuses.All)
            {
                <option value="@s">@ServiceOrderStatuses.Label(s)</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Prioridad</label>
        <select class="form-control" @bind="_filterPriority">
            <option value="">— Todas —</option>
            @foreach (var p in ServiceOrderPriorities.All)
            {
                <option value="@p">@ServiceOrderPriorities.Label(p)</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Flujo de residuo</label>
        <select class="form-control" @bind="_filterWasteStream">
            <option value="">— Todos —</option>
            <optgroup label="RAP">
                @foreach (var f in WasteFlowCatalog.All.Where(x => x.Type == WasteFlowCatalog.TypeRap))
                {
                    <option value="@f.Code">@f.Name</option>
                }
            </optgroup>
            <optgroup label="Operativos">
                @foreach (var f in WasteFlowCatalog.All.Where(x => x.Type == WasteFlowCatalog.TypeOperativo))
                {
                    <option value="@f.Code">@f.Name</option>
                }
            </optgroup>
        </select>
    </div>
    <div class="filter-group">
        <label>Recogida desde</label>
        <input type="date" class="form-control" @bind="_pickupFrom" @bind:format="yyyy-MM-dd" />
    </div>
    <div class="filter-group">
        <label>hasta</label>
        <input type="date" class="form-control" @bind="_pickupTo" @bind:format="yyyy-MM-dd" />
    </div>
    <div class="filter-actions">
        <button class="btn btn-primary btn-sm" @onclick="SearchAsync">
            <i class="bi bi-search me-1"></i>Buscar
        </button>
        <button class="btn btn-ghost btn-sm" @onclick="ResetFilters">Limpiar</button>
    </div>
</div>

<RadzenDataGrid @ref="_grid" TItem="ServiceOrderDto"
                Data="@(_result?.Items ?? [])" Count="@(_result?.TotalCount ?? 0)"
                LoadData="@OnLoadData"
                AllowPaging="true" PageSize="PageSize"
                AllowSorting="true" AllowFiltering="false"
                IsLoading="@_loading"
                EmptyText="No se encontraron órdenes de servicio."
                PagerHorizontalAlign="HorizontalAlign.Right">
    <Columns>
        <RadzenDataGridColumn TItem="ServiceOrderDto" Property="ServiceOrderNumber" Title="Nº Orden" Width="160px">
                <Template Context="so">
                    <a href="/service-orders/@so.Id" class="rz-link rz-text-weight-bold">@so.ServiceOrderNumber</a>
                    @if (!string.IsNullOrEmpty(so.WasteMoveReference))
                    { <br /><span class="rz-text-secondary-color rz-text-sm">@so.WasteMoveReference</span> }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ServiceOrderDto" Property="Status" Title="Estado" Width="130px">
                <Template Context="so">
                    <span class="@ServiceOrderStatuses.BadgeCss(so.Status)">@ServiceOrderStatuses.Label(so.Status)</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ServiceOrderDto" Property="Priority" Title="Prioridad" Width="110px">
                <Template Context="so">
                    <span class="@ServiceOrderPriorities.BadgeCss(so.Priority)">@ServiceOrderPriorities.Label(so.Priority)</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ServiceOrderDto" Property="IssuedAt" Title="Emisión" Width="105px" FormatString="{0:dd/MM/yyyy}" />
            <RadzenDataGridColumn TItem="ServiceOrderDto" Property="PlannedPickupStart" Title="Recogida planif." Width="120px">
                <Template Context="so">@(so.PlannedPickupStart?.ToString("dd/MM/yyyy") ?? "—")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ServiceOrderDto" Property="PickupPointName" Title="Punto recogida" Width="160px">
                <Template Context="so">@(so.PickupPointName ?? "—")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ServiceOrderDto" Property="WasteStream" Title="Flujo" Width="130px">
                <Template Context="so">@(WasteFlowCatalog.FindByCode(so.WasteStream)?.Name ?? so.WasteStream ?? "—")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ServiceOrderDto" Property="EstimatedWeight" Title="Peso est." Width="100px" TextAlign="TextAlign.Right">
                <Template Context="so">@(so.EstimatedWeight.HasValue ? $"{so.EstimatedWeight:N0} kg" : "—")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ServiceOrderDto" Title="" Width="120px" Filterable="false" Sortable="false" TextAlign="TextAlign.Left">
                <Template Context="so">
                    @{ var detailUrl = "/service-orders/" + so.Id; var editUrl = "/service-orders/" + so.Id + "/edit"; }
                    <RadzenButton Icon="visibility" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                  Click="@(() => Nav.NavigateTo(detailUrl))" title="Ver detalle" />
                    @if (_canWrite && ServiceOrderStatuses.Editable.Contains(so.Status))
                    {
                        <RadzenButton Icon="edit" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                      Click="@(() => Nav.NavigateTo(editUrl))" title="Editar" />
                    }
                    @if (_canWrite)
                    {
                        <RadzenButton Icon="content_copy" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                      Click="@(() => DuplicateAsync(so.Id))" title="Duplicar" />
                    }
                    @if (_canWrite && so.Status != ServiceOrderStatuses.Cancelled)
                    {
                        <RadzenButton Icon="cancel" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Danger"
                                      Click="@(() => ConfirmCancelAsync(so))" title="Cancelar" />
                    }
                </Template>
            </RadzenDataGridColumn>
        </Columns>
</RadzenDataGrid>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger mt-3">@_errorMessage</div>
}

<ConfirmDialog @ref="_confirmDialog"
               Title="Cancelar Orden de Servicio"
               Message="@_confirmMessage"
               ConfirmText="Sí, cancelar" />

@code {
    private const int PageSize = 20;

    private RadzenDataGrid<ServiceOrderDto> _grid = default!;
    private bool   _loading = true;
    private int    _page    = 1;
    private string _sortBy          = "";
    private bool   _sortDescending  = true;
    private string _search            = "";
    private string _filterStatus      = "";
    private string _filterPriority    = "";
    private string _filterWasteStream = "";
    private DateTime? _pickupFrom;
    private DateTime? _pickupTo;
    private string? _errorMessage;

    private GreenTransit.Application.Common.Models.PaginatedResult<ServiceOrderDto>? _result;
    private ConfirmDialog _confirmDialog = default!;
    private string _confirmMessage = "";
    private Guid   _cancelTargetId;
    private bool   _canWrite;

    protected override async Task OnInitializedAsync()
    {
        _canWrite = await PagePermissions.CanWriteRouteAsync("/service-orders");
        await LoadAsync();
    }

    private async Task OnLoadData(LoadDataArgs args)
    {
        _page = args.Skip.HasValue ? (args.Skip.Value / PageSize) + 1 : 1;
        var sort = args.Sorts?.FirstOrDefault();
        if (sort != null)
        {
            _sortBy         = sort.Property ?? "";
            _sortDescending = sort.SortOrder == SortOrder.Descending;
        }
        await LoadAsync();
    }

    private async Task SearchAsync()
    {
        _page = 1;
        await LoadAsync();
        if (_grid is not null) await _grid.Reload();
    }

    private async Task GoPageAsync(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _errorMessage = null;
        try
        {
            // Filtrado por datos propios: PRODUCER y PUBLIC_ENT solo ven sus SOs (§3.2)
            Guid? ownFilter = CurrentUser.IsInAnyProfile(ProfileConstants.Producer, ProfileConstants.PublicEnt)
                ? CurrentUser.LinkedEntityId
                : null;

            _result = await Mediator.Send(new GetServiceOrdersQuery(
                Status:            string.IsNullOrEmpty(_filterStatus)      ? null : _filterStatus,
                Priority:          string.IsNullOrEmpty(_filterPriority)    ? null : _filterPriority,
                WasteStream:       string.IsNullOrEmpty(_filterWasteStream) ? null : _filterWasteStream,
                IdIssuedBy:        ownFilter,
                SearchTerm:        string.IsNullOrEmpty(_search)            ? null : _search,
                PlannedPickupFrom: _pickupFrom,
                PlannedPickupTo:   _pickupTo,
                PageNumber:        _page,
                PageSize:          PageSize,
                SortBy:            string.IsNullOrEmpty(_sortBy) ? null : _sortBy,
                SortDescending:    _sortDescending));
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _loading = false; }
    }

    private void ResetFilters()
    {
        _search = ""; _filterStatus = ""; _filterPriority = ""; _filterWasteStream = "";
        _pickupFrom = null; _pickupTo = null; _page = 1;
        _ = LoadAsync();
        if (_grid is not null) _ = _grid.Reload();
    }

    private async Task DuplicateAsync(Guid id)
    {
        try
        {
            var newId = await Mediator.Send(
                new GreenTransit.Application.Features.ServiceOrders.Commands
                    .DuplicateServiceOrderCommand(id));
            Nav.NavigateTo($"/service-orders/{newId}/edit");
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    private async Task ConfirmCancelAsync(ServiceOrderDto so)
    {
        _cancelTargetId = so.Id;
        _confirmMessage = $"¿Cancelar la orden «{so.ServiceOrderNumber}»? Esta acción no se puede deshacer.";
        var confirmed = await _confirmDialog.ShowAsync();
        if (!confirmed) return;

        try
        {
            await Mediator.Send(
                new GreenTransit.Application.Features.ServiceOrders.Commands
                    .CancelServiceOrderCommand(_cancelTargetId, "Cancelada por el usuario"));
            await LoadAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }
}
