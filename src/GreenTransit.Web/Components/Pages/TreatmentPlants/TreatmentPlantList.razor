@using Radzen
@using Radzen.Blazor
@page "/treatment-plants"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.TreatmentPlants.DTOs
@using GreenTransit.Application.Features.TreatmentPlants.Queries
@using GreenTransit.Application.Features.WasteMoves.DTOs
@using GreenTransit.Application.Features.WasteMoves.Queries
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator        Mediator
@inject NavigationManager Nav

<PageTitle>Clasificación y Tratamiento</PageTitle>

<div class="page-header">
    <div class="page-header-info">
        <h1 class="page-title">
            <i class="bi bi-recycle me-2"></i>Clasificación y Tratamiento Final
        </h1>
    </div>
</div>

@* ── Panel: Nuevo tratamiento ─────────────────────────────────────────────── *@
<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0 text-success">
            <i class="bi bi-plus-circle me-2"></i>Nuevo tratamiento
        </h6>
    </div>
    <div class="card-body">
        @if (_loadingDisponibles)
        {
            <div class="text-muted small">
                <span class="spinner-border spinner-border-sm me-1"></span>
                Cargando traslados disponibles…
            </div>
        }
        else if (_disponibles.Count == 0)
        {
            <div class="text-muted small">
                <i class="bi bi-info-circle me-1"></i>
                No hay traslados en estado <strong>EN PLANTA</strong> pendientes de clasificación.
            </div>
        }
        else
        {
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-8">
                    <label class="form-label form-label-sm fw-semibold">
                        Traslado disponible para clasificar
                    </label>
                    <select class="form-select" @bind="_selectedWasteMoveId">
                        <option value="">— Seleccionar traslado —</option>
                        @foreach (var wm in _disponibles)
                        {
                            <option value="@wm.Id">
                                @wm.WasteMoveReference
                                @if (!string.IsNullOrEmpty(wm.SourceName))
                                {
                                    <text> — @wm.SourceName</text>
                                }
                            </option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <button class="btn btn-primary w-100"
                            disabled="@(_selectedWasteMoveId == Guid.Empty)"
                            @onclick="GoToForm">
                        <i class="bi bi-recycle me-1"></i>Registrar tratamiento
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@* ── Filtros ──────────────────────────────────────────────────────────────── *@
<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label form-label-sm">Referencia traslado</label>
                <input class="form-control form-control-sm"
                       @bind="_filterRef" @bind:event="oninput"
                       placeholder="WM-2024-…" />
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label form-label-sm">Fecha desde</label>
                <InputDate TValue="DateTime?" class="form-control form-control-sm"
                           @bind-Value="_filterFrom" />
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label form-label-sm">Fecha hasta</label>
                <InputDate TValue="DateTime?" class="form-control form-control-sm"
                           @bind-Value="_filterTo" />
            </div>
            <div class="col-12 col-md-2">
                <button class="btn btn-primary btn-sm w-100" @onclick="LoadAsync">
                    <i class="bi bi-search me-1"></i>Buscar
                </button>
            </div>
            <div class="col-12 col-md-2">
                <button class="btn btn-outline-secondary btn-sm w-100" @onclick="ClearFilters">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </button>
            </div>
        </div>
    </div>
</div>

@* ── Tabla ────────────────────────────────────────────────────────────────── *@
@if (_loading)
{
    <div class="gt-loading"><RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" /></div>
}
else if (_result is null || _result.TotalCount == 0)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">No se encontraron registros de tratamiento.</RadzenAlert>
}
else
{
    <RadzenDataGrid TItem="TreatmentPlantDto"
                    Data="@_result.Items" Count="@_result.TotalCount"
                    AllowPaging="false" AllowSorting="true" AllowFiltering="false"
                    EmptyText="No se encontraron registros de tratamiento.">
        <Columns>
            <RadzenDataGridColumn TItem="TreatmentPlantDto" Property="WasteMoveReference" Title="Referencia traslado" Width="160px">
                <Template Context="item"><strong>@(item.WasteMoveReference ?? "—")</strong></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TreatmentPlantDto" Property="TicketScale" Title="Ticket" Width="110px">
                <Template Context="item">@(item.TicketScale ?? "—")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TreatmentPlantDto" Property="PlantTreatmentDate" Title="Fecha tratamiento" Width="145px">
                <Template Context="item">@(item.PlantTreatmentDate?.ToString("dd/MM/yyyy") ?? "—")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TreatmentPlantDto" Property="TreatmentOperationCode" Title="Operación R/D">
                <Template Context="item">
                    @if (item.TreatmentOperationCode is not null)
                    {
                        <RadzenBadge Text="@item.TreatmentOperationCode"
                                     BadgeStyle="@(item.TreatmentOperationType == "Recovery" ? BadgeStyle.Success : BadgeStyle.Warning)" />
                        <span class="rz-text-secondary-color rz-text-sm ms-1">@item.TreatmentOperationDescription</span>
                    }
                    else { <text>—</text> }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TreatmentPlantDto" Property="ResidueLineCount" Title="Líneas" Width="80px" TextAlign="TextAlign.Center" />
            <RadzenDataGridColumn TItem="TreatmentPlantDto" Property="HasIncident" Title="Incidencia" Width="120px" TextAlign="TextAlign.Center">
                <Template Context="item">
                    @if (item.HasIncident) { <RadzenBadge Text="Incidencia" BadgeStyle="BadgeStyle.Danger" /> }
                    else { <RadzenBadge Text="OK" BadgeStyle="BadgeStyle.Success" /> }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TreatmentPlantDto" Title="" Width="70px" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                <Template Context="item">
                    <RadzenButton Icon="visibility" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                  Click="@(() => Nav.NavigateTo("/treatment-plants/" + item.Id))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>

    @if (_result.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-2">
            <small class="rz-text-secondary-color">
                @((_page - 1) * PageSize + 1)–@(Math.Min(_page * PageSize, _result.TotalCount))
                de @_result.TotalCount registros
            </small>
            <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-secondary" disabled="@(!_result.HasPrevious)" @onclick="PrevPage"><i class="bi bi-chevron-left"></i></button>
                <span class="btn btn-outline-secondary disabled">@_page / @_result.TotalPages</span>
                <button class="btn btn-outline-secondary" disabled="@(!_result.HasNext)" @onclick="NextPage"><i class="bi bi-chevron-right"></i></button>
            </div>
        </div>
    }
}

@code {
    private const int PageSize = 15;

    private GreenTransit.Application.Common.Models.PaginatedResult<TreatmentPlantDto>? _result;
    private bool _loading             = true;
    private bool _loadingDisponibles  = true;

    private string?   _filterRef;
    private DateTime? _filterFrom;
    private DateTime? _filterTo;
    private int       _page = 1;

    private List<WasteMoveDto> _disponibles         = [];
    private Guid               _selectedWasteMoveId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        await LoadDisponiblesAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _result  = await Mediator.Send(new GetTreatmentPlantsQuery(
            WasteMoveReference:     _filterRef,
            PlantTreatmentDateFrom: _filterFrom,
            PlantTreatmentDateTo:   _filterTo,
            PageNumber:             _page,
            PageSize:               PageSize));
        _loading = false;
    }

    private async Task LoadDisponiblesAsync()
    {
        _loadingDisponibles = true;
        var res = await Mediator.Send(new GetWasteMovesQuery(
            ServiceStatus: WasteMoveStatuses.EnPlanta,
            PageSize: 200));
        _disponibles        = res.Items.ToList();
        _loadingDisponibles = false;
    }

    private void GoToForm()
    {
        if (_selectedWasteMoveId != Guid.Empty)
            Nav.NavigateTo($"/waste-moves/{_selectedWasteMoveId}/treatment-plant");
    }

    private void ClearFilters()
    {
        _filterRef  = null;
        _filterFrom = null;
        _filterTo   = null;
        _page       = 1;
        _ = LoadAsync();
    }

    private async Task PrevPage() { _page--; await LoadAsync(); }
    private async Task NextPage() { _page++; await LoadAsync(); }
}
