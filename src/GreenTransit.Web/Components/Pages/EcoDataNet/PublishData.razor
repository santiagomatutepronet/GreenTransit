@page "/ecodatanet/publish"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization

<PageTitle>Publicar Datos — EcoDataNet — GreenTransit</PageTitle>

<div class="page-header">
    <h2 class="page-title">
        <i class="bi bi-broadcast me-2"></i>Publicar Datos
    </h2>
</div>

@* ── Bloque informativo ─────────────────────────────────────────────────── *@
<div class="alert alert-info d-flex gap-2 align-items-start mb-4" role="alert">
    <i class="bi bi-info-circle-fill fs-5 mt-1 flex-shrink-0"></i>
    <div>
        En <strong>EcoDataNet</strong> puedes publicar tus datos de gestión de residuos para que
        otros participantes autorizados los descubran y utilicen bajo las condiciones que tú
        definas.<br />
        El espacio de datos garantiza seguridad, trazabilidad, interoperabilidad y soberanía del
        dato, permitiendo generar valor compartido y facilitar el cumplimiento de las obligaciones
        regulatorias.
    </div>
</div>

@* ── Formulario ─────────────────────────────────────────────────────────── *@
<div class="card shadow-sm mb-4">
    <div class="card-header">
        <i class="bi bi-plug-fill me-2"></i>Configuración del conector
    </div>
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label fw-semibold">Conector EDC EcoDataNet del participante</label>
            <input class="form-control" readonly value="@_edcConnector" />
            <div class="form-text">Valor configurado en su perfil de participante.</div>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">API Key</label>
            <div class="input-group">
                <input class="form-control font-monospace" readonly value="@_apiKey" />
                <button class="btn btn-outline-secondary" type="button"
                        title="Regenerar API Key" @onclick="RegenerateApiKey" disabled="@_publishing">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
            <div class="form-text">Clave de conexión privada de su conector EDC.</div>
        </div>
    </div>
</div>

@* ── Acción principal ────────────────────────────────────────────────────── *@
<div class="card shadow-sm">
    <div class="card-body">

        @if (_publishing)
        {
            <div class="mb-3">
                <div class="d-flex justify-content-between mb-1">
                    <small class="text-muted">Publicando datos en EcoDataNet…</small>
                    <small class="fw-semibold">@_progress%</small>
                </div>
                <div class="progress" style="height:20px">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-success"
                         role="progressbar"
                         style="width:@(_progress)%"
                         aria-valuenow="@_progress" aria-valuemin="0" aria-valuemax="100">
                    </div>
                </div>
            </div>
        }

        @if (_completed)
        {
            <div class="alert alert-success d-flex gap-2 align-items-center" role="alert">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <span>Proceso completado con éxito</span>
            </div>
        }

        <button class="btn btn-primary"
                disabled="@_publishing"
                @onclick="PublishAsync">
            <i class="bi bi-broadcast me-1"></i>Publicar datos en EcoDataNet
        </button>
    </div>
</div>

@* ── Diagrama de integración ─────────────────────────────────────────────── *@
<div class="text-center mt-4">
    <img src="/images/ecodatanet/integracion-greentransit-ecodatanet.png"
         alt="Diagrama de integración GreenTransit → EcoDataNet"
         class="img-fluid rounded shadow-sm"
         style="max-width:860px; width:100%" />
</div>

@code {
    // ── Mock valores ──────────────────────────────────────────────────────────
    // En producción, _edcConnector provendría de Users.PortalEDCProvider via ICurrentUserService.
    private const string MockEdcConnector = "https://edc.greentransit.example.com/connector";

    private string _edcConnector = MockEdcConnector;
    private string _apiKey       = GenerateGuid();

    // ── Estado publicación ────────────────────────────────────────────────────
    private bool _publishing = false;
    private bool _completed  = false;
    private int  _progress   = 0;

    private static string GenerateGuid() => Guid.NewGuid().ToString("D").ToUpperInvariant();

    private void RegenerateApiKey()
    {
        _apiKey    = GenerateGuid();
        _completed = false;
    }

    private async Task PublishAsync()
    {
        _publishing = true;
        _completed  = false;
        _progress   = 0;

        const int steps    = 20;
        const int stepMs   = 80;

        for (var i = 1; i <= steps; i++)
        {
            await Task.Delay(stepMs);
            _progress = (int)Math.Round(100.0 * i / steps);
            StateHasChanged();
        }

        _publishing = false;
        _completed  = true;
    }
}
