@using Radzen
@using Radzen.Blazor
@using GreenTransit.Web.Components.Pages.EcoDataNet.Dataspace.Shared

<RadzenCard class="mb-4">
    <RadzenStack Gap="0.5rem">
        <RadzenText TextStyle="TextStyle.H5">
            <RadzenIcon Icon="cloud_download" class="me-2" />Datasets consumidos — @ProfileLabel
        </RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color)">
            Datos que este participante consume de otros actores del espacio de datos EcoDataNet.
        </RadzenText>
    </RadzenStack>
</RadzenCard>

@if (_profile is null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
        No se encontraron datos para el perfil «@ProfileId».
    </RadzenAlert>
}
else if (_profile.ConsumeGrouped.Count == 0)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
        Este perfil no consume datos de otros participantes en el espacio de datos.
    </RadzenAlert>
}
else
{
    @foreach (var group in _profile.ConsumeGrouped)
    {
        <RadzenFieldset Text="@($"Datos de: {group.FromProfileLabel}")" class="mb-4">
            @foreach (var item in group.Items)
            {
                <div class="mb-2 p-3 border rounded d-flex align-items-center justify-content-between gap-3"
                     style="background: var(--rz-base-background-color, #fff);">
                    <div style="text-align:left; min-width:0;">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@item.Uc" IsPill="true" />
                            <span style="font-size:0.875rem">@item.Desc</span>
                        </div>
                        <div>
                            <code style="font-size:0.78rem; color: var(--rz-text-secondary-color)">@item.Ref</code>
                        </div>
                    </div>
                    <div class="flex-shrink-0">
                        <RadzenButton Text="Consumir datos" Icon="cloud_download"
                                      ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small"
                                      Disabled="true"
                                      MouseEnter="@(args => ShowTooltip(args, "Funcionalidad pendiente de integración con conector EDC"))" />
                    </div>
                </div>
            }
        </RadzenFieldset>
    }

    <RadzenAlert AlertStyle="AlertStyle.Light" ShowIcon="false" class="mt-3">
        <strong>Nota:</strong> Si un perfil consume datos de otro perfil, se entiende que consume de <em>todos</em>
        los participantes de ese perfil (no hay selección por instancia).
    </RadzenAlert>
}

@code {
    [Parameter, EditorRequired]
    public string ProfileId { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string ProfileLabel { get; set; } = string.Empty;

    [Inject] private TooltipService TooltipService { get; set; } = default!;

    private ProfileDatasets? _profile;

    protected override void OnParametersSet()
    {
        _profile = EcoDataNetDatasetStore.GetBySlug(ProfileId);
    }

    private void ShowTooltip(ElementReference elementRef, string text)
        => TooltipService.Open(elementRef, text, new TooltipOptions { Duration = 3000 });
}
