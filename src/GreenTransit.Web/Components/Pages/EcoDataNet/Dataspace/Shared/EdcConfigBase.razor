@using Radzen
@using Radzen.Blazor
@using GreenTransit.Web.Components.Pages.EcoDataNet.Dataspace.Shared

@inject NotificationService  NotificationService
@inject NavigationManager    Nav

<RadzenCard class="mb-4">
    <RadzenStack Gap="0.5rem">
        <RadzenText TextStyle="TextStyle.H5">
            <RadzenIcon Icon="settings" class="me-2" />Configuración del Conector EDC — @ProfileLabel
        </RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color)">
            Configure los parámetros de conexión al conector EDC de EcoDataNet para el perfil <strong>@ProfileLabel</strong>.
        </RadzenText>
    </RadzenStack>
</RadzenCard>

<RadzenTemplateForm TItem="EdcConnectorConfigModel" Data="@_model" Submit="@OnSubmit">

    @* ── Datos del Conector ──────────────────────────────────────────────── *@
    <RadzenFieldset Text="Datos del Conector" class="mb-4">
        <RadzenRow Gap="1rem">
            <RadzenColumn SizeMD="6">
                <RadzenFormField Text="Nombre del conector" Style="width:100%">
                    <RadzenTextBox @bind-Value="_model.ConnectorName" Placeholder="ej. gt-connector-scrap-01" Style="width:100%" />
                </RadzenFormField>
            </RadzenColumn>
            <RadzenColumn SizeMD="6">
                <RadzenFormField Text="DNS del conector" Style="width:100%">
                    <RadzenTextBox @bind-Value="_model.ConnectorDns" Placeholder="ej. connector.example.com" Style="width:100%" />
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>
        <RadzenRow Gap="1rem" class="mt-3">
            <RadzenColumn SizeMD="6">
                <RadzenFormField Text="Management URL *" Style="width:100%">
                    <ChildContent>
                        <RadzenTextBox Name="ManagementUrl" @bind-Value="_model.ManagementUrl" Placeholder="https://..." Style="width:100%" />
                    </ChildContent>
                    <Helper>
                        <RadzenRequiredValidator Component="ManagementUrl" Text="La URL de Management es obligatoria" />
                    </Helper>
                </RadzenFormField>
            </RadzenColumn>
            <RadzenColumn SizeMD="6">
                <RadzenFormField Text="Default URL" Style="width:100%">
                    <RadzenTextBox @bind-Value="_model.DefaultUrl" Placeholder="https://..." Style="width:100%" />
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>
        <RadzenRow Gap="1rem" class="mt-3">
            <RadzenColumn SizeMD="6">
                <RadzenFormField Text="Protocol URL *" Style="width:100%">
                    <ChildContent>
                        <RadzenTextBox Name="ProtocolUrl" @bind-Value="_model.ProtocolUrl" Placeholder="https://..." Style="width:100%" />
                    </ChildContent>
                    <Helper>
                        <RadzenRequiredValidator Component="ProtocolUrl" Text="La URL de Protocol es obligatoria" />
                    </Helper>
                </RadzenFormField>
            </RadzenColumn>
            <RadzenColumn SizeMD="6">
                <RadzenFormField Text="DID (Decentralized Identifier)" Style="width:100%">
                    <RadzenTextBox @bind-Value="_model.Did" Placeholder="did:web:..." Style="width:100%" />
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>
    </RadzenFieldset>

    @* ── Catálogo Federado ───────────────────────────────────────────────── *@
    <RadzenFieldset Text="Catálogo Federado" class="mb-4">
        <RadzenRow Gap="1rem" AlignItems="AlignItems.Center">
            <RadzenColumn SizeMD="12">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                    <RadzenSwitch @bind-Value="_model.FederatedCatalogEnabled" />
                    <RadzenText>Habilitar catálogo federado</RadzenText>
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
        @if (_model.FederatedCatalogEnabled)
        {
            <RadzenRow Gap="1rem" class="mt-3">
                <RadzenColumn SizeMD="8">
                    <RadzenFormField Text="Federated Catalog URL *" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox Name="FederatedCatalogUrl" @bind-Value="_model.FederatedCatalogUrl" Placeholder="https://..." Style="width:100%" />
                        </ChildContent>
                        <Helper>
                            <RadzenRequiredValidator Component="FederatedCatalogUrl" Text="La URL del catálogo federado es obligatoria si está habilitado" />
                        </Helper>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        }
    </RadzenFieldset>

    @* ── Seguridad ───────────────────────────────────────────────────────── *@
    <RadzenFieldset Text="Seguridad" class="mb-4">
        <RadzenRow Gap="1rem" AlignItems="AlignItems.End">
            <RadzenColumn SizeMD="6">
                <RadzenFormField Text="API Token *" Style="width:100%">
                    <ChildContent>
                        <RadzenPassword Name="ApiToken" @bind-Value="_model.ApiToken" Style="width:100%" />
                    </ChildContent>
                    <Helper>
                        <RadzenRequiredValidator Component="ApiToken" Text="El API Token es obligatorio" />
                    </Helper>
                </RadzenFormField>
            </RadzenColumn>
            <RadzenColumn SizeMD="6">
                <RadzenButton Text="Probar conexión" Icon="wifi_tethering" ButtonStyle="ButtonStyle.Secondary"
                              Click="@OnTestConnection" Disabled="@_testing" Style="margin-bottom:0.25rem" />
                @if (_testing)
                {
                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.ExtraSmall" class="ms-2" />
                }
            </RadzenColumn>
        </RadzenRow>
    </RadzenFieldset>

    @* ── Keycloak (opcional) ─────────────────────────────────────────────── *@
    <RadzenFieldset Text="Keycloak (opcional)" class="mb-4">
        <RadzenRow Gap="1rem">
            <RadzenColumn SizeMD="6">
                <RadzenFormField Text="Token URL" Style="width:100%">
                    <RadzenTextBox @bind-Value="_model.KeycloakTokenUrl" Placeholder="https://..." Style="width:100%" />
                </RadzenFormField>
            </RadzenColumn>
            <RadzenColumn SizeMD="6">
                <RadzenFormField Text="JWKS URL" Style="width:100%">
                    <RadzenTextBox @bind-Value="_model.KeycloakJwksUrl" Placeholder="https://..." Style="width:100%" />
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>
        <RadzenRow Gap="1rem" class="mt-3">
            <RadzenColumn SizeMD="6">
                <RadzenFormField Text="Audience" Style="width:100%">
                    <RadzenTextBox @bind-Value="_model.KeycloakAudience" Style="width:100%" />
                </RadzenFormField>
            </RadzenColumn>
            <RadzenColumn SizeMD="6">
                <RadzenFormField Text="Public API Base URL" Style="width:100%">
                    <RadzenTextBox @bind-Value="_model.PublicApiBaseUrl" Placeholder="https://..." Style="width:100%" />
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>
    </RadzenFieldset>

    @* ── Observaciones ───────────────────────────────────────────────────── *@
    <RadzenFieldset Text="Observaciones" class="mb-4">
        <RadzenFormField Text="Notas" Style="width:100%">
            <RadzenTextArea @bind-Value="_model.Notes" Rows="3" Style="width:100%" />
        </RadzenFormField>
    </RadzenFieldset>

    @* ── Acciones ────────────────────────────────────────────────────────── *@
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
        <RadzenButton ButtonType="ButtonType.Submit" Text="Guardar" Icon="save" ButtonStyle="ButtonStyle.Primary" />
        <RadzenButton Text="Cancelar" Icon="cancel" ButtonStyle="ButtonStyle.Light" Click="@OnCancel" />
    </RadzenStack>

</RadzenTemplateForm>

@code {
    [Parameter, EditorRequired]
    public string ProfileId { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string ProfileLabel { get; set; } = string.Empty;

    private readonly EdcConnectorConfigModel _model = new();
    private bool _testing;

    private void OnSubmit(EdcConnectorConfigModel model)
    {
        NotificationService.Notify(new NotificationMessage
        {
            Severity  = NotificationSeverity.Info,
            Summary   = "Configuración guardada (simulado)",
            Detail    = "Sin persistencia — funcionalidad pendiente de integración EDC.",
            Duration  = 4000
        });
    }

    private async Task OnTestConnection()
    {
        _testing = true;
        await Task.Delay(1000);
        _testing = false;
        NotificationService.Notify(new NotificationMessage
        {
            Severity  = NotificationSeverity.Success,
            Summary   = "Conexión simulada correctamente",
            Detail    = "Prueba de conectividad EDC simulada — sin llamada real al conector.",
            Duration  = 4000
        });
    }

    private void OnCancel() => Nav.NavigateTo("/ecodatanet/publish");
}
