@using Radzen
@using Radzen.Blazor
@page "/settlements"
@attribute [Authorize(Policy = PolicyConstants.CanManageSettlements)]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.Agreements.Queries
@using GreenTransit.Application.Features.Settlements.DTOs
@using GreenTransit.Application.Features.Settlements.Queries
@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Domain.Authorization
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator           Mediator
@inject NavigationManager   Nav
@inject ICurrentUserService CurrentUser

<PageTitle>Liquidaciones</PageTitle>

<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-receipt me-2"></i>Liquidaciones
    </h1>
    <AuthorizeView Policy="@PolicyConstants.CanManageSettlements">
        <Authorized>
            <button class="btn btn-primary btn-sm" @onclick='() => Nav.NavigateTo("/settlements/generate")'>
                <i class="bi bi-plus-lg me-1"></i>Nueva liquidación
            </button>
        </Authorized>
    </AuthorizeView>
</div>

@* ── Filtros ────────────────────────────────────────────────────────────────── *@
<div class="filter-bar">
    <div class="filter-group">
        <label>Estado</label>
        <select class="form-control" @bind="_filterStatus">
            <option value="">— Todos —</option>
            <option value="Pending">Pendiente</option>
            <option value="Approved">Aprobado</option>
            <option value="Rejected">Rechazado</option>
        </select>
    </div>
    <div class="filter-group">
        <label>Año</label>
        <input type="number" class="form-control" style="width:90px"
               @bind="_filterYear" @bind:event="oninput" min="2020" max="2099" />
    </div>
    <div class="filter-group">
        <label>Mes</label>
        <select class="form-control" @bind="_filterMonth">
            <option value="">— Todos —</option>
            @for (int m = 1; m <= 12; m++)
            {
                var monthName = new DateTime(2000, m, 1).ToString("MMMM");
                <option value="@m">@monthName</option>
            }
        </select>
    </div>
    <div class="filter-group align-self-end">
        <button class="btn btn-secondary btn-sm" @onclick="LoadAsync">
            <i class="bi bi-search me-1"></i>Buscar
        </button>
    </div>
</div>

@* ── Grid ──────────────────────────────────────────────────────────────────── *@
@if (_loading)
{
    <div class="gt-loading"><RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" /></div>
}
else if (_page is null || _page.Items.Count == 0)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" class="mt-3">No se encontraron liquidaciones con los filtros aplicados.</RadzenAlert>
}
else
{
    <RadzenDataGrid TItem="SettlementSummaryDto"
                    Data="@_page.Items" Count="@_page.TotalCount"
                    AllowPaging="false" AllowSorting="true" AllowFiltering="false"
                    EmptyText="No hay liquidaciones."
                    class="mt-3">
        <Columns>
            <RadzenDataGridColumn TItem="SettlementSummaryDto" Property="SettlementNumber" Title="Número" Width="130px">
                <Template Context="s"><code>@s.SettlementNumber</code></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SettlementSummaryDto" Property="Status" Title="Estado" Width="110px">
                <Template Context="s"><span class="badge @StatusBadgeClass(s.Status)">@StatusLabel(s.Status)</span></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SettlementSummaryDto" Property="AgreementNumber" Title="Acuerdo" Width="130px">
                <Template Context="s"><a href="/agreements/@s.AgreementId" class="rz-link">@s.AgreementNumber</a></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SettlementSummaryDto" Title="Periodo" Width="100px">
                <Template Context="s">@s.Year / @(s.Month.HasValue ? s.Month.Value.ToString("D2") : "—")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SettlementSummaryDto" Property="ScrapName" Title="SCRAP" Width="150px">
                <Template Context="s">@(s.ScrapName ?? "—")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SettlementSummaryDto" Property="PublicEntityName" Title="Entidad pública" Width="160px">
                <Template Context="s">@(s.PublicEntityName ?? "—")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SettlementSummaryDto" Property="BaseAmount" Title="Base" Width="100px" TextAlign="TextAlign.Right">
                <Template Context="s">@s.BaseAmount.ToString("N2") @s.Currency</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SettlementSummaryDto" Property="AdjustmentsAmount" Title="Ajustes" Width="100px" TextAlign="TextAlign.Right">
                <Template Context="s">@s.AdjustmentsAmount.ToString("N2")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SettlementSummaryDto" Property="TaxAmount" Title="IVA" Width="90px" TextAlign="TextAlign.Right">
                <Template Context="s">@s.TaxAmount.ToString("N2")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SettlementSummaryDto" Property="TotalAmount" Title="Total" Width="120px" TextAlign="TextAlign.Right">
                <Template Context="s"><strong>@s.TotalAmount.ToString("N2") @s.Currency</strong></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SettlementSummaryDto" Title="" Width="70px" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                <Template Context="s">
                    <RadzenButton Icon="visibility" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                  Click="@(() => Nav.NavigateTo($"/settlements/{s.Id}"))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>

    @if (_page.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-2">
            <small class="rz-text-secondary-color">@_page.TotalCount resultados</small>
            <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-secondary" disabled="@(!_page.HasPrevious)" @onclick="PrevPage"><i class="bi bi-chevron-left"></i></button>
                <span class="btn btn-outline-secondary disabled">@_currentPage / @_page.TotalPages</span>
                <button class="btn btn-outline-secondary" disabled="@(!_page.HasNext)" @onclick="NextPage"><i class="bi bi-chevron-right"></i></button>
            </div>
        </div>
    }
}

@if (_errorMessage is not null)
{
    <div class="alert alert-danger mt-3">@_errorMessage</div>
}

@code {
    private GreenTransit.Application.Common.Models.PaginatedResult<SettlementSummaryDto>? _page;
    private bool    _loading      = true;
    private string? _errorMessage;
    private int     _currentPage  = 1;
    private int     _pageSize     = 15;

    private string? _filterStatus;
    private int?    _filterYear;
    private int?    _filterMonth;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading      = true;
        _errorMessage = null;
        try
        {
            _page = await Mediator.Send(new GetSettlementsQuery(
                Status:     _filterStatus,
                Year:       _filterYear,
                Month:      _filterMonth,
                PageNumber: _currentPage,
                PageSize:   _pageSize));
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task PrevPage() { _currentPage--; await LoadAsync(); }
    private async Task NextPage() { _currentPage++; await LoadAsync(); }

    private static string StatusBadgeClass(string status) => status switch
    {
        "Pending"  => "bg-warning text-dark",
        "Approved" => "bg-success",
        "Rejected" => "bg-danger",
        _          => "bg-secondary"
    };

    private static string StatusLabel(string status) => status switch
    {
        "Pending"  => "Pendiente",
        "Approved" => "Aprobado",
        "Rejected" => "Rechazado",
        _          => status
    };
}
