@page "/settlements/{Id:guid}"
@attribute [Authorize(Policy = PolicyConstants.CanManageSettlements)]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.Settlements.Commands
@using GreenTransit.Application.Features.Settlements.DTOs
@using GreenTransit.Application.Features.Settlements.Queries
@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Domain.Authorization
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator           Mediator
@inject NavigationManager   Nav
@inject ICurrentUserService CurrentUser

<PageTitle>Liquidación @(_detail?.SettlementNumber ?? "…")</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else if (_detail is null)
{
    <div class="alert alert-danger">Liquidación no encontrada.</div>
}
else
{
    <div class="page-header">
        <h1 class="page-title">
            <i class="bi bi-receipt me-2"></i>@_detail.SettlementNumber
            <span class="badge ms-2 @StatusBadgeClass(_detail.Status)">@StatusLabel(_detail.Status)</span>
        </h1>
        <button class="btn btn-outline-secondary btn-sm" @onclick='() => Nav.NavigateTo("/settlements")'>
            <i class="bi bi-arrow-left me-1"></i>Volver
        </button>
    </div>

    @if (_errorMessage is not null)
    {
        <div class="alert alert-danger mt-2">@_errorMessage</div>
    }
    @if (_successMessage is not null)
    {
        <div class="alert alert-success mt-2">@_successMessage</div>
    }

    @* ── Cabecera ──────────────────────────────────────────────────────────── *@
    <div class="row g-3 mt-1">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold">Datos del acuerdo</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-5">Acuerdo</dt>
                        <dd class="col-7">
                            <a href="/agreements/@_detail.AgreementId">@_detail.AgreementNumber</a>
                        </dd>
                        <dt class="col-5">Periodo</dt>
                        <dd class="col-7">@_detail.Year / @(_detail.Month?.ToString("D2") ?? "—")</dd>
                        <dt class="col-5">SCRAP</dt>
                        <dd class="col-7">@(_detail.ScrapName ?? "—")</dd>
                        <dt class="col-5">Entidad pública</dt>
                        <dd class="col-7">@(_detail.PublicEntityName ?? "—")</dd>
                        <dt class="col-5">Moneda</dt>
                        <dd class="col-7">@_detail.Currency</dd>
                        <dt class="col-5">Versión</dt>
                        <dd class="col-7">@_detail.Version</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold">Importes</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-6">Base imponible</dt>
                        <dd class="col-6 text-end">@_detail.BaseAmount.ToString("N2") @_detail.Currency</dd>
                        <dt class="col-6">Ajustes</dt>
                        <dd class="col-6 text-end">@_detail.AdjustmentsAmount.ToString("N2")</dd>
                        <dt class="col-6">IVA (21 %)</dt>
                        <dd class="col-6 text-end">@_detail.TaxAmount.ToString("N2")</dd>
                        <dt class="col-6 fw-bold">Total</dt>
                        <dd class="col-6 text-end fw-bold text-success fs-5">
                            @_detail.TotalAmount.ToString("N2") @_detail.Currency
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    @* ── Validación ────────────────────────────────────────────────────────── *@
    @if (_detail.Validator is not null)
    {
        <div class="card mt-3">
            <div class="card-header fw-semibold">Validación</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-4">Validador</dt>
                    <dd class="col-8">@_detail.Validator</dd>
                    <dt class="col-4">Estado</dt>
                    <dd class="col-8">@(_detail.ValidationStatus ?? "—")</dd>
                    <dt class="col-4">Fecha</dt>
                    <dd class="col-8">@(_detail.ValidatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</dd>
                    @if (_detail.ValidationRef is not null)
                    {
                        <dt class="col-4">Motivo</dt>
                        <dd class="col-8">@_detail.ValidationRef</dd>
                    }
                </dl>
            </div>
        </div>
    }

    @* ── Líneas ────────────────────────────────────────────────────────────── *@
    <div class="card mt-3">
        <div class="card-header fw-semibold">Líneas de liquidación</div>
        <div class="card-body p-0">
            @if (_detail.Lines.Count == 0)
            {
                <p class="p-3 text-muted mb-0">Sin líneas.</p>
            }
            else
            {
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Código LER</th>
                            <th>Descripción</th>
                            <th>Categoría</th>
                            <th class="text-end">Peso (kg)</th>
                            <th class="text-end">€/kg</th>
                            <th class="text-end">Importe</th>
                            <th>Evidencia</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var l in _detail.Lines)
                        {
                            <tr>
                                <td><code>@(l.LerCodeCode ?? "—")</code></td>
                                <td>@(l.LerCodeDescription ?? "—")</td>
                                <td>@(l.ProductCategory?.ToString() ?? "—")</td>
                                <td class="text-end">@l.WeightKg.ToString("N2")</td>
                                <td class="text-end">@l.PricePerKg.ToString("N4")</td>
                                <td class="text-end">@l.Amount.ToString("N2")</td>
                                <td><small class="text-muted">@(l.EvidenceType ?? "—")</small></td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light fw-semibold">
                        <tr>
                            <td colspan="5" class="text-end">Total líneas</td>
                            <td class="text-end">@_detail.Lines.Sum(l => l.Amount).ToString("N2")</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            }
        </div>
    </div>

    @* ── Acciones ──────────────────────────────────────────────────────────── *@
    @if (CanActOnSettlement)
    {
        <div class="d-flex gap-2 mt-4 flex-wrap">
            @if (_detail.Status == "Pending" && CurrentUser.IsInAnyProfile(
                ProfileConstants.Scrap, ProfileConstants.Admin))
            {
                <button class="btn btn-success" @onclick="ApproveAsync" disabled="@_busy">
                    @if (_busy && _action == "approve")
                    { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-check-circle me-1"></i>Aprobar
                </button>
                <button class="btn btn-danger" @onclick="() => _showRejectModal = true"
                        disabled="@_busy">
                    <i class="bi bi-x-circle me-1"></i>Rechazar
                </button>
                <button class="btn btn-outline-secondary" @onclick="RecalculateAsync" disabled="@_busy">
                    @if (_busy && _action == "recalc")
                    { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-arrow-clockwise me-1"></i>Recalcular
                </button>
            }
        </div>
    }
}

@* ── Modal rechazo ──────────────────────────────────────────────────────────── *@
@if (_showRejectModal)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Rechazar liquidación</h5>
                    <button class="btn-close" @onclick="() => _showRejectModal = false"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Motivo del rechazo <span class="text-danger">*</span></label>
                    <textarea class="form-control" rows="3" @bind="_rejectReason"
                              placeholder="Indique el motivo…"></textarea>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _showRejectModal = false">
                        Cancelar
                    </button>
                    <button class="btn btn-danger" @onclick="RejectAsync"
                            disabled="@(string.IsNullOrWhiteSpace(_rejectReason) || _busy)">
                        Rechazar
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private SettlementDetailDto? _detail;
    private bool    _loading = true;
    private bool    _busy;
    private string  _action = "";
    private string? _errorMessage;
    private string? _successMessage;
    private bool    _showRejectModal;
    private string  _rejectReason = "";

    private bool CanActOnSettlement =>
        _detail?.Status == "Pending" &&
        CurrentUser.IsInAnyProfile(ProfileConstants.Scrap, ProfileConstants.Admin);

    protected override async Task OnInitializedAsync()
        => await LoadDetailAsync();

    private async Task LoadDetailAsync()
    {
        _loading = true;
        _detail  = await Mediator.Send(new GetSettlementByIdQuery(Id));
        _loading = false;
    }

    private async Task ApproveAsync()
    {
        _action  = "approve";
        _busy    = true;
        _errorMessage   = null;
        _successMessage = null;
        try
        {
            await Mediator.Send(new ApproveSettlementCommand(Id));
            _successMessage = "Liquidación aprobada correctamente.";
            await LoadDetailAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _busy = false; }
    }

    private async Task RejectAsync()
    {
        _action         = "reject";
        _busy           = true;
        _showRejectModal = false;
        _errorMessage   = null;
        _successMessage = null;
        try
        {
            await Mediator.Send(new RejectSettlementCommand(Id, _rejectReason));
            _successMessage = "Liquidación rechazada.";
            _rejectReason  = "";
            await LoadDetailAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _busy = false; }
    }

    private async Task RecalculateAsync()
    {
        _action         = "recalc";
        _busy           = true;
        _errorMessage   = null;
        _successMessage = null;
        try
        {
            var newId = await Mediator.Send(new RecalculateSettlementCommand(Id));
            // El recálculo crea una nueva entidad; navegamos a ella si el Id cambió
            if (newId != Id && newId != Guid.Empty)
                Nav.NavigateTo($"/settlements/{newId}");
            else
            {
                _successMessage = "Liquidación recalculada correctamente.";
                await LoadDetailAsync();
            }
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _busy = false; }
    }

    private static string StatusBadgeClass(string status) => status switch
    {
        "Pending"  => "bg-warning text-dark",
        "Approved" => "bg-success",
        "Rejected" => "bg-danger",
        _          => "bg-secondary"
    };

    private static string StatusLabel(string status) => status switch
    {
        "Pending"  => "Pendiente",
        "Approved" => "Aprobado",
        "Rejected" => "Rechazado",
        _          => status
    };
}
