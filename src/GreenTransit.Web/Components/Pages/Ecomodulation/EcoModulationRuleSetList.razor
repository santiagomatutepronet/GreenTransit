@using Radzen
@using Radzen.Blazor
@page "/ecomodulation-rule-sets"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.Ecomodulation.Commands
@using GreenTransit.Application.Features.Ecomodulation.DTOs
@using GreenTransit.Application.Features.Ecomodulation.Queries
@using GreenTransit.Application.Features.Entities.DTOs
@using GreenTransit.Application.Features.Entities.Queries
@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Domain.Authorization
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator              Mediator
@inject ICurrentUserService    CurrentUser
@inject IPagePermissionService PagePermissions
@inject IJSRuntime             JS

<PageTitle>Conjuntos de Reglas de Ecomodulación</PageTitle>

<div class="page-header">
    <div class="page-header-info">
        <h1 class="page-title">
            <i class="bi bi-sliders me-2 text-success"></i>Reglas de Ecomodulación
        </h1>
        <p class="page-subtitle text-muted small mb-0">
            Conjuntos versionados de criterios y ajustes de tarifas por categoría de producto
        </p>
    </div>
    <div class="page-header-actions">
        @if (_canWrite)
        {
            <button class="btn btn-primary btn-sm" @onclick="OpenCreate">
                <i class="bi bi-plus-lg me-1"></i>Nuevo conjunto
            </button>
        }
    </div>
</div>

@if (_loading)
{
    <LoadingSpinner />
}
else
{
    <div class="row g-3">

        @* ── Lista de conjuntos ─────────────────────────────────────────── *@
        <div class="col-12 col-lg-5">
            <div class="card h-100">
                <div class="card-header py-2 small fw-semibold">Conjuntos de reglas</div>
                <div class="card-body p-0">
                    @if (_page is null || _page.Items.Count == 0)
                    {
                        <div class="text-center text-muted py-4 small">
                            Sin conjuntos registrados.
                        </div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var rs in _page.Items)
                            {
                                <li class="list-group-item list-group-item-action py-2 px-3
                                           @(_selectedId == rs.Id ? "active" : "")"
                                    @onclick="() => SelectAsync(rs.Id)">
                                    <div class="d-flex align-items-start gap-2">
                                        <div class="flex-grow-1">
                                            <div class="fw-semibold small">@rs.RuleSetName</div>
                                            <div class="text-muted" style="font-size:.72rem;">
                                                v@rs.Version &middot; @rs.ValidFrom.ToString("dd/MM/yyyy")
                                                @(rs.ValidTo.HasValue ? $" – {rs.ValidTo.Value:dd/MM/yyyy}" : "")
                                            </div>
                                            <div class="text-muted" style="font-size:.72rem;">
                                                @rs.RuleCount regla(s)
                                            </div>
                                        </div>
                                        <span class="badge @StatusBadge(rs.Status)">@rs.Status</span>
                                    </div>
                                    @if (_canWrite)
                                    {
                                        <div class="mt-1 d-flex gap-1 flex-wrap">
                                            @if (rs.Status != "Active")
                                            {
                                                <button class="btn btn-outline-success btn-sm py-0 px-2"
                                                        style="font-size:.72rem;"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => ConfirmActivate(rs)">
                                                    <i class="bi bi-check-circle me-1"></i>Activar
                                                </button>
                                            }
                                            <button class="btn btn-outline-secondary btn-sm py-0 px-2"
                                                    style="font-size:.72rem;"
                                                    @onclick:stopPropagation="true"
                                                    @onclick="() => OpenEdit(rs)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            @if (rs.Status != "Active")
                                            {
                                                <button class="btn btn-outline-danger btn-sm py-0 px-2"
                                                        style="font-size:.72rem;"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => ConfirmDelete(rs)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        @* ── Panel lateral: detalle de reglas ──────────────────────────── *@
        <div class="col-12 col-lg-7">
            @if (_detail is null)
            {
                <div class="card h-100 d-flex align-items-center justify-content-center text-muted">
                    <div class="py-5 small">
                        <i class="bi bi-arrow-left me-2"></i>Selecciona un conjunto para ver sus reglas
                    </div>
                </div>
            }
            else
            {
                <div class="card h-100">
                    <div class="card-header py-2 d-flex justify-content-between align-items-center">
                        <span class="fw-semibold small">
                            @_detail.RuleSetName — v@_detail.Version
                            <span class="badge @StatusBadge(_detail.Status) ms-2">@_detail.Status</span>
                        </span>
                        <span class="text-muted small">
                            @_detail.ValidFrom.ToString("dd/MM/yyyy")
                            @(_detail.ValidTo.HasValue ? $" – {_detail.ValidTo.Value:dd/MM/yyyy}" : "")
                        </span>
                    </div>
                    @if (_detail.PublisherName is not null)
                    {
                        <div class="card-body border-bottom py-2 small text-muted">
                            <i class="bi bi-building me-1"></i>@_detail.PublisherName
                            @if (_detail.PublisherNationalId is not null)
                            { <span class="ms-2">NIF: @_detail.PublisherNationalId</span> }
                            @if (_detail.PublisherCenterCode is not null)
                            { <span class="ms-2">Centro: @_detail.PublisherCenterCode</span> }
                        </div>
                    }
                    <div class="card-body p-0" style="overflow-y:auto; max-height:520px;">
                        @if (_detail.Rules.Count == 0)
                        {
                            <div class="text-center text-muted py-4 small">Sin reglas definidas.</div>
                        }
                        else
                        {
                            <RadzenDataGrid TItem="EcoModulationRuleDto"
                                            Data="@_detail.Rules"
                                            AllowSorting="true"
                                            EmptyText="Sin reglas."
                                            Style="border:none;">
                                <Columns>
                                    <RadzenDataGridColumn TItem="EcoModulationRuleDto"
                                                          Property="RuleCode" Title="Código" Width="130px" />
                                    <RadzenDataGridColumn TItem="EcoModulationRuleDto"
                                                          Property="ProductCategory" Title="Cat." Width="60px">
                                        <Template Context="r">@(r.ProductCategory?.ToString() ?? "—")</Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="EcoModulationRuleDto"
                                                          Property="FeeImpactType" Title="Tipo impacto" Width="120px">
                                        <Template Context="r">
                                            <span class="badge @ImpactBadge(r.FeeImpactType)">@r.FeeImpactType</span>
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="EcoModulationRuleDto"
                                                          Property="FeeImpactValue" Title="Valor (%)" Width="90px"
                                                          TextAlign="TextAlign.Right">
                                        <Template Context="r">
                                            <span class="@(r.FeeImpactValue < 0 ? "text-success" : r.FeeImpactValue > 0 ? "text-danger" : "text-muted")">
                                                @r.FeeImpactValue.ToString("+0.##;-0.##;0")%
                                            </span>
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="EcoModulationRuleDto"
                                                          Property="CriteriaJson" Title="Criterios (JSON)">
                                        <Template Context="r">
                                            <code style="font-size:.72rem;word-break:break-all;">@r.CriteriaJson</code>
                                        </Template>
                                    </RadzenDataGridColumn>
                                </Columns>
                            </RadzenDataGrid>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    @* ── Paginación ─────────────────────────────────────────────────────── *@
    @if (_page is { TotalCount: > 0 })
    {
        <div class="d-flex justify-content-end align-items-center gap-2 mt-2">
            <small class="text-muted">@_page.TotalCount resultado(s)</small>
            <button class="btn btn-ghost btn-sm" disabled="@(_page.PageNumber <= 1)"
                    @onclick="() => ChangePage(_page.PageNumber - 1)">
                <i class="bi bi-chevron-left"></i>
            </button>
            <small>@_page.PageNumber / @_page.TotalPages</small>
            <button class="btn btn-ghost btn-sm" disabled="@(_page.PageNumber >= _page.TotalPages)"
                    @onclick="() => ChangePage(_page.PageNumber + 1)">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>
    }
}

@* ── Modal de alta / edición ─────────────────────────────────────────────────── *@
@if (_showForm)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.55);z-index:9999;">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-xl" style="max-width:95vw;width:95vw;">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(_editId.HasValue ? "Editar conjunto de reglas" : "Nuevo conjunto de reglas")
                    </h5>
                    <button class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">

                    @* Cabecera *@
                    <h6 class="fw-semibold mb-3">Datos del conjunto</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label">Nombre <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="_form.RuleSetName" maxlength="200" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Versión <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="_form.Version" maxlength="50" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Estado</label>
                            <input class="form-control" readonly value="@(_editId.HasValue ? _form.Status : "Inactive")" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Válido desde <span class="text-danger">*</span></label>
                            <input type="date" class="form-control"
                                   value="@_form.ValidFrom.ToString("yyyy-MM-dd")"
                                   @onchange="e => _form.ValidFrom = ParseDateTime(e.Value?.ToString()) ?? DateTime.Today" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Válido hasta</label>
                            <input type="date" class="form-control"
                                   value="@(_form.ValidTo?.ToString("yyyy-MM-dd") ?? "")"
                                   @onchange="e => _form.ValidTo = ParseDateTime(e.Value?.ToString())" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Entidad publicadora (SCRAP)</label>
                            <select class="form-select" value="@_form.PublisherName"
                                    @onchange="OnPublisherChanged">
                                <option value="">— Seleccionar entidad —</option>
                                @foreach (var e in _scrapEntities)
                                {
                                    <option value="@e.Name">@e.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">NIF publicador</label>
                            <input type="text" class="form-control" readonly
                                   value="@_form.PublisherNationalId" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Código de centro</label>
                            <input type="text" class="form-control" readonly
                                   value="@_form.PublisherCenterCode" />
                        </div>
                    </div>

                    @* Reglas *@
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="fw-semibold mb-0">Reglas <span class="text-danger">*</span></h6>
                        <button class="btn btn-outline-primary btn-sm" @onclick="AddRule">
                            <i class="bi bi-plus me-1"></i>Añadir regla
                        </button>
                    </div>

                    @if (_form.Rules.Count == 0)
                    {
                        <div class="alert alert-warning py-2 small">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Añade al menos una regla antes de guardar.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="min-width:130px">Código <span class="text-danger">*</span></th>
                                        <th style="width:130px">Cat. prod.</th>
                                        <th style="min-width:220px">Criterios JSON <span class="text-danger">*</span></th>
                                        <th style="width:130px">Tipo impacto <span class="text-danger">*</span></th>
                                        <th style="width:100px">Valor (%)</th>
                                        <th style="width:48px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < _form.Rules.Count; i++)
                                    {
                                        var idx = i;
                                        var rule = _form.Rules[idx];
                                        <tr>
                                            <td>
                                                <input type="text" class="form-control form-control-sm"
                                                       value="@rule.RuleCode" maxlength="64"
                                                       @onchange="e => rule.RuleCode = e.Value?.ToString() ?? string.Empty" />
                                            </td>
                                            <td>
                                                <select class="form-select form-select-sm"
                                                        value="@rule.ProductCategory"
                                                        @onchange="e => rule.ProductCategory = ParseInt(e.Value?.ToString())">
                                                    <option value="">—</option>
                                                    @foreach (var cat in ProductCategories)
                                                    {
                                                        <option value="@cat.Id">@cat.Name</option>
                                                    }
                                                </select>
                                            </td>
                                            <td>
                                                <input type="text" class="form-control form-control-sm font-monospace"
                                                       value="@rule.CriteriaJson"
                                                       @onchange="e => rule.CriteriaJson = e.Value?.ToString() ?? string.Empty" />
                                            </td>
                                            <td>
                                                <select class="form-select form-select-sm"
                                                        value="@rule.FeeImpactType"
                                                        @onchange="e => rule.FeeImpactType = e.Value?.ToString() ?? string.Empty">
                                                    <option value="">— Tipo —</option>
                                                    @foreach (var t in FeeImpactTypes)
                                                    {
                                                        <option value="@t">@t</option>
                                                    }
                                                </select>
                                            </td>
                                            <td>
                                                <input type="number" class="form-control form-control-sm"
                                                       @bind="rule.FeeImpactValue"
                                                       @bind:culture="System.Globalization.CultureInfo.InvariantCulture"
                                                       step="0.01" />
                                            </td>
                                            <td class="text-center">
                                                <button class="btn btn-outline-danger btn-sm py-0 px-1"
                                                        @onclick="() => RemoveRule(idx)" title="Eliminar">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_formError))
                    {
                        <div class="alert alert-danger mt-3">@_formError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="CloseForm">Cancelar</button>
                    <button class="btn btn-primary btn-sm" @onclick="SaveAsync" disabled="@_saving">
                        @if (_saving)
                        { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Modal confirmación activar ──────────────────────────────────────────────── *@
@if (_activateTarget is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Activar conjunto</h5>
                    <button class="btn-close" @onclick="() => _activateTarget = null"></button>
                </div>
                <div class="modal-body">
                    ¿Activar <strong>@_activateTarget.RuleSetName</strong>?
                    El resto de conjuntos activos pasarán a <em>Inactive</em>.
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="() => _activateTarget = null">Cancelar</button>
                    <button class="btn btn-success btn-sm" @onclick="ActivateAsync">Activar</button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Modal confirmación borrado ──────────────────────────────────────────────── *@
@if (_deleteTarget is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar eliminación</h5>
                    <button class="btn-close" @onclick="() => _deleteTarget = null"></button>
                </div>
                <div class="modal-body">
                    ¿Eliminar el conjunto <strong>@_deleteTarget.RuleSetName</strong>?
                    Esta acción no se puede deshacer y eliminará también sus reglas.
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="() => _deleteTarget = null">Cancelar</button>
                    <button class="btn btn-danger btn-sm" @onclick="DeleteAsync">Eliminar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ── Estado ────────────────────────────────────────────────────────────────
    private GreenTransit.Application.Common.Models.PaginatedResult<EcoModulationRuleSetDto>? _page;
    private EcoModulationRuleSetDetailDto? _detail;
    private Guid? _selectedId;
    private bool  _loading  = true;
    private bool  _canWrite;
    private int   _currentPage = 1;

    // ── Formulario ────────────────────────────────────────────────────────────
    private bool    _showForm  = false;
    private bool    _saving    = false;
    private string? _formError;
    private Guid?   _editId;
    private FormModel _form = new();

    // ── Confirmaciones ────────────────────────────────────────────────────────
    private EcoModulationRuleSetDto? _activateTarget;
    private EcoModulationRuleSetDto? _deleteTarget;

    // ── Catálogos estáticos ───────────────────────────────────────────────────
    private static readonly string[] FeeImpactTypes = ["None", "Reduction", "Surcharge"];
    private static readonly (int Id, string Name)[] ProductCategories =
    [
        (1, "Envases"),
        (2, "RAEE"),
        (3, "Municipal"),
        (4, "Metales"),
        (5, "Construcción")
    ];

    // ── Entidades SCRAP para selector ─────────────────────────────────────────
    private IReadOnlyList<EntitySelectorDto> _scrapEntities = [];

    protected override async Task OnInitializedAsync()
    {
        _canWrite      = await PagePermissions.CanWriteRouteAsync("/ecomodulation-rule-sets");
        _scrapEntities = await Mediator.Send(new GetEntitiesForSelectorQuery([EntityRoles.SCRAP]));
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _page    = await Mediator.Send(new GetEcoModulationRuleSetsQuery(PageNumber: _currentPage));
        _loading = false;
    }

    private async Task SelectAsync(Guid id)
    {
        _selectedId = id;
        _detail     = await Mediator.Send(new GetEcoModulationRuleSetByIdQuery(id));
    }

    private async Task ChangePage(int page)
    {
        _currentPage = page;
        await LoadAsync();
    }

    // ── CRUD ──────────────────────────────────────────────────────────────────

    private async Task ShowModalAsync()
    {
        _showForm = true;
        await JS.InvokeVoidAsync("eval",
            "document.querySelector('.app-shell')?.style.setProperty('overflow','visible','important');"
            + "document.body.style.overflow='hidden';");
    }

    private async Task HideModalAsync()
    {
        _showForm = false;
        await JS.InvokeVoidAsync("eval",
            "document.querySelector('.app-shell')?.style.removeProperty('overflow');"
            + "document.body.style.overflow='';");
    }

    private void OpenCreate()
    {
        _editId    = null;
        _form      = new FormModel { ValidFrom = DateTime.Today, Rules = [] };
        _formError = null;
        _ = ShowModalAsync();
    }

    private async Task OpenEdit(EcoModulationRuleSetDto rs)
    {
        _editId    = rs.Id;
        _formError = null;

        // Cargar detalle si no está ya cargado
        if (_detail?.Id != rs.Id)
            _detail = await Mediator.Send(new GetEcoModulationRuleSetByIdQuery(rs.Id));

        _form = new FormModel
        {
            RuleSetName         = rs.RuleSetName,
            Version             = rs.Version,
            Status              = rs.Status,
            ValidFrom           = rs.ValidFrom,
            ValidTo             = rs.ValidTo,
            PublisherName       = rs.PublisherName,
            PublisherNationalId = rs.PublisherNationalId,
            PublisherCenterCode = rs.PublisherCenterCode,
            Rules               = _detail?.Rules.Select(r => new RuleFormRow
                {
                    RuleCode        = r.RuleCode,
                    ProductCategory = r.ProductCategory,
                    CriteriaJson    = r.CriteriaJson,
                    FeeImpactType   = r.FeeImpactType,
                    FeeImpactValue  = r.FeeImpactValue
                }).ToList() ?? []
        };

        await ShowModalAsync();
    }

    private void CloseForm()
    {
        _formError = null;
        _ = HideModalAsync();
    }

    private void AddRule() =>
        _form.Rules.Add(new RuleFormRow { CriteriaJson = "{}", FeeImpactType = "None" });

    private void RemoveRule(int idx) => _form.Rules.RemoveAt(idx);

    private async Task SaveAsync()
    {
        _formError = null;
        if (string.IsNullOrWhiteSpace(_form.RuleSetName) || string.IsNullOrWhiteSpace(_form.Version))
        {
            _formError = "El nombre y la versión son obligatorios.";
            return;
        }
        if (_form.Rules.Count == 0)
        {
            _formError = "Añade al menos una regla.";
            return;
        }

        // PublisherNationalId / CenterCode se mantienen sincronizados por OnPublisherChanged
        var lines = _form.Rules.Select(r => new EcoModulationRuleLineDto(
            r.RuleCode,
            r.ProductCategory,
            r.CriteriaJson,
            r.FeeImpactType,
            r.FeeImpactValue)).ToList();

        _saving = true;
        try
        {
            if (_editId.HasValue)
            {
                await Mediator.Send(new UpdateEcoModulationRuleSetCommand(
                    _editId.Value,
                    _form.RuleSetName,
                    _form.Version,
                    _form.ValidFrom,
                    _form.ValidTo,
                    _form.PublisherName,
                    _form.PublisherNationalId,
                    _form.PublisherCenterCode,
                    lines));
            }
            else
            {
                await Mediator.Send(new CreateEcoModulationRuleSetCommand(
                    _form.RuleSetName,
                    _form.Version,
                    _form.ValidFrom,
                    _form.ValidTo,
                    _form.PublisherName,
                    _form.PublisherNationalId,
                    _form.PublisherCenterCode,
                    lines));
            }

            var savedId = _editId;
            CloseForm();
            await LoadAsync();
            // Auto-seleccionar el ítem guardado para que el usuario vea el resultado
            var targetId = savedId ?? _page?.Items.OrderByDescending(x => x.CreatedAt).FirstOrDefault()?.Id;
            if (targetId.HasValue)
                await SelectAsync(targetId.Value);
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void OnPublisherChanged(ChangeEventArgs e)
    {
        var name = e.Value?.ToString() ?? string.Empty;
        var entity = _scrapEntities.FirstOrDefault(x => x.Name == name);
        _form.PublisherName       = string.IsNullOrEmpty(name) ? null : name;
        _form.PublisherNationalId = entity?.NationalId;
        _form.PublisherCenterCode = entity?.CenterCode;
    }

    private void ConfirmActivate(EcoModulationRuleSetDto rs) => _activateTarget = rs;

    private async Task ActivateAsync()
    {
        if (_activateTarget is null) return;
        await Mediator.Send(new ActivateEcoModulationRuleSetCommand(_activateTarget.Id));
        _activateTarget = null;
        if (_selectedId.HasValue)
            _detail = await Mediator.Send(new GetEcoModulationRuleSetByIdQuery(_selectedId.Value));
        await LoadAsync();
    }

    private void ConfirmDelete(EcoModulationRuleSetDto rs) => _deleteTarget = rs;

    private async Task DeleteAsync()
    {
        if (_deleteTarget is null) return;
        try
        {
            await Mediator.Send(new DeleteEcoModulationRuleSetCommand(_deleteTarget.Id));
        }
        catch { /* log */ }
        _deleteTarget = null;
        if (_selectedId == _deleteTarget?.Id) { _selectedId = null; _detail = null; }
        await LoadAsync();
    }

    // ── Helpers visuales ─────────────────────────────────────────────────────

    private static string StatusBadge(string status) => status switch
    {
        "Active"   => "bg-success",
        "Inactive" => "bg-secondary",
        _          => "bg-light text-dark"
    };

    private static string ImpactBadge(string type) => type switch
    {
        "Reduction" => "bg-success",
        "Surcharge" => "bg-danger",
        _           => "bg-secondary"
    };

    private static DateTime? ParseDateTime(string? val) =>
        DateTime.TryParse(val, out var d) ? d : null;

    private static int? ParseInt(string? val) =>
        int.TryParse(val, out var n) ? n : null;

    private static decimal ParseDecimal(string? val) =>
        decimal.TryParse(val, System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var d) ? d : 0m;

