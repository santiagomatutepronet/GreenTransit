@page "/mobility/coordinator-analysis"
@attribute [Authorize(Policy = PolicyConstants.CanViewMobilityCoordinatorAnalysis)]
@rendermode InteractiveServer

@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Application.Features.Entities.DTOs
@using GreenTransit.Application.Features.Entities.Queries
@using GreenTransit.Application.Features.Geography.DTOs
@using GreenTransit.Application.Features.Geography.Queries
@using GreenTransit.Application.Features.Mobility.DTOs
@using GreenTransit.Application.Features.Mobility.Queries
@using GreenTransit.Domain.Authorization
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using System.Globalization

@inject IMediator            Mediator
@inject ICurrentUserService  CurrentUser
@inject ILogger<CoordinatorAnalysis> Logger

<PageTitle>Impacto en Movilidad — Coordinador — GreenTransit</PageTitle>

<div class="page-header mb-4">
    <div class="page-header-info">
        <h1 class="page-title">
            <i class="bi bi-diagram-3-fill me-2"></i>Análisis de Impacto en Movilidad
        </h1>
        <p class="text-muted mb-0">
            Panel del Coordinador · Recogidas RAEE vs movilidad urbana ·
            @(_filterMonth.HasValue
                ? new DateTime(_filterYear, _filterMonth.Value, 1).ToString("MMMM yyyy", _es)
                : _filterYear.ToString())
        </p>
    </div>
    <div class="page-header-actions">
        <button class="btn btn-outline-neutral btn-sm" @onclick="RefreshAsync" disabled="@_loading">
            <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
        </button>
    </div>
</div>

@* ── Filtros ──────────────────────────────────────────────────────────────── *@
<div class="filter-bar mb-4">
    <div class="filter-group">
        <label>Año</label>
        <select class="form-select form-select-sm" @bind="_filterYear" @bind:after="RefreshAsync">
            @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
            { <option value="@y">@y</option> }
        </select>
    </div>
    <div class="filter-group">
        <label>Mes</label>
        <select class="form-select form-select-sm" @bind="_filterMonth" @bind:after="RefreshAsync">
            <option value="">Todos</option>
            @for (int m = 1; m <= 12; m++)
            { <option value="@m">@(new DateTime(2000, m, 1).ToString("MMMM", _es))</option> }
        </select>
    </div>
    <div class="filter-group">
        <label>Flujo residuo</label>
        <select class="form-select form-select-sm" @bind="_filterWasteStream" @bind:after="RefreshAsync">
            <option value="">Todos</option>
            <option value="RAEE">RAEE</option>
            <option value="PILAS">Pilas</option>
            <option value="NEUMATICOS">Neumáticos</option>
            <option value="NFU">NFU</option>
            <option value="VFU">VFU</option>
            <option value="OIL">Aceite</option>
        </select>
    </div>
    @if (_scraps.Count > 0)
    {
        <div class="filter-group">
            <label>SCRAP</label>
            <select class="form-select form-select-sm" @bind="_filterScrapId" @bind:after="RefreshAsync">
                <option value="">Todos</option>
                @foreach (var s in _scraps)
                { <option value="@s.Id">@s.Name</option> }
            </select>
        </div>
    }
    <div class="filter-group">
        <label>Provincia</label>
        <select class="form-select form-select-sm" @bind="_filterProvinceId" @bind:after="OnProvinceChangedAsync">
            <option value="0">Todas</option>
            @foreach (var p in _provinces)
            { <option value="@p.Id">@p.Name</option> }
        </select>
    </div>
    <div class="filter-group">
        <label>Municipio</label>
        <select class="form-select form-select-sm" @bind="_filterMunicipalityCode" @bind:after="RefreshAsync"
                disabled="@(_filterProvinceId == 0)">
            <option value="">Todos</option>
            @foreach (var m in _municipalities)
            { <option value="@m.Code">@m.Name</option> }
        </select>
    </div>
</div>

@if (_loading)
{
    <LoadingSpinner Message="Cargando análisis de movilidad…" />
}
else if (_data is not null)
{
    @* ── KPI summary cards ─────────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <p class="kpi-label">% Recogidas en hora pico</p>
                    <p class="kpi-value @(_data.PeakHourPercent > 30 ? "text-danger" : "text-success")">
                        @_data.PeakHourPercent.ToString("F1")%
                    </p>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <p class="kpi-label">Municipios analizados</p>
                    <p class="kpi-value">@_data.ConflictIndex.Count</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <p class="kpi-label">Municipios en alerta (índice &gt;70)</p>
                    <p class="kpi-value text-danger">
                        @_data.ConflictIndex.Count(m => m.TrafficLight == "Red")
                    </p>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <p class="kpi-label">Recomendaciones generadas</p>
                    <p class="kpi-value text-warning">@_data.Recommendations.Count</p>
                </div>
            </div>
        </div>
    </div>

    @* ── Heatmap semanal ───────────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-calendar3-week me-1"></i>Distribución semanal de recogidas vs franjas pico
                </div>
                <div class="card-body p-0 p-md-3">
                    @if (_data.WeeklyHeatmap.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-0" style="font-size:0.78rem">
                                <thead class="table-light">
                                    <tr>
                                        <th>Hora</th>
                                        @foreach (var d in new[] { "Lun","Mar","Mié","Jue","Vie","Sáb","Dom" }) { <th class="text-center">@d</th> }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var h in _data.WeeklyHeatmap.Select(c => c.Hour).Distinct().OrderBy(hh => hh))
                                    {
                                        var maxC = _data.WeeklyHeatmap.Max(c => c.PickupCount);
                                        <tr>
                                            <td>@h:00</td>
                                            @for (int d = 0; d < 7; d++)
                                            {
                                                var cell = _data.WeeklyHeatmap.FirstOrDefault(c => c.DayOfWeek == d && c.Hour == h);
                                                var pct  = cell is not null && maxC > 0 ? (int)((double)cell.PickupCount / maxC * 100) : 0;
                                                var bg   = (pct / 100.0).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                                                var fg   = pct > 50 ? "white" : "inherit";
                                                <td class="text-center" style="background-color:rgba(25,135,84,@bg);color:@fg">
                                                    @(cell?.PickupCount > 0 ? cell.PickupCount.ToString() : "")
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4">Sin datos de frecuencia semanal.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ── Tabla índice de conflicto ─────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <span><i class="bi bi-table me-1"></i>Índice de conflicto logístico-movilidad por municipio</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Municipio</th>
                                    <th>Provincia</th>
                                    <th class="text-end">Recogidas</th>
                                    <th class="text-end">% Hora pico</th>
                                    <th class="text-end">% Fuera DUM</th>
                                    <th class="text-end">Incidencias</th>
                                    <th class="text-end">Índice</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in _data.ConflictIndex)
                                {
                                    <tr>
                                        <td>@(m.MunicipalityName ?? m.MunicipalityCode)</td>
                                        <td>@(m.ProvinceName ?? m.ProvinceCode ?? "—")</td>
                                        <td class="text-end">@m.TotalPickups</td>
                                        <td class="text-end">@m.PeakHourPercent.ToString("F1")%</td>
                                        <td class="text-end">@m.OutsideDumWindowPercent.ToString("F1")%</td>
                                        <td class="text-end">@m.LogisticsIncidents</td>
                                        <td class="text-end fw-semibold">@m.ConflictIndex.ToString("F0")</td>
                                        <td>
                                            <span class="badge @TrafficLightBadge(m.TrafficLight)">
                                                @TrafficLightLabel(m.TrafficLight)
                                            </span>
                                        </td>
                                    </tr>
                                }
                                @if (!_data.ConflictIndex.Any())
                                {
                                    <tr><td colspan="8" class="text-center text-muted py-3">Sin datos para el periodo seleccionado.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Recomendaciones automáticas ───────────────────────────────────────── *@
    @if (_data.Recommendations.Any())
    {
        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-lightbulb-fill me-1 text-warning"></i>Recomendaciones automáticas
                    </div>
                    <div class="card-body">
                        @foreach (var rec in _data.Recommendations)
                        {
                            <div class="alert @(rec.Severity == "Critical" ? "alert-danger" : "alert-warning") py-2 mb-2">
                                <i class="bi @(rec.Severity == "Critical" ? "bi-exclamation-octagon-fill" : "bi-exclamation-triangle-fill") me-2"></i>
                                @rec.Message
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── Comparativa pre/post ─────────────────────────────────────────────── *@
    @if (_data.EfficiencyComparison is not null)
    {
        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-bar-chart-steps me-1"></i>Comparativa de eficiencia
                        (@_data.EfficiencyComparison.PeriodA vs @_data.EfficiencyComparison.PeriodB)
                    </div>
                    <div class="card-body">
                        @if (_comparisonItems.Any())
                        {
                            <AppChart Height="250" ShowLegend="true" CategoryAxisTitle="Métrica" ValueAxisTitle="Valor">
                                <RadzenBarSeries Data="@_comparisonItems" CategoryProperty="Metric" ValueProperty="ValueA"
                                                Title="@(_data.EfficiencyComparison?.PeriodA ?? "A")" Fill="@ChartPalette.GetColor(0)" />
                                <RadzenBarSeries Data="@_comparisonItems" CategoryProperty="Metric" ValueProperty="ValueB"
                                                Title="@(_data.EfficiencyComparison?.PeriodB ?? "B")" Fill="@ChartPalette.GetColor(1)" />
                            </AppChart>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private record ComparisonItem(string Metric, double ValueA, double ValueB);

    private MobilityCoordinatorAnalysisDto? _data;
    private List<ComparisonItem> _comparisonItems = [];
    private bool   _loading           = true;
    private int    _filterYear        = DateTime.Now.Year;
    private int?   _filterMonth       = DateTime.Now.Month;
    private string _filterWasteStream = string.Empty;
    private Guid?  _filterScrapId;

    private IReadOnlyList<EntitySelectorDto> _scraps = [];

    // Filtros geográficos en cascada
    private int    _filterProvinceId       = 0;
    private string _filterProvinceCode     = "";
    private string _filterMunicipalityCode = "";

    private IReadOnlyList<ProvinceDto>     _provinces      = [];
    private IReadOnlyList<MunicipalityDto> _municipalities = [];

    private static readonly CultureInfo _es = new("es-ES");

    protected override async Task OnInitializedAsync()
    {
        var provList = await Mediator.Send(new GetAllProvincesQuery());
        _provinces = provList.ToList();
        await LoadScrapsAsync();
        await RefreshAsync();
    }

    private async Task LoadScrapsAsync()
    {
        // COORDINATOR: carga solo los SCRAPs de sus acuerdos a través del selector.
        // El handler de GetEntitiesForSelectorQuery no filtra por coordinador,
        // pero la query del dashboard ya restringe los datos al subconjunto correcto.
        // El desplegable muestra todos los SCRAPs del tenant para ADMIN,
        // o solo los propios para COORDINATOR (filtrado en backend al ejecutar la query).
        // Para mostrar solo los SCRAPs relevantes en UI, cargamos según perfil.
        var isAdmin = CurrentUser.IsInProfile(ProfileConstants.Admin);
        if (isAdmin)
        {
            _scraps = await Mediator.Send(new GetEntitiesForSelectorQuery([EntityRoles.SCRAP]));
        }
        else if (CurrentUser.IsInProfile(ProfileConstants.Coordinator) && CurrentUser.LinkedEntityId.HasValue)
        {
            // Obtener SCRAPs vía acuerdos del coordinador (devueltos por la query de selector con rol SCRAP,
            // pero filtrados en el handler del dashboard; aquí los obtenemos todos para el selector
            // ya que el handler de la query de movilidad aplica la restricción real).
            _scraps = await Mediator.Send(new GetEntitiesForSelectorQuery([EntityRoles.SCRAP]));
        }
    }

    private async Task OnProvinceChangedAsync()
    {
        _filterMunicipalityCode = "";
        if (_filterProvinceId > 0)
        {
            var prov = _provinces.FirstOrDefault(p => p.Id == _filterProvinceId);
            _filterProvinceCode = prov?.Code ?? "";
            var munList = await Mediator.Send(new GetMunicipalitiesByProvinceQuery(_filterProvinceId));
            _municipalities = munList.ToList();
        }
        else
        {
            _filterProvinceCode = "";
            _municipalities = [];
        }
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _data = await Mediator.Send(new GetMobilityCoordinatorAnalysisQuery(
                Year:              _filterYear,
                Month:             _filterMonth,
                IdScrap:           _filterScrapId,
                WasteStream:       _filterWasteStream,
                MunicipalityCode:  string.IsNullOrEmpty(_filterMunicipalityCode) ? null : _filterMunicipalityCode,
                ProvinceCode:      string.IsNullOrEmpty(_filterProvinceCode)     ? null : _filterProvinceCode));
            if (_data?.EfficiencyComparison is { } cmp)
            {
                _comparisonItems =
                [
                    new("Dist. media (km)",   (double)cmp.AvgDistanceKmA,   (double)cmp.AvgDistanceKmB),
                    new("Dur. media (min)",   (double)cmp.AvgDurationMinA,  (double)cmp.AvgDurationMinB),
                    new("CO₂e/t",             (double)cmp.CO2ePerTonneA,    (double)cmp.CO2ePerTonneB),
                    new("% Hora pico",        cmp.PeakHourPercentA,          cmp.PeakHourPercentB)
                ];
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error cargando análisis de movilidad coordinador");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private static string TrafficLightBadge(string light) => light switch
    {
        "Red"    => "bg-danger",
        "Orange" => "bg-warning text-dark",
        _        => "bg-success"
    };

    private static string TrafficLightLabel(string light) => light switch
    {
        "Red"    => "Crítico",
        "Orange" => "Moderado",
        _        => "Normal"
    };

}
