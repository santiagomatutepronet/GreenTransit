@page "/reporting/regulatory-compliance/dispatch-data"
@attribute [Authorize(Policy = PolicyConstants.CanViewDispatchOfficeComplianceData)]
@rendermode InteractiveServer

@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Application.Features.Entities.DTOs
@using GreenTransit.Application.Features.Entities.Queries
@using GreenTransit.Application.Features.Reporting.RegulatoryCompliance.DTOs
@using GreenTransit.Application.Features.Reporting.RegulatoryCompliance.Queries
@using GreenTransit.Domain.Authorization
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop

@inject IMediator           Mediator
@inject ICurrentUserService CurrentUser
@inject IJSRuntime          JS
@inject ILogger<DispatchOfficeComplianceData> Logger

<PageTitle>Datos de Cumplimiento — Oficina de Asignación — GreenTransit</PageTitle>

<div class="page-header mb-4">
    <div class="page-header-info">
        <h1 class="page-title">
            <i class="bi bi-database-fill-gear me-2 text-primary"></i>Datos de Cumplimiento — Oficina de Asignación
        </h1>
        <p class="text-muted mb-0">Dashboard CN-E · Visión consolidada del ecosistema para auditoría externa (AENOR Confía)</p>
        <p class="text-muted small mt-1">
            Ranking de SCRAPs, exportación para auditorías y evolución interanual de tasas regulatorias.
        </p>
    </div>
    <div class="page-header-actions">
        <button class="btn btn-outline-success btn-sm me-2" @onclick="ExportAsync" disabled="@_loading">
            <i class="bi bi-file-earmark-excel me-1"></i>Exportar XLSX
        </button>
        <button class="btn btn-outline-neutral btn-sm" @onclick="LoadAsync" disabled="@_loading">
            <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
        </button>
    </div>
</div>

@* ── Filtros ───────────────────────────────────────────────────────────────── *@
<div class="filter-bar mb-4">
    <div class="filter-group">
        <label>Año</label>
        <input type="number" class="form-control form-control-sm" style="width:100px"
               @bind="_year" @bind:after="LoadAsync" min="2020" max="2030" />
    </div>
    <div class="filter-group">
        <label>Comunidad Autónoma</label>
        <select class="form-select form-select-sm" style="width:180px" @bind="_autonomousCommunity" @bind:after="LoadAsync">
            <option value="">Todas</option>
            @foreach (var c in _filterOptions.AutonomousCommunities)
            {
                <option value="@c">@c</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Flujo</label>
        <select class="form-select form-select-sm" style="width:160px" @bind="_flowType" @bind:after="LoadAsync">
            <option value="">Todos</option>
            @foreach (var f in _filterOptions.FlowTypes)
            {
                <option value="@f">@f</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Categoría</label>
        <select class="form-select form-select-sm" style="width:160px" @bind="_category" @bind:after="LoadAsync">
            <option value="">Todas</option>
            @foreach (var cat in _filterOptions.Categories)
            {
                <option value="@cat">@cat</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>SCRAP</label>
        <select class="form-select form-select-sm" style="width:200px" @bind="_filterIdScrap" @bind:after="LoadAsync">
            <option value="">Todos los SCRAPs</option>
            @foreach (var s in _scraps)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
    </div>
</div>

@if (_loading)
{
    <div class="text-center" style="padding:3rem 0"><div class="spinner spinner-lg"></div></div>
}
else if (_data is null)
{
    <div class="alert alert-warning">No se han podido cargar los datos.</div>
}
else
{
    @* ── KPIs ─────────────────────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-2">
            <div class="card kpi-card h-100 border-success">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-recycle me-1 text-success"></i>Reciclaje Ecosistema</div>
                    <div class="kpi-value">@_data.EcosystemRecyclingPct.ToString("N1")<small class="text-muted"> %</small></div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-2">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-lightning-charge me-1 text-warning"></i>Valorización</div>
                    <div class="kpi-value">@_data.EcosystemValorizationPct.ToString("N1")<small class="text-muted"> %</small></div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-2">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-arrow-repeat me-1 text-info"></i>Reutilización</div>
                    <div class="kpi-value">@_data.EcosystemReusePct.ToString("N1")<small class="text-muted"> %</small></div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-2">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-building me-1 text-primary"></i>SCRAPs Activos</div>
                    <div class="kpi-value">@_data.ActiveScraps</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-2">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-file-earmark-text me-1 text-info"></i>Convenios Activos</div>
                    <div class="kpi-value">@_data.ActiveAgreements</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-2">
            <div class="card kpi-card h-100 border-success">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-currency-euro me-1 text-success"></i>Importe Aprobado (año)</div>
                    <div class="kpi-value">@_data.TotalApprovedAmountYear.ToString("N0") <small class="text-muted">€</small></div>
                </div>
            </div>
        </div>
    </div>

    @* ── Ranking de SCRAPs ────────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-bar-chart-fill me-2"></i>Ranking de SCRAPs por cumplimiento</div>
        <div class="card-body">
            @if (_rankingItems.Any())
            {
                <AppChart Height="300" ShowLegend="false" CategoryAxisTitle="SCRAP" ValueAxisTitle="%">
                    <RadzenBarSeries Data="@_rankingItems" CategoryProperty="Name" ValueProperty="Value"
                                     Title="Cumplimiento %" Fill="@ChartPalette.GetColor(0)" />
                </AppChart>
            }
            else
            {
                <p class="text-muted text-center pt-4">Sin datos de ranking.</p>
            }
        </div>
    </div>

    @* ── Tabla ranking ────────────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-table me-2"></i>Tabla de cumplimiento por SCRAP</div>
        <div class="card-body p-0">
            @{ var _rankRows = _data.ScrapRanking.ToList(); }
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>SCRAP</th>
                            <th class="text-end">% Cumpl.</th>
                            <th class="text-end">Objetivo (kg)</th>
                            <th class="text-end">Real (kg)</th>
                            <th class="text-end">Reciclaje %</th>
                            <th class="text-end">Valorización %</th>
                            <th class="text-end">Convenios</th>
                            <th class="text-end">Importe Aprobado</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _rankRows.Skip((_pgRanking - 1) * PageSize).Take(PageSize))
                        {
                            <tr>
                                <td>@r.ScrapName</td>
                                <td class="text-end">
                                    <span class="badge bg-@StatusBadge(r.Status)">@r.CompliancePct.ToString("N1")%</span>
                                </td>
                                <td class="text-end">@r.TargetWeightKg.ToString("N0")</td>
                                <td class="text-end">@r.RealWeightKg.ToString("N0")</td>
                                <td class="text-end">@r.RecyclingPct.ToString("N1")</td>
                                <td class="text-end">@r.ValorizationPct.ToString("N1")</td>
                                <td class="text-end">@r.ActiveAgreements</td>
                                <td class="text-end">@r.TotalApprovedAmount.ToString("N0") €</td>
                                <td><i class="bi bi-circle-fill text-@StatusColor(r.Status)"></i></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <TablePager TotalCount="_rankRows.Count" PageSize="PageSize" CurrentPage="_pgRanking"
                        CurrentPageChanged="p => _pgRanking = p" />
        </div>
    </div>

    @* ── Evolución interanual ─────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-graph-up me-2"></i>Evolución interanual de tasas regulatorias</div>
        <div class="card-body">
            @if (_trendItems.Any())
            {
                <AppChart Height="280" ShowLegend="true" CategoryAxisTitle="Año" ValueAxisTitle="%">
                    <RadzenLineSeries Data="@_trendItems" CategoryProperty="Year" ValueProperty="RecyclingPct"
                                      Title="Reciclaje %" Stroke="@ChartPalette.GetColor(0)" StrokeWidth="2" />
                    <RadzenLineSeries Data="@_trendItems" CategoryProperty="Year" ValueProperty="ValorizationPct"
                                      Title="Valorización %" Stroke="@ChartPalette.GetColor(1)" StrokeWidth="2" />
                    <RadzenLineSeries Data="@_trendItems" CategoryProperty="Year" ValueProperty="ReusePct"
                                      Title="Reutilización %" Stroke="@ChartPalette.GetColor(2)" StrokeWidth="2" />
                    <RadzenLineSeries Data="@_trendItems" CategoryProperty="Year" ValueProperty="TargetPct"
                                      Title="Objetivo Reciclaje" Stroke="@ChartPalette.GetColor(4)" StrokeWidth="1"
                                      LineType="LineType.Dashed" />
                </AppChart>
            }
            else
            {
                <p class="text-muted text-center pt-4">Sin datos interanuales.</p>
            }
        </div>
    </div>

    @* ── Mapa de calor geográfico ─────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-grid-3x3-gap-fill me-2"></i>Mapa de calor geográfico de cumplimiento</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                @{
                    var scraps = _data.GeoHeatmap.Select(g => g.ScrapName).Distinct().OrderBy(s => s).ToList();
                    var regions = _data.GeoHeatmap.Select(g => g.AutonomousCommunity).Distinct().OrderBy(r => r).ToList();
                }
                <table class="table table-sm table-bordered mb-0">
                    <thead>
                        <tr>
                            <th>Comunidad Autónoma</th>
                            @foreach (var s in scraps) { <th class="text-center" style="white-space:nowrap">@s</th> }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var region in regions)
                        {
                            <tr>
                                <td><strong>@region</strong></td>
                                @foreach (var scrap in scraps)
                                {
                                    var cell = _data.GeoHeatmap.FirstOrDefault(g => g.AutonomousCommunity == region && g.ScrapName == scrap);
                                    <td class="text-center" style="background-color:@HeatmapColor(cell?.Status)">
                                        @(cell is not null ? cell.CompliancePct.ToString("N0") + "%" : "—")
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ── Panel normativo ──────────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-journal-check me-2"></i>Cambios normativos y actualizaciones recientes</div>
        <div class="card-body p-0">
            @{ var _regChgRows = _data.RegulatoryChanges.ToList(); }
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Tipo</th><th>Descripción</th><th>Versión</th>
                            <th>Desde</th><th>Hasta</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in _regChgRows.Skip((_pgRegChanges - 1) * PageSize).Take(PageSize))
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@c.ChangeType</span></td>
                                <td>@c.Description</td>
                                <td><code>@c.Version</code></td>
                                <td>@c.ValidFrom.ToString("dd/MM/yyyy")</td>
                                <td>@(c.ValidTo?.ToString("dd/MM/yyyy") ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <TablePager TotalCount="_regChgRows.Count" PageSize="PageSize" CurrentPage="_pgRegChanges"
                        CurrentPageChanged="p => _pgRegChanges = p" />
        </div>
    </div>
}

@code {
    private record RankingItem(string Name, double Value);
    private record TrendItem(int Year, double RecyclingPct, double ValorizationPct, double ReusePct, double TargetPct);

    private const int PageSize = 15;
    private DispatchOfficeComplianceDataDto? _data;
    private List<RankingItem> _rankingItems = [];
    private List<TrendItem>   _trendItems   = [];
    private ComplianceFilterOptionsDto  _filterOptions = new([], [], [], []);
    private IReadOnlyList<EntitySelectorDto> _scraps = [];
    private bool    _loading = true;
    private bool    _initialized;
    private int     _year = DateTime.Now.Year;
    private string? _autonomousCommunity;
    private string? _flowType;
    private string? _category;
    private string? _filterIdScrap;
    private int     _pgRanking    = 1;
    private int     _pgRegChanges = 1;

    protected override async Task OnInitializedAsync()
    {
        if (_initialized) return;
        _initialized = true;
        try { _filterOptions = await Mediator.Send(new GetComplianceFilterOptionsQuery()); }
        catch (Exception ex) { Logger.LogWarning(ex, "Error cargando opciones de filtro CN-E"); }
        try { _scraps = await Mediator.Send(new GetEntitiesForSelectorQuery(new[] { EntityRoles.SCRAP })); }
        catch (Exception ex) { Logger.LogWarning(ex, "Error cargando SCRAPs CN-E"); }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading        = true;
        _pgRanking      = 1;
        _pgRegChanges   = 1;
        try
        {
            _data = await Mediator.Send(new GetDispatchOfficeComplianceDataQuery(
                _year,
                Guid.TryParse(_filterIdScrap, out var sid) ? sid : null,
                string.IsNullOrEmpty(_autonomousCommunity) ? null : _autonomousCommunity,
                string.IsNullOrEmpty(_flowType)            ? null : _flowType,
                string.IsNullOrEmpty(_category)            ? null : _category));
            _rankingItems = _data?.ScrapRanking.Select(r => new RankingItem(r.ScrapName, (double)r.CompliancePct)).ToList() ?? [];
            _trendItems   = _data?.InterannualTrend.Select(t => new TrendItem(t.Year, (double)t.RecyclingPct, (double)t.ValorizationPct, (double)t.ReusePct, (double)t.TargetRecyclingPct)).ToList() ?? [];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error cargando CN-E");
            _data = null;
        }
        finally { _loading = false; }
    }

    private async Task ExportAsync()
    {
        try
        {
            var result = await Mediator.Send(new ExportComplianceDataToExcelQuery(
                _year, "DispatchOffice", null,
                string.IsNullOrEmpty(_autonomousCommunity) ? null : _autonomousCommunity,
                string.IsNullOrEmpty(_flowType)            ? null : _flowType,
                string.IsNullOrEmpty(_category)            ? null : _category));

            var base64 = Convert.ToBase64String(result.FileContent);
            await JS.InvokeVoidAsync("downloadBase64File", base64, result.FileName, result.ContentType);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error exportando CN-E");
        }
    }

    private static string StatusColor(string status) => status switch
    {
        "GREEN"  => "success",
        "ORANGE" => "warning",
        _        => "danger"
    };

    private static string StatusBadge(string status) => status switch
    {
        "GREEN"  => "success",
        "ORANGE" => "warning text-dark",
        _        => "danger"
    };

    private static string HeatmapColor(string? status) => status switch
    {
        "GREEN"  => "#d8f3dc",
        "ORANGE" => "#fff3cd",
        "RED"    => "#f8d7da",
        _        => "transparent"
    };

    }
