@page "/reporting/regulatory-compliance/public-view"
@attribute [Authorize(Policy = PolicyConstants.CanViewPublicEntityComplianceView)]
@rendermode InteractiveServer

@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Application.Features.Entities.DTOs
@using GreenTransit.Application.Features.Entities.Queries
@using GreenTransit.Application.Features.Reporting.RegulatoryCompliance.DTOs
@using GreenTransit.Application.Features.Reporting.RegulatoryCompliance.Queries
@using GreenTransit.Domain.Authorization
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator           Mediator
@inject ICurrentUserService CurrentUser
@inject ILogger<PublicEntityComplianceView> Logger

<PageTitle>Cumplimiento Normativo — Entidad Pública — GreenTransit</PageTitle>

<div class="page-header mb-4">
    <div class="page-header-info">
        <h1 class="page-title">
            <i class="bi bi-building-check me-2 text-primary"></i>Cumplimiento Normativo — Entidad Pública
        </h1>
        <p class="text-muted mb-0">Dashboard CN-D · Servicios recibidos, liquidaciones y cumplimiento de SCRAPs en tu territorio</p>
        <p class="text-muted small mt-1">
            Monitoriza las obligaciones de los SCRAPs: toneladas recogidas, compensaciones y cumplimiento de la Ley 22/2011.
        </p>
    </div>
    <div class="page-header-actions">
        <button class="btn btn-outline-neutral btn-sm" @onclick="LoadAsync" disabled="@_loading">
            <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
        </button>
    </div>
</div>

@* ── Filtros ───────────────────────────────────────────────────────────────── *@
<div class="filter-bar mb-4">
    <div class="filter-group">
        <label>Año</label>
        <input type="number" class="form-control form-control-sm" style="width:100px"
               @bind="_year" @bind:after="LoadAsync" min="2020" max="2030" />
    </div>
    <div class="filter-group">
        <label>Mes</label>
        <select class="form-select form-select-sm" style="width:130px" @bind="_month" @bind:after="LoadAsync">
            <option value="">Todos</option>
            @for (var m = 1; m <= 12; m++) { var mo = m; <option value="@mo">@System.Globalization.CultureInfo.GetCultureInfo("es-ES").DateTimeFormat.GetMonthName(mo)</option> }
        </select>
    </div>
    <div class="filter-group">
        <label>Flujo</label>
        <select class="form-select form-select-sm" style="width:160px" @bind="_wasteStream" @bind:after="LoadAsync">
            <option value="">Todos</option>
            @foreach (var s in _filterOptions.WasteStreams)
            {
                <option value="@s">@s</option>
            }
        </select>
    </div>
    @if (CurrentUser.IsInAnyProfile("ADMIN"))
    {
        <div class="filter-group">
            <label>SCRAP</label>
            <select class="form-select form-select-sm" style="width:200px" @bind="_filterIdScrap" @bind:after="LoadAsync">
                <option value="">Todos los SCRAPs</option>
                @foreach (var s in _scraps)
                {
                    <option value="@s.Id">@s.Name</option>
                }
            </select>
        </div>
    }
</div>

@if (_loading)
{
    <div class="text-center" style="padding:3rem 0"><div class="spinner spinner-lg"></div></div>
}
else if (_data is null)
{
    <div class="alert alert-warning">No se han podido cargar los datos.</div>
}
else
{
    @* ── KPIs ─────────────────────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100 border-success">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-recycle me-1 text-success"></i>Toneladas Recogidas</div>
                    <div class="kpi-value">@_data.TotalTonnesCollected.ToString("N1") <small class="text-muted">t</small></div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-clipboard2-check me-1 text-info"></i>Servicios Completados</div>
                    <div class="kpi-value">@_data.ServicesCompleted</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-building me-1 text-primary"></i>SCRAPs Operando</div>
                    <div class="kpi-value">@_data.ScrapCount</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100 border-success">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-currency-euro me-1 text-success"></i>Compensación Recibida (año)</div>
                    <div class="kpi-value">@_data.TotalCompensatedAmount.ToString("N0") <small class="text-muted">€</small></div>
                </div>
            </div>
        </div>
    </div>

    @* ── Gráfico + donut ──────────────────────────────────────────────────── *@
    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-bar-chart-fill me-2"></i>Evolución mensual de recogidas por SCRAP</div>
                <div class="card-body">
                    @if (_monthlyItems.Any())
                    {
                        <AppChart Height="280" ShowLegend="true" CategoryAxisTitle="Mes" ValueAxisTitle="kg">
                            @{ int mIdx = 0; }
                            @foreach (var scrap in _monthlyScrapNames)
                            {
                                var s = scrap;
                                var idx = mIdx++;
                                <RadzenColumnSeries Data="@_monthlyItems.Where(x => x.ScrapName == s).ToList()"
                                                   CategoryProperty="Label" ValueProperty="WeightKg"
                                                   Title="@s" Fill="@ChartPalette.GetColor(idx)" />
                            }
                        </AppChart>
                    }
                    else
                    {
                        <p class="text-muted text-center pt-4">Sin datos mensuales.</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-pie-chart-fill me-2"></i>Toneladas por método de recolección</div>
                <div class="card-body">
                    @if (_methodItems.Any())
                    {
                        <AppChart Height="280" ShowLegend="true">
                            <RadzenDonutSeries Data="@_methodItems" CategoryProperty="Method" ValueProperty="Pct"
                                              Fills="@ChartPalette.CorporateColors" />
                        </AppChart>
                    }
                    else
                    {
                        <p class="text-muted text-center pt-4">Sin datos de métodos.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ── Cumplimiento por SCRAP ───────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-speedometer2 me-2"></i>Cumplimiento de objetivos por SCRAP en el territorio</div>
        <div class="card-body p-0">
            @{ var _scrapCmpRows = _data.ScrapCompliance.ToList(); }
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>SCRAP</th><th>Categoría</th><th>Flujo</th>
                            <th class="text-end">Objetivo (kg)</th><th class="text-end">Real (kg)</th>
                            <th>Progreso</th><th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _scrapCmpRows.Skip((_pgScrapCompliance - 1) * PageSize).Take(PageSize))
                        {
                            <tr>
                                <td>@s.ScrapName</td>
                                <td>@s.Category</td>
                                <td>@s.FlowType</td>
                                <td class="text-end">@s.TargetWeightKg.ToString("N0")</td>
                                <td class="text-end">@s.RealWeightKg.ToString("N0")</td>
                                <td style="min-width:120px">
                                    <div class="progress" style="height:8px">
                                        <div class="progress-bar bg-@StatusColor(s.Status)"
                                             style="width:@Math.Min(100m,s.CompliancePct).ToString("N0")%"></div>
                                    </div>
                                    <small>@s.CompliancePct.ToString("N1")%</small>
                                </td>
                                <td><i class="bi bi-circle-fill text-@StatusColor(s.Status)"></i></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <TablePager TotalCount="_scrapCmpRows.Count" PageSize="PageSize" CurrentPage="_pgScrapCompliance"
                        CurrentPageChanged="p => _pgScrapCompliance = p" />
        </div>
    </div>

    @* ── Liquidaciones de compensación ────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-receipt me-2"></i>Liquidaciones de compensación</div>
        <div class="card-body p-0">
            @{ var _compStlRows = _data.CompensationSettlements.ToList(); }
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>SCRAP</th><th>Nº</th><th>Año</th><th>Mes</th>
                            <th class="text-end">Base</th><th class="text-end">Ajustes</th>
                            <th class="text-end">Total</th><th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _compStlRows.Skip((_pgCompSettlements - 1) * PageSize).Take(PageSize))
                        {
                            <tr>
                                <td>@s.ScrapName</td>
                                <td><code>@s.SettlementNumber</code></td>
                                <td>@s.Year</td>
                                <td>@(s.Month > 0 ? s.Month.ToString() : "—")</td>
                                <td class="text-end">@s.BaseAmount.ToString("N2")</td>
                                <td class="text-end">@s.AdjustmentsAmount.ToString("N2")</td>
                                <td class="text-end">@s.TotalAmount.ToString("N2")</td>
                                <td><span class="badge bg-@ValidationStatusBadge(s.Status)">@s.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <TablePager TotalCount="_compStlRows.Count" PageSize="PageSize" CurrentPage="_pgCompSettlements"
                        CurrentPageChanged="p => _pgCompSettlements = p" />
        </div>
    </div>

    @* ── Incidencias ──────────────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header">
            <i class="bi bi-exclamation-triangle-fill me-2 text-warning"></i>Incidencias abiertas
            @if (_data.OpenIncidentsCount > 0)
            {
                <span class="badge bg-danger ms-2">@_data.OpenIncidentsCount</span>
            }
        </div>
        <div class="card-body p-0">
            @{ var _incRows = _data.Incidents.ToList(); }
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Tipo</th><th>Severidad</th><th>Traslado</th>
                            <th>SCRAP</th><th>Fecha apertura</th><th class="text-end">Días abierta</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var i in _incRows.Skip((_pgIncidents - 1) * PageSize).Take(PageSize))
                        {
                            <tr>
                                <td>@i.Type</td>
                                <td><span class="badge bg-@SeverityBadge(i.Severity)">@i.Severity</span></td>
                                <td>@(i.WasteMoveReference is not null ? $"→ /traceability?term={i.WasteMoveReference}" : "—")</td>
                                <td>@(i.ScrapName ?? "—")</td>
                                <td>@i.OpenedAt.ToString("dd/MM/yyyy")</td>
                                <td class="text-end">@i.DaysOpen</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <TablePager TotalCount="_incRows.Count" PageSize="PageSize" CurrentPage="_pgIncidents"
                        CurrentPageChanged="p => _pgIncidents = p" />
        </div>
    </div>
}

@code {
    private record MonthScrapItem(string Label, string ScrapName, double WeightKg);
    private record MethodItem(string Method, double Pct);

    private const int PageSize = 15;
    private PublicEntityComplianceViewDto? _data;
    private List<MonthScrapItem> _monthlyItems      = [];
    private List<string>         _monthlyScrapNames = [];
    private List<MethodItem>     _methodItems       = [];
    private ComplianceFilterOptionsDto  _filterOptions = new([], [], [], []);
    private IReadOnlyList<EntitySelectorDto> _scraps = [];
    private bool    _loading = true;
    private bool    _initialized;
    private int     _year  = DateTime.Now.Year;
    private string? _month;
    private string? _wasteStream;
    private string? _filterIdScrap;
    private int     _pgScrapCompliance  = 1;
    private int     _pgCompSettlements  = 1;
    private int     _pgIncidents        = 1;

    protected override async Task OnInitializedAsync()
    {
        if (_initialized) return;
        _initialized = true;
        try { _filterOptions = await Mediator.Send(new GetComplianceFilterOptionsQuery()); }
        catch (Exception ex) { Logger.LogWarning(ex, "Error cargando opciones de filtro CN-D"); }
        if (CurrentUser.IsInAnyProfile("ADMIN"))
        {
            try { _scraps = await Mediator.Send(new GetEntitiesForSelectorQuery(new[] { EntityRoles.SCRAP })); }
            catch (Exception ex) { Logger.LogWarning(ex, "Error cargando SCRAPs CN-D"); }
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading               = true;
        _pgScrapCompliance     = 1;
        _pgCompSettlements     = 1;
        _pgIncidents           = 1;
        try
        {
            _data = await Mediator.Send(new GetPublicEntityComplianceViewQuery(
                _year,
                string.IsNullOrEmpty(_month) ? null : int.Parse(_month),
                Guid.TryParse(_filterIdScrap, out var sid) ? sid : null,
                string.IsNullOrEmpty(_wasteStream) ? null : _wasteStream));
            _monthlyItems      = _data?.MonthlyByScrap.Select(x => new MonthScrapItem($"{x.Month:00}/{x.Year}", x.ScrapName, (double)x.WeightKg)).ToList() ?? [];
            _monthlyScrapNames = _data?.MonthlyByScrap.Select(x => x.ScrapName).Distinct().ToList() ?? [];
            _methodItems       = _data?.CollectionMethods.Select(m => new MethodItem(m.Method, m.Pct)).ToList() ?? [];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error cargando CN-D");
            _data = null;
        }
        finally { _loading = false; }
    }

    private static string StatusColor(string status) => status switch
    {
        "GREEN"  => "success",
        "ORANGE" => "warning",
        _        => "danger"
    };

    private static string ValidationStatusBadge(string status) => status switch
    {
        "Approved" => "success",
        "Rejected" => "danger",
        _          => "warning text-dark"
    };

    private static string SeverityBadge(string severity) => severity switch
    {
        "HIGH"   => "danger",
        "MEDIUM" => "warning text-dark",
        _        => "secondary"
    };

    }
