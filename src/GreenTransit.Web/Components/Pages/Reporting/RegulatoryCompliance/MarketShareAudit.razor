@page "/reporting/regulatory-compliance/market-share-audit"
@attribute [Authorize(Policy = PolicyConstants.CanViewMarketShareAudit)]
@rendermode InteractiveServer

@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Application.Features.Entities.DTOs
@using GreenTransit.Application.Features.Entities.Queries
@using GreenTransit.Application.Features.Reporting.RegulatoryCompliance.DTOs
@using GreenTransit.Application.Features.Reporting.RegulatoryCompliance.Queries
@using GreenTransit.Domain.Authorization
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop

@inject IMediator           Mediator
@inject ICurrentUserService CurrentUser
@inject IJSRuntime          JS
@inject ILogger<MarketShareAudit> Logger
@inject NavigationManager   Nav

<PageTitle>Auditoría de Cuotas de Mercado — GreenTransit</PageTitle>

<div class="page-header mb-4">
    <div class="page-header-info">
        <h1 class="page-title">
            <i class="bi bi-pie-chart-fill me-2 text-primary"></i>Auditoría de Cuotas de Mercado
        </h1>
        <p class="text-muted mb-0">Dashboard CN-B · Reparto proporcional de responsabilidad entre SCRAPs</p>
        <p class="text-muted small mt-1">
            Verifica que cada SCRAP asume su cuota de mercado según la Ley 22/2011 (principio de proporcionalidad).
        </p>
    </div>
    <div class="page-header-actions">
        <button class="btn btn-outline-success btn-sm me-2" @onclick="ExportAsync" disabled="@_loading">
            <i class="bi bi-file-earmark-excel me-1"></i>Exportar XLSX
        </button>
        <button class="btn btn-outline-neutral btn-sm" @onclick="LoadAsync" disabled="@_loading">
            <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
        </button>
    </div>
</div>

@* ── Filtros ───────────────────────────────────────────────────────────────── *@
<div class="filter-bar mb-4">
    <div class="filter-group">
        <label>Año</label>
        <input type="number" class="form-control form-control-sm" style="width:100px"
               @bind="_year" @bind:after="LoadAsync" min="2020" max="2030" />
    </div>
    <div class="filter-group">
        <label>Comunidad Autónoma</label>
        <select class="form-select form-select-sm" style="width:180px" @bind="_autonomousCommunity" @bind:after="LoadAsync">
            <option value="">Todas</option>
            @foreach (var c in _filterOptions.AutonomousCommunities)
            {
                <option value="@c">@c</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Flujo</label>
        <select class="form-select form-select-sm" style="width:160px" @bind="_flowType" @bind:after="LoadAsync">
            <option value="">Todos</option>
            @foreach (var f in _filterOptions.FlowTypes)
            {
                <option value="@f">@f</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Categoría</label>
        <select class="form-select form-select-sm" style="width:160px" @bind="_category" @bind:after="LoadAsync">
            <option value="">Todas</option>
            @foreach (var cat in _filterOptions.Categories)
            {
                <option value="@cat">@cat</option>
            }
        </select>
    </div>
    @if (CurrentUser.IsInAnyProfile("ADMIN", "DISPATCH_OFFICE"))
    {
        <div class="filter-group">
            <label>SCRAP</label>
            <select class="form-select form-select-sm" style="width:200px" @bind="_filterIdScrap" @bind:after="LoadAsync">
                <option value="">Todos los SCRAPs</option>
                @foreach (var s in _scraps)
                {
                    <option value="@s.Id">@s.Name</option>
                }
            </select>
        </div>
    }
</div>

@if (_loading)
{
    <div class="text-center" style="padding:3rem 0"><div class="spinner spinner-lg"></div></div>
}
else if (_data is null)
{
    <div class="alert alert-warning">No se han podido cargar los datos.</div>
}
else
{
    @* ── Donut + tabla resumen ────────────────────────────────────────────── *@
    <div class="row g-4 mb-4">
        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-pie-chart-fill me-2"></i>Proporcionalidad global de cuotas</div>
                <div class="card-body">
                    @if (_donutItems.Any())
                    {
                        <AppChart Height="280" ShowLegend="true">
                            <RadzenDonutSeries Data="@_donutItems" CategoryProperty="Name" ValueProperty="Value"
                                              Fills="@ChartPalette.CorporateColors" />
                        </AppChart>
                    }
                    else
                    {
                        <p class="text-muted text-center pt-4">Sin datos de cuotas para el año seleccionado.</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-table me-2"></i>Resumen por SCRAP</div>
                <div class="card-body p-0">
                    @{ var _scrapPage = _data.ScrapSummaries.OrderByDescending(x => x.CompliancePct).ToList(); }
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>SCRAP</th>
                                    <th class="text-end">Objetivo (kg)</th>
                                    <th class="text-end">Real (kg)</th>
                                    <th class="text-end">% Cumpl.</th>
                                    <th class="text-end">Desviación</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in _scrapPage.Skip((_pgScrapSummaries - 1) * PageSize).Take(PageSize))
                                {
                                    <tr>
                                        <td>@s.ScrapName</td>
                                        <td class="text-end">@s.TargetWeightKg.ToString("N0")</td>
                                        <td class="text-end">@s.RealWeightKg.ToString("N0")</td>
                                        <td class="text-end">
                                            <span class="badge bg-@StatusBadge(s.CompliancePct)">@s.CompliancePct.ToString("N1")%</span>
                                        </td>
                                        <td class="text-end @(s.DeviationKg >= 0 ? "text-success" : "text-danger")">
                                            @(s.DeviationKg >= 0 ? "+" : "")@s.DeviationKg.ToString("N0") kg
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <TablePager TotalCount="_scrapPage.Count" PageSize="PageSize" CurrentPage="_pgScrapSummaries"
                                CurrentPageChanged="p => _pgScrapSummaries = p" />
                </div>
            </div>
        </div>
    </div>

    @* ── Índice de desviación ─────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-bar-chart-line me-2"></i>Índice de desviación por SCRAP</div>
        <div class="card-body">
            @if (_deviationItems.Any())
            {
                <AppChart Height="280" ShowLegend="false" CategoryAxisTitle="SCRAP" ValueAxisTitle="%">
                    <RadzenBarSeries Data="@_deviationItems" CategoryProperty="Name" ValueProperty="Value"
                                     Title="Desviación %" Fill="@ChartPalette.GetColor(0)" />
                </AppChart>
            }
            else
            {
                <p class="text-muted text-center pt-4">Sin datos de desviación.</p>
            }
        </div>
    </div>

    @* ── Evolución mensual ────────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-graph-up me-2"></i>Evolución mensual del reparto real vs objetivo</div>
        <div class="card-body">
            @if (_monthlyItems.Any())
            {
                <AppChart Height="280" ShowLegend="true" CategoryAxisTitle="Mes" ValueAxisTitle="kg">
                    @{ int mIdx = 0; }
                    @foreach (var scrap in _monthlyScrapNames)
                    {
                        var s = scrap;
                        var idx = mIdx++;
                        <RadzenColumnSeries Data="@_monthlyItems.Where(x => x.ScrapName == s).ToList()"
                                           CategoryProperty="Label" ValueProperty="RealKg"
                                           Title="@s" Fill="@ChartPalette.GetColor(idx)" />
                    }
                </AppChart>
            }
            else
            {
                <p class="text-muted text-center pt-4">Sin datos mensuales.</p>
            }
        </div>
    </div>

    @* ── Heatmap SCRAP × Categoría ────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-grid-3x3-gap-fill me-2"></i>Comparativa de cumplimiento por SCRAP y categoría</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                @{
                    var cats = _data.Heatmap.SelectMany(r => r.Cells).Select(c => c.Category).Distinct().OrderBy(c => c).ToList();
                }
                <table class="table table-sm table-bordered mb-0">
                    <thead>
                        <tr>
                            <th>SCRAP</th>
                            @foreach (var cat in cats) { <th class="text-center" style="white-space:nowrap">@cat</th> }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _data.Heatmap)
                        {
                            <tr>
                                <td><strong>@row.ScrapName</strong></td>
                                @foreach (var cat in cats)
                                {
                                    var cell = row.Cells.FirstOrDefault(c => c.Category == cat);
                                    <td class="text-center" style="background-color:@HeatmapColor(cell?.Status)">
                                        @(cell is not null ? cell.CompliancePct.ToString("N0") + "%" : "—")
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ── Desglose territorial ─────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-map-fill me-2"></i>Desglose por comunidad autónoma y flujo</div>
        <div class="card-body p-0">
            @{ var _terrRows = _data.TerritorialBreakdown.OrderBy(x => x.AutonomousCommunity).ThenBy(x => x.ScrapName).ToList(); }
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Comunidad Autónoma</th><th>SCRAP</th><th>Categoría</th>
                            <th class="text-end">Objetivo (kg)</th><th class="text-end">Real (kg)</th>
                            <th class="text-end">% Cumpl.</th><th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in _terrRows.Skip((_pgTerritorial - 1) * PageSize).Take(PageSize))
                        {
                            <tr>
                                <td>@t.AutonomousCommunity</td>
                                <td>@t.ScrapName</td>
                                <td>@t.Category</td>
                                <td class="text-end">@t.TargetWeightKg.ToString("N0")</td>
                                <td class="text-end">@t.RealWeightKg.ToString("N0")</td>
                                <td class="text-end">
                                    <span class="badge bg-@StatusBadge(t.CompliancePct)">@t.CompliancePct.ToString("N1")%</span>
                                </td>
                                <td><i class="bi bi-circle-fill text-@StatusColor(t.Status)"></i></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <TablePager TotalCount="_terrRows.Count" PageSize="PageSize" CurrentPage="_pgTerritorial"
                        CurrentPageChanged="p => _pgTerritorial = p" />
        </div>
    </div>
}

@code {
    private record DonutItem(string Name, double Value);
    private record DeviationItem(string Name, double Value);
    private record MonthlyItem(string Label, string ScrapName, double RealKg);

    private const int PageSize = 15;
    private MarketShareAuditDto? _data;
    private List<DonutItem>    _donutItems      = [];
    private List<DeviationItem> _deviationItems = [];
    private List<MonthlyItem>  _monthlyItems    = [];
    private List<string>       _monthlyScrapNames = [];
    private ComplianceFilterOptionsDto  _filterOptions = new([], [], [], []);
    private IReadOnlyList<EntitySelectorDto> _scraps = [];
    private bool    _loading = true;
    private bool    _initialized;
    private int     _year = DateTime.Now.Year;
    private string? _autonomousCommunity;
    private string? _flowType;
    private string? _category;
    private string? _filterIdScrap;
    private int     _pgScrapSummaries = 1;
    private int     _pgTerritorial    = 1;

    protected override async Task OnInitializedAsync()
    {
        if (_initialized) return;
        _initialized = true;
        try { _filterOptions = await Mediator.Send(new GetComplianceFilterOptionsQuery()); }
        catch (Exception ex) { Logger.LogWarning(ex, "Error cargando opciones de filtro CN-B"); }
        if (CurrentUser.IsInAnyProfile("ADMIN", "DISPATCH_OFFICE"))
        {
            try { _scraps = await Mediator.Send(new GetEntitiesForSelectorQuery(new[] { EntityRoles.SCRAP })); }
            catch (Exception ex) { Logger.LogWarning(ex, "Error cargando SCRAPs CN-B"); }
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading            = true;
        _pgScrapSummaries   = 1;
        _pgTerritorial      = 1;
        try
        {
            _data = await Mediator.Send(new GetMarketShareAuditQuery(
                _year,
                string.IsNullOrEmpty(_autonomousCommunity) ? null : _autonomousCommunity,
                string.IsNullOrEmpty(_flowType)            ? null : _flowType,
                string.IsNullOrEmpty(_category)            ? null : _category,
                Guid.TryParse(_filterIdScrap, out var sid) ? sid : null));
            _donutItems        = _data?.ScrapShares.Select(s => new DonutItem(s.ScrapName, s.Pct)).ToList() ?? [];
            _deviationItems    = _data?.DeviationIndex.Select(d => new DeviationItem(d.ScrapName, (double)d.DeviationPct)).ToList() ?? [];
            _monthlyItems      = _data?.MonthlyEvolution.Select(x => new MonthlyItem($"{x.Month:00}/{x.Year}", x.ScrapName, (double)x.RealWeightKg)).ToList() ?? [];
            _monthlyScrapNames = _data?.MonthlyEvolution.Select(x => x.ScrapName).Distinct().ToList() ?? [];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error cargando CN-B");
            _data = null;
        }
        finally { _loading = false; }
    }

    private async Task ExportAsync()
    {
        try
        {
            var result = await Mediator.Send(new ExportComplianceDataToExcelQuery(
                _year, "MarketShareAudit", null,
                string.IsNullOrEmpty(_autonomousCommunity) ? null : _autonomousCommunity,
                string.IsNullOrEmpty(_flowType)            ? null : _flowType,
                string.IsNullOrEmpty(_category)            ? null : _category));

            var base64 = Convert.ToBase64String(result.FileContent);
            await JS.InvokeVoidAsync("downloadBase64File", base64, result.FileName, result.ContentType);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error exportando CN-B");
        }
    }

    private static string StatusColor(string status) => status switch
    {
        "GREEN"  => "success",
        "ORANGE" => "warning",
        _        => "danger"
    };

    private static string StatusBadge(decimal pct) =>
        pct >= 100m ? "success" : pct >= 80m ? "warning text-dark" : "danger";

    private static string StatusBadge(string status) => status switch
    {
        "GREEN"  => "success",
        "ORANGE" => "warning text-dark",
        _        => "danger"
    };

    private static string HeatmapColor(string? status) => status switch
    {
        "GREEN"  => "#d8f3dc",
        "ORANGE" => "#fff3cd",
        "RED"    => "#f8d7da",
        _        => "transparent"
    };

    }
