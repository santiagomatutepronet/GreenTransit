@page "/reporting/regulatory-compliance/scrap-overview"
@attribute [Authorize(Policy = PolicyConstants.CanViewScrapComplianceOverview)]
@rendermode InteractiveServer
@implements IAsyncDisposable

@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Application.Features.Reporting.RegulatoryCompliance.DTOs
@using GreenTransit.Application.Features.Reporting.RegulatoryCompliance.Queries
@using GreenTransit.Domain.Authorization
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop

@inject IMediator           Mediator
@inject ICurrentUserService CurrentUser
@inject IJSRuntime          JS
@inject ILogger<ScrapComplianceOverview> Logger

<PageTitle>Cumplimiento Normativo — Panel SCRAP — GreenTransit</PageTitle>

<div class="page-header mb-4">
    <div class="page-header-info">
        <h1 class="page-title">
            <i class="bi bi-shield-check me-2 text-primary"></i>Cumplimiento Normativo — Panel SCRAP
        </h1>
        <p class="text-muted mb-0">Dashboard CN-A · Tasas de reciclaje, cuotas de mercado y estado de convenios</p>
        <p class="text-muted small mt-1">
            Evaluación del cumplimiento RAP según la Ley 22/2011. Alineado con el «Objetivo 55» de la Ley Europea del Clima.
        </p>
    </div>
    <div class="page-header-actions">
        <button class="btn btn-outline-neutral btn-sm" @onclick="LoadAsync" disabled="@_loading">
            <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
        </button>
    </div>
</div>

@* ── Filtros ───────────────────────────────────────────────────────────────── *@
<div class="filter-bar mb-4">
    <div class="filter-group">
        <label>Año</label>
        <input type="number" class="form-control form-control-sm" style="width:100px"
               @bind="_year" @bind:after="LoadAsync" min="2020" max="2030" />
    </div>
    <div class="filter-group">
        <label>Trimestre</label>
        <select class="form-select form-select-sm" style="width:130px"
                @bind="_quarter" @bind:after="LoadAsync">
            <option value="">Todos</option>
            <option value="1">T1</option><option value="2">T2</option>
            <option value="3">T3</option><option value="4">T4</option>
        </select>
    </div>
    <div class="filter-group">
        <label>Comunidad Autónoma</label>
        <select class="form-select form-select-sm" style="width:180px" @bind="_autonomousCommunity" @bind:after="LoadAsync">
            <option value="">Todas</option>
            @foreach (var c in _filterOptions.AutonomousCommunities)
            {
                <option value="@c">@c</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Flujo</label>
        <select class="form-select form-select-sm" style="width:160px" @bind="_flowType" @bind:after="LoadAsync">
            <option value="">Todos</option>
            @foreach (var f in _filterOptions.FlowTypes)
            {
                <option value="@f">@f</option>
            }
        </select>
    </div>
</div>

@if (_loading)
{
    <div class="text-center" style="padding:3rem 0"><div class="spinner spinner-lg"></div></div>
}
else if (_data is null)
{
    <div class="alert alert-warning">No se han podido cargar los datos.</div>
}
else
{
    @* ── Alertas ──────────────────────────────────────────────────────────── *@
    @if (_data.Alerts.Any())
    {
        <div class="alert alert-danger mb-4">
            <strong><i class="bi bi-exclamation-triangle-fill me-2"></i>@_data.Alerts.Count alertas activas</strong>
            <ul class="mb-0 mt-2">
                @foreach (var a in _data.Alerts.Take(5))
                {
                    <li><span class="badge @(a.Severity == "HIGH" ? "bg-danger" : "bg-warning text-dark") me-1">@a.Severity</span>@a.Message</li>
                }
            </ul>
        </div>
    }

    @* ── KPIs ─────────────────────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100 border-@StatusColor(_data.RecyclingStatus)">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-recycle me-1 text-success"></i>Tasa de Reciclaje</div>
                    <div class="kpi-value">@_data.RecyclingRatePct.ToString("N1")<small class="text-muted"> %</small></div>
                    <div class="kpi-badge badge-@StatusBadge(_data.RecyclingStatus)">
                        <i class="bi bi-circle-fill me-1"></i>@_data.RecyclingStatus
                    </div>
                    @if (_data.VariationRecyclingVsPrevPct != 0)
                    {
                        <div class="kpi-badge @(_data.VariationRecyclingVsPrevPct > 0 ? "badge-success" : "badge-danger") mt-1">
                            <i class="bi bi-@(_data.VariationRecyclingVsPrevPct > 0 ? "arrow-up" : "arrow-down") me-1"></i>
                            @Math.Abs(_data.VariationRecyclingVsPrevPct).ToString("N1")% vs año anterior
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100 border-@StatusColor(_data.ValorizationStatus)">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-lightning-charge me-1 text-warning"></i>Tasa de Valorización</div>
                    <div class="kpi-value">@_data.ValorizationRatePct.ToString("N1")<small class="text-muted"> %</small></div>
                    <div class="kpi-badge badge-@StatusBadge(_data.ValorizationStatus)">
                        <i class="bi bi-circle-fill me-1"></i>@_data.ValorizationStatus
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100 border-@StatusColor(_data.MarketShareStatus)">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-pie-chart-fill me-1 text-primary"></i>Cumplimiento Cuota</div>
                    <div class="kpi-value">@_data.MarketShareCompliancePct.ToString("N1")<small class="text-muted"> %</small></div>
                    <div class="kpi-badge badge-@StatusBadge(_data.MarketShareStatus)">
                        <i class="bi bi-circle-fill me-1"></i>@_data.MarketShareStatus
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-file-earmark-text me-1 text-info"></i>Convenios Activos</div>
                    <div class="kpi-value">@_data.ActiveAgreements</div>
                </div>
            </div>
        </div>
    </div>

    @* ── Evolución trimestral ─────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-graph-up me-2"></i>Evolución trimestral de tasas de cumplimiento</div>
        <div class="card-body">
            @if (_data.QuarterlyTrend.Any())
            {
                <div id="chart-cn-a-quarterly" style="min-height:280px"></div>
            }
            else
            {
                <p class="text-muted text-center pt-4">Sin datos trimestrales en el periodo.</p>
            }
        </div>
    </div>

    @* ── Cuotas por categoría ─────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-bar-chart-steps me-2"></i>Cumplimiento de cuotas por categoría y comunidad autónoma</div>
        <div class="card-body p-0">
            @{ var _mktRows = _data.MarketShareRows.ToList(); }
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Categoría</th><th>Comunidad Autónoma</th><th>Flujo</th>
                            <th class="text-end">Objetivo (kg)</th><th class="text-end">Real (kg)</th>
                            <th class="text-end">% Cumpl.</th><th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _mktRows.Skip((_pgMarketShare - 1) * PageSize).Take(PageSize))
                        {
                            <tr>
                                <td>@r.Category</td>
                                <td>@r.AutonomousCommunity</td>
                                <td>@r.FlowType</td>
                                <td class="text-end">@r.TargetWeightKg.ToString("N0")</td>
                                <td class="text-end">@r.RealWeightKg.ToString("N0")</td>
                                <td class="text-end">
                                    <span class="badge bg-@StatusBadge(r.Status)">@r.CompliancePct.ToString("N1")%</span>
                                </td>
                                <td><i class="bi bi-circle-fill text-@StatusColor(r.Status)"></i></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <TablePager TotalCount="_mktRows.Count" PageSize="PageSize" CurrentPage="_pgMarketShare"
                        CurrentPageChanged="p => _pgMarketShare = p" />
        </div>
    </div>

    @* ── Convenios ────────────────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-file-earmark-text-fill me-2"></i>Estado de convenios</div>
        <div class="card-body p-0">
            @{ var _agrmRows = _data.Agreements.ToList(); }
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Nº Acuerdo</th><th>Entidad Pública</th><th>CCAA</th><th>Flujo</th>
                            <th>Estado</th><th class="text-end">Vigencia</th><th class="text-end">Días</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in _agrmRows.Skip((_pgAgreements - 1) * PageSize).Take(PageSize))
                        {
                            <tr>
                                <td><a href="/agreements/@a.Id"><code>@a.AgreementNumber</code></a></td>
                                <td class="text-truncate" style="max-width:140px">@a.PublicEntityName</td>
                                <td>@a.AutonomousCommunity</td>
                                <td>@a.WasteStream</td>
                                <td><span class="badge bg-@StatusBadge(a.ExpiryStatus)">@a.Status</span></td>
                                <td class="text-end">@a.EffectiveFrom.ToString("dd/MM/yyyy") – @(a.EffectiveTo?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td class="text-end">
                                    @if (a.DaysToExpiry < 9999)
                                    {
                                        <span class="badge bg-@StatusBadge(a.ExpiryStatus)">@a.DaysToExpiry d</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <TablePager TotalCount="_agrmRows.Count" PageSize="PageSize" CurrentPage="_pgAgreements"
                        CurrentPageChanged="p => _pgAgreements = p" />
        </div>
    </div>

    @* ── Liquidaciones ────────────────────────────────────────────────────── *@
    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-receipt me-2"></i>Liquidaciones mensuales</div>
                <div class="card-body">
                    @if (_data.SettlementMonthly.Any())
                    {
                        <div id="chart-cn-a-settlements" style="min-height:280px"></div>
                    }
                    else
                    {
                        <p class="text-muted text-center pt-4">Sin datos de liquidaciones.</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-table me-2"></i>Detalle de liquidaciones</div>
                <div class="card-body p-0">
                    @{ var _stlRows = _data.Settlements.ToList(); }
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Nº</th><th>Entidad</th><th class="text-end">Importe</th>
                                    <th>Estado</th><th>Validación</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in _stlRows.Skip((_pgSettlements - 1) * PageSize).Take(PageSize))
                                {
                                    <tr>
                                        <td><code>@s.SettlementNumber</code></td>
                                        <td class="text-truncate" style="max-width:120px">@s.PublicEntityName</td>
                                        <td class="text-end">@s.TotalAmount.ToString("N2") @s.Currency</td>
                                        <td><span class="badge bg-@ValidationStatusBadge(s.ValidationStatus)">@s.ValidationStatus</span></td>
                                        <td>@(s.ValidatedAt?.ToString("dd/MM/yyyy") ?? "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <TablePager TotalCount="_stlRows.Count" PageSize="PageSize" CurrentPage="_pgSettlements"
                                CurrentPageChanged="p => _pgSettlements = p" />
                </div>
            </div>
        </div>
    </div>
}

@code {
    private const int PageSize = 15;
    private ScrapComplianceOverviewDto? _data;
    private ComplianceFilterOptionsDto  _filterOptions = new([], [], [], []);
    private bool    _loading = true;
    private bool    _initialized;
    private bool    _chartsRendered;
    private int     _year    = DateTime.Now.Year;
    private string? _quarter;
    private string? _autonomousCommunity;
    private string? _flowType;
    private int     _pgMarketShare = 1;
    private int     _pgAgreements  = 1;
    private int     _pgSettlements = 1;

    protected override async Task OnInitializedAsync()
    {
        if (_initialized) return;
        _initialized = true;
        try { _filterOptions = await Mediator.Send(new GetComplianceFilterOptionsQuery()); }
        catch (Exception ex) { Logger.LogWarning(ex, "Error cargando opciones de filtro CN-A"); }
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loading && _data is not null && !_chartsRendered)
        {
            _chartsRendered = true;
            await RenderChartsAsync();
        }
    }

    private async Task LoadAsync()
    {
        _loading         = true;
        _chartsRendered  = false;
        _pgMarketShare   = 1;
        _pgAgreements    = 1;
        _pgSettlements   = 1;
        try
        {
            _data = await Mediator.Send(new GetScrapComplianceOverviewQuery(
                _year,
                string.IsNullOrEmpty(_quarter) ? null : int.Parse(_quarter),
                null,
                string.IsNullOrEmpty(_autonomousCommunity) ? null : _autonomousCommunity,
                null,
                string.IsNullOrEmpty(_flowType) ? null : _flowType));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error cargando CN-A");
            _data = null;
        }
        finally { _loading = false; }
    }

    private async Task RenderChartsAsync()
    {
        if (_data is null) return;
        try
        {
            if (_data.QuarterlyTrend.Any())
            {
                var series = _data.QuarterlyTrend.Select(q => new {
                    year = q.Year, quarter = q.Quarter,
                    recyclingPct    = (double)q.RecyclingPct,
                    valorizationPct = (double)q.ValorizationPct,
                    reusePct        = (double)q.ReusePct,
                    targetPct       = (double)q.TargetRecyclingPct
                }).ToList();
                await JS.InvokeVoidAsync("complianceCharts.renderQuarterlyTrend", "chart-cn-a-quarterly", series);
            }
            if (_data.SettlementMonthly.Any())
            {
                var series = _data.SettlementMonthly.Select(s => new {
                    year    = s.Year, month = s.Month,
                    pending  = (double)s.PendingAmount,
                    approved = (double)s.ApprovedAmount,
                    rejected = (double)s.RejectedAmount
                }).ToList();
                await JS.InvokeVoidAsync("complianceCharts.renderSettlementBar", "chart-cn-a-settlements", series);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error renderizando gráficos CN-A");
        }
    }

    private static string StatusColor(string status) => status switch
    {
        "GREEN"  => "success",
        "ORANGE" => "warning",
        _        => "danger"
    };

    private static string StatusBadge(string status) => status switch
    {
        "GREEN"  => "success",
        "ORANGE" => "warning text-dark",
        _        => "danger"
    };

    private static string ValidationStatusBadge(string status) => status switch
    {
        "Approved" => "success",
        "Rejected" => "danger",
        _          => "warning text-dark"
    };

    public ValueTask DisposeAsync()
    {
        _ = JS.InvokeVoidAsync("complianceCharts.clear", "chart-cn-a-quarterly");
        _ = JS.InvokeVoidAsync("complianceCharts.clear", "chart-cn-a-settlements");
        return ValueTask.CompletedTask;
    }
}
