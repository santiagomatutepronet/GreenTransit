@page "/reporting/carbon-footprint/producer-report"
@attribute [Authorize(Policy = PolicyConstants.CanViewCarbonProducerReport)]
@rendermode InteractiveServer

@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Application.Features.Reporting.CarbonFootprint.DTOs
@using GreenTransit.Application.Features.Reporting.CarbonFootprint.Queries
@using GreenTransit.Domain.Authorization
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using System.Globalization

@inject IMediator           Mediator
@inject ICurrentUserService CurrentUser
@inject ILogger<ProducerCarbonReport> Logger

<PageTitle>Reporte de Huella de Carbono — Productor — GreenTransit</PageTitle>

<div class="page-header mb-4">
    <div class="page-header-info">
        <h1 class="page-title">
            <i class="bi bi-person-fill-gear me-2 text-primary"></i>Reporte de Huella de Carbono — Productor
        </h1>
        <p class="text-muted mb-0">Dashboard HC-D · Evaluación del impacto ambiental de mis residuos · @_dateFrom.ToString("dd/MM/yyyy") – @_dateTo.ToString("dd/MM/yyyy")</p>
        <p class="text-muted small mt-1">
            Permite evaluar el impacto ambiental de la gestión de sus residuos, alineado con el «Objetivo 55» de la Ley Europea del Clima.
        </p>
    </div>
    <div class="page-header-actions">
        <button class="btn btn-outline-neutral btn-sm" @onclick="LoadAsync" disabled="@_loading">
            <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
        </button>
    </div>
</div>

@* ── Filtros ───────────────────────────────────────────────────────────────── *@
<div class="filter-bar mb-4">
    <div class="filter-group">
        <label>Desde</label>
        <input type="date" class="form-control form-control-sm"
               value="@_dateFrom.ToString("yyyy-MM-dd")"
               @onchange="e => { _dateFrom = DateTime.Parse(e.Value!.ToString()!); _ = LoadAsync(); }" />
    </div>
    <div class="filter-group">
        <label>Hasta</label>
        <input type="date" class="form-control form-control-sm"
               value="@_dateTo.ToString("yyyy-MM-dd")"
               @onchange="e => { _dateTo = DateTime.Parse(e.Value!.ToString()!); _ = LoadAsync(); }" />
    </div>
    <div class="filter-group">
        <label>Código LER</label>
        <input class="form-control form-control-sm" @bind="_filterLerCode" @bind:after="LoadAsync" placeholder="Todos" />
    </div>
</div>

@if (_loading)
{
    <div class="text-center" style="padding:3rem 0"><div class="spinner spinner-lg"></div></div>
}
else if (_data is null)
{
    <div class="alert alert-warning">No se han podido cargar los datos.</div>
}
else
{
    @* ── KPIs ─────────────────────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100 border-primary">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-cloud-fill text-success me-1"></i>Emisiones de mis residuos</div>
                    <div class="kpi-value">@(_data.TotalCO2eKg / 1000m).ToString("N2") <small class="text-muted">t CO₂e</small></div>
                    @if (_data.VariationVsPreviousPct != 0)
                    {
                        <div class="kpi-badge @(_data.VariationVsPreviousPct > 0 ? "badge-danger" : "badge-success")">
                            <i class="bi bi-@(_data.VariationVsPreviousPct > 0 ? "arrow-up" : "arrow-down") me-1"></i>
                            @Math.Abs(_data.VariationVsPreviousPct).ToString("N1")% vs periodo anterior
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-recycle me-1 text-success"></i>Toneladas gestionadas</div>
                    <div class="kpi-value">@_data.TotalTonnesManaged.ToString("N1") <small class="text-muted">t</small></div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-speedometer2 me-1 text-warning"></i>Mi intensidad</div>
                    <div class="kpi-value">@_data.IntensityCO2ePerTonne.ToString("N1") <small class="text-muted">kg/t</small></div>
                    <div class="kpi-badge @(_data.IntensityCO2ePerTonne > _data.EcosystemAvgCO2ePerTonne ? "badge-danger" : "badge-success")">
                        Media: @_data.EcosystemAvgCO2ePerTonne.ToString("N1") kg/t
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-clipboard2-check me-1 text-info"></i>Traslados del periodo</div>
                    <div class="kpi-value">@_data.TotalServices</div>
                </div>
            </div>
        </div>
    </div>

    @* -- Grafico LER + tabla destinos ----------------------------------------- *@
    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-pie-chart-fill me-2"></i>Emision por tipo de residuo (LER)</div>
                <div class="card-body">
                    @if (_lerItems.Any())
                    {
                        <AppChart Height="280" ShowLegend="true">
                            <RadzenDonutSeries Data="@_lerItems" CategoryProperty="Label" ValueProperty="CO2eKg"
                                              Fills="@ChartPalette.CorporateColors" />
                        </AppChart>
                    }
                    else
                    {
                        <p class="text-muted text-center pt-4">Sin datos por codigo LER.</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-building-fill me-2"></i>Emisiones por planta de destino</div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Planta</th><th class="text-end">km prom.</th>
                                    <th class="text-end">CO2e (kg)</th><th class="text-end">kg/t</th><th class="text-end">Servicios</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in _data.ByDestination)
                                {
                                    <tr>
                                        <td class="text-truncate" style="max-width:160px">@d.PlantName</td>
                                        <td class="text-end">@d.AvgDistanceKm.ToString("N0")</td>
                                        <td class="text-end">@d.CO2eKg.ToString("N1")</td>
                                        <td class="text-end">@d.IntensityCO2ePerTonne.ToString("N1")</td>
                                        <td class="text-end">@d.ServiceCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* -- Evolucion mensual ----------------------------------------------------- *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-graph-up me-2"></i>Evolucion mensual de mi huella</div>
        <div class="card-body">
            @if (_monthlyItems.Any())
            {
                <AppChart Height="280" ShowLegend="false" CategoryAxisTitle="Mes" ValueAxisTitle="CO₂e (kg)">
                    <RadzenLineSeries Data="@_monthlyItems" CategoryProperty="Label" ValueProperty="CO2eKg"
                                      Title="CO₂e kg" Stroke="@ChartPalette.GetColor(0)" StrokeWidth="2" />
                </AppChart>
            }
            else
            {
                <p class="text-muted text-center pt-4">Sin datos mensuales en el periodo.</p>
            }
        </div>
    </div>

    @* ── Detalle de operaciones ───────────────────────────────────────────── *@
    <div class="card">
        <div class="card-header"><i class="bi bi-table me-2"></i>Detalle de operaciones</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Referencia</th><th>Fecha</th><th>LER</th><th>Destino</th>
                            <th class="text-end">km</th><th>Vehículo</th><th>Comb.</th>
                            <th class="text-end">Peso (kg)</th><th class="text-end">CO₂e (kg)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in _data.Details.Take(200))
                        {
                            <tr>
                                <td><code>@d.WasteMoveReference</code></td>
                                <td>@d.Date?.ToString("dd/MM/yyyy")</td>
                                <td><code>@(d.LerCode ?? "—")</code></td>
                                <td class="text-truncate" style="max-width:130px">@(d.DestinationName ?? "—")</td>
                                <td class="text-end">@d.DistanceKm.ToString("N0")</td>
                                <td>@(d.VehicleType ?? "—")</td>
                                <td>@(d.FuelType ?? "—")</td>
                                <td class="text-end">@d.WeightKg.ToString("N0")</td>
                                <td class="text-end">@(d.CO2eKg?.ToString("N1") ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private record LerItem(string Label, double CO2eKg);
    private record MonthlyItem(string Label, double CO2eKg);

    private CarbonProducerReportDto? _data;
    private List<LerItem>     _lerItems     = [];
    private List<MonthlyItem> _monthlyItems = [];
    private bool    _loading;
    private DateTime _dateFrom = new(DateTime.Now.Year, 1, 1);
    private DateTime _dateTo   = DateTime.Now;
    private string?  _filterLerCode;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading        = true;
        try
        {
            _data = await Mediator.Send(new GetProducerCarbonReportQuery(
                _dateFrom, _dateTo,
                LerCode: string.IsNullOrEmpty(_filterLerCode) ? null : _filterLerCode));
            _lerItems     = _data?.ByLerCode.Select(l => new LerItem($"{l.LerCode} {l.LerDescription}", (double)l.CO2eKg)).ToList() ?? [];
            _monthlyItems = _data?.MonthlyEvolution.Select(m => new MonthlyItem($"{m.Month:00}/{m.Year}", (double)m.CO2eKg)).ToList() ?? [];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error cargando HC-D");
            _data = null;
        }
        finally { _loading = false; }
    }

    private static string MonthName(int m) =>
        CultureInfo.GetCultureInfo("es-ES").DateTimeFormat.GetMonthName(m);
}
