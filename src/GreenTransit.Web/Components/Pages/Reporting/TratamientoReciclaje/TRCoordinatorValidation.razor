@page "/reporting/tratamiento-reciclaje/coordinator-validation"
@attribute [Authorize(Policy = PolicyConstants.CanViewTRCoordinatorValidation)]
@rendermode InteractiveServer
@implements IAsyncDisposable

@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Application.Features.Entities.DTOs
@using GreenTransit.Application.Features.Entities.Queries
@using GreenTransit.Application.Features.Reporting.TratamientoReciclaje.DTOs
@using GreenTransit.Application.Features.Reporting.TratamientoReciclaje.Queries
@using GreenTransit.Domain.Authorization
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@using System.Globalization

@inject IMediator              Mediator
@inject ICurrentUserService    CurrentUser
@inject IJSRuntime             JS
@inject ILogger<TRCoordinatorValidation> Logger

<PageTitle>Validación Multi-SCRAP — Coordinador — GreenTransit</PageTitle>

<div class="page-header mb-4">
    <div class="page-header-info">
        <h1 class="page-title">
            <i class="bi bi-diagram-3-fill me-2"></i>Validación y Datos Multi-SCRAP
        </h1>
        <p class="text-muted mb-0">
            Coordinador · Tratamiento y Reciclaje ·
            @(_filterMonth.HasValue
                ? new DateTime(_filterYear, _filterMonth.Value, 1).ToString("MMMM yyyy", _es)
                : _filterYear.ToString())
        </p>
        <p class="text-muted small mt-1">
            Vista agregada multi-SCRAP para el coordinador: compara tasas de reciclaje, impropios
            y operaciones de tratamiento entre los SCRAPs bajo su convenio. Facilita la validación
            cruzada de datos y la detección de desviaciones antes del cierre de liquidaciones.
        </p>
    </div>
    <div class="page-header-actions">
        <button class="btn btn-success btn-sm" @onclick="ExportXlsxAsync" disabled="@(_loading || _exporting)">
            <i class="bi bi-file-earmark-excel me-1"></i>Exportar XLSX
        </button>
    </div>
</div>

@* ── Filtros ──────────────────────────────────────────────────────────────── *@
<div class="filter-bar mb-4">
    <div class="filter-group">
        <label>Año</label>
        <select class="form-select form-select-sm" @bind="_filterYear" @bind:after="RefreshAsync">
            @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
            { <option value="@y">@y</option> }
        </select>
    </div>
    <div class="filter-group">
        <label>Mes</label>
        <select class="form-select form-select-sm" @bind="_filterMonth" @bind:after="RefreshAsync">
            <option value="">Todos</option>
            @for (int m = 1; m <= 12; m++)
            { <option value="@m">@(new DateTime(2000, m, 1).ToString("MMMM", _es))</option> }
        </select>
    </div>
    @if (_scraps.Count > 0)
    {
        <div class="filter-group">
            <label>SCRAP</label>
            <select class="form-select form-select-sm" @bind="_filterScrapId" @bind:after="RefreshAsync">
                <option value="">Todos</option>
                @foreach (var s in _scraps)
                { <option value="@s.Id">@s.Name</option> }
            </select>
        </div>
    }
</div>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-success" role="status"></div>
        <p class="mt-2 text-muted">Cargando datos de validación…</p>
    </div>
}
else if (_data is not null)
{
    @* ── Resumen Multi-SCRAP ───────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        @foreach (var s in _data.ScrapSummaries)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100">
                    <div class="card-header fw-semibold">@s.ScrapName</div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0 small">
                            <li><span class="text-muted">Recogidas:</span> <strong>@s.TotalMoves</strong></li>
                            <li><span class="text-muted">Kg tratados:</span> <strong>@s.TotalWeightKg.ToString("N0")</strong></li>
                            <li><span class="text-muted">Tasa reciclaje:</span>
                                <strong class="@RecyclingClass(s.RecyclingRate)">@s.RecyclingRate.ToString("F1")%</strong>
                            </li>
                            <li><span class="text-muted">% Impropios:</span> <strong>@s.ImproperRate.ToString("F1")%</strong></li>
                            <li><span class="text-muted">Incidencias abiertas:</span>
                                <strong class="@(s.OpenIncidents > 0 ? "text-warning" : "")">@s.OpenIncidents</strong>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        }
        @if (!_data.ScrapSummaries.Any())
        { <div class="col-12"><p class="text-muted">Sin SCRAPs vinculados para el periodo.</p></div> }
    </div>

    @* ── Evolución mensual ─────────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header fw-semibold">
            <i class="bi bi-graph-up me-1"></i>Evolución mensual por SCRAP (últimos 12 meses)
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Periodo</th>
                            <th class="text-end">Tasa reciclaje</th>
                            <th class="text-end">% Impropios</th>
                            <th class="text-end">Kg valorizados</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in _data.MonthlyTrend)
                        {
                            <tr>
                                <td>@t.Period</td>
                                <td class="text-end">@t.RecyclingRate.ToString("F1")%</td>
                                <td class="text-end">@t.ImproperRate.ToString("F1")%</td>
                                <td class="text-end">@t.WeightValued.ToString("N0")</td>
                            </tr>
                        }
                        @if (!_data.MonthlyTrend.Any())
                        { <tr><td colspan="4" class="text-muted text-center py-3">Sin datos</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ── Distribución de operaciones R/D ─────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header fw-semibold">
            <i class="bi bi-pie-chart-fill me-1"></i>Distribución de operaciones de tratamiento R/D
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Descripción</th>
                            <th>Tipo</th>
                            <th class="text-end">Kg tratados</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in _data.OperationsDistribution)
                        {
                            <tr>
                                <td><code>@o.OperationCode</code></td>
                                <td>@o.OperationDescription</td>
                                <td>
                                    <span class="badge @(o.OperationType == "R" ? "bg-success" : "bg-danger")">@o.OperationType</span>
                                </td>
                                <td class="text-end">@o.WeightTotal.ToString("N0")</td>
                            </tr>
                        }
                        @if (!_data.OperationsDistribution.Any())
                        { <tr><td colspan="4" class="text-muted text-center py-3">Sin datos</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ── Dataset exportable ────────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
            <span><i class="bi bi-table me-1"></i>Dataset para validación (@_data.ExportDataset.Count filas)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height:400px;overflow-y:auto;">
                <table class="table table-sm mb-0">
                    <thead class="sticky-top bg-white">
                        <tr>
                            <th>Fecha trat.</th>
                            <th>SCRAP</th>
                            <th>LER</th>
                            <th>Residuo</th>
                            <th>Operación</th>
                            <th class="text-end">Kg totales</th>
                            <th class="text-end">Kg reutilizados</th>
                            <th class="text-end">Kg valorizados</th>
                            <th class="text-end">Kg rechazados</th>
                            <th class="text-end">Tasa rec.</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _data.ExportDataset.Take(200))
                        {
                            <tr>
                                <td>@(row.TreatmentDate ?? "—")</td>
                                <td>@(row.ScrapName ?? "—")</td>
                                <td><code>@(row.LERCode ?? "—")</code></td>
                                <td>@(row.ResidueName ?? "—")</td>
                                <td><code>@(row.TreatmentOperationCode ?? "—")</code></td>
                                <td class="text-end">@(row.WeightTotal?.ToString("N0") ?? "—")</td>
                                <td class="text-end">@(row.WeightReused?.ToString("N0") ?? "—")</td>
                                <td class="text-end">@(row.WeightValued?.ToString("N0") ?? "—")</td>
                                <td class="text-end">@(row.WeightRemove?.ToString("N0") ?? "—")</td>
                                <td class="text-end">@(row.RecyclingRate.HasValue ? row.RecyclingRate.Value.ToString("F1") + "%" : "—")</td>
                            </tr>
                        }
                        @if (!_data.ExportDataset.Any())
                        { <tr><td colspan="10" class="text-muted text-center py-3">Sin datos</td></tr> }
                    </tbody>
                </table>
            </div>
            @if (_data.ExportDataset.Count > 200)
            {
                <div class="card-footer text-muted small">
                    Mostrando 200 de @_data.ExportDataset.Count filas. Exporta a XLSX para ver el dataset completo.
                </div>
            }
        </div>
    </div>
}

@code {
    private TRCoordinatorValidationDto? _data;
    private bool  _loading   = true;
    private bool  _exporting = false;
    private int   _filterYear  = DateTime.Now.Year;
    private int?  _filterMonth = null;
    private Guid? _filterScrapId;

    private IReadOnlyList<EntitySelectorDto> _scraps = [];

    private static readonly CultureInfo _es = new("es-ES");

    protected override async Task OnInitializedAsync()
    {
        await LoadScrapsAsync();
        await RefreshAsync();
    }

    private async Task LoadScrapsAsync()
    {
        // COORDINATOR: carga todos los SCRAPs del tenant; el handler restringe al subconjunto
        // de sus Agreements. ADMIN/DISPATCH_OFFICE: todos los SCRAPs.
        _scraps = await Mediator.Send(new GetEntitiesForSelectorQuery([EntityRoles.SCRAP]));
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _data = await Mediator.Send(new GetTRCoordinatorValidationQuery(
                Year:    _filterYear,
                Month:   _filterMonth,
                IdScrap: _filterScrapId));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error cargando TR-C CoordinatorValidation");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ExportXlsxAsync()
    {
        if (_data is null) return;
        _exporting = true;
        try
        {
            using var wb  = new ClosedXML.Excel.XLWorkbook();
            var ws = wb.Worksheets.Add("Tratamiento y Reciclaje");
            var headers = new[]
            {
                "Fecha tratamiento", "SCRAP", "Planta", "Código LER", "Residuo",
                "Operación R/D", "Kg totales", "Kg reutilizados", "Kg valorizados",
                "Kg rechazados", "Impropios", "Tasa reciclaje (%)"
            };
            for (int c = 0; c < headers.Length; c++)
                ws.Cell(1, c + 1).Value = headers[c];

            int row = 2;
            foreach (var r in _data.ExportDataset)
            {
                ws.Cell(row, 1).Value  = r.TreatmentDate ?? "";
                ws.Cell(row, 2).Value  = r.ScrapName ?? "";
                ws.Cell(row, 3).Value  = r.PlantName ?? "";
                ws.Cell(row, 4).Value  = r.LERCode ?? "";
                ws.Cell(row, 5).Value  = r.ResidueName ?? "";
                ws.Cell(row, 6).Value  = r.TreatmentOperationCode ?? "";
                ws.Cell(row, 7).Value  = (double?)r.WeightTotal ?? 0;
                ws.Cell(row, 8).Value  = (double?)r.WeightReused ?? 0;
                ws.Cell(row, 9).Value  = (double?)r.WeightValued ?? 0;
                ws.Cell(row, 10).Value = (double?)r.WeightRemove ?? 0;
                ws.Cell(row, 11).Value = (double?)r.ImproperWeight ?? 0;
                ws.Cell(row, 12).Value = r.RecyclingRate ?? 0;
                row++;
            }
            ws.Columns().AdjustToContents();

            using var ms = new System.IO.MemoryStream();
            wb.SaveAs(ms);
            var b64  = Convert.ToBase64String(ms.ToArray());
            var name = $"TR_Coordinador_{_filterYear}_{(_filterMonth.HasValue ? _filterMonth.Value.ToString("00") : "anual")}.xlsx";
            await JS.InvokeVoidAsync("downloadBase64File", b64, name,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error exportando TR-C a XLSX");
        }
        finally
        {
            _exporting = false;
        }
    }

    private static string RecyclingClass(double rate) =>
        rate > 70 ? "text-success" : rate >= 40 ? "text-warning" : "text-danger";

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
