@page "/reporting/tratamiento-reciclaje/scrap-analysis"
@attribute [Authorize(Policy = PolicyConstants.CanViewTRScrapAnalysis)]
@rendermode InteractiveServer
@implements IAsyncDisposable

@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Application.Features.Entities.DTOs
@using GreenTransit.Application.Features.Entities.Queries
@using GreenTransit.Application.Features.Reporting.TratamientoReciclaje.DTOs
@using GreenTransit.Application.Features.Reporting.TratamientoReciclaje.Queries
@using GreenTransit.Domain.Authorization
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using System.Globalization

@inject IMediator            Mediator
@inject ICurrentUserService  CurrentUser
@inject ILogger<TRScrapAnalysis> Logger

<PageTitle>Análisis de Calidad y Revalorización — SCRAP — GreenTransit</PageTitle>

<div class="page-header mb-4">
    <div class="page-header-info">
        <h1 class="page-title">
            <i class="bi bi-recycle me-2"></i>Análisis de Calidad y Revalorización
        </h1>
        <p class="text-muted mb-0">
            SCRAP · Tratamiento y Reciclaje ·
            @(_filterMonth.HasValue
                ? new DateTime(_filterYear, _filterMonth.Value, 1).ToString("MMMM yyyy", _es)
                : _filterYear.ToString())
        </p>
        <p class="text-muted small mt-1">
            Analiza el balance de tratamiento por planta, la tasa de revalorización por tipo de residuo
            y la evolución mensual de calidad. Permite al SCRAP detectar fracciones con bajo reciclaje,
            controlar impropios e identificar oportunidades de mejora operativa.
        </p>
    </div>
</div>

@* ── Filtros ──────────────────────────────────────────────────────────────── *@
<div class="filter-bar mb-4">
    <div class="filter-group">
        <label>Año</label>
        <select class="form-select form-select-sm" @bind="_filterYear" @bind:after="RefreshAsync">
            @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
            { <option value="@y">@y</option> }
        </select>
    </div>
    <div class="filter-group">
        <label>Mes</label>
        <select class="form-select form-select-sm" @bind="_filterMonth" @bind:after="RefreshAsync">
            <option value="">Todos</option>
            @for (int m = 1; m <= 12; m++)
            { <option value="@m">@(new DateTime(2000, m, 1).ToString("MMMM", _es))</option> }
        </select>
    </div>
    @if (_scraps.Count > 0)
    {
        <div class="filter-group">
            <label>SCRAP</label>
            <select class="form-select form-select-sm" @bind="_filterScrapId" @bind:after="RefreshAsync">
                <option value="">Todos</option>
                @foreach (var s in _scraps)
                { <option value="@s.Id">@s.Name</option> }
            </select>
        </div>
    }
</div>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-success" role="status"></div>
        <p class="mt-2 text-muted">Cargando análisis de reciclaje…</p>
    </div>
}
else if (_data is not null)
{
    @* ── Balance de tratamiento ────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header fw-semibold">
            <i class="bi bi-bar-chart-fill me-1"></i>Balance de tratamiento por planta
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Planta</th>
                            <th class="text-end">Kg reutilizados</th>
                            <th class="text-end">Kg valorizados</th>
                            <th class="text-end">Kg rechazados</th>
                            <th class="text-end">Tasa reciclaje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in _data.TreatmentBalance)
                        {
                            <tr>
                                <td>@b.PlantName</td>
                                <td class="text-end">@b.WeightReused.ToString("N0")</td>
                                <td class="text-end">@b.WeightValued.ToString("N0")</td>
                                <td class="text-end">@b.WeightRemove.ToString("N0")</td>
                                <td class="text-end">
                                    <span class="badge @RecyclingBadge(b.RecyclingRate)">
                                        @b.RecyclingRate.ToString("F1")%
                                    </span>
                                </td>
                            </tr>
                        }
                        @if (!_data.TreatmentBalance.Any())
                        { <tr><td colspan="5" class="text-muted text-center py-3">Sin datos</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ── Gráfico: Balance de tratamiento por planta ───────────────────────── *@
    @if (_data.TreatmentBalance.Any())
    {
        <div class="card mb-4">
            <div class="card-header fw-semibold">
                <i class="bi bi-bar-chart-fill me-1"></i>Balance de tratamiento por planta — vista gráfica
            </div>
            <div class="card-body">
                @{
                    const int cW = 700, cH = 220, cPadL = 110, cPadB = 40, cPadT = 20;
                    var bars    = _data.TreatmentBalance;
                    int cInnW   = cW - cPadL - 20;
                    int cInnH   = cH - cPadB - cPadT;
                    double maxV = (double)bars.Max(b => Math.Max(b.WeightReused, Math.Max(b.WeightValued, b.WeightRemove)));
                    if (maxV == 0) maxV = 1;
                    int gW      = cInnW / bars.Count;
                    int bW      = Math.Max(6, gW / 4 - 2);
                    var inv     = System.Globalization.CultureInfo.InvariantCulture;

                    var svgBars = new System.Text.StringBuilder();
                    svgBars.Append($"<svg viewBox=\"0 0 {cW} {cH}\" style=\"width:100%;max-width:{cW}px;height:{cH}px;font-family:inherit;\">");
                    for (int i = 0; i <= 4; i++)
                    {
                        double yv  = maxV * i / 4;
                        int    yp  = cPadT + cInnH - cInnH * i / 4;
                        svgBars.Append($"<line x1=\"{cPadL}\" y1=\"{yp}\" x2=\"{cW-20}\" y2=\"{yp}\" stroke=\"#e0e0e0\" stroke-width=\"1\"/>");
                        svgBars.Append($"<text x=\"{cPadL-6}\" y=\"{yp+4}\" text-anchor=\"end\" font-size=\"10\" fill=\"#888\">{FormatKg(yv)}</text>");
                    }
                    for (int gi = 0; gi < bars.Count; gi++)
                    {
                        var b   = bars[gi];
                        int gx  = cPadL + gi * gW + gW / 2;
                        double hR = (double)b.WeightReused > 0 ? cInnH * (double)b.WeightReused / maxV : 0;
                        double hV = (double)b.WeightValued > 0 ? cInnH * (double)b.WeightValued / maxV : 0;
                        double hX = (double)b.WeightRemove > 0 ? cInnH * (double)b.WeightRemove / maxV : 0;
                        int x1 = gx - bW * 3 / 2 - 2, x2 = gx - bW / 2, x3 = gx + bW / 2 + 2;
                        svgBars.Append($"<rect x=\"{x1}\" y=\"{(cPadT+cInnH-hR).ToString("F1",inv)}\" width=\"{bW}\" height=\"{hR.ToString("F1",inv)}\" fill=\"#198754\" rx=\"2\"/>");
                        svgBars.Append($"<rect x=\"{x2}\" y=\"{(cPadT+cInnH-hV).ToString("F1",inv)}\" width=\"{bW}\" height=\"{hV.ToString("F1",inv)}\" fill=\"#0d6efd\" rx=\"2\"/>");
                        svgBars.Append($"<rect x=\"{x3}\" y=\"{(cPadT+cInnH-hX).ToString("F1",inv)}\" width=\"{bW}\" height=\"{hX.ToString("F1",inv)}\" fill=\"#dc3545\" rx=\"2\"/>");
                        svgBars.Append($"<text x=\"{gx}\" y=\"{cH-6}\" text-anchor=\"middle\" font-size=\"9\" fill=\"#555\">{TruncateName(b.PlantName, 12)}</text>");
                    }
                    svgBars.Append($"<line x1=\"{cPadL}\" y1=\"{cPadT+cInnH}\" x2=\"{cW-20}\" y2=\"{cPadT+cInnH}\" stroke=\"#aaa\" stroke-width=\"1\"/>");
                    svgBars.Append($"<rect x=\"{cPadL}\" y=\"6\" width=\"10\" height=\"10\" fill=\"#198754\"/><text x=\"{cPadL+13}\" y=\"15\" font-size=\"10\" fill=\"#333\">Reutilizados</text>");
                    svgBars.Append($"<rect x=\"{cPadL+80}\" y=\"6\" width=\"10\" height=\"10\" fill=\"#0d6efd\"/><text x=\"{cPadL+93}\" y=\"15\" font-size=\"10\" fill=\"#333\">Valorizados</text>");
                    svgBars.Append($"<rect x=\"{cPadL+160}\" y=\"6\" width=\"10\" height=\"10\" fill=\"#dc3545\"/><text x=\"{cPadL+173}\" y=\"15\" font-size=\"10\" fill=\"#333\">Rechazados</text>");
                    svgBars.Append("</svg>");
                }
                <div class="overflow-auto">@((MarkupString)svgBars.ToString())</div>
            </div>
        </div>
    }

    @* ── Tasa de revalorización por residuo ───────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header fw-semibold">
            <i class="bi bi-pie-chart-fill me-1"></i>Tasa de revalorización por tipo de residuo
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Código LER</th>
                            <th>Residuo</th>
                            <th class="text-end">Kg totales</th>
                            <th class="text-end">Tasa revalorización</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _data.RecyclingRateByResidue)
                        {
                            <tr>
                                <td><code>@r.LERCode</code></td>
                                <td>@r.ResidueName</td>
                                <td class="text-end">@r.WeightTotal.ToString("N0")</td>
                                <td class="text-end">
                                    <span class="badge @TrafficLightBadge(r.TrafficLight)">
                                        @r.RecyclingRate.ToString("F1")%
                                    </span>
                                </td>
                            </tr>
                        }
                        @if (!_data.RecyclingRateByResidue.Any())
                        { <tr><td colspan="4" class="text-muted text-center py-3">Sin datos</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ── Evolución mensual ─────────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header fw-semibold">
            <i class="bi bi-graph-up me-1"></i>Evolución mensual de calidad (últimos 12 meses)
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Periodo</th>
                            <th class="text-end">Tasa reciclaje</th>
                            <th class="text-end">% Impropios</th>
                            <th class="text-end">Kg valorizados</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in _data.MonthlyTrend)
                        {
                            <tr>
                                <td>@t.Period</td>
                                <td class="text-end">@t.RecyclingRate.ToString("F1")%</td>
                                <td class="text-end">@t.ImproperRate.ToString("F1")%</td>
                                <td class="text-end">@t.WeightValued.ToString("N0")</td>
                            </tr>
                        }
                        @if (!_data.MonthlyTrend.Any())
                        { <tr><td colspan="4" class="text-muted text-center py-3">Sin datos</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ── Gráfico: Evolución mensual de calidad ───────────────────────────── *@
    @if (_data.MonthlyTrend.Any())
    {
        <div class="card mb-4">
            <div class="card-header fw-semibold">
                <i class="bi bi-graph-up me-1"></i>Evolución mensual — Tasa reciclaje &amp; % Impropios
            </div>
            <div class="card-body">
                @{
                    const int lW = 700, lH = 220, lPadL = 40, lPadB = 40, lPadT = 20;
                    var trend  = _data.MonthlyTrend;
                    int lInnW  = lW - lPadL - 20;
                    int lInnH  = lH - lPadB - lPadT;
                    int pts    = trend.Count;
                    var linv   = System.Globalization.CultureInfo.InvariantCulture;
                    Func<int, double>    lxPos = idx => lPadL + (pts > 1 ? lInnW * idx / (double)(pts - 1) : lInnW / 2.0);
                    Func<double, double> lyPos = v   => lPadT + lInnH - lInnH * Math.Min(v, 100) / 100.0;

                    var recycPts  = string.Join(" ", trend.Select((t, i) => $"{lxPos(i).ToString("F1", linv)},{lyPos(t.RecyclingRate).ToString("F1", linv)}"));
                    var impropPts = string.Join(" ", trend.Select((t, i) => $"{lxPos(i).ToString("F1", linv)},{lyPos(t.ImproperRate).ToString("F1", linv)}"));

                    var svgLine = new System.Text.StringBuilder();
                    svgLine.Append($"<svg viewBox=\"0 0 {lW} {lH}\" style=\"width:100%;max-width:{lW}px;height:{lH}px;font-family:inherit;\">");
                    for (int i = 0; i <= 4; i++)
                    {
                        double yv = 25.0 * i;
                        double yp = lyPos(yv);
                        svgLine.Append($"<line x1=\"{lPadL}\" y1=\"{yp.ToString("F1",linv)}\" x2=\"{lW-20}\" y2=\"{yp.ToString("F1",linv)}\" stroke=\"#e0e0e0\" stroke-width=\"1\"/>");
                        svgLine.Append($"<text x=\"{lPadL-4}\" y=\"{(yp+4).ToString("F1",linv)}\" text-anchor=\"end\" font-size=\"10\" fill=\"#888\">{(int)yv}%</text>");
                    }
                    svgLine.Append($"<polyline points=\"{recycPts}\" fill=\"none\" stroke=\"#198754\" stroke-width=\"2.5\" stroke-linejoin=\"round\"/>");
                    for (int i = 0; i < trend.Count; i++)
                        svgLine.Append($"<circle cx=\"{lxPos(i).ToString("F1",linv)}\" cy=\"{lyPos(trend[i].RecyclingRate).ToString("F1",linv)}\" r=\"4\" fill=\"#198754\"/>");
                    svgLine.Append($"<polyline points=\"{impropPts}\" fill=\"none\" stroke=\"#dc3545\" stroke-width=\"2.5\" stroke-linejoin=\"round\" stroke-dasharray=\"6 3\"/>");
                    for (int i = 0; i < trend.Count; i++)
                        svgLine.Append($"<circle cx=\"{lxPos(i).ToString("F1",linv)}\" cy=\"{lyPos(trend[i].ImproperRate).ToString("F1",linv)}\" r=\"4\" fill=\"#dc3545\"/>");
                    for (int i = 0; i < trend.Count; i++)
                        svgLine.Append($"<text x=\"{lxPos(i).ToString("F1",linv)}\" y=\"{lH-6}\" text-anchor=\"middle\" font-size=\"9\" fill=\"#555\">{TruncateName(trend[i].Period, 7)}</text>");
                    svgLine.Append($"<line x1=\"{lPadL}\" y1=\"{lPadT+lInnH}\" x2=\"{lW-20}\" y2=\"{lPadT+lInnH}\" stroke=\"#aaa\" stroke-width=\"1\"/>");
                    svgLine.Append($"<line x1=\"{lPadL}\" y1=\"10\" x2=\"{lPadL+20}\" y2=\"10\" stroke=\"#198754\" stroke-width=\"2.5\"/><text x=\"{lPadL+24}\" y=\"14\" font-size=\"10\" fill=\"#333\">Tasa reciclaje</text>");
                    svgLine.Append($"<line x1=\"{lPadL+110}\" y1=\"10\" x2=\"{lPadL+130}\" y2=\"10\" stroke=\"#dc3545\" stroke-width=\"2.5\" stroke-dasharray=\"6 3\"/><text x=\"{lPadL+134}\" y=\"14\" font-size=\"10\" fill=\"#333\">% Impropios</text>");
                    svgLine.Append("</svg>");
                }
                <div class="overflow-auto">@((MarkupString)svgLine.ToString())</div>
            </div>
        </div>
    }

    @* ── Comparativa Multi-SCRAP ──────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header fw-semibold">
            <i class="bi bi-table me-1"></i>Comparativa Multi-SCRAP
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>SCRAP</th>
                            <th class="text-end">Traslados</th>
                            <th class="text-end">Kg tratados</th>
                            <th class="text-end">Tasa reciclaje</th>
                            <th class="text-end">% Impropios</th>
                            <th class="text-end">Incidencias</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _data.ScrapComparison)
                        {
                            <tr>
                                <td>@s.ScrapName</td>
                                <td class="text-end">@s.TotalMoves</td>
                                <td class="text-end">@s.TotalWeightKg.ToString("N0")</td>
                                <td class="text-end">
                                    <span class="badge @RecyclingBadge(s.RecyclingRate)">@s.RecyclingRate.ToString("F1")%</span>
                                </td>
                                <td class="text-end">@s.ImproperRate.ToString("F1")%</td>
                                <td class="text-end">
                                    @if (s.OpenIncidents > 0)
                                    { <span class="badge bg-warning text-dark">@s.OpenIncidents</span> }
                                    else
                                    { <span class="text-muted">0</span> }
                                </td>
                            </tr>
                        }
                        @if (!_data.ScrapComparison.Any())
                        { <tr><td colspan="6" class="text-muted text-center py-3">Sin datos</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ── Distribución operaciones R/D ─────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header fw-semibold">
            <i class="bi bi-diagram-3-fill me-1"></i>Distribución de operaciones de tratamiento R/D
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Descripción</th>
                            <th>Tipo</th>
                            <th class="text-end">Kg tratados</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in _data.OperationsDistribution)
                        {
                            <tr>
                                <td><code>@o.OperationCode</code></td>
                                <td>@o.OperationDescription</td>
                                <td>
                                    <span class="badge @(o.OperationType == "R" ? "bg-success" : "bg-danger")">
                                        @o.OperationType
                                    </span>
                                </td>
                                <td class="text-end">@o.WeightTotal.ToString("N0")</td>
                            </tr>
                        }
                        @if (!_data.OperationsDistribution.Any())
                        { <tr><td colspan="4" class="text-muted text-center py-3">Sin datos</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ── Incidencias abiertas ──────────────────────────────────────────────── *@
    @if (_data.OpenIncidents.Any())
    {
        <div class="card mb-4">
            <div class="card-header fw-semibold text-warning">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>Incidencias de tratamiento abiertas
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Referencia</th>
                                <th>Tipo</th>
                                <th>Severidad</th>
                                <th>Apertura</th>
                                <th class="text-end">Días abierta</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var i in _data.OpenIncidents)
                            {
                                <tr>
                                    <td>
                                        <a href="/incidents/@i.IncidentId">@(i.WasteMoveReference ?? i.IncidentId.ToString()[..8])</a>
                                    </td>
                                    <td>@(i.IncidentType ?? "—")</td>
                                    <td>@(i.Severity ?? "—")</td>
                                    <td>@i.OpenedAt.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end @(i.DaysOpen > 30 ? "text-danger fw-semibold" : "")">@i.DaysOpen</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@code {
    private TRScrapAnalysisDto? _data;
    private bool  _loading      = true;
    private int   _filterYear   = DateTime.Now.Year;
    private int?  _filterMonth  = null;
    private Guid? _filterScrapId;

    private IReadOnlyList<EntitySelectorDto> _scraps = [];

    private static readonly CultureInfo _es = new("es-ES");

    protected override async Task OnInitializedAsync()
    {
        await LoadScrapsAsync();
        await RefreshAsync();
    }

    private async Task LoadScrapsAsync()
    {
        // COORDINATOR: carga todos los SCRAPs; el handler restringe al subconjunto de sus Agreements.
        // SCRAP: no ve el dropdown (lista vacía, solo ve sus propios datos).
        // ADMIN: todos los SCRAPs.
        if (CurrentUser.IsInProfile(ProfileConstants.Coordinator)
            || CurrentUser.IsInProfile(ProfileConstants.Admin))
        {
            _scraps = await Mediator.Send(new GetEntitiesForSelectorQuery([EntityRoles.SCRAP]));
        }
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _data = await Mediator.Send(new GetTRScrapAnalysisQuery(
                Year:   _filterYear,
                Month:  _filterMonth,
                IdScrap: _filterScrapId));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error cargando TR-A ScrapAnalysis");
        }
        finally
        {
            _loading = false;
        }
    }

    private static string RecyclingBadge(double rate) =>
        rate > 70 ? "bg-success" : rate >= 40 ? "bg-warning text-dark" : "bg-danger";

    private static string TrafficLightBadge(string light) => light switch
    {
        "Green"  => "bg-success",
        "Orange" => "bg-warning text-dark",
        _        => "bg-danger"
    };

    private static string FormatKg(double v) =>
        v >= 1_000 ? $"{v / 1_000:F0}t" : $"{v:F0}";

    private static string TruncateName(string name, int max) =>
        name.Length <= max ? name : name[..max] + "…";

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
