@page "/reporting/heat-maps/waste-density"
@attribute [Authorize(Policy = PolicyConstants.CanViewHeatMapWasteDensity)]
@rendermode InteractiveServer
@implements IAsyncDisposable

@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Application.Features.Reporting.HeatMaps.DTOs
@using GreenTransit.Application.Features.Reporting.HeatMaps.Queries
@using GreenTransit.Application.Features.Geography.DTOs
@using GreenTransit.Application.Features.Geography.Queries
@using GreenTransit.Domain.Authorization
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using System.Globalization

@inject IMediator           Mediator
@inject ICurrentUserService CurrentUser
@inject IJSRuntime          JS
@inject NavigationManager   Nav
@inject ILogger<WasteDensityHeatMap> Logger

<PageTitle>Mapa de Calor — Densidad de Residuos — GreenTransit</PageTitle>

<div class="page-header mb-4">
    <div class="page-header-info">
        <h1 class="page-title">
            <i class="bi bi-geo-alt-fill me-2"></i>Mapa de Calor — Densidad de Residuos
        </h1>
        <p class="text-muted mb-0">Dashboard HM-A · SCRAP · @_filterYear</p>
        <p class="text-muted small mt-1">
            Visualización geográfica de la densidad de residuos por punto de recogida.
            Identifica zonas de alta concentración y patrones por tipología.
        </p>
    </div>
    <div class="page-header-actions">
        <button class="btn btn-outline-neutral btn-sm me-2" @onclick="RefreshAsync" disabled="@_loading">
            <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
        </button>
        <button class="btn btn-outline-success btn-sm" @onclick="ExportAsync" disabled="@(_loading || _exporting)">
            @if (_exporting) { <span class="spinner-border spinner-border-sm me-1"></span> }
            <i class="bi bi-file-earmark-excel me-1"></i>Exportar XLSX
        </button>
    </div>
</div>

@* ── Filtros ───────────────────────────────────────────────────────────────── *@
<div class="filter-bar mb-4">
    <div class="filter-group">
        <label>Año</label>
        <select class="form-select form-select-sm" @bind="_filterYear" @bind:after="RefreshAsync">
            @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
            { <option value="@y">@y</option> }
        </select>
    </div>
    <div class="filter-group">
        <label>Mes</label>
        <select class="form-select form-select-sm" @bind="_filterMonth" @bind:after="RefreshAsync">
            <option value="">Todo el año</option>
            @for (int m = 1; m <= 12; m++)
                    { <option value="@m">@MonthName(m)</option> }
        </select>
    </div>
    <div class="filter-group">
        <label>Provincia</label>
        <select class="form-select form-select-sm" @bind="_filterProvince" @bind:after="RefreshAsync">
            <option value="">Todas las provincias</option>
            @foreach (var p in _provinces)
            {
                <option value="@p.Code">@p.Name</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Código LER</label>
        <input class="form-control form-control-sm" @bind="_filterLerCode" @bind:after="RefreshAsync"
               placeholder="ej. 16" />
    </div>
</div>

@if (_loading)
{
    <div class="text-center" style="padding:3rem 0"><div class="spinner spinner-lg"></div></div>
}
else if (_data is null)
{
    <div class="alert alert-warning">No se han podido cargar los datos.</div>
}
else
{
    @* ── KPIs de frecuencia ─────────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-md-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label">Puntos de recogida activos</div>
                    <div class="kpi-value">@_data.HeatMapPoints.Count</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-md-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label">Kg totales recogidos</div>
                    <div class="kpi-value">@FormatKg(_data.HeatMapPoints.Sum(p => p.TotalKg))</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-md-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label">Frecuencia media (rec/punto/mes)</div>
                    <div class="kpi-value">@_data.AvgPickupsPerPointPerMonth.ToString("F2")</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-md-3">
            <div class="card kpi-card h-100 @(_data.AnomalousFrequencyPoints > 0 ? "border-danger" : "")">
                <div class="card-body">
                    <div class="kpi-label">Puntos con frecuencia anómala</div>
                    <div class="kpi-value @(_data.AnomalousFrequencyPoints > 0 ? "text-danger" : "")">
                        @_data.AnomalousFrequencyPoints
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Mapa de calor interactivo ───────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-map me-1"></i>Mapa de Calor de Densidad de Residuos
                </div>
                <div class="card-body p-0">
                    <div id="heatmap-density" style="height:500px;width:100%;"></div>
                </div>
            </div>
        </div>
    </div>

    @* ── Densidad por zona + Tipología ──────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-12 col-lg-7">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-bar-chart-line me-1"></i>Densidad de residuos por zona geográfica
                </div>
                <div class="card-body">
                    @if (!_data.DensityByZone.Any())
                    {
                        <p class="text-muted text-center py-4">Sin datos para el periodo seleccionado.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Zona</th>
                                        <th class="text-end">Recogidas</th>
                                        <th class="text-end">Total kg</th>
                                        <th>Distribución</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ var maxZoneKg = _data.DensityByZone.Max(z => z.TotalKg); }
                                    @foreach (var zone in _data.DensityByZone.Take(15))
                                    {
                                        var pct = maxZoneKg > 0 ? (double)(zone.TotalKg / maxZoneKg * 100) : 0;
                                        <tr>
                                            <td>@zone.ZoneName</td>
                                            <td class="text-end">@zone.PickupCount</td>
                                            <td class="text-end">@FormatKg(zone.TotalKg)</td>
                                            <td style="width:30%">
                                                <div class="progress" style="height:10px">
                                                    <div class="progress-bar bg-success" style="width:@pct.ToString("F0", CultureInfo.InvariantCulture)%"></div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-5">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-pie-chart me-1"></i>Tipología de residuos por código LER
                </div>
                <div class="card-body">
                    <div id="chart-waste-typology-hma" style="min-height:280px;"></div>
                </div>
            </div>
        </div>
    </div>

    @* ── Top 20 puntos de recogida ────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-trophy me-1"></i>Top 20 puntos de recogida por volumen
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Entidad</th>
                                    <th>Municipio</th>
                                    <th>Provincia</th>
                                    <th class="text-end">Kg totales</th>
                                    <th class="text-end">Recogidas</th>
                                    <th class="text-end">Kg/recogida</th>
                                    <th>LER predominante</th>
                                    <th>Semáforo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int rank = 1; }
                                @foreach (var p in _data.TopPickupPoints)
                                {
                                    <tr>
                                        <td>@rank</td>
                                        <td>@p.EntityName</td>
                                        <td>@(p.Municipality ?? "—")</td>
                                        <td>@(p.Province ?? "—")</td>
                                        <td class="text-end">@FormatKg(p.TotalKg)</td>
                                        <td class="text-end">@p.PickupCount</td>
                                        <td class="text-end">@FormatKg(p.AvgKgPerPickup)</td>
                                        <td><small>@(p.PredominantLerCode ?? "—")</small></td>
                                        <td>
                                            <span class="badge @TrafficLightClass(p.TrafficLight)">
                                                @TrafficLightLabel(p.TrafficLight)
                                            </span>
                                        </td>
                                    </tr>
                                    rank++;
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Comparativa de periodos ──────────────────────────────────────────────── *@
    @if (_data.PeriodComparison.Any())
    {
        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-arrow-left-right me-1"></i>Comparativa de densidad entre periodos
                    </div>
                    <div class="card-body">
                        <div id="chart-period-comparison-hma" style="min-height:280px;"></div>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private WasteDensityHeatMapDto?    _data;
    private IReadOnlyList<ProvinceDto> _provinces      = [];
    private bool    _loading        = true;
    private bool    _exporting      = false;
    private bool    _chartsRendered = false;
    private int     _filterYear  = DateTime.Now.Year;
    private int?    _filterMonth = null;
    private string? _filterProvince;
    private string? _filterLerCode;

    private DotNetObjectReference<WasteDensityHeatMap>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
        _provinces = (await Mediator.Send(new GetAllProvincesQuery())).ToList();
        await RefreshAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_data is not null && !_loading && !_chartsRendered)
        {
            _chartsRendered = true;
            await RenderChartsAsync();
        }
    }

    private async Task RefreshAsync()
    {
        _loading        = true;
        _chartsRendered = false;
        StateHasChanged();
        try
        {
            _data = await Mediator.Send(new GetWasteDensityHeatMapQuery(
                Year             : _filterYear,
                Month            : _filterMonth,
                ProvinceCode     : _filterProvince,
                LerCodeFilter    : _filterLerCode));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al cargar datos del mapa de calor de densidad");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task RenderChartsAsync()
    {
        if (_data is null) return;
        try
        {
            // Mapa de calor con Leaflet
            var mapPoints = _data.HeatMapPoints
                .Select(p => new { lat = p.Latitude, lng = p.Longitude, value = (double)p.TotalKg, name = p.EntityName })
                .ToArray();
            await JS.InvokeVoidAsync("heatMapCharts.renderLeafletHeatMap", "heatmap-density", mapPoints);

            // Donut tipología
            var typologyLabels  = _data.WasteTypology.Take(8).Select(t => t.LerCode).ToArray();
            var typologyValues  = _data.WasteTypology.Take(8).Select(t => (double)t.TotalKg).ToArray();
            await JS.InvokeVoidAsync("heatMapCharts.renderDonut", "chart-waste-typology-hma", typologyLabels, typologyValues, "Tipología LER (kg)");

            // Comparativa periodos
            if (_data.PeriodComparison.Any())
            {
                var zoneLabels  = _data.PeriodComparison.Select(p => p.ZoneName).ToArray();
                var periodAKg   = _data.PeriodComparison.Select(p => (double)p.PeriodAKg).ToArray();
                var periodBKg   = _data.PeriodComparison.Select(p => (double)p.PeriodBKg).ToArray();
                await JS.InvokeVoidAsync("heatMapCharts.renderComparisonBar", "chart-period-comparison-hma", zoneLabels, periodAKg, periodBKg);
            }
        }
        catch (Exception ex)
        {
            _chartsRendered = false;   // permitir reintento en el circuito interactivo
            Logger.LogWarning(ex, "Error al renderizar gráficos del mapa de calor de densidad");
        }
    }

    private async Task ExportAsync()
    {
        _exporting = true;
        StateHasChanged();
        try
        {
            var result = await Mediator.Send(new ExportHeatMapDataToExcelQuery(
                Year         : _filterYear,
                Month        : _filterMonth,
                DashboardType: "WasteDensity",
                ProvinceCode : _filterProvince,
                LerCodeFilter: _filterLerCode));
            await JS.InvokeVoidAsync("downloadFile", result.FileName, result.ContentType, result.Content);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al exportar mapa de calor de densidad");
        }
        finally
        {
            _exporting = false;
            StateHasChanged();
        }
    }

    private static string FormatKg(decimal kg) =>
        kg >= 1_000_000 ? $"{kg / 1_000_000:F2} Mt"
        : kg >= 1_000   ? $"{kg / 1_000:F2} t"
        : $"{kg:F0} kg";

    private static string TrafficLightClass(string tl) => tl switch
    {
        "Red"    => "bg-danger",
        "Orange" => "bg-warning text-dark",
        _        => "bg-success"
    };

    private static string TrafficLightLabel(string tl) => tl switch
    {
        "Red"    => "Alto",
        "Orange" => "Medio",
        _        => "Normal"
    };

    private static string MonthName(int m) =>
        new System.DateTime(2000, m, 1).ToString("MMMM", new System.Globalization.CultureInfo("es-ES"));

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        await Task.CompletedTask;
    }
}
