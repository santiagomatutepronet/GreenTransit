@page "/reporting/heat-maps/pattern-analysis"
@attribute [Authorize(Policy = PolicyConstants.CanViewHeatMapPatternAnalysis)]
@rendermode InteractiveServer

@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Application.Features.Geography.DTOs
@using GreenTransit.Application.Features.Geography.Queries
@using GreenTransit.Application.Features.Reporting.HeatMaps.DTOs
@using GreenTransit.Application.Features.Reporting.HeatMaps.Queries
@using GreenTransit.Application.Features.Entities.DTOs
@using GreenTransit.Application.Features.Entities.Queries
@using GreenTransit.Domain.Authorization
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using System.Globalization

@inject IMediator           Mediator
@inject ICurrentUserService CurrentUser
@inject ILogger<WastePatternAnalysis> Logger

<PageTitle>Mapa de Calor — Patrones y Estacionalidad — GreenTransit</PageTitle>

<div class="page-header mb-4">
    <div class="page-header-info">
        <h1 class="page-title">
            <i class="bi bi-calendar3 me-2"></i>Mapa de Calor — Patrones y Estacionalidad
        </h1>
        <p class="text-muted mb-0">Dashboard HM-B · Mapas de Calor · @_filterYear</p>
        <p class="text-muted small mt-1">
            Análisis temporal de los patrones de generación de residuos: estacionalidad,
            tendencias, picos y valles para optimizar la planificación de recogidas.
        </p>
    </div>
    <div class="page-header-actions">
        <button class="btn btn-outline-neutral btn-sm" @onclick="RefreshAsync" disabled="@_loading">
            <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
        </button>
    </div>
</div>

@* ── Filtros ───────────────────────────────────────────────────────────────── *@
<div class="filter-bar mb-4">
    <div class="filter-group">
        <label>Año</label>
        <select class="form-select form-select-sm" @bind="_filterYear" @bind:after="RefreshAsync">
            @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
            { <option value="@y">@y</option> }
        </select>
    </div>
    <div class="filter-group">
        <label>Provincia</label>
        <select class="form-select form-select-sm" @bind="_filterProvinceCode" @bind:after="RefreshAsync">
            <option value="">Todas las provincias</option>
            @foreach (var p in _provinces)
            {
                <option value="@p.Code">@p.Name</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Código LER</label>
        <input class="form-control form-control-sm" @bind="_filterLerCode" @bind:after="RefreshAsync"
               placeholder="ej. 16" />
    </div>
    @if (CurrentUser.IsInAnyProfile("ADMIN", "DISPATCH_OFFICE"))
    {
        <div class="filter-group">
            <label>SCRAP</label>
            <select class="form-select form-select-sm" @bind="_filterIdScrap" @bind:after="RefreshAsync">
                <option value="">Todos los SCRAPs</option>
                @foreach (var s in _scraps)
                {
                    <option value="@s.Id">@s.Name</option>
                }
            </select>
        </div>
    }
</div>

@if (_loading)
{
    <div class="text-center" style="padding:3rem 0"><div class="spinner spinner-lg"></div></div>
}
else if (_data is null)
{
    <div class="alert alert-warning">No se han podido cargar los datos.</div>
}
else
{
    @* ── KPIs: Índice de concentración y alertas ─────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-md-4">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label">Índice de concentración geográfica (Gini)</div>
                    <div class="kpi-value">@_data.ConcentrationIndex.ToString("F4")</div>
                    @if (_data.ConcentrationIndexVariationPct != 0)
                    {
                        <div class="kpi-variation @(_data.ConcentrationIndexVariationPct > 0 ? "text-danger" : "text-success")">
                            @(_data.ConcentrationIndexVariationPct > 0 ? "▲" : "▼")
                            @Math.Abs(_data.ConcentrationIndexVariationPct).ToString("F1")% vs año anterior
                        </div>
                    }
                    <small class="text-muted">
                        Valor alto = residuos concentrados en pocos puntos (mayor riesgo de acumulación).
                    </small>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-md-4">
            <div class="card kpi-card h-100 @(_data.Alerts.Any() ? "border-warning" : "")">
                <div class="card-body">
                    <div class="kpi-label">Alertas de acumulación activas</div>
                    <div class="kpi-value @(_data.Alerts.Any() ? "text-warning" : "text-success")">
                        @_data.Alerts.Count
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Panel de alertas ─────────────────────────────────────────────────────── *@
    @if (_data.Alerts.Any())
    {
        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card border-warning">
                    <div class="card-header text-warning fw-semibold">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i>Alertas de acumulación
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            @foreach (var alert in _data.Alerts)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-start">
                                    <div>
                                        <span class="badge @AlertSeverityClass(alert.Severity) me-2">@SeverityLabel(alert.Severity)</span>
                                        @alert.Message
                                    </div>
                                    <small class="text-muted text-nowrap ms-3">@alert.GeneratedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── Heatmap temporal 12 meses × capítulo LER ────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-grid-3x3 me-1"></i>
                    Heatmap de generación de residuos (12 meses × tipología LER)
                </div>
                <div class="card-body">
                    @if (!_data.TemporalHeatMap.Any())
                    {
                        <p class="text-muted text-center py-4">Sin datos para el periodo seleccionado.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-0" style="font-size:0.78rem">
                                <thead class="table-light">
                                    <tr>
                                        <th>Capítulo LER</th>
                                        @foreach (var mn in Enumerable.Range(1, 12))
                                        {
                                            <th class="text-center">@(new DateTime(2000,mn,1).ToString("MMM",new System.Globalization.CultureInfo("es-ES")))</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ch in _data.TemporalHeatMap.Select(c => c.LerChapter).Distinct().OrderBy(x => x))
                                    {
                                        var maxKg2 = _data.TemporalHeatMap.Max(c => c.TotalKg);
                                        <tr>
                                            <td><small>@ch</small></td>
                                            @foreach (var mn in Enumerable.Range(1, 12))
                                            {
                                                var cell = _data.TemporalHeatMap.FirstOrDefault(c => c.LerChapter == ch && c.Month == mn);
                                                var intensity = cell is not null && maxKg2 > 0 ? (int)(cell.TotalKg / maxKg2 * 100) : 0;
                                                var bgAlpha = (intensity / 100.0).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                                                var fgColor = intensity > 50 ? "white" : "inherit";
                                                <td class="text-center" style="background-color:rgba(25,135,84,@bgAlpha);color:@fgColor">
                                                    @(cell is not null ? $"{cell.TotalKg / 1000m:F0}t" : "")
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ── Tendencia de volumen mensual ─────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-graph-up-arrow me-1"></i>
                    Tendencia de volumen mensual — Top 5 tipologías (con media móvil 3 meses)
                </div>
                <div class="card-body">
                    @if (!_data.MonthlyTrends.Any())
                    {
                        <p class="text-muted text-center py-4">Sin datos de tendencia para el año seleccionado.</p>
                    }
                    else
                    {
                        <AppChart Height="280" ShowLegend="true" CategoryAxisTitle="Mes" ValueAxisTitle="kg">
                            @{ int ti = 0; }
                            @foreach (var trend in _trendSeries)
                            {
                                <RadzenLineSeries Data="@trend.Items" CategoryProperty="Month" ValueProperty="Kg"
                                                  Title="@trend.Name" Stroke="@ChartPalette.GetColor(ti++)" StrokeWidth="2" />
                            }
                        </AppChart>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ── Heatmap semanal 7×24 ────────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-calendar-week me-1"></i>
                    Heatmap semanal de frecuencia de recogidas (día × franja horaria)
                </div>
                <div class="card-body">
                    @if (!_data.WeeklyFrequency.Any())
                    {
                        <p class="text-muted text-center py-4">Sin datos de frecuencia horaria para el año seleccionado.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-0" style="font-size:0.78rem">
                                <thead class="table-light">
                                    <tr>
                                        <th>Hora</th>
                                        @foreach (var d in new[] { "Lun","Mar","Mié","Jue","Vie","Sáb","Dom" }) { <th class="text-center">@d</th> }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var h in _data.WeeklyFrequency.Select(c => c.Hour).Distinct().OrderBy(hh => hh))
                                    {
                                        var maxCount2 = _data.WeeklyFrequency.Max(c => c.PickupCount);
                                        <tr>
                                            <td>@h:00</td>
                                            @for (int d = 0; d < 7; d++)
                                            {
                                                var cell = _data.WeeklyFrequency.FirstOrDefault(c => c.DayOfWeek == d && c.Hour == h);
                                                var pct  = cell is not null && maxCount2 > 0 ? (int)((double)cell.PickupCount / maxCount2 * 100) : 0;
                                                var bgAlpha2 = (pct / 100.0).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                                                var fgColor2 = pct > 50 ? "white" : "inherit";
                                                <td class="text-center" style="background-color:rgba(13,110,253,@bgAlpha2);color:@fgColor2">
                                                    @(cell?.PickupCount > 0 ? cell.PickupCount.ToString() : "")
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private record TrendPoint(string Month, double Kg);
    private record TrendSerie(string Name, List<TrendPoint> Items);

    private WastePatternAnalysisDto?      _data;
    private List<TrendSerie> _trendSeries = [];
    private bool    _loading        = true;
    private int     _filterYear     = DateTime.Now.Year;
    private string? _filterProvinceCode;
    private string? _filterLerCode;
    private string? _filterIdScrap;
    private IReadOnlyList<ProvinceDto>       _provinces = [];
    private IReadOnlyList<EntitySelectorDto> _scraps    = [];

    protected override async Task OnInitializedAsync()
    {
        _provinces = (await Mediator.Send(new GetAllProvincesQuery())).ToList();
        if (CurrentUser.IsInAnyProfile("ADMIN", "DISPATCH_OFFICE"))
            _scraps = await Mediator.Send(new GetEntitiesForSelectorQuery(new[] { EntityRoles.SCRAP }));
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _loading        = true;
        StateHasChanged();
        try
        {
            var idScrap = Guid.TryParse(_filterIdScrap, out var sid) ? (Guid?)sid : null;
            _data = await Mediator.Send(new GetWastePatternAnalysisQuery(
                Year         : _filterYear,
                ProvinceCode : _filterProvinceCode,
                LerCodeFilter: _filterLerCode,
                IdScrap      : idScrap));
            _trendSeries = _data?.MonthlyTrends.Select(t => new TrendSerie(
                t.LerCode,
                t.MonthlyKg.Select((kg, i) => new TrendPoint($"{i+1:00}", (double)kg)).ToList()
            )).ToList() ?? [];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al cargar datos de patrones de residuos");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private static string AlertSeverityClass(string severity) => severity switch
    {
        "High"   => "bg-danger",
        "Medium" => "bg-warning text-dark",
        _        => "bg-info text-dark"
    };

    private static string SeverityLabel(string severity) => severity switch
    {
        "High"   => "Alta",
        "Medium" => "Media",
        _        => "Baja"
    };

    }
