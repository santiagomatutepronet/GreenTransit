@page "/acceso-denegado"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Acceso denegado</PageTitle>

<div style="max-width: 500px; margin: 100px auto; text-align: center; font-family: sans-serif;">
    <h2>Acceso denegado</h2>
    <p style="color: #666; margin: 20px 0;">
        Tu cuenta se ha autenticado correctamente en el servidor de identidad,
        pero no tienes un usuario asignado en GreenTransit.
    </p>
    <p style="color: #666;">
        Contacta con el administrador para que te cree un usuario en el sistema.
    </p>

    @if (!string.IsNullOrEmpty(_errorDetail))
    {
        <details style="margin: 20px 0; text-align: left; background: #f5f5f5; padding: 12px; border-radius: 8px;">
            <summary style="cursor: pointer; font-weight: 500;">Detalle técnico</summary>
            <pre style="font-size: 12px; margin-top: 8px; white-space: pre-wrap;">@_errorDetail</pre>
        </details>
    }

    <a href="/account/logout" style="display: inline-block; margin-top: 20px; padding: 10px 24px;
       background: #dc3545; color: white; border-radius: 6px; text-decoration: none;">
        Cerrar sesión
    </a>
</div>

@code {
    private string? _errorDetail;

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "detail")]
    public string? Detail { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Error))
            _errorDetail = $"Error: {Error}";
        if (!string.IsNullOrEmpty(Detail))
            _errorDetail += $"\nDetalle: {Detail}";
    }
}
