@using Radzen
@using Radzen.Blazor
@page "/waste-moves"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.WasteMoves.DTOs
@using GreenTransit.Application.Features.WasteMoves.Queries
@using GreenTransit.Application.Features.Entities.DTOs
@using GreenTransit.Application.Features.Entities.Queries
@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Application.Common.Models
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator              Mediator
@inject NavigationManager      Nav
@inject IPagePermissionService PagePermissions

<PageTitle>Traslados de Residuos</PageTitle>

<div class="page-header">
    <div class="page-header-info">
        <h1><i class="bi bi-truck me-2"></i>Traslados de Residuos</h1>
        <p>Gestión del ciclo de vida de traslados, desde SOLICITADO hasta CLASIFICADO.</p>
    </div>
    <div class="page-header-actions">
        @if (_canWrite)
        {
            <button class="btn btn-primary btn-sm"
                    @onclick='() => Nav.NavigateTo("/waste-moves/new")'>
                <i class="bi bi-plus-lg me-1"></i>Nuevo Traslado
            </button>
        }
    </div>
</div>

@* ── Panel de filtros ──────────────────────────────────────────────────────── *@
<div class="filter-bar">
    <div class="filter-group">
        <label>Referencia</label>
        <input class="form-control"
               placeholder="WM-2026-…"
               @bind="_search" @bind:event="oninput" />
    </div>
    <div class="filter-group">
        <label>Estado</label>
        <select class="form-control" @bind="_filterStatus">
            <option value="">— Todos —</option>
            @foreach (var s in WasteMoveStatuses.All)
            {
                <option value="@s">@WasteMoveStatuses.Label(s)</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Origen</label>
        <select class="form-control" @bind="_filterSource">
            <option value="">— Todos —</option>
            @foreach (var e in _sourceEntities)
            {
                <option value="@e.Id">@e.Name</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Destino</label>
        <select class="form-control" @bind="_filterDestination">
            <option value="">— Todos —</option>
            @foreach (var e in _destinationEntities)
            {
                <option value="@e.Id">@e.Name</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Recogida desde</label>
        <input type="date" class="form-control"
               @bind="_dateFrom" @bind:format="yyyy-MM-dd" />
    </div>
    <div class="filter-group">
        <label>hasta</label>
        <input type="date" class="form-control"
               @bind="_dateTo" @bind:format="yyyy-MM-dd" />
    </div>
    <div class="filter-actions">
        <button class="btn btn-primary btn-sm" @onclick="SearchAsync">
            <i class="bi bi-search me-1"></i>Buscar
        </button>
        <button class="btn btn-ghost btn-sm" @onclick="ResetFilters">Limpiar</button>
    </div>
</div>

@* ── Tabla ─────────────────────────────────────────────────────────────────── *@
@if (_loading)
{
    <div class="gt-loading"><RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" /></div>
}
else if (_result is null || _result.Items.Count == 0)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">No se encontraron traslados con los filtros aplicados.</RadzenAlert>
}
else
{
    <RadzenDataGrid @ref="_grid" TItem="WasteMoveDto"
                    Data="@_result.Items" Count="@_result.TotalCount"
                    LoadData="@OnLoadData"
                    AllowPaging="true" PageSize="PageSize"
                    AllowSorting="true" AllowFiltering="false"
                    IsLoading="@_loading"
                    EmptyText="No se encontraron traslados."
                    PagerHorizontalAlign="HorizontalAlign.Right">
        <Columns>
            <RadzenDataGridColumn TItem="WasteMoveDto" Property="WasteMoveReference" Title="Referencia" Width="150px">
                <Template Context="wm">
                    <a href="/waste-moves/@wm.Id" class="rz-link rz-text-weight-bold">
                        @(wm.WasteMoveReference ?? wm.Id.ToString()[..8])
                    </a>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="WasteMoveDto" Property="ServiceStatus" Title="Estado" Width="320px">
                <Template Context="wm">
                    <WasteMoveStatusStepper Status="@wm.ServiceStatus" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="WasteMoveDto" Property="SourceName" Title="Origen" Width="160px">
                <Template Context="wm"><span class="rz-text-secondary-color">@(wm.SourceName ?? "—")</span></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="WasteMoveDto" Property="DestinationName" Title="Destino" Width="160px">
                <Template Context="wm"><span class="rz-text-secondary-color">@(wm.DestinationName ?? "—")</span></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="WasteMoveDto" Property="PlannedPickupStart" Title="Recogida planif." Width="130px">
                <Template Context="wm">@(wm.PlannedPickupStart?.ToString("dd/MM/yyyy") ?? "—")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="WasteMoveDto" Property="ResidueCount" Title="Líneas" Width="80px" TextAlign="TextAlign.Right" />
            <RadzenDataGridColumn TItem="WasteMoveDto" Title="" Width="110px" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                <Template Context="wm">
                    @{ var detailUrl = "/waste-moves/" + wm.Id; var editUrl = "/waste-moves/" + wm.Id + "/edit"; }
                    <RadzenButton Icon="visibility" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                  Click="@(() => Nav.NavigateTo(detailUrl))" title="Ver detalle" />
                    <RadzenButton Icon="device_hub" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                  Click="@(() => Nav.NavigateTo("/waste-moves/" + wm.Id + "/timeline"))" title="Vista 360º" />
                    @if (_canWrite && wm.ServiceStatus == WasteMoveStatuses.Solicitado)
                    {
                        <RadzenButton Icon="edit" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                      Click="@(() => Nav.NavigateTo(editUrl))" title="Editar" />
                    }
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    private const int PageSize = 15;

    private RadzenDataGrid<WasteMoveDto> _grid = default!;
    private bool   _loading = true;
    private int    _page    = 1;
    private string _search             = "";
    private string _filterStatus       = "";
    private Guid?  _filterSource;
    private Guid?  _filterDestination;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;

    private PaginatedResult<WasteMoveDto>? _result;
    private IReadOnlyList<EntitySelectorDto> _sourceEntities      = [];
    private IReadOnlyList<EntitySelectorDto> _destinationEntities = [];
    private bool _canWrite;

    protected override async Task OnInitializedAsync()
    {
        _canWrite = await PagePermissions.CanWriteRouteAsync("/waste-moves");
        var all = await Mediator.Send(new GetEntitiesForSelectorQuery());
        _sourceEntities      = all.Where(e => WasteMoveSourceRoles.Valid.Contains(e.EntityRole)).ToList();
        _destinationEntities = all.Where(e => WasteMoveDestinationRoles.Valid.Contains(e.EntityRole)).ToList();
        await SearchAsync();
    }

    private async Task OnLoadData(LoadDataArgs args)
    {
        _page = args.Skip.HasValue ? (args.Skip.Value / PageSize) + 1 : 1;
        await SearchAsync();
    }

    private async Task SearchAsync()
    {
        _loading = true;
        _result  = await Mediator.Send(new GetWasteMovesQuery(
            ServiceStatus : string.IsNullOrWhiteSpace(_filterStatus) ? null : _filterStatus,
            IdSource      : _filterSource,
            IdDestination : _filterDestination,
            DateFrom      : _dateFrom,
            DateTo        : _dateTo,
            SearchTerm    : string.IsNullOrWhiteSpace(_search) ? null : _search,
            PageNumber    : _page,
            PageSize      : PageSize
        ));
        _loading = false;
    }

    private async Task GoPageAsync(int pg)
    {
        _page = pg;
        await SearchAsync();
    }

    private async Task ResetFilters()
    {
        _search            = "";
        _filterStatus      = "";
        _filterSource      = null;
        _filterDestination = null;
        _dateFrom          = null;
        _dateTo            = null;
        _page              = 1;
        await SearchAsync();
        if (_grid is not null) await _grid.Reload();
    }
}
