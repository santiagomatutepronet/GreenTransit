@page "/waste-moves/{WasteMoveId:guid}/timeline"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.WasteMoves.DTOs
@using GreenTransit.Application.Features.WasteMoves.Queries
@using GreenTransit.Application.Features.WasteMoves.Commands
@using GreenTransit.Domain.Constants
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop

@inject IMediator        Mediator
@inject NavigationManager Nav
@inject IJSRuntime       JS

<PageTitle>Vista 360º del Traslado</PageTitle>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner spinner-lg"></div>
    </div>
}
else if (_tl is null)
{
    <div class="alert alert-warning">Traslado no encontrado o sin acceso.</div>
    <button class="btn btn-outline-neutral btn-sm"
            @onclick='() => Nav.NavigateTo("/waste-moves")'>
        <i class="bi bi-arrow-left me-1"></i>Volver al listado
    </button>
}
else
{
    var tl = _tl;

    <div class="page-header">
        <div class="page-header-info">
            <h1 class="page-title">
                <i class="bi bi-diagram-3 me-2"></i>
                Traslado 360º — @(tl.WasteMoveReference ?? WasteMoveId.ToString()[..8])
            </h1>
            <div class="d-flex gap-2 mt-1 flex-wrap">
                <WasteMoveStatusStepper Status="@tl.CurrentStatus"
                                        StatusDates="@tl.StatusDates" />
            </div>
        </div>
        <div class="page-header-actions">
            <button class="btn btn-outline-neutral btn-sm"
                    @onclick='() => Nav.NavigateTo("/waste-moves/" + WasteMoveId)'>
                <i class="bi bi-arrow-left me-1"></i>Ver detalle
            </button>
            <button class="btn btn-outline-primary btn-sm"
                    @onclick="ExportPdfAsync"
                    disabled="@_exportingPdf">
                @if (_exportingPdf)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                else
                {
                    <i class="bi bi-file-earmark-pdf me-1"></i>
                }
                Exportar expediente PDF
            </button>
        </div>
    </div>

    @* ── Incidencia bloqueante ──────────────────────────────────────────── *@
    @if (tl.Incidents.Any(i => i.IsOpen && i.Severity is "High" or "Critical"))
    {
        <div class="alert alert-danger d-flex align-items-center gap-2">
            <i class="bi bi-shield-exclamation fs-5"></i>
            <div>
                <strong>Traslado bloqueado.</strong>
                Hay @(tl.Incidents.Count(i => i.IsOpen && i.Severity is "High" or "Critical"))
                incidencia(s) crítica(s) abiertas que impiden avanzar al siguiente estado.
            </div>
        </div>
    }

    <div class="row g-3">

        @* ── Columna izquierda: timeline de pasos ──────────────────────── *@
        <div class="col-12 col-xl-7">

            @* SO Origen *@
            <TimelineStepCard Icon="bi-file-earmark-text"
                              Title="Orden de Servicio"
                              Date="@tl.ServiceOrder?.IssuedAt"
                              Color="primary"
                              Empty="@(tl.ServiceOrder is null)">
                @if (tl.ServiceOrder is { } so)
                {
                    <div class="row g-2 small">
                        <div class="col-6">
                            <span class="text-muted">Nº SO:</span>
                            <strong class="ms-1">@so.ServiceOrderNumber</strong>
                        </div>
                        <div class="col-6">
                            <span class="text-muted">Estado:</span>
                            <span class="ms-1 badge bg-secondary">@so.Status</span>
                        </div>
                        <div class="col-6">
                            <span class="text-muted">Emisor:</span>
                            <span class="ms-1">@so.IssuedByName</span>
                        </div>
                        <div class="col-6">
                            <span class="text-muted">Flujo:</span>
                            <span class="ms-1">@so.WasteStream</span>
                        </div>
                        @if (!string.IsNullOrEmpty(so.LerCodeCode))
                        {
                            <div class="col-12">
                                <span class="text-muted">LER:</span>
                                <strong class="ms-1">@so.LerCodeCode</strong>
                                <span class="ms-1 text-muted">— @so.LerCodeDescription</span>
                                @if (so.LerCodeIsDangerous)
                                {
                                    <span class="badge bg-danger ms-1">
                                        <i class="bi bi-radioactive me-1"></i>Peligroso
                                    </span>
                                }
                            </div>
                        }
                        @if (so.EstimatedWeight.HasValue)
                        {
                            <div class="col-6">
                                <span class="text-muted">Peso estimado:</span>
                                <strong class="ms-1">@so.EstimatedWeight!.Value.ToString("N0") kg</strong>
                            </div>
                        }
                    </div>
                }
            </TimelineStepCard>

            @* Traslado *@
            <TimelineStepCard Icon="bi-truck"
                              Title="Traslado"
                              Date="@tl.RequestDate"
                              Color="info"
                              Empty="false">
                <div class="row g-2 small">
                    <div class="col-6">
                        <span class="text-muted">Origen:</span>
                        <strong class="ms-1">@(tl.SourceName ?? "—")</strong>
                    </div>
                    <div class="col-6">
                        <span class="text-muted">Destino:</span>
                        <strong class="ms-1">@(tl.DestinationName ?? "—")</strong>
                    </div>
                    @if (!string.IsNullOrEmpty(tl.ScrapName))
                    {
                        <div class="col-6">
                            <span class="text-muted">SCRAP:</span>
                            <span class="ms-1">@tl.ScrapName</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(tl.OperatorTransferName))
                    {
                        <div class="col-6">
                            <span class="text-muted">Operador traslado:</span>
                            <span class="ms-1">@tl.OperatorTransferName</span>
                        </div>
                    }
                    @if (tl.ActualPickupStart.HasValue)
                    {
                        <div class="col-6">
                            <span class="text-muted">Recogida real:</span>
                            <span class="ms-1">@tl.ActualPickupStart!.Value.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(tl.SignatureStatus))
                    {
                        <div class="col-6">
                            <span class="text-muted">Firma:</span>
                            <span class="ms-1 badge @(tl.SignatureStatus == "Signed" ? "bg-success" : "bg-warning text-dark")">
                                @tl.SignatureStatus
                            </span>
                        </div>
                    }
                    @* Residuos del traslado *@
                    @if (tl.Residues.Count > 0)
                    {
                        <div class="col-12 mt-1">
                            <p class="text-muted mb-1 fw-semibold">Líneas de residuo:</p>
                            <table class="table table-sm table-borderless mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Residuo</th>
                                        <th>Kg</th>
                                        <th>DI / NT</th>
                                        <th>Transportista</th>
                                        <th>CO₂ (kg)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in tl.Residues)
                                    {
                                        <tr>
                                            <td>
                                                @(r.ResidueName ?? "—")
                                                @if (r.IsDangerous)
                                                {
                                                    <span class="badge bg-danger ms-1" title="Peligroso">P</span>
                                                }
                                                @if (r.IsRAEE)
                                                {
                                                    <span class="badge bg-warning text-dark ms-1" title="RAEE">R</span>
                                                }
                                            </td>
                                            <td>@(r.Weight?.ToString("N0") ?? "—")</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(r.DINumber))
                                                {
                                                    <span title="DI">@r.DINumber</span>
                                                }
                                                @if (!string.IsNullOrEmpty(r.NTNumber))
                                                {
                                                    <br /><span class="text-muted" title="NT">@r.NTNumber</span>
                                                }
                                            </td>
                                            <td>@(r.CarrierName ?? "—")</td>
                                            <td>@(r.TransportCarbonEmissions?.ToString("N2") ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </TimelineStepCard>

            @* EntryCACs *@
            <TimelineStepCard Icon="bi-building"
                              Title="Centro de Acopio (CAC)"
                              Date="@tl.EntryCACs.FirstOrDefault()?.CACEntryDate"
                              Color="warning"
                              Empty="@(!tl.EntryCACs.Any())"
                              Optional="true">
                @foreach (var cac in tl.EntryCACs)
                {
                    <div class="row g-2 small mb-2">
                        <div class="col-6">
                            <span class="text-muted">Entrada:</span>
                            <span class="ms-1">@cac.CACEntryDate?.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="col-6">
                            <span class="text-muted">Método:</span>
                            <span class="ms-1">@(cac.CollectionMethod ?? "—")</span>
                        </div>
                        <div class="col-12">
                            <span class="text-muted">Residuos:</span>
                            <strong class="ms-1">@cac.Residues.Count línea(s),
                                @cac.Residues.Sum(r => r.Weight ?? 0m).ToString("N0") kg</strong>
                        </div>
                    </div>
                }
            </TimelineStepCard>

            @* EntryPlants *@
            <TimelineStepCard Icon="bi-building-gear"
                              Title="Entrada en Planta — Pesaje"
                              Date="@tl.EntryPlants.FirstOrDefault()?.PlantEntryDate"
                              Color="success"
                              Empty="@(!tl.EntryPlants.Any())">
                @foreach (var ep in tl.EntryPlants)
                {
                    <div class="row g-2 small mb-2">
                        <div class="col-6">
                            <span class="text-muted">Ticket báscula:</span>
                            <strong class="ms-1">@(ep.TicketScale ?? "—")</strong>
                        </div>
                        <div class="col-6">
                            <span class="text-muted">Fecha:</span>
                            <span class="ms-1">@ep.PlantEntryDate?.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="col-4">
                            <span class="text-muted">Bruto:</span>
                            <span class="ms-1">@(ep.GrossWeight?.ToString("N0") ?? "—") kg</span>
                        </div>
                        <div class="col-4">
                            <span class="text-muted">Tara:</span>
                            <span class="ms-1">@(ep.TareWeight?.ToString("N0") ?? "—") kg</span>
                        </div>
                        <div class="col-4">
                            <span class="text-muted">Neto:</span>
                            <strong class="ms-1 text-success">@(ep.NetWeight?.ToString("N0") ?? "—") kg</strong>
                        </div>
                        @if (ep.HasWeightDiscrepancy)
                        {
                            <div class="col-12">
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-exclamation-triangle me-1"></i>Descuadre &gt; 5%
                                </span>
                            </div>
                        }
                    </div>
                }
            </TimelineStepCard>

            @* TreatmentPlants *@
            <TimelineStepCard Icon="bi-recycle"
                              Title="Clasificación y Tratamiento"
                              Date="@tl.TreatmentPlants.FirstOrDefault()?.PlantTreatmentDate"
                              Color="secondary"
                              Empty="@(!tl.TreatmentPlants.Any())">
                @foreach (var tp in tl.TreatmentPlants)
                {
                    <div class="row g-2 small mb-2">
                        <div class="col-6">
                            <span class="text-muted">Operación:</span>
                            <strong class="ms-1">@(tp.TreatmentOperationCode ?? "—")</strong>
                            <span class="text-muted ms-1">@tp.TreatmentOperationDescription</span>
                        </div>
                        <div class="col-6">
                            <span class="text-muted">Tipo:</span>
                            <span class="ms-1 badge @(tp.TreatmentOperationType == "Recovery" ? "bg-success" : "bg-secondary")">
                                @(tp.TreatmentOperationType ?? "—")
                            </span>
                        </div>
                        <div class="col-3">
                            <span class="text-muted d-block">Entrada</span>
                            <strong>@tp.TotalWeightIn.ToString("N0") kg</strong>
                        </div>
                        <div class="col-3">
                            <span class="text-muted d-block">Reutil.</span>
                            <strong class="text-primary">@tp.TotalWeightReused.ToString("N0") kg</strong>
                        </div>
                        <div class="col-3">
                            <span class="text-muted d-block">Valoriz.</span>
                            <strong class="text-success">@tp.TotalWeightValued.ToString("N0") kg</strong>
                        </div>
                        <div class="col-3">
                            <span class="text-muted d-block">Rechazo</span>
                            <strong class="text-danger">@tp.TotalWeightRemove.ToString("N0") kg</strong>
                        </div>
                        <div class="col-12">
                            <div class="progress" style="height:6px">
                                @{
                                    var wIn = tp.TotalWeightIn > 0 ? tp.TotalWeightIn : 1m;
                                }
                                <div class="progress-bar bg-primary"
                                     style="width:@((tp.TotalWeightReused / wIn * 100).ToString("F0"))%"
                                     title="Reutilizado"></div>
                                <div class="progress-bar bg-success"
                                     style="width:@((tp.TotalWeightValued / wIn * 100).ToString("F0"))%"
                                     title="Valorizado"></div>
                                <div class="progress-bar bg-danger"
                                     style="width:@((tp.TotalWeightRemove / wIn * 100).ToString("F0"))%"
                                     title="Rechazo"></div>
                            </div>
                        </div>
                        @if (tp.IsRecycling)
                        {
                            <div class="col-auto">
                                <span class="badge bg-success">
                                    <i class="bi bi-recycle me-1"></i>Reciclaje
                                </span>
                            </div>
                        }
                        @if (tp.IsEnergyRecovery)
                        {
                            <div class="col-auto">
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-lightning me-1"></i>Valorización energética
                                </span>
                            </div>
                        }
                        @if (tp.IsPreparationForReuse)
                        {
                            <div class="col-auto">
                                <span class="badge bg-primary">
                                    <i class="bi bi-arrow-repeat me-1"></i>Prep. reutilización
                                </span>
                            </div>
                        }
                    </div>
                }
            </TimelineStepCard>

        </div>

        @* ── Columna derecha: paneles de soporte ───────────────────────── *@
        <div class="col-12 col-xl-5">

            @* Mapa *@
            <div class="card mb-3">
                <div class="card-header">
                    <h6 class="mb-0">
                        <i class="bi bi-geo-alt me-2"></i>Mapa de origen y destino
                    </h6>
                </div>
                <div class="card-body p-0">
                    <div id="waste-move-map" style="height:260px;border-radius:0 0 .375rem .375rem"></div>
                </div>
            </div>

            @* KPI Huella CO₂ *@
            <div class="card mb-3 border-success">
                <div class="card-header bg-success-subtle">
                    <h6 class="mb-0 text-success">
                        <i class="bi bi-tree me-2"></i>Huella de CO₂
                    </h6>
                </div>
                <div class="card-body">
                    <div class="fs-4 fw-bold text-success">
                        @tl.TotalCO2EmissionsKg.ToString("N2") kgCO₂e
                    </div>
                    @if (tl.Residues.Any(r => r.TransportCarbonEmissions.HasValue))
                    {
                        <table class="table table-sm mt-2 mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Transportista</th>
                                    <th>Vehículo</th>
                                    <th class="text-end">kgCO₂e</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in tl.Residues.Where(r => r.TransportCarbonEmissions.HasValue))
                                {
                                    <tr>
                                        <td>@(r.CarrierName ?? "—")</td>
                                        <td>@(r.VehicleRegistration ?? r.VehicleType ?? "—")</td>
                                        <td class="text-end">@r.TransportCarbonEmissions!.Value.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>

            @* Documentos *@
            <div class="card mb-3">
                <div class="card-header">
                    <h6 class="mb-0">
                        <i class="bi bi-folder2-open me-2"></i>Documentos del expediente
                    </h6>
                </div>
                <div class="card-body p-2">
                    @{
                        var docs = BuildDocumentList(tl);
                    }
                    @if (!docs.Any())
                    {
                        <p class="text-muted small mb-0">Sin documentos registrados.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var doc in docs)
                            {
                                <li class="list-group-item px-2 py-1 d-flex align-items-start gap-2">
                                    <i class="bi bi-file-earmark-text text-primary mt-1"></i>
                                    <div class="small">
                                        <div class="fw-semibold">@doc.Label</div>
                                        @if (!string.IsNullOrEmpty(doc.Reference))
                                        {
                                            <div class="text-muted">Ref: @doc.Reference</div>
                                        }
                                        @if (!string.IsNullOrEmpty(doc.Hash))
                                        {
                                            <div class="text-muted font-monospace" style="font-size:.65rem"
                                                 title="Hash SHA">
                                                @doc.Hash[..Math.Min(doc.Hash.Length, 20)]…
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(doc.Status))
                                        {
                                            <span class="badge @(doc.Status == "Signed" ? "bg-success" : "bg-warning text-dark")">
                                                @doc.Status
                                            </span>
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            @* Incidencias *@
            @if (tl.Incidents.Any())
            {
                <div class="card mb-3 border-warning">
                    <div class="card-header bg-warning-subtle">
                        <h6 class="mb-0 text-warning-emphasis">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Incidencias (@tl.Incidents.Count)
                        </h6>
                    </div>
                    <div class="card-body p-2">
                        <ul class="list-group list-group-flush">
                            @foreach (var inc in tl.Incidents)
                            {
                                <li class="list-group-item px-2 py-2">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <span class="badge @SeverityBadge(inc.Severity) me-2">
                                                @inc.Severity
                                            </span>
                                            <strong class="small">@inc.Type</strong>
                                        </div>
                                        @if (inc.IsOpen)
                                        {
                                            <span class="badge bg-danger">Abierta</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Cerrada</span>
                                        }
                                    </div>
                                    <div class="text-muted small mt-1">@inc.Description</div>
                                    <div class="text-muted" style="font-size:.7rem">
                                        @inc.OpenedAt.ToString("dd/MM/yyyy HH:mm")
                                        @if (!string.IsNullOrEmpty(inc.ReportedByName))
                                        {
                                            <span class="ms-2">· @inc.ReportedByName</span>
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }

            @* Liquidaciones *@
            @if (tl.SettlementLines.Any())
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <h6 class="mb-0">
                            <i class="bi bi-receipt me-2"></i>Liquidaciones vinculadas
                        </h6>
                    </div>
                    <div class="card-body p-2">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Liquidación</th>
                                    <th>LER</th>
                                    <th class="text-end">Kg</th>
                                    <th class="text-end">Importe</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sl in tl.SettlementLines)
                                {
                                    <tr>
                                        <td class="small">@(sl.SettlementNumber ?? sl.SettlementId.ToString()[..8])</td>
                                        <td class="small">@(sl.LerCodeCode ?? "—")</td>
                                        <td class="text-end small">@sl.WeightKg.ToString("N0")</td>
                                        <td class="text-end small">@sl.Amount.ToString("C")</td>
                                        <td>
                                            <span class="badge @SettlementStatusBadge(sl.SettlementStatus)">
                                                @sl.SettlementStatus
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

        </div>
    </div>
}

@code {
    [Parameter] public Guid WasteMoveId { get; set; }

    private WasteMoveTimelineDto? _tl;
    private bool _loading    = true;
    private bool _exportingPdf = false;

    protected override async Task OnInitializedAsync()
    {
        _tl = await Mediator.Send(new GetWasteMoveTimelineQuery(WasteMoveId));
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _tl is not null)
        {
            await InitMapAsync(_tl);
        }
    }

    private async Task InitMapAsync(WasteMoveTimelineDto tl)
    {
        try
        {
            double srcLat = 0, srcLng = 0, dstLat = 0, dstLng = 0;
                double.TryParse(tl.SourceLatitude,       System.Globalization.NumberStyles.Any,
                    System.Globalization.CultureInfo.InvariantCulture, out srcLat);
                double.TryParse(tl.SourceLongitude,      System.Globalization.NumberStyles.Any,
                    System.Globalization.CultureInfo.InvariantCulture, out srcLng);
                double.TryParse(tl.DestinationLatitude,  System.Globalization.NumberStyles.Any,
                    System.Globalization.CultureInfo.InvariantCulture, out dstLat);
                double.TryParse(tl.DestinationLongitude, System.Globalization.NumberStyles.Any,
                    System.Globalization.CultureInfo.InvariantCulture, out dstLng);

            await JS.InvokeVoidAsync("wasteMoveMap.init",
                "waste-move-map",
                srcLat, srcLng, tl.SourceName ?? "",
                dstLat, dstLng, tl.DestinationName ?? "");
        }
        catch { /* Leaflet no disponible en prerender */ }
    }

    private async Task ExportPdfAsync()
    {
        if (_tl is null) return;
        _exportingPdf = true;
        try
        {
            await Mediator.Send(new ExportWasteMoveTimelinePdfCommand(WasteMoveId));
            Nav.NavigateTo($"/waste-moves/{WasteMoveId}/timeline/pdf", forceLoad: true);
        }
        finally
        {
            _exportingPdf = false;
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private record DocItem(string Label, string? Reference, string? Hash, string? Status);

    private List<DocItem> BuildDocumentList(WasteMoveTimelineDto tl)
    {
        var list = new List<DocItem>();

        if (!string.IsNullOrEmpty(tl.DocumentId))
            list.Add(new DocItem("Documento del traslado", tl.DocumentId,
                tl.DocumentHash, tl.SignatureStatus));

        foreach (var r in tl.Residues)
        {
            if (!string.IsNullOrEmpty(r.DINumber))
                list.Add(new DocItem($"DI — {r.ResidueName}", r.DINumber, null, r.DIPhase));
            if (!string.IsNullOrEmpty(r.NTNumber))
                list.Add(new DocItem($"NT — {r.ResidueName}", r.NTNumber, null, null));
        }

        foreach (var ep in tl.EntryPlants)
            if (!string.IsNullOrEmpty(ep.TicketScale))
                list.Add(new DocItem("Ticket de báscula", ep.TicketScale, null, null));

        foreach (var tp in tl.TreatmentPlants)
            if (!string.IsNullOrEmpty(tp.TicketScale))
                list.Add(new DocItem("Certificado de tratamiento", tp.TicketScale, null,
                    tp.TreatmentOperationCode));

        return list;
    }

    private static string SeverityBadge(string? severity) => severity switch
    {
        "Critical" => "bg-danger",
        "High"     => "bg-orange text-dark",
        "Medium"   => "bg-warning text-dark",
        _          => "bg-secondary"
    };

    private static string SettlementStatusBadge(string? status) => status switch
    {
        "Approved" => "bg-success",
        "Rejected" => "bg-danger",
        "Pending"  => "bg-warning text-dark",
        _          => "bg-secondary"
    };
}
