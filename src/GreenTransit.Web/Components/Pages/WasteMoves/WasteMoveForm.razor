@page "/waste-moves/new"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.WasteMoves.Commands
@using GreenTransit.Application.Features.WasteMoves.DTOs
@using GreenTransit.Application.Features.ServiceOrders.DTOs
@using GreenTransit.Application.Features.ServiceOrders.Queries
@using GreenTransit.Application.Features.ServiceOrders.DTOs
@using GreenTransit.Application.Features.Entities.DTOs
@using GreenTransit.Application.Features.Entities.Queries
@using GreenTransit.Application.Features.Residues.DTOs
@using GreenTransit.Application.Features.Residues.Queries
@using GreenTransit.Application.Common.Models
@using GreenTransit.Domain.Constants
@using GreenTransit.Domain.Authorization
@using GreenTransit.Application.Common.Interfaces
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator              Mediator
@inject NavigationManager      Nav
@inject ICurrentUserService    CurrentUser

<PageTitle>Nuevo Traslado de Residuos</PageTitle>

<div class="page-header">
    <div class="page-header-info">
        <h1><i class="bi bi-truck me-2"></i>Nuevo Traslado de Residuos</h1>
        <p>Agrupa una o varias Órdenes de Servicio. Define residuo y cantidad por cada línea.</p>
    </div>
</div>

@if (_loading)
{
    <div class="text-center" style="padding:3rem 0">
        <div class="spinner spinner-lg"></div>
    </div>
}
else
{
    <EditForm Model="_formModel" OnValidSubmit="SaveAsync">

        @* ── 1. Órdenes de Servicio ──────────────────────────────────────── *@
        <div class="form-section">
            <div class="form-section-title">
                <i class="bi bi-clipboard2-check form-section-title-icon"></i>
                Órdenes de Servicio a agrupar
            </div>

            @if (_eligibleSOs.Count == 0)
            {
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle-fill alert-icon"></i>
                    <div class="alert-content">
                        No hay Órdenes de Servicio disponibles (Pendiente/Planificada sin traslado asignado).
                    </div>
                </div>
            }
            else
            {
                <div class="table-wrapper mb-3">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th style="width:40px"></th>
                                <th>Nº Orden</th>
                                <th>Estado</th>
                                <th>Código LER</th>
                                <th class="cell-number">Peso est.</th>
                                <th>Unid. medida</th>
                                <th>Recogida planif.</th>
                                <th>Punto recogida</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var so in _eligibleSOs)
                            {
                                var isSelected = _lines.Any(l => l.SoId == so.Id);
                                <tr class="@(isSelected ? "selected" : "")"
                                    style="cursor:pointer"
                                    @onclick="async () => await ToggleSoAsync(so)">
                                    <td @onclick:stopPropagation>
                                        <input type="checkbox" checked="@isSelected"
                                               @onchange="async () => await ToggleSoAsync(so)" />
                                    </td>
                                    <td class="font-semibold">@so.ServiceOrderNumber</td>
                                    <td>
                                        <span class="@ServiceOrderStatuses.BadgeCss(so.Status)">
                                            @ServiceOrderStatuses.Label(so.Status)
                                        </span>
                                    </td>
                                    <td class="cell-muted">
                                        @if (!string.IsNullOrEmpty(so.LerCodesDisplay))
                                        {
                                            <span>@so.LerCodesDisplay</span>
                                        }
                                        else if (so.LerCodeCode != null)
                                        {
                                            <span title="@so.LerCodeDescription">@so.LerCodeCode</span>
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </td>
                                    <td class="cell-number">
                                        @(so.EstimatedWeight.HasValue ? $"{so.EstimatedWeight:N0} kg" : "—")
                                    </td>
                                    <td class="cell-muted">@(so.MeasureUnit?.ToString() ?? "—")</td>
                                    <td class="cell-muted">
                                        @(so.PlannedPickupStart?.ToString("dd/MM/yyyy") ?? "—")
                                    </td>
                                    <td class="cell-muted">@(so.PickupPointName ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (_lines.Count == 0)
                {
                    <div class="field-error">Selecciona al menos una Orden de Servicio.</div>
                }
            }
        </div>

        @* ── 2. Líneas de residuos (agrupadas por SO) ───────────────────── *@
        @if (_lines.Count > 0)
        {
            var includedCount = _lines.Count(l => l.IsIncluded);
            <div class="form-section">
                <div class="form-section-title">
                    <i class="bi bi-list-ul form-section-title-icon"></i>
                    Líneas de residuos
                    <span class="badge badge-neutral ms-2">@includedCount incluida@(includedCount == 1 ? "" : "s")</span>
                </div>
                <p class="cell-muted mb-3">
                    Marca las líneas que deseas incluir en el traslado. Para cada línea activa,
                    selecciona el residuo concreto y ajusta la cantidad.
                    Los residuos disponibles están filtrados por el código LER de la línea.
                </p>

                @foreach (var soGroup in _lines.GroupBy(l => l.SoId))
                {
                    var soLines     = soGroup.ToList();
                    var soNumber    = soLines[0].SoNumber;
                    var multiLine   = soLines.Count > 1;

                    <div class="card mb-3">
                        <div class="card-header d-flex align-items-center gap-3">
                            <span class="font-semibold"><i class="bi bi-clipboard2-check me-1"></i>@soNumber</span>
                            @if (multiLine)
                            {
                                <span class="badge badge-neutral">@soLines.Count líneas</span>
                            }
                        </div>

                        @foreach (var line in soLines)
                        {
                            <div class="card-body border-top py-3 @(!line.IsIncluded ? "opacity-50" : "")">
                                <div class="row g-3 align-items-center">

                                    @* Checkbox incluir línea *@
                                    @if (multiLine)
                                    {
                                        <div class="col-auto d-flex align-items-center">
                                            <input type="checkbox"
                                                   checked="@line.IsIncluded"
                                                   @onchange="e => line.IsIncluded = (bool)(e.Value ?? true)" />
                                            <span class="ms-2 cell-muted" style="white-space:nowrap">
                                                Línea @(line.SortOrder + 1)
                                            </span>
                                        </div>
                                    }

                                    @* Código LER *@
                                    @if (line.LerCodeCode != null)
                                    {
                                        <div class="col-auto">
                                            <span class="badge badge-neutral" title="@line.LerCodeDescription">
                                                <i class="bi bi-tag me-1"></i>@line.LerCodeCode
                                            </span>
                                        </div>
                                    }

                                    @* Selector de residuo *@
                                    <div class="col-md-4">
                                        <label>Residuo</label>
                                        @if (line.LoadingResidues)
                                        {
                                            <div class="d-flex align-items-center gap-2 mt-1">
                                                <div class="spinner spinner-sm"></div>
                                                <span class="cell-muted">Cargando residuos…</span>
                                            </div>
                                        }
                                        else if (line.AvailableResidues.Count == 0)
                                        {
                                            <div class="alert alert-info py-1 px-2 mt-1">
                                                No hay residuos con el código LER
                                                <strong>@(line.LerCodeCode ?? "—")</strong>.
                                                Puedes continuar sin asignar residuo.
                                            </div>
                                        }
                                        else
                                        {
                                            <select class="form-control"
                                                    value="@(line.IdResidue?.ToString() ?? "")"
                                                    disabled="@(!line.IsIncluded)"
                                                    @onchange="e => OnResidueChanged(line, e.Value?.ToString())">
                                                <option value="">— Sin especificar —</option>
                                                @foreach (var r in line.AvailableResidues)
                                                {
                                                    <option value="@r.Id">
                                                        @r.Name
                                                        @(r.IsDangerous ? " ⚠️ Peligroso" : "")
                                                        @(r.IsRAEE ? " ♻️ RAEE" : "")
                                                    </option>
                                                }
                                            </select>
                                        }
                                    </div>

                                    @* Peso *@
                                    <div class="col-md-2">
                                        <label>Peso (kg)</label>
                                        <input type="number" class="form-control"
                                               min="0" step="0.001"
                                               placeholder="0,000"
                                               disabled="@(!line.IsIncluded)"
                                               value="@line.Weight"
                                               @onchange="e => line.Weight = ParseDecimal(e.Value?.ToString())" />
                                    </div>

                                    @* Unidades *@
                                    <div class="col-md-2">
                                        <label>Unidades</label>
                                        <input type="number" class="form-control"
                                               min="0" step="1"
                                               placeholder="0"
                                               disabled="@(!line.IsIncluded)"
                                               value="@line.Units"
                                               @onchange="e => line.Units = ParseInt(e.Value?.ToString())" />
                                    </div>

                                </div>
                            </div>
                        }
                    </div>
                }

                @if (includedCount == 0)
                {
                    <div class="field-error">Debes incluir al menos una línea de residuo.</div>
                }
            </div>
        }

        @* ── 3. Entidades implicadas ─────────────────────────────────────── *@
        <div class="form-section">
            <div class="form-section-title">
                <i class="bi bi-building form-section-title-icon"></i>
                Entidades del traslado
            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label>
                        Origen <span class="required">*</span>
                        <span class="field-help">Roles: @string.Join(", ", WasteMoveSourceRoles.Valid)</span>
                    </label>
                    <select class="form-control" @bind="_formModel.IdSource">
                        <option value="">— Seleccionar —</option>
                        @foreach (var e in _sourceEntities)
                        {
                            <option value="@e.Id">@e.Name (@EntityRoles.Label(e.EntityRole))</option>
                        }
                    </select>
                    <FieldMessage Field="IdSource" Errors="_validationErrors" />
                </div>

                <div class="col-md-4">
                    <label>
                        Destino <span class="required">*</span>
                        <span class="field-help">Roles: @string.Join(", ", WasteMoveDestinationRoles.Valid)</span>
                    </label>
                    <select class="form-control" @bind="_formModel.IdDestination">
                        <option value="">— Seleccionar —</option>
                        @foreach (var e in _destinationEntities)
                        {
                            <option value="@e.Id">@e.Name (@EntityRoles.Label(e.EntityRole))</option>
                        }
                    </select>
                    <FieldMessage Field="IdDestination" Errors="_validationErrors" />
                </div>

                <div class="col-md-4">
                    <label>SCRAP <span class="required">*</span></label>
                    @if (_isScrapProfile)
                    {
                        <input class="form-control" readonly
                               value="@(_scrapEntities.FirstOrDefault(e => e.Id == _formModel.IdScrap)?.Name ?? "—")" />
                    }
                    else
                    {
                        <select class="form-control" @bind="_formModel.IdScrap">
                            <option value="">— Seleccionar —</option>
                            @foreach (var e in _scrapEntities)
                            {
                                <option value="@e.Id">@e.Name</option>
                            }
                        </select>
                    }
                    <FieldMessage Field="IdScrap" Errors="_validationErrors" />
                </div>

                <div class="col-md-4">
                    <label>SCRAP secundario (opcional)</label>
                    <select class="form-control" @bind="_formModel.IdScrap2">
                        <option value="">— Ninguno —</option>
                        @foreach (var e in _scrapEntities)
                        {
                            <option value="@e.Id">@e.Name</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        @* ── 4. Fechas planificadas ──────────────────────────────────────── *@
        <div class="form-section">
            <div class="form-section-title">
                <i class="bi bi-calendar3 form-section-title-icon"></i>
                Fechas planificadas (opcionales)
            </div>

            <div class="row g-3">
                <div class="col-md-3">
                    <label>Inicio recogida</label>
                    <input type="datetime-local" class="form-control"
                           value="@(_formModel.PlannedPickupStart?.ToString("yyyy-MM-ddTHH:mm") ?? "")"
                           @onchange="e => _formModel.PlannedPickupStart = ParseDate(e.Value?.ToString())" />
                </div>
                <div class="col-md-3">
                    <label>Fin recogida</label>
                    <input type="datetime-local" class="form-control"
                           value="@(_formModel.PlannedPickupEnd?.ToString("yyyy-MM-ddTHH:mm") ?? "")"
                           @onchange="e => _formModel.PlannedPickupEnd = ParseDate(e.Value?.ToString())" />
                    <FieldMessage Field="PlannedPickupEnd" Errors="_validationErrors" />
                </div>
                <div class="col-md-3">
                    <label>Inicio entrega</label>
                    <input type="datetime-local" class="form-control"
                           value="@(_formModel.PlannedDeliveryStart?.ToString("yyyy-MM-ddTHH:mm") ?? "")"
                           @onchange="e => _formModel.PlannedDeliveryStart = ParseDate(e.Value?.ToString())" />
                    <FieldMessage Field="PlannedDeliveryStart" Errors="_validationErrors" />
                </div>
                <div class="col-md-3">
                    <label>Fin entrega</label>
                    <input type="datetime-local" class="form-control"
                           value="@(_formModel.PlannedDeliveryEnd?.ToString("yyyy-MM-ddTHH:mm") ?? "")"
                           @onchange="e => _formModel.PlannedDeliveryEnd = ParseDate(e.Value?.ToString())" />
                </div>
            </div>
        </div>

        @* ── Errores y acciones ──────────────────────────────────────────── *@
        @if (_validationErrors.Any())
        {
            <div class="alert alert-danger mt-3">
                <ul class="mb-0">
                    @foreach (var err in _validationErrors.Values.SelectMany(v => v))
                    {
                        <li>@err</li>
                    }
                </ul>
            </div>
        }

        @if (!string.IsNullOrEmpty(_serverError))
        {
            <div class="alert alert-danger mt-3">@_serverError</div>
        }

        <div class="form-actions">
            <button type="submit" class="btn btn-primary" disabled="@_saving">
                @if (_saving) { <span class="spinner spinner-sm me-1"></span> }
                <i class="bi bi-truck me-1"></i>Crear Traslado
            </button>
            <button type="button" class="btn btn-outline-neutral"
                    @onclick='() => Nav.NavigateTo("/waste-moves")'>
                Cancelar
            </button>
        </div>

    </EditForm>
}

@code {
    private bool    _loading = true;
    private bool    _saving  = false;
    private string? _serverError;
    private Dictionary<string, List<string>> _validationErrors = new();

    // ── Modelo de cabecera del formulario ─────────────────────────────────────
    private sealed class HeaderModel
    {
        public Guid?     IdSource             { get; set; }
        public Guid?     IdDestination        { get; set; }
        public Guid?     IdScrap              { get; set; }
        public Guid?     IdScrap2             { get; set; }
        public DateTime? PlannedPickupStart   { get; set; }
        public DateTime? PlannedPickupEnd     { get; set; }
        public DateTime? PlannedDeliveryStart { get; set; }
        public DateTime? PlannedDeliveryEnd   { get; set; }
    }

    // ── Modelo de línea de residuo ────────────────────────────────────────────
    private sealed class LineModel
    {
        public Guid     SoId               { get; init; }
        public string   SoNumber           { get; init; } = "";
        public Guid?    SoResidueId        { get; init; }   // ID de la línea de residuo de la SO (null si no procede de una línea concreta)
        public int      SortOrder          { get; init; }
        public Guid?    IdLerCode          { get; init; }
        public string?  LerCodeCode        { get; init; }
        public string?  LerCodeDescription { get; init; }
        public bool     IsIncluded         { get; set; } = true;
        public bool     LoadingResidues    { get; set; } = true;
        public List<ResidueDto> AvailableResidues { get; set; } = [];

        public Guid?    IdResidue   { get; set; }
        public decimal? Weight      { get; set; }
        public string?  MeasureUnit { get; set; }
        public int?     Units       { get; set; }
    }

    private readonly HeaderModel _formModel = new();
    private readonly List<LineModel> _lines = [];

    // Caché de residuos por LER code para no recargar si ya se cargaron
    private readonly Dictionary<Guid, List<ResidueDto>> _residueCache = new();

    private bool _isScrapProfile;

    private IReadOnlyList<ServiceOrderDto>   _eligibleSOs         = [];
    private IReadOnlyList<EntitySelectorDto> _sourceEntities      = [];
    private IReadOnlyList<EntitySelectorDto> _destinationEntities = [];
    private IReadOnlyList<EntitySelectorDto> _scrapEntities       = [];

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var allSOs = await Mediator.Send(new GetServiceOrdersQuery(PageSize: 500));
        _eligibleSOs = allSOs.Items
            .Where(s => s.Status is ServiceOrderStatuses.Pending
                                 or ServiceOrderStatuses.Scheduled
                      && string.IsNullOrEmpty(s.WasteMoveReference))
            .ToList();

        var allEntities = await Mediator.Send(new GetEntitiesForSelectorQuery());
        _sourceEntities      = allEntities.Where(e => WasteMoveSourceRoles.Valid.Contains(e.EntityRole)).ToList();
        _destinationEntities = allEntities.Where(e => WasteMoveDestinationRoles.Valid.Contains(e.EntityRole)).ToList();
        _scrapEntities       = allEntities.Where(e => e.EntityRole == EntityRoles.SCRAP).ToList();

        // Perfil SCRAP: prefijar entidad vinculada y bloquear el campo
        _isScrapProfile = CurrentUser.IsInProfile(ProfileConstants.Scrap);
        if (_isScrapProfile && CurrentUser.LinkedEntityId.HasValue)
            _formModel.IdScrap = CurrentUser.LinkedEntityId.Value;

        _loading = false;
    }

    // ── Eventos ───────────────────────────────────────────────────────────────

    private async Task ToggleSoAsync(ServiceOrderDto so)
    {
        // Si ya está seleccionada, eliminar todas sus líneas
        var existingLines = _lines.Where(l => l.SoId == so.Id).ToList();
        if (existingLines.Count > 0)
        {
            foreach (var l in existingLines) _lines.Remove(l);
            return;
        }

        // Autocompletar Origen con el punto de recogida de la SO (primera SO seleccionada)
        if (_formModel.IdSource is null && so.IdPickupPoint.HasValue)
            _formModel.IdSource = so.IdPickupPoint.Value;

        // Obtener el detalle de la SO para acceder a todas sus líneas de residuo
        var detail = await Mediator.Send(new GetServiceOrderByIdQuery(so.Id));

        if (detail is not null && detail.Residues.Count > 0)
        {
            // Crear una LineModel por cada línea de residuo de la SO.
            // Carga secuencial para evitar race conditions en la caché y
            // llamadas concurrentes a StateHasChanged en Blazor Server.
            foreach (var residue in detail.Residues)
            {
                var line = new LineModel
                {
                    SoId               = so.Id,
                    SoNumber           = so.ServiceOrderNumber,
                    SoResidueId        = residue.Id,
                    SortOrder          = residue.SortOrder,
                    IdLerCode          = residue.IdLERCode,
                    LerCodeCode        = residue.LerCodeCode,
                    LerCodeDescription = residue.LerCodeDescription,
                    LoadingResidues    = true,
                    IsIncluded         = true,
                    Weight             = residue.EstimatedWeight,
                    MeasureUnit        = "Kg",
                    Units              = residue.Units
                };
                _lines.Add(line);
                await LoadResiduesForLineAsync(line);
            }
        }
        else
        {
            // Fallback: SO sin líneas de residuo — crear una línea desde la cabecera
            var line = new LineModel
            {
                SoId               = so.Id,
                SoNumber           = so.ServiceOrderNumber,
                SortOrder          = 0,
                IdLerCode          = so.IdLERCode,
                LerCodeCode        = so.LerCodeCode,
                LerCodeDescription = so.LerCodeDescription,
                LoadingResidues    = true,
                IsIncluded         = true,
                Weight             = so.EstimatedWeight,
                MeasureUnit        = "Kg",
                Units              = null
            };
            _lines.Add(line);
            await LoadResiduesForLineAsync(line);
        }
    }

    private async Task LoadResiduesForLineAsync(LineModel line)
    {
        line.LoadingResidues = true;
        StateHasChanged();

        if (line.IdLerCode.HasValue)
        {
            if (!_residueCache.TryGetValue(line.IdLerCode.Value, out var cached))
            {
                var result = await Mediator.Send(new GetResiduesQuery(
                    IdLERCode: line.IdLerCode.Value,
                    PageSize : 200
                ));
                cached = result.Items.ToList();
                _residueCache[line.IdLerCode.Value] = cached;
            }
            line.AvailableResidues = cached;
        }
        else
        {
            line.AvailableResidues = [];
        }

        line.LoadingResidues = false;
        StateHasChanged();
    }

    private void OnResidueChanged(LineModel line, string? value)
    {
        line.IdResidue = Guid.TryParse(value, out var id) ? id : null;

        // Precargar medida del residuo seleccionado si el usuario no ha tocado el campo
        // MeasureUnit siempre fijo a Kg, no se sobreescribe
    }

    private async Task SaveAsync()
    {
        _validationErrors.Clear();
        _serverError = null;

        if (_lines.Count == 0)
        {
            _validationErrors["ServiceOrderIds"] = ["Selecciona al menos una Orden de Servicio."];
            return;
        }
        if (_formModel.IdSource is null)
        {
            _validationErrors["IdSource"] = ["El origen es obligatorio."];
            return;
        }
        if (_formModel.IdDestination is null)
        {
            _validationErrors["IdDestination"] = ["El destino es obligatorio."];
            return;
        }
        if (_formModel.IdScrap is null)
        {
            _validationErrors["IdScrap"] = ["El SCRAP es obligatorio."];
            return;
        }

        // Validar que haya al menos una línea incluida
        if (!_lines.Any(l => l.IsIncluded))
        {
            _validationErrors["Lines"] = ["Debes incluir al menos una línea de residuo."];
            return;
        }

        _saving = true;
        try
        {
            var includedLines = _lines.Where(l => l.IsIncluded).ToList();
            var soIds = includedLines.Select(l => l.SoId).Distinct().ToArray();
            var lineInputs = includedLines.Select(l => new WasteMoveLineInput(
                IdResidue   : l.IdResidue,
                Weight      : l.Weight,
                MeasureUnit : l.MeasureUnit,
                Units       : l.Units
            )).ToArray();

            var cmd = new CreateWasteMoveCommand(
                ServiceOrderIds      : soIds,
                IdSource             : _formModel.IdSource.Value,
                IdDestination        : _formModel.IdDestination.Value,
                IdScrap              : _formModel.IdScrap.Value,
                IdScrap2             : _formModel.IdScrap2,
                PlannedPickupStart   : _formModel.PlannedPickupStart,
                PlannedPickupEnd     : _formModel.PlannedPickupEnd,
                PlannedDeliveryStart : _formModel.PlannedDeliveryStart,
                PlannedDeliveryEnd   : _formModel.PlannedDeliveryEnd,
                Lines                : lineInputs
            );

            var newId = await Mediator.Send(cmd);
            Nav.NavigateTo($"/waste-moves/{newId}");
        }
        catch (FluentValidation.ValidationException vex)
        {
            foreach (var err in vex.Errors)
            {
                var key = err.PropertyName;
                if (!_validationErrors.ContainsKey(key))
                    _validationErrors[key] = [];
                _validationErrors[key].Add(err.ErrorMessage);
            }
        }
        catch (Exception ex)
        {
            _serverError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    // ── Helpers de parsing ────────────────────────────────────────────────────

    private static DateTime? ParseDate(string? value)
        => DateTime.TryParse(value, out var dt) ? dt : null;

    private static decimal? ParseDecimal(string? value)
        => decimal.TryParse(value, System.Globalization.NumberStyles.Any,
               System.Globalization.CultureInfo.InvariantCulture, out var d) ? d : null;

    private static int? ParseInt(string? value)
        => int.TryParse(value, out var i) ? i : null;
}
