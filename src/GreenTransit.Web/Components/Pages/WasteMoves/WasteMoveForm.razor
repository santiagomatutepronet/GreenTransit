@page "/waste-moves/new"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.WasteMoves.Commands
@using GreenTransit.Application.Features.WasteMoves.DTOs
@using GreenTransit.Application.Features.ServiceOrders.DTOs
@using GreenTransit.Application.Features.ServiceOrders.Queries
@using GreenTransit.Application.Features.ServiceOrders.DTOs
@using GreenTransit.Application.Features.Entities.DTOs
@using GreenTransit.Application.Features.Entities.Queries
@using GreenTransit.Application.Features.Residues.DTOs
@using GreenTransit.Application.Features.Residues.Queries
@using GreenTransit.Application.Common.Models
@using GreenTransit.Domain.Constants
@using GreenTransit.Domain.Authorization
@using GreenTransit.Application.Common.Interfaces
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using Radzen
@using Radzen.Blazor

@inject IMediator              Mediator
@inject NavigationManager      Nav
@inject ICurrentUserService    CurrentUser

<PageTitle>Nuevo Traslado de Residuos</PageTitle>

<div class="page-header">
    <div class="page-header-info">
        <h1><i class="bi bi-truck me-2"></i>Nuevo Traslado de Residuos</h1>
        <p>Agrupa una o varias Órdenes de Servicio. Define residuo y cantidad por cada línea.</p>
    </div>
</div>

@if (_loading)
{
    <LoadingSpinner />
}
else
{
    <RadzenTemplateForm TItem="HeaderModel" Data="@_formModel" Submit="@SaveAsync">

        @* ── 1. Órdenes de Servicio ──────────────────────────────────────── *@
        <RadzenFieldset Text="Órdenes de Servicio a agrupar" class="rz-mb-4">
            @if (_eligibleSOs.Count == 0)
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning">
                    No hay Órdenes de Servicio disponibles (Pendiente/Planificada sin traslado asignado).
                </RadzenAlert>
            }
            else
            {
                <RadzenDropDown TValue="IEnumerable<Guid>" 
                                Multiple="true" 
                                Chips="true" 
                                MaxSelectedLabels="4" 
                                Data="@_eligibleSOs" 
                                ValueProperty="Id" 
                                @bind-Value="@_selectedSoIds"
                                Change="@OnSOsSelectionChanged"
                                AllowFiltering="true" 
                                AllowVirtualization="true"
                                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" 
                                Placeholder="— Seleccionar Órdenes de Servicio —" 
                                Style="width:100%">
                    <Template Context="soItem">
                        <span><strong>@(((EligibleServiceOrderDto)soItem).ServiceOrderNumber)</strong> — @(((EligibleServiceOrderDto)soItem).LerCodeCode ?? "Sin LER") — @(((EligibleServiceOrderDto)soItem).EstimatedWeight?.ToString("N0") ?? "—") kg</span>
                    </Template>
                </RadzenDropDown>

                @if (_lines.Count == 0)
                {
                    <small class="rz-color-danger d-block mt-2">Selecciona al menos una Orden de Servicio.</small>
                }
            }
        </RadzenFieldset>

        @* ── 2. Líneas de residuos ─────────────────────────────────────── *@
        @if (_lines.Count > 0)
        {
            var includedCount = _lines.Count(l => l.IsIncluded);
            <RadzenFieldset Text="@($"Líneas de residuos ({includedCount} incluida{(includedCount == 1 ? "" : "s")})")" class="rz-mb-4">
                <p class="rz-text-secondary-color rz-mb-4">
                    Marca las líneas que deseas incluir. Para cada línea activa, selecciona el residuo y ajusta la cantidad.
                </p>

                @foreach (var soGroup in _lines.GroupBy(l => l.SoId))
                {
                    var soLines   = soGroup.ToList();
                    var soNumber  = soLines[0].SoNumber;
                    var multiLine = soLines.Count > 1;

                    <div class="card rz-mb-3">
                        <div class="card-header d-flex align-items-center gap-3">
                            <span class="font-semibold"><i class="bi bi-clipboard2-check me-1"></i>@soNumber</span>
                            @if (multiLine) { <RadzenBadge Text="@($"{soLines.Count} líneas")" /> }
                        </div>

                        @foreach (var line in soLines)
                        {
                            <div class="card-body border-top py-3 @(!line.IsIncluded ? "opacity-50" : "")">
                                <RadzenRow Gap="1rem" AlignItems="AlignItems.Center">
                                    @if (multiLine)
                                    {
                                        <RadzenColumn Size="12" SizeMD="1">
                                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                                <RadzenCheckBox TValue="bool" @bind-Value="line.IsIncluded" />
                                                <span class="cell-muted">Línea @(line.SortOrder + 1)</span>
                                            </RadzenStack>
                                        </RadzenColumn>
                                    }
                                    @if (line.LerCodeCode != null)
                                    {
                                        <RadzenColumn Size="12" SizeMD="2">
                                            <RadzenBadge Text="@line.LerCodeCode" Title="@line.LerCodeDescription" />
                                        </RadzenColumn>
                                    }
                                    <RadzenColumn Size="12" SizeMD="4">
                                        <RadzenFormField Text="Residuo" Variant="Variant.Outlined" Style="width:100%">
                                            <ChildContent>
                                                @if (line.LoadingResidues)
                                                {
                                                    <RadzenTextBox Value="Cargando residuos…" ReadOnly="true" Style="width:100%" />
                                                }
                                                else if (line.AvailableResidues.Count == 0)
                                                {
                                                    <RadzenTextBox Value="@($"Sin residuos para LER {line.LerCodeCode ?? "—"}")" ReadOnly="true" Style="width:100%" />
                                                }
                                                else
                                                {
                                                    <RadzenDropDown TValue="Guid?" @bind-Value="line.IdResidue"
                                                                    Data="@line.AvailableResidues" TextProperty="Name" ValueProperty="Id"
                                                                    Disabled="@(!line.IsIncluded)" AllowClear="true"
                                                                    AllowFiltering="true" AllowVirtualization="true"
                                                                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                                                    Placeholder="â€” Sin especificar â€”" Style="width:100%" />
                                                }
                                            </ChildContent>
                                        </RadzenFormField>
                                    </RadzenColumn>
                                    <RadzenColumn Size="6" SizeMD="2">
                                        <RadzenFormField Text="Peso (kg)" Variant="Variant.Outlined" Style="width:100%">
                                            <ChildContent>
                                                <RadzenNumeric TValue="decimal?" @bind-Value="line.Weight"
                                                               Min="0" Format="0.000" Disabled="@(!line.IsIncluded)" Style="width:100%" />
                                            </ChildContent>
                                        </RadzenFormField>
                                    </RadzenColumn>
                                    <RadzenColumn Size="6" SizeMD="2">
                                        <RadzenFormField Text="Unidades" Variant="Variant.Outlined" Style="width:100%">
                                            <ChildContent>
                                                <RadzenNumeric TValue="int?" @bind-Value="line.Units"
                                                               Min="0" Step="1" Disabled="@(!line.IsIncluded)" Style="width:100%" />
                                            </ChildContent>
                                        </RadzenFormField>
                                    </RadzenColumn>
                                </RadzenRow>
                            </div>
                        }
                    </div>
                }
                @if (includedCount == 0)
                {
                    <small class="rz-color-danger">Debes incluir al menos una línea de residuo.</small>
                }
            </RadzenFieldset>
        }

        @* ── 3. Entidades implicadas ──────────────────────────────────── *@
        <RadzenFieldset Text="Entidades del traslado" class="rz-mb-4">
            <RadzenRow Gap="1rem">
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="Origen *" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="Guid?" Name="IdSource" @bind-Value="_formModel.IdSource"
                                            Data="@_sourceEntities" TextProperty="Name" ValueProperty="Id"
                                            AllowFiltering="true" AllowClear="true" AllowVirtualization="true"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            Placeholder="— Seleccionar —" Style="width:100%" />
                        </ChildContent>
                        <Helper><RadzenRequiredValidator Component="IdSource" Text="Obligatorio" /></Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="Destino *" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="Guid?" Name="IdDestination" @bind-Value="_formModel.IdDestination"
                                            Data="@_destinationEntities" TextProperty="Name" ValueProperty="Id"
                                            AllowFiltering="true" AllowClear="true" AllowVirtualization="true"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            Placeholder="— Seleccionar —" Style="width:100%" />
                        </ChildContent>
                        <Helper><RadzenRequiredValidator Component="IdDestination" Text="Obligatorio" /></Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="SCRAP *" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            @if (_isScrapProfile)
                            {
                                <RadzenTextBox Style="width:100%" ReadOnly="true"
                                               Value="@(_scrapEntities.FirstOrDefault(e => e.Id == _formModel.IdScrap)?.Name ?? "—")" />
                            }
                            else
                            {
                                <RadzenDropDown TValue="Guid?" Name="IdScrap" @bind-Value="_formModel.IdScrap"
                                                Data="@_scrapEntities" TextProperty="Name" ValueProperty="Id"
                                                AllowClear="true" AllowFiltering="true" AllowVirtualization="true"
                                                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                                Placeholder="— Seleccionar —" Style="width:100%" />
                            }
                        </ChildContent>
                        <Helper><RadzenRequiredValidator Component="IdScrap" Text="Obligatorio" /></Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="4">
                    <RadzenFormField Text="SCRAP secundario (opcional)" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDropDown TValue="Guid?" Name="IdScrap2" @bind-Value="_formModel.IdScrap2"
                                            Data="@_scrapEntities" TextProperty="Name" ValueProperty="Id"
                                            AllowClear="true" AllowFiltering="true" AllowVirtualization="true"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            Placeholder="— Ninguno —" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        @* ── 4. Fechas planificadas ───────────────────────────────────── *@
        <RadzenFieldset Text="Fechas planificadas (opcionales)" class="rz-mb-4">
            <RadzenRow Gap="1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Inicio recogida" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDatePicker TValue="DateTime?" @bind-Value="_formModel.PlannedPickupStart"
                                              ShowTime="true" HourFormat="24" DateFormat="dd/MM/yyyy HH:mm" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Fin recogida" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDatePicker TValue="DateTime?" @bind-Value="_formModel.PlannedPickupEnd"
                                              ShowTime="true" HourFormat="24" DateFormat="dd/MM/yyyy HH:mm" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Inicio entrega" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDatePicker TValue="DateTime?" @bind-Value="_formModel.PlannedDeliveryStart"
                                              ShowTime="true" HourFormat="24" DateFormat="dd/MM/yyyy HH:mm" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeMD="3">
                    <RadzenFormField Text="Fin entrega" Variant="Variant.Outlined" Style="width:100%">
                        <ChildContent>
                            <RadzenDatePicker TValue="DateTime?" @bind-Value="_formModel.PlannedDeliveryEnd"
                                              ShowTime="true" HourFormat="24" DateFormat="dd/MM/yyyy HH:mm" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        @* ── Errores y acciones ──────────────────────────────────────── *@
        @if (_validationErrors.Any())
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" class="rz-mt-4">
                <ul class="mb-0">
                    @foreach (var err in _validationErrors.Values.SelectMany(v => v))
                    {
                        <li>@err</li>
                    }
                </ul>
            </RadzenAlert>
        }
        @if (!string.IsNullOrEmpty(_serverError))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" class="rz-mt-4">@_serverError</RadzenAlert>
        }

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" class="rz-mt-4">
            <RadzenButton ButtonType="ButtonType.Submit" Text="Crear Traslado" Icon="local_shipping"
                          ButtonStyle="ButtonStyle.Primary" Disabled="@_saving" IsBusy="@_saving" />
            <RadzenButton Text="Cancelar" Icon="cancel" ButtonStyle="ButtonStyle.Light"
                          ButtonType="ButtonType.Button" Click="@(_ => Nav.NavigateTo("/waste-moves"))" />
        </RadzenStack>

    </RadzenTemplateForm>
}

@code {
    private bool    _loading = true;
    private bool    _saving  = false;
    private string? _serverError;
    private Dictionary<string, List<string>> _validationErrors = new();

    // ── Modelo de cabecera del formulario ──────────────────────────────
    private sealed class HeaderModel
    {
        public Guid?     IdSource             { get; set; }
        public Guid?     IdDestination        { get; set; }
        public Guid?     IdScrap              { get; set; }
        public Guid?     IdScrap2             { get; set; }
        public DateTime? PlannedPickupStart   { get; set; }
        public DateTime? PlannedPickupEnd     { get; set; }
        public DateTime? PlannedDeliveryStart { get; set; }
        public DateTime? PlannedDeliveryEnd   { get; set; }
    }

    // â”€â”€ Modelo de lÃ­nea de residuo â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private sealed class LineModel
    {
        public Guid     SoId               { get; init; }
        public string   SoNumber           { get; init; } = "";
        public Guid?    SoResidueId        { get; init; }   // ID de la lÃ­nea de residuo de la SO (null si no procede de una lÃ­nea concreta)
        public int      SortOrder          { get; init; }
        public Guid?    IdLerCode          { get; init; }
        public string?  LerCodeCode        { get; init; }
        public string?  LerCodeDescription { get; init; }
        public bool     IsIncluded         { get; set; } = true;
        public bool     LoadingResidues    { get; set; } = true;
        public List<ResidueDto> AvailableResidues { get; set; } = [];

        public Guid?    IdResidue   { get; set; }
        public decimal? Weight      { get; set; }
        public string?  MeasureUnit { get; set; }
        public int?     Units       { get; set; }
    }

    private readonly HeaderModel _formModel = new();
    private readonly List<LineModel> _lines = [];

    // CachÃ© de residuos por LER code para no recargar si ya se cargaron
    private readonly Dictionary<Guid, List<ResidueDto>> _residueCache = new();

    private bool _isScrapProfile;

    [Parameter, SupplyParameterFromQuery(Name = "serviceOrderId")]
    public Guid? PreselectedServiceOrderId { get; set; }

    // Valor del dropdown de SOs (permite preselección programática)
    private IEnumerable<Guid> _selectedSoIds = [];

    private IReadOnlyList<EligibleServiceOrderDto> _eligibleSOs         = [];
    private IReadOnlyList<EntitySelectorDto>       _sourceEntities      = [];
    private IReadOnlyList<EntitySelectorDto>       _destinationEntities = [];
    private IReadOnlyList<EntitySelectorDto>       _scrapEntities       = [];

    // â”€â”€ Lifecycle â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    protected override async Task OnInitializedAsync()
    {
        // Roles necesarios para los tres selectores de entidades (unión sin duplicados).
        var roles = WasteMoveSourceRoles.Valid
            .Concat(WasteMoveDestinationRoles.Valid)
            .Append(EntityRoles.SCRAP)
            .Distinct()
            .ToArray();

        // Lanzar ambas consultas en paralelo: cada Mediator.Send resuelve su propio
        // IApplicationDbContext (registrado Transient sobre IDbContextFactory),
        // por lo que es seguro ejecutarlas concurrentemente.
        // Para las SOs usamos una query ligera (sin Count, sin subqueries Sum/Join,
        // sólo los campos que pinta el dropdown).
        var sosTask      = Mediator.Send(new GetEligibleServiceOrdersForWasteMoveQuery());
        var entitiesTask = Mediator.Send(new GetEntitiesForSelectorQuery(roles));

        await Task.WhenAll(sosTask, entitiesTask);

        _eligibleSOs         = sosTask.Result;
        var allEntities      = entitiesTask.Result;
        _sourceEntities      = allEntities.Where(e => WasteMoveSourceRoles.Valid.Contains(e.EntityRole)).ToList();
        _destinationEntities = allEntities.Where(e => WasteMoveDestinationRoles.Valid.Contains(e.EntityRole)).ToList();
        _scrapEntities       = allEntities.Where(e => e.EntityRole == EntityRoles.SCRAP).ToList();

        // Perfil SCRAP: prefijar entidad vinculada y bloquear el campo
        _isScrapProfile = CurrentUser.IsInProfile(ProfileConstants.Scrap);
        if (_isScrapProfile && CurrentUser.LinkedEntityId.HasValue)
            _formModel.IdScrap = CurrentUser.LinkedEntityId.Value;

        // Si se llegó desde el detalle de una SO, preseleccionarla automáticamente
        if (PreselectedServiceOrderId.HasValue &&
            _eligibleSOs.Any(s => s.Id == PreselectedServiceOrderId.Value))
        {
            _selectedSoIds = [PreselectedServiceOrderId.Value];
            await OnSOsSelectionChanged(_selectedSoIds);
        }

        _loading = false;
    }

    // ── Eventos ────────────────────────────────────────────────────────────

    private async Task OnSOsSelectionChanged(object value)
    {
        var selectedIds = ((IEnumerable<Guid>?)value)?.ToList() ?? [];

        // Eliminar líneas de SOs que ya no están seleccionadas
        var toRemove = _lines.Where(l => !selectedIds.Contains(l.SoId)).ToList();
        foreach (var l in toRemove) _lines.Remove(l);

        // Determinar las SOs realmente nuevas
        var currentSoIds = _lines.Select(l => l.SoId).Distinct().ToHashSet();
        var newSoIds = selectedIds.Where(id => !currentSoIds.Contains(id)).ToList();
        if (newSoIds.Count == 0) return;

        // ── 1 sola consulta para TODAS las líneas de residuo de las nuevas SOs.
        var residuesTask = Mediator.Send(
            new GetServiceOrderResiduesByIdsQuery(newSoIds));

        // ── Autocompletar origen con el pickup point de la primera SO seleccionada
        //    (si aún no se ha rellenado).
        if (_formModel.IdSource is null)
        {
            var firstWithPickup = newSoIds
                .Select(id => _eligibleSOs.FirstOrDefault(s => s.Id == id))
                .FirstOrDefault(s => s is not null && s.IdPickupPoint.HasValue);
            if (firstWithPickup is not null)
                _formModel.IdSource = firstWithPickup.IdPickupPoint;
        }

        var residues = await residuesTask;

        // ── Crear las LineModel agrupadas por SO. Si una SO no trae residuos,
        //    se crea una línea desde la cabecera (igual que antes).
        var residuesBySo = residues.GroupBy(r => r.IdServiceOrder)
                                   .ToDictionary(g => g.Key, g => g.ToList());

        foreach (var soId in newSoIds)
        {
            var so = _eligibleSOs.FirstOrDefault(s => s.Id == soId);
            if (so is null) continue;

            if (residuesBySo.TryGetValue(soId, out var soResidues) && soResidues.Count > 0)
            {
                foreach (var residue in soResidues)
                {
                    _lines.Add(new LineModel
                    {
                        SoId               = so.Id,
                        SoNumber           = so.ServiceOrderNumber,
                        SoResidueId        = residue.Id,
                        SortOrder          = residue.SortOrder,
                        IdLerCode          = residue.IdLERCode,
                        LerCodeCode        = residue.LerCodeCode,
                        LerCodeDescription = residue.LerCodeDescription,
                        LoadingResidues    = true,
                        IsIncluded         = true,
                        Weight             = residue.EstimatedWeight,
                        MeasureUnit        = "Kg",
                        Units              = residue.Units
                    });
                }
            }
            else
            {
                _lines.Add(new LineModel
                {
                    SoId               = so.Id,
                    SoNumber           = so.ServiceOrderNumber,
                    SortOrder          = 0,
                    IdLerCode          = so.IdLERCode,
                    LerCodeCode        = so.LerCodeCode,
                    LerCodeDescription = so.LerCodeDescription,
                    LoadingResidues    = true,
                    IsIncluded         = true,
                    Weight             = so.EstimatedWeight,
                    MeasureUnit        = "Kg",
                    Units              = null
                });
            }
        }

        // ── Cargar los catálogos de residuos por LER. Se cachea por LER code,
        //    se piden en paralelo los que falten y se reutilizan para todas las
        //    líneas que comparten LER (caso muy común con varias SOs del mismo
        //    productor).
        var missingLers = _lines
            .Where(l => l.LoadingResidues && l.IdLerCode.HasValue && !_residueCache.ContainsKey(l.IdLerCode.Value))
            .Select(l => l.IdLerCode!.Value)
            .Distinct()
            .ToList();

        if (missingLers.Count > 0)
        {
            var fetchTasks = missingLers.Select(async lerId =>
            {
                var result = await Mediator.Send(new GetResiduesQuery(IdLERCode: lerId, PageSize: 200));
                return (lerId, items: result.Items.ToList());
            }).ToArray();

            var fetched = await Task.WhenAll(fetchTasks);
            foreach (var (lerId, items) in fetched)
                _residueCache[lerId] = items;
        }

        foreach (var line in _lines.Where(l => l.LoadingResidues))
        {
            line.AvailableResidues = line.IdLerCode.HasValue && _residueCache.TryGetValue(line.IdLerCode.Value, out var cached)
                ? cached
                : [];
            line.LoadingResidues = false;
        }

        StateHasChanged();
    }

    private void OnResidueChanged(LineModel line, string? value)
    {
        line.IdResidue = Guid.TryParse(value, out var id) ? id : null;

        // Precargar medida del residuo seleccionado si el usuario no ha tocado el campo
        // MeasureUnit siempre fijo a Kg, no se sobreescribe
    }

    private async Task SaveAsync()
    {
        _validationErrors.Clear();
        _serverError = null;

        if (_lines.Count == 0)
        {
            _validationErrors["ServiceOrderIds"] = ["Selecciona al menos una Orden de Servicio."];
            return;
        }
        if (_formModel.IdSource is null)
        {
            _validationErrors["IdSource"] = ["El origen es obligatorio."];
            return;
        }
        if (_formModel.IdDestination is null)
        {
            _validationErrors["IdDestination"] = ["El destino es obligatorio."];
            return;
        }
        if (_formModel.IdScrap is null)
        {
            _validationErrors["IdScrap"] = ["El SCRAP es obligatorio."];
            return;
        }

        // Validar que haya al menos una lÃ­nea incluida
        if (!_lines.Any(l => l.IsIncluded))
        {
            _validationErrors["Lines"] = ["Debes incluir al menos una lÃ­nea de residuo."];
            return;
        }

        _saving = true;
        try
        {
            var includedLines = _lines.Where(l => l.IsIncluded).ToList();
            var soIds = includedLines.Select(l => l.SoId).Distinct().ToArray();
            var lineInputs = includedLines.Select(l => new WasteMoveLineInput(
                IdResidue   : l.IdResidue,
                IdLerCode   : l.IdLerCode,
                Weight      : l.Weight,
                MeasureUnit : l.MeasureUnit,
                Units       : l.Units
            )).ToArray();

            var cmd = new CreateWasteMoveCommand(
                ServiceOrderIds      : soIds,
                IdSource             : _formModel.IdSource.Value,
                IdDestination        : _formModel.IdDestination.Value,
                IdScrap              : _formModel.IdScrap.Value,
                IdScrap2             : _formModel.IdScrap2,
                PlannedPickupStart   : _formModel.PlannedPickupStart,
                PlannedPickupEnd     : _formModel.PlannedPickupEnd,
                PlannedDeliveryStart : _formModel.PlannedDeliveryStart,
                PlannedDeliveryEnd   : _formModel.PlannedDeliveryEnd,
                Lines                : lineInputs
            );

            var newId = await Mediator.Send(cmd);
            Nav.NavigateTo($"/waste-moves/{newId}");
        }
        catch (FluentValidation.ValidationException vex)
        {
            foreach (var err in vex.Errors)
            {
                var key = err.PropertyName;
                if (!_validationErrors.ContainsKey(key))
                    _validationErrors[key] = [];
                _validationErrors[key].Add(err.ErrorMessage);
            }
        }
        catch (Exception ex)
        {
            _serverError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    // â”€â”€ Helpers de parsing â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    private static DateTime? ParseDate(string? value)
        => DateTime.TryParse(value, out var dt) ? dt : null;

    private static decimal? ParseDecimal(string? value)
        => decimal.TryParse(value, System.Globalization.NumberStyles.Any,
               System.Globalization.CultureInfo.InvariantCulture, out var d) ? d : null;

    private static int? ParseInt(string? value)
        => int.TryParse(value, out var i) ? i : null;
}
