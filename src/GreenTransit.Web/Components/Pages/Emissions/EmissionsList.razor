@using Radzen
@using Radzen.Blazor
@page "/emissions"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.Emissions.Commands
@using GreenTransit.Application.Features.Emissions.Queries
@using GreenTransit.Application.Common.Interfaces
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator                                                       Mediator
@inject GreenTransit.Application.Common.Interfaces.ICurrentUserService CurrentUser

<PageTitle>Emisiones CO₂</PageTitle>

<div class="page-header">
    <div class="page-header-info">
        <h1 class="page-title">
            <i class="bi bi-cloud-haze2-fill me-2 text-secondary"></i>Emisiones CO₂ — Traslados
        </h1>
        <p class="page-subtitle text-muted small mb-0">
            Huella de carbono (Scope 3) de los traslados de residuos calculada con el set de factores activo
        </p>
    </div>
    @if (_isAdmin)
    {
        <div class="page-header-actions">
            <button class="btn btn-outline-warning btn-sm" @onclick="ConfirmRecalculate"
                    disabled="@_recalculating">
                @if (_recalculating)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                else
                {
                    <i class="bi bi-arrow-repeat me-1"></i>
                }
                Recalcular todo
            </button>
        </div>
    }
</div>

@* ── Filtros ──────────────────────────────────────────────────────────────── *@
<div class="card mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-6 col-md-3">
                <label class="form-label form-label-sm mb-1">Desde</label>
                <input type="date" class="form-control form-control-sm" @bind="_dateFrom" />
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label form-label-sm mb-1">Hasta</label>
                <input type="date" class="form-control form-control-sm" @bind="_dateTo" />
            </div>
            <div class="col-auto">
                <button class="btn btn-primary btn-sm" @onclick="FilterAsync">
                    <i class="bi bi-search me-1"></i>Filtrar
                </button>
            </div>
        </div>
    </div>
</div>

@* ── KPI cards ────────────────────────────────────────────────────────────── *@
@if (_summary is not null)
{
    <div class="row g-3 mb-3">
        <div class="col-12 col-sm-4">
            <div class="card border-0 bg-light h-100">
                <div class="card-body text-center py-3">
                    <div class="text-muted small mb-1">Total CO₂e</div>
                    <div class="fw-bold fs-4 text-danger">
                        @(_summary.TotalKgCO2e >= 1000
                            ? $"{_summary.TotalKgCO2e / 1000:N2} tCO₂e"
                            : $"{_summary.TotalKgCO2e:N1} kgCO₂e")
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-4">
            <div class="card border-0 bg-light h-100">
                <div class="card-body text-center py-3">
                    <div class="text-muted small mb-1">Traslados con emisión</div>
                    <div class="fw-bold fs-4">@_summary.TotalMoves</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-4">
            <div class="card border-0 bg-light h-100">
                <div class="card-body text-center py-3">
                    <div class="text-muted small mb-1">Líneas de residuo</div>
                    <div class="fw-bold fs-4">@_summary.TotalLines</div>
                </div>
            </div>
        </div>
    </div>
}

@* ── Tabla ────────────────────────────────────────────────────────────────── *@
@if (_loading)
{
    <LoadingSpinner />
}
else if (_summary is null || _summary.Page.Items.Count == 0)
{
    <RadzenAlert AlertStyle="AlertStyle.Light" class="text-center">
        Sin traslados con emisiones calculadas para los filtros seleccionados.<br />
        <span class="rz-text-secondary-color rz-text-sm">
            Las emisiones se calculan al confirmar la recogida de un traslado.
            @if (_isAdmin) { <span> Usa <strong>Recalcular todo</strong> para forzar el cálculo de traslados existentes.</span> }
        </span>
    </RadzenAlert>
}
else
{
    <RadzenDataGrid TItem="EmissionSummaryLineDto"
                    Data="@_summary.Page.Items" Count="@_summary.Page.TotalCount"
                    AllowPaging="false" AllowSorting="true" AllowFiltering="false"
                    EmptyText="Sin emisiones calculadas.">
        <Columns>
            <RadzenDataGridColumn TItem="EmissionSummaryLineDto" Property="WasteMoveReference" Title="Referencia" Width="140px">
                <Template Context="line">
                    <span class="font-monospace rz-text-weight-bold rz-text-sm">
                        @(line.WasteMoveReference ?? line.WasteMoveId.ToString("N")[..8].ToUpper())
                    </span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="EmissionSummaryLineDto" Property="ServiceStatus" Title="Estado" Width="110px">
                <Template Context="line">
                    <span class="badge @StatusBadge(line.ServiceStatus)">@line.ServiceStatus</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="EmissionSummaryLineDto" Property="GatheredDate" Title="Fecha recogida" Width="130px">
                <Template Context="line">@(line.GatheredDate?.ToString("dd/MM/yyyy") ?? "—")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="EmissionSummaryLineDto" Property="TotalDistanceKm" Title="Distancia (km)" Width="120px" TextAlign="TextAlign.Right">
                <Template Context="line">@line.TotalDistanceKm.ToString("N0")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="EmissionSummaryLineDto" Property="TotalKgCO2e" Title="CO₂e (kg)" Width="110px" TextAlign="TextAlign.Right">
                <Template Context="line"><strong class="rz-color-danger">@line.TotalKgCO2e.ToString("N2")</strong></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="EmissionSummaryLineDto" Title="CO₂e (t)" Width="100px" TextAlign="TextAlign.Right">
                <Template Context="line"><span class="rz-text-secondary-color rz-text-sm">@((line.TotalKgCO2e / 1000m).ToString("N4"))</span></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="EmissionSummaryLineDto" Property="EmissionFactorVersion" Title="Set factores" Width="100px">
                <Template Context="line">v@line.EmissionFactorVersion</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="EmissionSummaryLineDto" Property="ResidueLines" Title="Líneas" Width="80px" TextAlign="TextAlign.Center" />
        </Columns>
    </RadzenDataGrid>

    <div class="d-flex justify-content-between align-items-center mt-2">
        <small class="rz-text-secondary-color">@_summary.Page.TotalCount traslado(s) con emisiones calculadas</small>
        @if (_summary.Page.TotalPages > 1)
        {
            <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-secondary" disabled="@(!_summary.Page.HasPrevious)" @onclick="() => GoPageAsync(_page - 1)"><i class="bi bi-chevron-left"></i></button>
                <span class="btn btn-outline-secondary disabled">@_page / @_summary.Page.TotalPages</span>
                <button class="btn btn-outline-secondary" disabled="@(!_summary.Page.HasNext)" @onclick="() => GoPageAsync(_page + 1)"><i class="bi bi-chevron-right"></i></button>
            </div>
        }
    </div>
}

@* ── Confirmación de recálculo (ADMIN) ───────────────────────────────────── *@
@if (_showRecalcConfirm)
{
    <div class="modal-backdrop">
        <div class="modal" style="max-width:480px;">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
                    Recalcular emisiones
                </h5>
                <button type="button" class="btn-close"
                        @onclick="() => _showRecalcConfirm = false"></button>
            </div>
            <div class="modal-body small">
                <p>
                    Se recalcularán las emisiones de <strong>todos los traslados</strong> en estado
                    RECOGIDO o posterior usando el set de factores activo.
                </p>
                <p class="text-muted mb-0">Esta operación puede tardar unos segundos.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary btn-sm"
                        @onclick="() => _showRecalcConfirm = false">Cancelar</button>
                <button class="btn btn-warning btn-sm"
                        disabled="@_recalculating"
                        @onclick="RunRecalculateAsync">
                    @if (_recalculating)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Sí, recalcular
                </button>
            </div>
        </div>
    </div>
}

@* ── Resultado del recálculo ──────────────────────────────────────────────── *@
@if (_recalcResult is not null)
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div class="toast show align-items-center text-bg-success border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body small">
                    <i class="bi bi-check-circle me-2"></i>
                    Recalculadas <strong>@_recalcResult.LinesUpdated</strong> líneas
                    (@_recalcResult.LinesProcessed procesadas,
                    @_recalcResult.LinesSkipped omitidas).
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        @onclick="() => _recalcResult = null"></button>
            </div>
        </div>
    </div>
}

@code {
    private const int PageSize = 15;

    // ── Estado ────────────────────────────────────────────────────────────────
    private EmissionsSummaryDto? _summary;
    private bool                 _loading  = true;
    private bool                 _isAdmin;
    private int                  _page     = 1;

    // Filtros
    private DateTime? _dateFrom = new DateTime(DateTime.UtcNow.Year, 1, 1);
    private DateTime? _dateTo;

    // Recalcular
    private bool                        _showRecalcConfirm;
    private bool                        _recalculating;
    private RecalculateAllEmissionsResult? _recalcResult;

    // ── Ciclo de vida ─────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _isAdmin = CurrentUser.UserProfile == "ADMIN";
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _summary = await Mediator.Send(new GetEmissionsSummaryQuery(
            DateFrom:   _dateFrom,
            DateTo:     _dateTo,
            PageNumber: _page,
            PageSize:   PageSize));
        _loading = false;
    }

    private async Task FilterAsync()
    {
        _page = 1;
        await LoadDataAsync();
    }

    private async Task GoPageAsync(int page)
    {
        _page = page;
        await LoadDataAsync();
    }

    // ── Recalcular ────────────────────────────────────────────────────────────
    private void ConfirmRecalculate() => _showRecalcConfirm = true;

    private async Task RunRecalculateAsync()
    {
        _recalculating     = true;
        _showRecalcConfirm = false;
        try
        {
            _recalcResult = await Mediator.Send(new RecalculateAllEmissionsCommand());
            await LoadDataAsync();
        }
        finally
        {
            _recalculating = false;
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    private static string StatusBadge(string? status) => status switch
    {
        "RECOGIDO"    => "bg-info text-dark",
        "EN_CAC"      => "bg-warning text-dark",
        "EN_PLANTA"   => "bg-primary",
        "CLASIFICADO" => "bg-success",
        _             => "bg-secondary"
    };
}
