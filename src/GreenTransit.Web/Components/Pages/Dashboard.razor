@page "/dashboard"
@attribute [Authorize]
@implements IAsyncDisposable

@using GreenTransit.Application.Common.Interfaces
@using GreenTransit.Application.Features.Dashboard.DTOs
@using GreenTransit.Application.Features.Dashboard.Queries
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@using System.Globalization
@using System.Text.Json

@inject IMediator           Mediator
@inject ICurrentUserService CurrentUser
@inject ILogger<Dashboard>  Logger
@inject IJSRuntime          JS

<PageTitle>Dashboard — GreenTransit</PageTitle>

@* ── Cabecera ──────────────────────────────────────────────────────────────── *@
<div class="page-header mb-4">
    <div class="page-header-info">
        <h1 class="page-title">
            <i class="bi bi-speedometer2 me-2"></i>Dashboard operativo
        </h1>
        <p class="text-muted mb-0">
            Vista 360° del ecosistema · @DateTime.Now.ToString("MMMM yyyy", new CultureInfo("es-ES"))
        </p>
    </div>
    <div class="page-header-actions">
        <button class="btn btn-outline-neutral btn-sm" @onclick="RefreshAsync" disabled="@_loading">
            <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
        </button>
    </div>
</div>

@if (_loading)
{
    @* ── Skeleton loaders ──────────────────────────────────────────────────── *@
    <div class="row g-3 mb-3">
        @for (int i = 0; i < 4; i++)
        {
            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="skeleton skeleton-text mb-2" style="height:1rem;width:60%"></div>
                        <div class="skeleton skeleton-text" style="height:2rem;width:40%"></div>
                    </div>
                </div>
            </div>
        }
    </div>
    <div class="row g-3 mb-3">
        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-body">
                    <div class="skeleton" style="height:260px"></div>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-body">
                    <div class="skeleton" style="height:260px"></div>
                </div>
            </div>
        </div>
    </div>
}
else if (_summary is not null)
{
    var s = _summary;

    @* ── Fila 1: KPI cards ────────────────────────────────────────────────── *@
    <div class="row g-3 mb-3">

        @* Kg recogidos *@
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-truck me-1 text-muted"></i>Kg recogidos (mes)</div>
                    <div class="kpi-value mt-1">@FormatKg(s.KgCollectedThisMonth)</div>
                </div>
            </div>
        </div>

        @* Kg tratados *@
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-arrow-repeat me-1 text-muted"></i>Kg tratados (mes)</div>
                    <div class="kpi-value mt-1">@FormatKg(s.KgTreatedThisMonth)</div>
                </div>
            </div>
        </div>

        @* Tasa de reciclaje *@
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-recycle me-1 text-muted"></i>Tasa reciclaje</div>
                    <div class="kpi-value mt-1">@s.RecyclingRatePercent.ToString("N1")%</div>
                </div>
            </div>
        </div>

        @* Huella CO₂ *@
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label"><i class="bi bi-cloud-haze2 me-1 text-muted"></i>CO₂ transport (mes)</div>
                    <div class="kpi-value mt-1 d-flex align-items-baseline gap-1">
                        @FormatKg(s.TotalCO2ThisMonth)
                        <small class="fs-6 fw-normal text-muted">kgCO₂e</small>
                        @if (Co2Trend != 0)
                        {
                            <small class="fs-6 @(Co2Trend > 0 ? "text-danger" : "text-success")">
                                @(Co2Trend > 0 ? "↑" : "↓")@Math.Abs(Co2Trend).ToString("N0")%
                            </small>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>

    @* ── Fila 2: Embudo traslados + Tasas de tratamiento ─────────────────── *@
    <div class="row g-3 mb-3">

        @* Embudo de traslados — barras horizontales *@
        <div class="col-12 col-lg-7">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-bar-chart-steps me-2"></i>Traslados por estado
                </div>
                <div class="card-body p-2">
                    @if (_statusItems.Count > 0)
                    {
                        <AppChart Height="240" ShowLegend="false" ValueAxisTitle="Traslados">
                            <RadzenBarSeries Data="@_statusItems"
                                             ValueProperty="Count"
                                             CategoryProperty="Label"
                                             Title="Traslados"
                                             Fill="@ChartPalette.GetColor(0)" />
                        </AppChart>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-3 d-block mb-1"></i>Sin traslados registrados
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Tasas de tratamiento — dona *@
        <div class="col-12 col-lg-5">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-pie-chart me-2"></i>Tasas de tratamiento (mes)
                </div>
                <div class="card-body p-2">
                    @if (_rateItems.Any(r => r.Value > 0))
                    {
                        <AppChart Height="240">
                            <RadzenDonutSeries Data="@_rateItems"
                                              CategoryProperty="Label"
                                              ValueProperty="Value"
                                              Title="Fracción (%)" />
                        </AppChart>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-3 d-block mb-1"></i>Sin datos de tratamiento
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>

    @* ── Fila 3: Kg últimos 6 meses + Incidencias ────────────────────────── *@
    <div class="row g-3 mb-3">

        @* Kg recogidos vs tratados — últimos 6 meses *@
        <div class="col-12 col-lg-8">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-bar-chart-line me-2"></i>Kg recogidos vs tratados (6 meses)
                </div>
                <div class="card-body p-2">
                    <AppChart Height="240" ValueFormatString="{0:N0}" ValueAxisTitle="Kg">
                        <RadzenColumnSeries Data="@_monthlyItems"
                                            CategoryProperty="Label"
                                            ValueProperty="KgCollected"
                                            Title="Recogidos"
                                            Fill="@ChartPalette.GetColor(0)" />
                        <RadzenColumnSeries Data="@_monthlyItems"
                                            CategoryProperty="Label"
                                            ValueProperty="KgTreated"
                                            Title="Tratados"
                                            Fill="@ChartPalette.GetColor(1)" />
                    </AppChart>
                </div>
            </div>
        </div>

        @* Incidencias abiertas por severidad *@
        <div class="col-12 col-lg-4">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-exclamation-triangle me-2"></i>Incidencias abiertas
                </div>
                <div class="card-body p-0">
                    <ul class="list-unstyled mb-0">
                        @foreach (var (severity, color, icon) in _severityDef)
                        {
                            var count = s.OpenIncidentsBySeverity.TryGetValue(severity, out var c) ? c : 0;
                            <li class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="kpi-severity-dot" style="background:@color"></span>
                                    <span class="small text-secondary">@severity</span>
                                </div>
                                <span class="fw-semibold small @(count > 0 ? "" : "text-muted")">@count</span>
                            </li>
                        }
                    </ul>
                    <div class="px-3 py-2">
                        <a href="/incidents" class="btn btn-sm btn-outline-neutral w-100">
                            Ver todas las incidencias
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>

    @* ── Fila 4: Cumplimiento MarketShares + Próximas recogidas ──────────── *@
    <div class="row g-3 mb-3">

        @* Cumplimiento MarketShares *@
        <div class="col-12 col-lg-5">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-bullseye me-2"></i>Cumplimiento de cuotas (@DateTime.Now.Year)
                </div>
                <div class="card-body">
                    @if (s.MarketShareCompliance.Count == 0)
                    {
                        <div class="text-center py-3 text-muted">
                            <i class="bi bi-inbox d-block mb-1"></i>Sin cuotas definidas
                        </div>
                    }
                    else
                    {
                        @foreach (var ms in s.MarketShareCompliance.Take(6))
                        {
                            var pct   = Math.Min((double)ms.CompliancePercent, 100);
                            var color = pct >= 80 ? "success" : pct >= 50 ? "warning" : "danger";
                            <div class="mb-2">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="fw-semibold text-truncate" style="max-width:60%">
                                        @ms.Category
                                        @if (!string.IsNullOrEmpty(ms.ScrapName))
                                        {
                                            <span class="text-muted"> · @ms.ScrapName</span>
                                        }
                                        @if (!string.IsNullOrEmpty(ms.AutonomousCommunity))
                                        {
                                            <span class="text-muted"> · @ms.AutonomousCommunity</span>
                                        }
                                    </span>
                                    <span class="text-@color fw-bold">@ms.CompliancePercent.ToString("N1")%</span>
                                </div>
                                <div class="progress" style="height:8px">
                                    <div class="progress-bar bg-@color"
                                         role="progressbar"
                                         style="width:@pct.ToString("F1", CultureInfo.InvariantCulture)%"
                                         aria-valuenow="@pct"
                                         aria-valuemin="0"
                                         aria-valuemax="100"></div>
                                </div>
                                <div class="d-flex justify-content-between text-muted" style="font-size:.7rem">
                                    <span>Real: @FormatKg(ms.ActualKg) kg</span>
                                    <span>Obj: @FormatKg(ms.TargetKg) kg</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        @* Próximas recogidas *@
        <div class="col-12 col-lg-7">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-calendar-event me-2"></i>Próximas recogidas (7 días)
                </div>
                <div class="card-body p-0">
                    @if (s.UpcomingPickups.Count == 0)
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-calendar-x d-block fs-3 mb-1"></i>
                            Sin recogidas planificadas para los próximos 7 días
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Nº Orden</th>
                                        <th>Punto de recogida</th>
                                        <th>Fecha planificada</th>
                                        <th>Prioridad</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var so in s.UpcomingPickups)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@so.ServiceOrderNumber</td>
                                            <td class="text-truncate" style="max-width:160px">
                                                @(so.PickupPointName ?? "—")
                                            </td>
                                            <td>
                                                @(so.PlannedPickupStart.HasValue
                                                    ? so.PlannedPickupStart.Value.ToString("dd/MM HH:mm")
                                                    : "—")
                                            </td>
                                            <td>
                                                <span class="badge @PriorityBadge(so.Priority)">
                                                    @so.Priority
                                                </span>
                                            </td>
                                            <td>
                                                <a href="/service-orders/@so.Id"
                                                   class="btn btn-xs btn-outline-neutral">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>

    @* ── Fila 5: Mapa interactivo ─────────────────────────────────────────── *@
    <div class="row g-3 mb-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-map me-2"></i>Mapa de entidades y zonas DUM
                </div>
                <div class="card-body p-0">
                    <div id="@_mapContainerId" style="height:420px;width:100%;border-radius:0 0 .5rem .5rem"></div>
                </div>
            </div>
        </div>
    </div>

    @* ── Fila 6: Widgets Declaraciones de Producción ─────────────────────── *@
    @if (_decWidgets is not null)
    {
        <div class="row g-3 mb-3">

            @if (CurrentUser.IsInProfile(GreenTransit.Domain.Authorization.ProfileConstants.Admin)
                 && _decWidgets.IssuedPendingValidation > 0)
            {
                <div class="col-12 col-sm-6 col-xl-3">
                    <a href="/product-declarations?state=Emitido" class="text-decoration-none">
                        <div class="card kpi-card h-100">
                            <div class="card-body d-flex align-items-center gap-3">
                                <div class="kpi-icon kpi-icon--orange">
                                    <i class="bi bi-hourglass-split fs-4"></i>
                                </div>
                                <div>
                                    <div class="kpi-label">Decl. pendientes validación</div>
                                    <div class="kpi-value text-warning">
                                        @_decWidgets.IssuedPendingValidation
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }

            @if (CurrentUser.IsInProfile(GreenTransit.Domain.Authorization.ProfileConstants.Producer))
            {
                <div class="col-12 col-sm-6 col-xl-4">
                    <a href="/product-declarations" class="text-decoration-none">
                        <div class="card kpi-card h-100">
                            <div class="card-body d-flex align-items-center gap-3">
                                <div class="kpi-icon kpi-icon--blue">
                                    <i class="bi bi-box-seam fs-4"></i>
                                </div>
                                <div>
                                    <div class="kpi-label">Mis declaraciones</div>
                                    <div class="kpi-value">@_decWidgets.TotalOwn</div>
                                    <div class="d-flex gap-2 mt-1 flex-wrap">
                                        <span class="badge bg-secondary">B: @_decWidgets.OwnByState.GetValueOrDefault(GreenTransit.Domain.Entities.ProductDeclaration.States.Draft)</span>
                                        <span class="badge bg-primary">E: @_decWidgets.OwnByState.GetValueOrDefault(GreenTransit.Domain.Entities.ProductDeclaration.States.Issued)</span>
                                        <span class="badge bg-success">V: @_decWidgets.OwnByState.GetValueOrDefault(GreenTransit.Domain.Entities.ProductDeclaration.States.Validated)</span>
                                        <span class="badge bg-danger">R: @_decWidgets.OwnByState.GetValueOrDefault(GreenTransit.Domain.Entities.ProductDeclaration.States.Rejected)</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }

            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card kpi-card h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="kpi-icon kpi-icon--teal">
                            <i class="bi bi-bar-chart-line fs-4"></i>
                        </div>
                        <div>
                            <div class="kpi-label">
                                Volumen declarado T@(_decWidgets.CurrentPeriod) @_decWidgets.CurrentYear
                            </div>
                            <div class="kpi-value">
                                @_decWidgets.CurrentPeriodQuantity.ToString("N0")
                                <small class="fs-6 fw-normal">ud.</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    }
}
else
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        No se pudo cargar el resumen del dashboard.
    </div>
}

@code {
    // ── Tipos auxiliares para los gráficos ────────────────────────────────────

    private sealed record StatusItem(string Label, int Count, string Color);
    private sealed record RateItem(string Label, double Value);
    private sealed record MonthlyItem(string Label, decimal KgCollected, decimal KgTreated);

    // ── Estado del componente ─────────────────────────────────────────────────

    private bool                  _loading        = true;
    private bool                  _mapInitialized = false;
    private DashboardSummaryDto?  _summary;
    private GreenTransit.Application.Features.ProductDeclarations.Queries.DeclarationDashboardWidgetsDto? _decWidgets;
    private const string          _mapContainerId = "dashboard-map";

    // Datos para gráficos
    private List<StatusItem>   _statusItems  = [];
    private List<RateItem>     _rateItems    = [];
    private List<MonthlyItem>  _monthlyItems = [];

    // Trend CO₂ vs mes anterior (% cambio)
    private double Co2Trend => _summary is { TotalCO2ThisMonth: > 0, CO2PreviousMonth: > 0 }
        ? Math.Round(((double)(_summary.TotalCO2ThisMonth - _summary.CO2PreviousMonth)
            / (double)_summary.CO2PreviousMonth) * 100, 1)
        : 0d;

    // Colores por estado de traslado (paleta corporativa GreenTransit)
    private static readonly Dictionary<string, string> StatusColors = new(StringComparer.OrdinalIgnoreCase)
    {
        ["SOLICITADO"]  = "#4F5E5A",   // stone-green
        ["PLANIFICADO"] = "#0A404B",   // dark-petroleum
        ["RECOGIDO"]    = "#D8B00E",   // secondary-3
        ["EN CAC"]      = "#D36F15",   // secondary-4
        ["EN PLANTA"]   = "#8ACCC3",   // secondary-1
        ["CLASIFICADO"] = "#05C168",   // success
        ["BLOQUEADO"]   = "#DC2B2B",   // danger
    };

    private static readonly (string Severity, string Color, string Icon)[] _severityDef =
    [
        ("Low",      "#05C168", "bi bi-check-circle-fill"),
        ("Medium",   "#D8B00E", "bi bi-exclamation-circle-fill"),
        ("High",     "#D36F15", "bi bi-exclamation-triangle-fill"),
        ("Critical", "#DC2B2B", "bi bi-shield-exclamation"),
    ];

    // ── Ciclo de vida ─────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_summary is not null && !_mapInitialized)
        {
            _mapInitialized = true;
            await InitMapAsync();
        }
    }

    // ── Métodos privados ──────────────────────────────────────────────────────

    private async Task RefreshAsync()
    {
        _loading        = true;
        _mapInitialized = false;
        _summary        = null;
        StateHasChanged();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _summary    = await Mediator.Send(new GetDashboardSummaryQuery());
            _decWidgets = await Mediator.Send(
                new GreenTransit.Application.Features.ProductDeclarations.Queries
                    .GetDeclarationDashboardWidgetsQuery());
            BuildChartData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al cargar el resumen del dashboard.");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void BuildChartData()
    {
        if (_summary is null) return;

        // Datos para el histórico de Kg (últimos 6 meses)
        _monthlyItems = _summary.MonthlyKgLast6Months
            .Select(m => new MonthlyItem($"{m.Month:D2}/{m.Year}", m.KgCollected, m.KgTreated))
            .ToList();

        // Datos para el embudo de traslados (barra horizontal)
        _statusItems = _summary.WasteMovesByStatus
            .OrderByDescending(kv => kv.Value)
            .Select(kv => new StatusItem(
                kv.Key,
                kv.Value,
                StatusColors.TryGetValue(kv.Key, out var c) ? c : "#6c757d"))
            .ToList();

        // Datos para la dona de tasas de tratamiento
        var totalRates = _summary.RecyclingRatePercent
            + _summary.EnergyRecoveryPercent
            + _summary.ReusePercent;
        var rejectionRate = Math.Max(0d, 100d - totalRates);

        _rateItems =
        [
            new("Reciclaje",       _summary.RecyclingRatePercent),
            new("Energ. recuper.", _summary.EnergyRecoveryPercent),
            new("Reutilización",   _summary.ReusePercent),
            new("Rechazo",         rejectionRate),
        ];
    }

    private async Task InitMapAsync()
    {
        if (_summary is null) return;
        try
        {
            var points = _summary.EntityMapPoints
                .Select(p => new { name = p.Name, role = p.EntityRole, lat = p.Lat, lng = p.Lng })
                .ToList();

            var zones = _summary.DumZones
                .Select(z => new { zoneCode = z.ZoneCode, name = z.Name, geometryJson = z.GeometryJson })
                .ToList();

            await JS.InvokeVoidAsync("dashboardMap.initLazy",
                _mapContainerId,
                points,
                zones);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error al inicializar el mapa del dashboard.");
        }
    }

    // ── Helpers de formato ────────────────────────────────────────────────────

    private static string FormatKg(decimal kg) =>
        kg >= 1_000_000 ? $"{kg / 1_000_000:N2} Mt"
        : kg >= 1_000   ? $"{kg / 1_000:N1} t"
        : $"{kg:N0} kg";

    private static string PriorityBadge(string priority) => priority switch
    {
        "High"   or "Alta"   => "bg-danger",
        "Normal" or "Media"  => "bg-primary",
        "Low"    or "Baja"   => "bg-secondary",
        _                    => "bg-light text-dark"
    };

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("dashboardMap.dispose", _mapContainerId); }
        catch { /* componente ya desmontado */ }
    }
}
