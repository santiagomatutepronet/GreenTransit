@page "/entry-cacs/{Id:guid}"
@attribute [Authorize]
@rendermode InteractiveServer

@using GreenTransit.Application.Features.EntryCACs.DTOs
@using GreenTransit.Application.Features.EntryCACs.Queries
@using MediatR
@using Microsoft.AspNetCore.Authorization

@inject IMediator        Mediator
@inject NavigationManager Nav

<PageTitle>Detalle Entrada CAC</PageTitle>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner spinner-lg"></div>
    </div>
}
else if (_detail is null)
{
    <div class="alert alert-warning">Entrada en CAC no encontrada.</div>
    <button class="btn btn-outline-neutral btn-sm"
            @onclick='() => Nav.NavigateTo("/entry-cacs")'>
        <i class="bi bi-arrow-left me-1"></i>Volver al listado
    </button>
}
else
{
    <div class="page-header">
        <div class="page-header-info">
            <h1 class="page-title">
                <i class="bi bi-building me-2"></i>
                Entrada CAC — @(_detail.WasteMoveReference ?? _detail.IdWasteMove.ToString()[..8])
            </h1>
        </div>
        <div class="page-header-actions">
            <button class="btn btn-outline-neutral btn-sm"
                    @onclick='() => Nav.NavigateTo("/entry-cacs")'>
                <i class="bi bi-arrow-left me-1"></i>Volver
            </button>
            <button class="btn btn-outline-primary btn-sm"
                    @onclick='() => Nav.NavigateTo("/waste-moves/" + _detail.IdWasteMove)'>
                <i class="bi bi-arrow-right-circle me-1"></i>Ver traslado
            </button>
        </div>
    </div>

    @* ── Cabecera ─────────────────────────────────────────────────────────── *@
    <div class="card mb-3">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Datos de entrada</h5>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4">Fecha entrada</dt>
                <dd class="col-sm-8">
                    @(_detail.CACEntryDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                </dd>
                <dt class="col-sm-4">Tipo contenedor</dt>
                <dd class="col-sm-8">@(_detail.TypeContainer ?? "—")</dd>
                <dt class="col-sm-4">Precio contenedor</dt>
                <dd class="col-sm-8">
                    @(_detail.PriceContainer.HasValue
                        ? _detail.PriceContainer.Value.ToString("N2") + " €"
                        : "—")
                </dd>
                <dt class="col-sm-4">Método recogida</dt>
                <dd class="col-sm-8">@(_detail.CollectionMethod ?? "—")</dd>
                <dt class="col-sm-4">Creado</dt>
                <dd class="col-sm-8">
                    @(_detail.DateCreateSys?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                    por usuario #@_detail.IdUser
                </dd>
            </dl>
        </div>
    </div>

    @* ── Líneas ───────────────────────────────────────────────────────────── *@
    <div class="card mb-3">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="bi bi-list-ul me-2"></i>
                Residuos acopiados
                <span class="badge text-bg-secondary ms-2">@_detail.Residues.Count</span>
            </h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Residuo</th>
                            <th class="text-end">Peso</th>
                            <th>Unidad</th>
                            <th class="text-end">Uds.</th>
                            <th class="text-end">€/kg</th>
                            <th class="text-end">€/ud</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _detail.Residues)
                        {
                            <tr>
                                <td>@(r.ResidueName ?? r.IdResidue?.ToString()?[..8] ?? "—")</td>
                                <td class="text-end fw-semibold">
                                    @(r.Weight?.ToString("N2") ?? "—")
                                </td>
                                <td>@(r.MeasureUnit ?? "—")</td>
                                <td class="text-end">@(r.Units?.ToString() ?? "—")</td>
                                <td class="text-end">@(r.PriceWeight?.ToString("N3") ?? "—")</td>
                                <td class="text-end">@(r.PriceUnit?.ToString("N2") ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        <tr>
                            <td>Total</td>
                            <td class="text-end">
                                @(_detail.Residues.Sum(r => r.Weight ?? 0m).ToString("N2"))
                            </td>
                            <td colspan="4"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool             _loading = true;
    private EntryCACDetailDto? _detail;

    protected override async Task OnInitializedAsync()
    {
        _detail  = await Mediator.Send(new GetEntryCACByIdQuery(Id));
        _loading = false;
    }
}
