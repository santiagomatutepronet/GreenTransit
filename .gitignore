# ═══════════════════════════════════════════════════════════════
# .gitignore para GreenTransit — Solución .NET 10 / Blazor
# ═══════════════════════════════════════════════════════════════

# ── Carpetas de compilación ───────────────────────────────────
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
logs/

# ── Cobertura de tests ────────────────────────────────────────
coverage/
TestResults/
*.coverage
*.coveragexml
*.cobertura.xml

# ── Visual Studio ─────────────────────────────────────────────
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# ── Visual Studio Code ────────────────────────────────────────
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# ── Rider / JetBrains ─────────────────────────────────────────
.idea/
*.sln.iml

# ── Artefactos de compilación .NET ───────────────────────────
*.dll
*.exe
*.pdb
*.mdb
*.lib
*.exp
*.ilk
*.meta
*.gz
*.br
*.cache
*.tmp
*.bak
*.swp
*.nupkg
*.snupkg
publish/

# ── Entity Framework Core: migraciones auto-generadas ─────────
# Descomenta si quieres excluir las migraciones del repositorio
# */Migrations/

# ── Secretos y configuración local ───────────────────────────
# NUNCA subir secretos al repo
appsettings.Local.json
appsettings.*.local.json
secrets.json
*.pfx
*.p12
*.cer
*.key
# User Secrets de .NET
**/Properties/launchSettings.json

# ── NuGet ─────────────────────────────────────────────────────
*.nuget.props
*.nuget.targets
packages/
.nuget/
nuget.config.local

# ── Herramientas de análisis ──────────────────────────────────
BenchmarkDotNet.Artifacts/
_ReSharper*/
*.DotSettings.user

# ── Node / npm (si se añaden herramientas frontend) ───────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Docker (ignorar imágenes y volúmenes locales) ─────────────
docker-compose.override.yml

# ── Sistema operativo ─────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
